<!DOCTYPE html>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["StarWin.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="assets/images/StarforgedAtlasLogo.png" />
    <HeadOutlet />
</head>

<body class="@BodyClass">
    <Routes />
    <ReconnectModal />
    <div id="explorer-navigation-loading" class="loading-modal-backdrop" role="status" aria-live="polite" aria-label="Opening Sector Explorer" hidden>
        <section class="loading-modal">
            <span class="panel-kicker">Opening Sector Explorer</span>
            <h2>Loading archive records and restoring the explorer workspace.</h2>
            <p class="loading-elapsed" aria-live="off" data-loading-timer="true">Elapsed time: 00:00.0</p>
            <div class="loading-meter" aria-hidden="true">
                <span></span>
            </div>
            <ol>
                <li>Connecting to the explorer workspace.</li>
                <li>Loading the current sector archive.</li>
                <li>Preparing the selected explorer section.</li>
            </ol>
        </section>
    </div>
    <div id="explorer-section-loading" class="loading-modal-backdrop" role="status" aria-live="polite" aria-label="Loading section" hidden>
        <section class="loading-modal">
            <span class="panel-kicker" data-section-loading-target>Loading section</span>
            <h2 data-section-loading-status>Preparing explorer records.</h2>
            <p class="loading-elapsed" aria-live="off" data-loading-timer="true">Elapsed time: 00:00.0</p>
            <div class="loading-meter" aria-hidden="true">
                <span></span>
            </div>
            <ol>
                <li>Resolving the selected sector context.</li>
                <li>Preparing the requested explorer records.</li>
                <li>Rendering the updated section workspace.</li>
            </ol>
        </section>
    </div>
    <script src="@Assets["js/navigationLoading.js"]"></script>
    <script type="module" src="@Assets["js/loadingElapsedTime.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    private string? BodyClass =>
        string.Equals(Configuration["StarforgedAtlas:HostKind"], "Desktop", StringComparison.OrdinalIgnoreCase)
            ? "atlas-desktop-shell"
            : null;
}
