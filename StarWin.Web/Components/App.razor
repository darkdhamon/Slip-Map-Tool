<!DOCTYPE html>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["StarWin.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" href="favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="assets/images/StarforgedAtlasLogo.png" />
    <HeadOutlet />
</head>

<body class="@BodyClass">
    <Routes />
    <ReconnectModal />
    <LoadingModal IsVisible="false"
                  AlwaysRender="true"
                  OverlayId="explorer-navigation-loading"
                  AriaLabel="Opening Sector Explorer"
                  Kicker="Opening Sector Explorer"
                  Title="Loading archive records and restoring the explorer workspace."
                  Steps="@navigationLoadingSteps" />
    <LoadingModal IsVisible="false"
                  AlwaysRender="true"
                  OverlayId="explorer-section-loading"
                  AriaLabel="Loading section"
                  Steps="@sectionLoadingSteps">
        <KickerContent>
            <span class="panel-kicker" data-section-loading-target>Loading section</span>
        </KickerContent>
        <TitleContent>
            <h2 data-section-loading-status>Preparing explorer records.</h2>
        </TitleContent>
    </LoadingModal>
    <script src="@Assets["js/navigationLoading.js"]"></script>
    <script type="module" src="@Assets["js/loadingElapsedTime.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    private static readonly IReadOnlyList<string> navigationLoadingSteps =
    [
        "Connecting to the explorer workspace.",
        "Loading the current sector archive.",
        "Preparing the selected explorer section."
    ];

    private static readonly IReadOnlyList<string> sectionLoadingSteps =
    [
        "Resolving the selected sector context.",
        "Preparing the requested explorer records.",
        "Rendering the updated section workspace."
    ];

    private string? BodyClass =>
        string.Equals(Configuration["StarforgedAtlas:HostKind"], "Desktop", StringComparison.OrdinalIgnoreCase)
            ? "atlas-desktop-shell"
            : null;
}
