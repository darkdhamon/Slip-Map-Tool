@inject IJSRuntime JS
@inject IStarWinExplorerQueryService ExplorerQueryService
@implements IAsyncDisposable

<section class="timeline-layout">
    <aside class="timeline-filter-panel">
        <span class="panel-kicker">Sector chronology</span>
        <h2>@SectorName</h2>
        <label>
            Search
            <input placeholder="Event or category..."
                   @bind="timelineQuery"
                   @bind:event="oninput"
                   @bind:after="ReloadTimelineAsync" />
        </label>
        <label>
            Race
            <select @bind="timelineRaceId" @bind:after="ReloadTimelineAsync">
                <option value="@AllFilterId">All races</option>
                @foreach (var race in timelineOptions.Races)
                {
                    <option value="@race.Id">@race.Name</option>
                }
            </select>
        </label>
        <label>
            Empire
            <select @bind="timelineEmpireId" @bind:after="ReloadTimelineAsync">
                <option value="@AllFilterId">All empires</option>
                @foreach (var empire in timelineOptions.Empires)
                {
                    <option value="@empire.Id">@empire.Name</option>
                }
            </select>
        </label>
        <button type="button" class="timeline-clear-button" @onclick="ToggleLocationFilters">
            @(showLocationFilters ? "Hide location filters" : "Show location filters")
        </button>
        @if (showLocationFilters)
        {
            <label>
                Colony
                <input list="timeline-colony-options"
                       placeholder="All colonies"
                       @bind="timelineColonyText"
                       @bind:event="oninput"
                       @bind:after="ApplyTimelineColonyFilter" />
                <datalist id="timeline-colony-options">
                    @foreach (var item in timelineOptions.Colonies)
                    {
                        <option value="@FormatTimelineOption(item)" />
                    }
                </datalist>
            </label>
            <label>
                System
                <input list="timeline-system-options"
                       placeholder="All systems"
                       @bind="timelineSystemText"
                       @bind:event="oninput"
                       @bind:after="ApplyTimelineSystemFilter" />
                <datalist id="timeline-system-options">
                    @foreach (var item in timelineOptions.Systems)
                    {
                        <option value="@FormatTimelineOption(item)" />
                    }
                </datalist>
            </label>
            <label>
                World
                <input list="timeline-world-options"
                       placeholder="All worlds"
                       @bind="timelineWorldText"
                       @bind:event="oninput"
                       @bind:after="ApplyTimelineWorldFilter" />
                <datalist id="timeline-world-options">
                    @foreach (var item in timelineOptions.Worlds)
                    {
                        <option value="@FormatTimelineOption(item)" />
                    }
                </datalist>
            </label>
        }
        <label>
            Event type
            <select @bind="timelineEventType" @bind:after="ReloadTimelineAsync">
                <option value="">All event types</option>
                @foreach (var eventType in timelineOptions.EventTypes)
                {
                    <option value="@eventType">@eventType</option>
                }
            </select>
        </label>
        <button type="button" class="timeline-clear-button" @onclick="ClearTimelineFiltersAsync">Clear filters</button>
    </aside>

    <div class="timeline-list">
        <div class="timeline-count">Showing @timelineEvents.Count event@(timelineEvents.Count == 1 ? string.Empty : "s")@(timelineHasMoreEvents ? "+" : string.Empty)</div>
        @if (timelineLoading && timelineEvents.Count == 0)
        {
            <article class="timeline-event-card">
                <span class="timeline-century">Loading</span>
                <p>Preparing the sector timeline list.</p>
            </article>
        }
        else if (timelineEvents.Count == 0)
        {
            <article class="timeline-event-card">
                <span class="timeline-century">No matches</span>
                <p>Adjust the filters to widen the sector history view.</p>
            </article>
        }
        @foreach (var item in timelineEvents)
        {
            <button type="button"
                    class="timeline-event-card timeline-event-card-button @(selectedTimelineEventId == item.EventId ? "active" : null)"
                    @onclick="() => SelectTimelineEventAsync(item.EventId)">
                <div class="timeline-event-header">
                    <span class="timeline-century">@item.TimeLabel</span>
                    <strong>@item.EventType</strong>
                </div>
                <p>@item.Title</p>
            </button>
        }
        @if (timelineHasMoreEvents)
        {
            <div @ref="timelineLoadMoreElement" class="timeline-load-more">
                <button type="button" @onclick="LoadMoreTimelineEvents">Load more</button>
            </div>
        }
    </div>

    <article class="feature-panel timeline-detail-panel">
        @if (timelineDetailLoading)
        {
            <span class="panel-kicker">Loading event</span>
            <h2>Preparing timeline detail</h2>
            <p>Fetching the selected event record.</p>
        }
        else if (selectedTimelineEventDetail is null)
        {
            <span class="panel-kicker">Timeline detail</span>
            <h2>Select an event</h2>
            <p>Choose an entry from the timeline list to load the event viewer.</p>
        }
        else
        {
            <span class="panel-kicker">@selectedTimelineEventDetail.TimeLabel</span>
            <h2>@selectedTimelineEventDetail.EventType</h2>
            <p>@selectedTimelineEventDetail.Description</p>
            <div class="timeline-links">
                @if (selectedTimelineEventDetail.Race is { } race)
                {
                    <button type="button" @onclick="() => RaceSelected.InvokeAsync(race.Id)">Race: @race.Name</button>
                }
                @if (selectedTimelineEventDetail.OtherRace is { } otherRace)
                {
                    <button type="button" @onclick="() => RaceSelected.InvokeAsync(otherRace.Id)">Other race: @otherRace.Name</button>
                }
                @if (selectedTimelineEventDetail.Empire is { } empire)
                {
                    <button type="button" @onclick="() => EmpireSelected.InvokeAsync(empire.Id)">Empire: @empire.Name</button>
                }
                @if (selectedTimelineEventDetail.Colony is { } colony)
                {
                    <button type="button" @onclick="() => ColonySelected.InvokeAsync(colony.Id)">Colony: @colony.Name</button>
                }
                @if (selectedTimelineEventDetail.World is { } world)
                {
                    <button type="button" @onclick="() => WorldSelected.InvokeAsync(world.Id)">World: @world.Name</button>
                }
                @if (selectedTimelineEventDetail.System is { } system)
                {
                    <button type="button" @onclick="() => SystemSelected.InvokeAsync(system.Id)">System: @system.Name</button>
                }
            </div>
        }
    </article>
</section>

@code {
    private const int TimelineBatchSize = 40;
    private const int AllFilterId = -1;

    [Parameter, EditorRequired]
    public int SectorId { get; set; }

    [Parameter, EditorRequired]
    public string SectorName { get; set; } = string.Empty;

    [Parameter]
    public EventCallback<int> RaceSelected { get; set; }

    [Parameter]
    public EventCallback<int> EmpireSelected { get; set; }

    [Parameter]
    public EventCallback<int> ColonySelected { get; set; }

    [Parameter]
    public EventCallback<int> WorldSelected { get; set; }

    [Parameter]
    public EventCallback<int> SystemSelected { get; set; }

    private ElementReference timelineLoadMoreElement;
    private DotNetObjectReference<ExplorerTimelineSection>? dotNetReference;
    private IJSObjectReference? timelineScrollModule;
    private ExplorerTimelineOptions timelineOptions = new([], [], [], [], [], []);
    private List<ExplorerTimelineListItem> timelineEvents = [];
    private ExplorerTimelineEventDetail? selectedTimelineEventDetail;
    private int selectedTimelineEventId;
    private int renderedSectorId;
    private string timelineQuery = string.Empty;
    private int timelineRaceId = AllFilterId;
    private int timelineEmpireId = AllFilterId;
    private int timelineColonyId = AllFilterId;
    private int timelineSystemId = AllFilterId;
    private int timelineWorldId = AllFilterId;
    private string timelineColonyText = string.Empty;
    private string timelineSystemText = string.Empty;
    private string timelineWorldText = string.Empty;
    private string timelineEventType = string.Empty;
    private bool timelineHasMoreEvents;
    private bool timelineObserverConfigured;
    private bool showLocationFilters;
    private bool timelineLoading;
    private bool timelineDetailLoading;

    protected override async Task OnParametersSetAsync()
    {
        if (renderedSectorId == SectorId)
        {
            return;
        }

        renderedSectorId = SectorId;
        await ClearTimelineFiltersAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ConfigureTimelineObserverAsync();
    }

    private async Task ConfigureTimelineObserverAsync()
    {
        if (!timelineHasMoreEvents)
        {
            timelineObserverConfigured = false;
            if (timelineScrollModule is not null)
            {
                await timelineScrollModule.InvokeVoidAsync("disconnectTimelineLoadMore");
            }

            return;
        }

        if (timelineObserverConfigured)
        {
            return;
        }

        timelineScrollModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/timelineInfiniteScroll.js");
        dotNetReference ??= DotNetObjectReference.Create(this);
        await timelineScrollModule.InvokeVoidAsync("observeTimelineLoadMore", timelineLoadMoreElement, dotNetReference);
        timelineObserverConfigured = true;
    }

    [JSInvokable]
    public async Task LoadMoreTimelineEvents()
    {
        if (timelineLoading || !timelineHasMoreEvents)
        {
            return;
        }

        if (timelineScrollModule is not null)
        {
            await timelineScrollModule.InvokeVoidAsync("disconnectTimelineLoadMore");
        }

        timelineObserverConfigured = false;
        timelineLoading = true;
        var page = await ExplorerQueryService.LoadTimelinePageAsync(BuildPageRequest(timelineEvents.Count, TimelineBatchSize));
        timelineEvents.AddRange(page.Items);
        timelineHasMoreEvents = page.HasMore;
        timelineLoading = false;
        StateHasChanged();
    }

    private async Task ReloadTimelineAsync()
    {
        timelineObserverConfigured = false;
        timelineLoading = true;
        timelineOptions = await ExplorerQueryService.LoadTimelineOptionsAsync(SectorId);
        var page = await ExplorerQueryService.LoadTimelinePageAsync(BuildPageRequest(0, TimelineBatchSize));
        timelineEvents = page.Items.ToList();
        timelineHasMoreEvents = page.HasMore;
        timelineLoading = false;

        var nextEventId = timelineEvents.FirstOrDefault()?.EventId ?? 0;
        if (nextEventId > 0)
        {
            await SelectTimelineEventAsync(nextEventId);
        }
        else
        {
            selectedTimelineEventId = 0;
            selectedTimelineEventDetail = null;
        }

        StateHasChanged();
    }

    private void ToggleLocationFilters()
    {
        showLocationFilters = !showLocationFilters;
    }

    private async Task ApplyTimelineColonyFilter()
    {
        timelineColonyId = ParseTimelineOptionId(timelineColonyText);
        await ReloadTimelineAsync();
    }

    private async Task ApplyTimelineSystemFilter()
    {
        timelineSystemId = ParseTimelineOptionId(timelineSystemText);
        await ReloadTimelineAsync();
    }

    private async Task ApplyTimelineWorldFilter()
    {
        timelineWorldId = ParseTimelineOptionId(timelineWorldText);
        await ReloadTimelineAsync();
    }

    private async Task ClearTimelineFiltersAsync()
    {
        timelineQuery = string.Empty;
        timelineRaceId = AllFilterId;
        timelineEmpireId = AllFilterId;
        timelineColonyId = AllFilterId;
        timelineSystemId = AllFilterId;
        timelineWorldId = AllFilterId;
        timelineColonyText = string.Empty;
        timelineSystemText = string.Empty;
        timelineWorldText = string.Empty;
        timelineEventType = string.Empty;
        showLocationFilters = false;
        await ReloadTimelineAsync();
    }

    private async Task SelectTimelineEventAsync(int eventId)
    {
        if (eventId <= 0 || selectedTimelineEventId == eventId && selectedTimelineEventDetail is not null)
        {
            return;
        }

        selectedTimelineEventId = eventId;
        timelineDetailLoading = true;
        selectedTimelineEventDetail = null;
        StateHasChanged();

        selectedTimelineEventDetail = await ExplorerQueryService.LoadTimelineEventDetailAsync(eventId);
        timelineDetailLoading = false;
        StateHasChanged();
    }

    private ExplorerTimelinePageRequest BuildPageRequest(int offset, int limit)
    {
        return new ExplorerTimelinePageRequest(
            SectorId,
            timelineQuery,
            timelineRaceId,
            timelineEmpireId,
            timelineColonyId,
            timelineSystemId,
            timelineWorldId,
            timelineEventType,
            offset,
            limit);
    }

    private static int ParseTimelineOptionId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return AllFilterId;
        }

        var separatorIndex = value.IndexOf(" - ", StringComparison.Ordinal);
        var idText = separatorIndex < 0 ? value : value[..separatorIndex];
        return int.TryParse(idText, out var id) ? id : AllFilterId;
    }

    private static string FormatTimelineOption(ExplorerLookupOption item)
    {
        return $"{item.Id} - {item.Name}";
    }

    public async ValueTask DisposeAsync()
    {
        if (timelineScrollModule is not null)
        {
            try
            {
                await timelineScrollModule.InvokeVoidAsync("disconnectTimelineLoadMore");
                await timelineScrollModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        dotNetReference?.Dispose();
    }
}
