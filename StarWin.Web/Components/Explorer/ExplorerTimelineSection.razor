@inject IJSRuntime JS
@implements IAsyncDisposable

<section class="timeline-layout">
    <aside class="timeline-filter-panel">
        <span class="panel-kicker">Sector chronology</span>
        <h2>@Sector.Name</h2>
        <label>
            Search
            <input placeholder="Event, system, race, colony..."
                   @bind="timelineQuery"
                   @bind:event="oninput"
                   @bind:after="ResetTimelineWindow" />
        </label>
        <label>
            Race
            <select @bind="timelineRaceId" @bind:after="ResetTimelineWindow">
                <option value="@AllFilterId">All races</option>
                @foreach (var race in Races)
                {
                    <option value="@race.Id">@race.Name</option>
                }
            </select>
        </label>
        <label>
            Empire
            <select @bind="timelineEmpireId" @bind:after="ResetTimelineWindow">
                <option value="@AllFilterId">All empires</option>
                @foreach (var empire in Empires)
                {
                    <option value="@empire.Id">@empire.Name</option>
                }
            </select>
        </label>
        <button type="button" class="timeline-clear-button" @onclick="ToggleLocationFilters">
            @(showLocationFilters ? "Hide location filters" : "Show location filters")
        </button>
        @if (showLocationFilters)
        {
            <label>
                Colony
                <input list="timeline-colony-options"
                       placeholder="All colonies"
                       @bind="timelineColonyText"
                       @bind:event="oninput"
                       @bind:after="ApplyTimelineColonyFilter" />
                <datalist id="timeline-colony-options">
                    @foreach (var item in SectorCache.ColoniesByWorldName)
                    {
                        <option value="@FormatTimelineColonyOption(item)" />
                    }
                </datalist>
            </label>
            <label>
                System
                <input list="timeline-system-options"
                       placeholder="All systems"
                       @bind="timelineSystemText"
                       @bind:event="oninput"
                       @bind:after="ApplyTimelineSystemFilter" />
                <datalist id="timeline-system-options">
                    @foreach (var system in SectorCache.SystemsByName)
                    {
                        <option value="@FormatTimelineSystemOption(system)" />
                    }
                </datalist>
            </label>
            <label>
                World
                <input list="timeline-world-options"
                       placeholder="All worlds"
                       @bind="timelineWorldText"
                       @bind:event="oninput"
                       @bind:after="ApplyTimelineWorldFilter" />
                <datalist id="timeline-world-options">
                    @foreach (var world in SectorCache.WorldsByName)
                    {
                        <option value="@FormatTimelineWorldOption(world)" />
                    }
                </datalist>
            </label>
        }
        <label>
            Event type
            <select @bind="timelineEventType" @bind:after="ResetTimelineWindow">
                <option value="">All event types</option>
                @foreach (var eventType in SectorCache.EventTypes)
                {
                    <option value="@eventType">@eventType</option>
                }
            </select>
        </label>
        <button type="button" class="timeline-clear-button" @onclick="ClearTimelineFilters">Clear filters</button>
    </aside>

    <div class="timeline-list">
        @{
            var timelineWindow = GetFilteredTimelineEvents()
                .Take(timelineVisibleCount + 1)
                .ToList();
            var hasMoreTimelineEvents = timelineWindow.Count > timelineVisibleCount;
            var timelineEvents = timelineWindow
                .Take(timelineVisibleCount)
                .ToList();
            timelineHasMoreEvents = hasMoreTimelineEvents;
        }
        <div class="timeline-count">Showing @timelineEvents.Count event@(timelineEvents.Count == 1 ? string.Empty : "s")@(hasMoreTimelineEvents ? "+" : string.Empty)</div>
        @if (timelineEvents.Count == 0)
        {
            <article class="timeline-event-card">
                <span class="timeline-century">No matches</span>
                <p>Adjust the filters to widen the sector history view.</p>
            </article>
        }
        @foreach (var history in timelineEvents)
        {
            StarSystem? eventSystem = null;
            if (history.StarSystemId is int historySystemId)
            {
                SectorCache.SystemsById.TryGetValue(historySystemId, out eventSystem);
            }

            World? eventWorld = null;
            if (history.PlanetId is int historyWorldId)
            {
                SectorCache.WorldsById.TryGetValue(historyWorldId, out eventWorld);
            }

            (World World, Colony Colony)? eventColony = null;
            if (history.ColonyId is int historyColonyId
                && SectorCache.ColoniesByColonyId.TryGetValue(historyColonyId, out var foundEventColony))
            {
                eventColony = foundEventColony;
            }
            <article class="timeline-event-card">
                <div class="timeline-event-header">
                    <span class="timeline-century">Century @history.Century</span>
                    <strong>@history.EventType</strong>
                </div>
                <p>@history.Description</p>
                <div class="timeline-links">
                    @if (history.RaceId is int raceId)
                    {
                        <button type="button" @onclick="() => RaceSelected.InvokeAsync(raceId)">Race: @DisplayRace(raceId)</button>
                    }
                    @if (history.OtherRaceId is int otherRaceId)
                    {
                        <button type="button" @onclick="() => RaceSelected.InvokeAsync(otherRaceId)">Other race: @DisplayRace(otherRaceId)</button>
                    }
                    @if (history.EmpireId is int empireId)
                    {
                        <button type="button" @onclick="() => EmpireSelected.InvokeAsync(empireId)">Empire: @DisplayEmpire(empireId)</button>
                    }
                    @if (eventColony is not null)
                    {
                        <button type="button" @onclick="() => ColonySelected.InvokeAsync(eventColony.Value.World.Id)">Colony: @eventColony.Value.Colony.ColonyClass</button>
                    }
                    @if (eventWorld is not null)
                    {
                        <button type="button" @onclick="() => WorldSelected.InvokeAsync(eventWorld.Id)">World: @eventWorld.Name</button>
                    }
                    @if (eventSystem is not null)
                    {
                        <button type="button" @onclick="() => SystemSelected.InvokeAsync(eventSystem.Id)">System: @eventSystem.Name</button>
                    }
                </div>
            </article>
        }
        @if (hasMoreTimelineEvents)
        {
            <div @ref="timelineLoadMoreElement" class="timeline-load-more">
                <button type="button" @onclick="LoadMoreTimelineEvents">Load more</button>
            </div>
        }
    </div>
</section>

@code {
    private const int TimelineBatchSize = 40;
    private const int AllFilterId = -1;

    [Parameter, EditorRequired]
    public StarWinSector Sector { get; set; } = default!;

    [Parameter, EditorRequired]
    public ExplorerSectorCache SectorCache { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<AlienRace> Races { get; set; } = [];

    [Parameter]
    public IReadOnlyList<Empire> Empires { get; set; } = [];

    [Parameter]
    public EventCallback<int> RaceSelected { get; set; }

    [Parameter]
    public EventCallback<int> EmpireSelected { get; set; }

    [Parameter]
    public EventCallback<int> ColonySelected { get; set; }

    [Parameter]
    public EventCallback<int> WorldSelected { get; set; }

    [Parameter]
    public EventCallback<int> SystemSelected { get; set; }

    private readonly Dictionary<int, string> raceNamesById = [];
    private readonly Dictionary<int, string> empireNamesById = [];
    private ElementReference timelineLoadMoreElement;
    private DotNetObjectReference<ExplorerTimelineSection>? dotNetReference;
    private IJSObjectReference? timelineScrollModule;
    private int renderedSectorId;
    private string timelineQuery = string.Empty;
    private int timelineRaceId = AllFilterId;
    private int timelineEmpireId = AllFilterId;
    private int timelineColonyId = AllFilterId;
    private int timelineSystemId = AllFilterId;
    private int timelineWorldId = AllFilterId;
    private string timelineColonyText = string.Empty;
    private string timelineSystemText = string.Empty;
    private string timelineWorldText = string.Empty;
    private string timelineEventType = string.Empty;
    private int timelineVisibleCount = TimelineBatchSize;
    private bool timelineHasMoreEvents;
    private bool timelineObserverConfigured;
    private bool showLocationFilters;

    protected override void OnParametersSet()
    {
        raceNamesById.Clear();
        foreach (var race in Races)
        {
            raceNamesById[race.Id] = race.Name;
        }

        empireNamesById.Clear();
        foreach (var empire in Empires)
        {
            empireNamesById[empire.Id] = empire.Name;
        }

        if (renderedSectorId != 0 && renderedSectorId != Sector.Id)
        {
            ClearTimelineFilters();
        }

        renderedSectorId = Sector.Id;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await ConfigureTimelineObserverAsync();
    }

    private async Task ConfigureTimelineObserverAsync()
    {
        if (!timelineHasMoreEvents)
        {
            timelineObserverConfigured = false;
            if (timelineScrollModule is not null)
            {
                await timelineScrollModule.InvokeVoidAsync("disconnectTimelineLoadMore");
            }

            return;
        }

        if (timelineObserverConfigured)
        {
            return;
        }

        timelineScrollModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/timelineInfiniteScroll.js");
        dotNetReference ??= DotNetObjectReference.Create(this);
        await timelineScrollModule.InvokeVoidAsync("observeTimelineLoadMore", timelineLoadMoreElement, dotNetReference);
        timelineObserverConfigured = true;
    }

    [JSInvokable]
    public async Task LoadMoreTimelineEvents()
    {
        if (timelineScrollModule is not null)
        {
            await timelineScrollModule.InvokeVoidAsync("disconnectTimelineLoadMore");
        }

        timelineVisibleCount += TimelineBatchSize;
        timelineObserverConfigured = false;
        StateHasChanged();
    }

    private void ResetTimelineWindow()
    {
        timelineVisibleCount = TimelineBatchSize;
        timelineObserverConfigured = false;
    }

    private void ToggleLocationFilters()
    {
        showLocationFilters = !showLocationFilters;
    }

    private void ApplyTimelineColonyFilter()
    {
        timelineColonyId = ParseTimelineOptionId(timelineColonyText);
        ResetTimelineWindow();
    }

    private void ApplyTimelineSystemFilter()
    {
        timelineSystemId = ParseTimelineOptionId(timelineSystemText);
        ResetTimelineWindow();
    }

    private void ApplyTimelineWorldFilter()
    {
        timelineWorldId = ParseTimelineOptionId(timelineWorldText);
        ResetTimelineWindow();
    }

    private IEnumerable<HistoryEvent> GetFilteredTimelineEvents()
    {
        return SectorCache.SortedHistory.Where(TimelineMatches);
    }

    private bool TimelineMatches(HistoryEvent history)
    {
        if (timelineRaceId != AllFilterId && history.RaceId != timelineRaceId && history.OtherRaceId != timelineRaceId)
        {
            return false;
        }

        if (timelineEmpireId != AllFilterId && history.EmpireId != timelineEmpireId)
        {
            return false;
        }

        if (timelineColonyId != AllFilterId && history.ColonyId != timelineColonyId)
        {
            return false;
        }

        if (timelineSystemId != AllFilterId && history.StarSystemId != timelineSystemId)
        {
            return false;
        }

        if (timelineWorldId != AllFilterId && history.PlanetId != timelineWorldId)
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(timelineEventType)
            && !string.Equals(history.EventType, timelineEventType, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(timelineQuery))
        {
            return true;
        }

        var query = timelineQuery.Trim();
        var systemName = history.StarSystemId is int systemId && SectorCache.SystemsById.TryGetValue(systemId, out var system)
            ? system.Name
            : null;
        var worldName = history.PlanetId is int planetId && SectorCache.WorldsById.TryGetValue(planetId, out var world)
            ? world.Name
            : null;
        var colonyName = history.ColonyId is int colonyId && SectorCache.ColoniesByColonyId.TryGetValue(colonyId, out var colonyListing)
            ? $"{colonyListing.Colony.ColonyClass} {colonyListing.World.Name}"
            : null;
        var raceName = history.RaceId is int raceId ? DisplayRace(raceId) : null;
        var otherRaceName = history.OtherRaceId is int otherRaceId ? DisplayRace(otherRaceId) : null;
        var empireName = history.EmpireId is int empireId ? DisplayEmpire(empireId) : null;

        return ContainsTimelineQuery(history.EventType, query)
            || ContainsTimelineQuery(history.Description, query)
            || ContainsTimelineQuery(systemName, query)
            || ContainsTimelineQuery(worldName, query)
            || ContainsTimelineQuery(colonyName, query)
            || ContainsTimelineQuery(raceName, query)
            || ContainsTimelineQuery(otherRaceName, query)
            || ContainsTimelineQuery(empireName, query);
    }

    private void ClearTimelineFilters()
    {
        timelineQuery = string.Empty;
        timelineRaceId = AllFilterId;
        timelineEmpireId = AllFilterId;
        timelineColonyId = AllFilterId;
        timelineSystemId = AllFilterId;
        timelineWorldId = AllFilterId;
        timelineColonyText = string.Empty;
        timelineSystemText = string.Empty;
        timelineWorldText = string.Empty;
        timelineEventType = string.Empty;
        showLocationFilters = false;
        ResetTimelineWindow();
    }

    private static int ParseTimelineOptionId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return AllFilterId;
        }

        var separatorIndex = value.IndexOf(" - ", StringComparison.Ordinal);
        var idText = separatorIndex < 0 ? value : value[..separatorIndex];
        return int.TryParse(idText, out var id) ? id : AllFilterId;
    }

    private static string FormatTimelineColonyOption((World World, Colony Colony) item)
    {
        return $"{item.Colony.Id} - {item.Colony.ColonyClass} on {item.World.Name}";
    }

    private static string FormatTimelineSystemOption(StarSystem system)
    {
        return $"{system.Id} - {system.Name}";
    }

    private static string FormatTimelineWorldOption(World world)
    {
        return $"{world.Id} - {world.Name}";
    }

    private static bool ContainsTimelineQuery(string? value, string query)
    {
        return value?.Contains(query, StringComparison.OrdinalIgnoreCase) == true;
    }

    private string DisplayRace(int raceId)
    {
        return raceNamesById.TryGetValue(raceId, out var raceName) ? raceName : raceId.ToString();
    }

    private string DisplayEmpire(int empireId)
    {
        return empireNamesById.TryGetValue(empireId, out var empireName) ? empireName : empireId.ToString();
    }

    public async ValueTask DisposeAsync()
    {
        if (timelineScrollModule is not null)
        {
            try
            {
                await timelineScrollModule.InvokeVoidAsync("disconnectTimelineLoadMore");
                await timelineScrollModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        dotNetReference?.Dispose();
    }
}
