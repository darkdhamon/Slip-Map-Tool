@implements IAsyncDisposable
@inject IJSRuntime JS

@if (IsVisible)
{
    <p @ref="timerElement" class="loading-elapsed" aria-live="off">Elapsed time: 00:00</p>
}

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    private ElementReference timerElement;
    private IJSObjectReference? module;
    private long? startedAtUnixMs;
    private long? activeTimerStartedAtUnixMs;

    protected override void OnParametersSet()
    {
        if (IsVisible)
        {
            startedAtUnixMs ??= DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
            return;
        }

        startedAtUnixMs = null;
        activeTimerStartedAtUnixMs = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsVisible || startedAtUnixMs is null)
        {
            return;
        }

        if (activeTimerStartedAtUnixMs == startedAtUnixMs)
        {
            return;
        }

        module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/loadingElapsedTime.js");
        await module.InvokeVoidAsync("start", timerElement, startedAtUnixMs.Value);
        activeTimerStartedAtUnixMs = startedAtUnixMs;
    }

    public async ValueTask DisposeAsync()
    {
        if (module is null)
        {
            return;
        }

        try
        {
            await module.InvokeVoidAsync("stop", timerElement);
            await module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
