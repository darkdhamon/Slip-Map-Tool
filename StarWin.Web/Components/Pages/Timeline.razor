@page "/sector-explorer/timeline"
@rendermode InteractiveServer

@{
    var sector = GetSelectedSector();
}

<PageTitle>Timeline | Starforged Atlas</PageTitle>

<section class="explorer-page">
    <SectorExplorerShell ShowHero="false"
                         Sectors="ExplorerSectors"
                         Systems="sector.Systems.ToList()"
                         SelectedSectorId="@selectedSectorId"
                         SelectedSectorChanged="HandleSectorChangedAsync"
                         SelectedSystemText="@selectedSystemText"
                         SelectedSystemTextChanged="HandleSelectedSystemTextChangedAsync"
                         SearchQuery="@searchQuery"
                         SearchQueryChanged="HandleSearchQueryChangedAsync"
                         SearchResults="searchResults"
                         SearchResultSelected="NavigateToSearchResult"
                         Sections="sections"
                         ActiveSection="Timeline"
                         ErrorMessage="@explorerRenderError"
                         ResultTypeDisplayFactory="DisplayResultType"
                         SectionHrefFactory="BuildSectionRoute">
        <ExplorerTimelineSection SectorId="@sector.Id"
                                 SectorName="@sector.Name"
                                 LoadingStateChanged="HandleTimelineLoadingStateChangedAsync"
                                 RaceSelected="NavigateToRace"
                                 EmpireSelected="NavigateToEmpire"
                                 ColonySelected="NavigateToColony"
                                 WorldSelected="NavigateToWorld"
                                 SystemSelected="NavigateToSystemRecord" />
    </SectorExplorerShell>
</section>

@if (timelinePageLoadingVisible)
{
    <div class="loading-modal-backdrop" role="status" aria-live="polite" aria-label="Loading Timeline">
        <section class="loading-modal">
            <span class="panel-kicker">Loading Timeline</span>
            <h2>Preparing timeline events for the selected sector.</h2>
            <p class="loading-progress-detail">The page will stay visible until the first chronology batch is ready.</p>
            <div class="loading-meter" aria-hidden="true">
                <span></span>
            </div>
            <ol>
                <li>Resolve the selected sector context.</li>
                <li>Load the first timeline event page.</li>
                <li>Render the chronology and detail workspace.</li>
            </ol>
        </section>
    </div>
}
