@layout SectorExplorerLayout
@page "/sector-explorer/aliens"
@rendermode InteractiveServer

@{
    var sector = GetSelectedSector();
    var sectorRaces = GetFilteredRaces(LoadedRaceSummaries).ToList();
    var sectorEmpires = selectedRaceDetail?.Empires ?? [];
    var selectedRace = selectedRaceDetail?.Race;
    var layoutState = new SectorExplorerLayoutState(
        null,
        ExplorerSectors,
        sector.Systems.ToList(),
        selectedSectorId,
        EventCallback.Factory.Create<int>(this, HandleSectorChangedAsync),
        selectedSystemText,
        EventCallback.Factory.Create<string>(this, HandleSelectedSystemTextChangedAsync),
        searchQuery,
        EventCallback.Factory.Create<string>(this, HandleSearchQueryChangedAsync),
        searchResults,
        EventCallback.Factory.Create<StarWinSearchResult>(this, NavigateToSearchResult),
        sections,
        "Aliens",
        explorerRenderError,
        DisplayResultType,
        BuildSectionRoute);
}

<PageTitle>Aliens | Starforged Atlas</PageTitle>
<SectorExplorerLayoutSync State="layoutState" />

<section class="content-grid">
            <div class="record-list">
                <details class="record-filter-panel">
                    <summary class="record-filter-summary">Search</summary>
                    <label>
                        Search
                        <input placeholder="Name, appearance, environment..."
                               @bind="raceQuery"
                               @bind:event="oninput"
                               @bind:after="ResetRaceWindowAsync" />
                    </label>
                    <button type="button" class="timeline-clear-button" @onclick="ToggleRaceFilters">
                        @(showRaceFilters ? "Hide filters" : "Show filters")
                    </button>
                    @if (showRaceFilters)
                    {
                        <label>
                            Environment
                            <input list="race-environment-options"
                                   placeholder="All environments"
                                   @bind="raceEnvironment"
                                   @bind:event="oninput"
                                   @bind:after="ResetRaceWindowAsync" />
                            <datalist id="race-environment-options">
                                @foreach (var environment in sectorRaces.Select(race => race.EnvironmentType).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct().OrderBy(value => value))
                                {
                                    <option value="@environment" />
                                }
                            </datalist>
                        </label>
                        <label>
                            Appearance
                            <input list="race-appearance-options"
                                   placeholder="All appearances"
                                   @bind="raceAppearance"
                                   @bind:event="oninput"
                                   @bind:after="ResetRaceWindowAsync" />
                            <datalist id="race-appearance-options">
                                @foreach (var appearance in sectorRaces.Select(race => race.AppearanceType).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct().OrderBy(value => value))
                                {
                                    <option value="@appearance" />
                                }
                            </datalist>
                        </label>
                    }
                    <button type="button" class="timeline-clear-button" @onclick="ClearRaceFilters">Clear filters</button>
                </details>
                <div class="timeline-count">Showing @sectorRaces.Count race@(sectorRaces.Count == 1 ? string.Empty : "s")@(raceHasMoreRecords ? "+" : string.Empty)</div>
                @if (sectorRaces.Count == 0)
                {
                    <article class="timeline-event-card">
                        @if (raceSearchInProgress)
                        {
                            <span class="timeline-century">Searching races</span>
                            <p>Looking through additional race records for matches...</p>
                        }
                        else
                        {
                            <span class="timeline-century">No matches</span>
                            <p>Adjust the filters to widen the race list.</p>
                        }
                    </article>
                }
                @foreach (var race in sectorRaces)
                {
                    <button type="button" class="record-row @(selectedRace?.Id == race.RaceId ? "active" : null)" @onclick="() => SelectRace(race.RaceId)">
                        <strong>@race.Name</strong>
                        <span>@race.AppearanceType; @race.EnvironmentType</span>
                    </button>
                }
                @if (raceHasMoreRecords)
                {
                    <div @ref="raceLoadMoreElement" class="timeline-load-more">
                        <button type="button" @onclick="LoadMoreRaces">Load more</button>
                    </div>
                }
            </div>

            @{
                var raceImages = selectedRace is null
                    ? []
                    : GetEntityImages(EntityImageTargetKind.AlienRace, selectedRace.Id);
            }
            <AlienRaceDetailPanel Race="selectedRace"
                                  HomeWorld="selectedRaceDetail?.HomeWorld"
                                  Empires="sectorEmpires"
                                  RaceImages="raceImages"
                                  ImageUploadStatus="imageUploadStatus"
                                  SelectedEmpireId="RequestedEmpireId ?? 0"
                                  NameSaved="@(name => SaveEntityNameAsync(EntityNoteTargetKind.AlienRace, selectedRace?.Id ?? 0, name))"
                                  UploadRequested="@(args => selectedRace is null ? Task.CompletedTask : UploadEntityImage(EntityImageTargetKind.AlienRace, selectedRace.Id, args))"
                                  WorldSelected="NavigateToWorld"
                                  EmpireSelected="NavigateToEmpire" />
        </section>
