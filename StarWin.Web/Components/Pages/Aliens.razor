@layout SectorExplorerLayout
@page "/sector-explorer/aliens"
@rendermode InteractiveServer

@{
    var sector = GetSelectedSector();
    var sectorSummary = GetSectorSummary(sector);
    var sectionCache = GetSectorCache(sector);
    var sectorRaceIds = sectionCache.RaceIds;
    var sectorEmpireIds = sectionCache.EmpireIds;
    var sectorRaces = ExplorerAlienRaces.Where(race => sectorRaceIds.Contains(race.Id)).OrderBy(race => race.Name).ToList();
    var sectorEmpires = ExplorerEmpires.Where(empire => sectorEmpireIds.Contains(empire.Id)).OrderBy(empire => empire.Name).ToList();
    var selectedRace = sectorRaces.FirstOrDefault(race => race.Id == selectedRaceId) ?? sectorRaces.FirstOrDefault();
    var layoutState = new SectorExplorerLayoutState(
        null,
        ExplorerSectors,
        sector.Systems.ToList(),
        selectedSectorId,
        EventCallback.Factory.Create<int>(this, HandleSectorChangedAsync),
        selectedSystemText,
        EventCallback.Factory.Create<string>(this, HandleSelectedSystemTextChangedAsync),
        searchQuery,
        EventCallback.Factory.Create<string>(this, HandleSearchQueryChangedAsync),
        searchResults,
        EventCallback.Factory.Create<StarWinSearchResult>(this, NavigateToSearchResult),
        sections,
        "Aliens",
        explorerRenderError,
        DisplayResultType,
        BuildSectionRoute);
}

<PageTitle>Aliens | Starforged Atlas</PageTitle>
<SectorExplorerLayoutSync State="layoutState" />

<section class="content-grid">
            <div class="record-list">
                <details class="record-filter-panel" open>
                    <summary class="record-filter-summary">Search</summary>
                    <label>
                        Search
                        <input placeholder="Name, biology, traits..."
                               @bind="raceQuery"
                               @bind:event="oninput"
                               @bind:after="ResetRaceWindow" />
                    </label>
                    <button type="button" class="timeline-clear-button" @onclick="ToggleRaceFilters">
                        @(showRaceFilters ? "Hide filters" : "Show filters")
                    </button>
                    @if (showRaceFilters)
                    {
                        <label>
                            Environment
                            <input list="race-environment-options"
                                   placeholder="All environments"
                                   @bind="raceEnvironment"
                                   @bind:event="oninput"
                                   @bind:after="ResetRaceWindow" />
                            <datalist id="race-environment-options">
                                @foreach (var environment in sectorRaces.Select(race => race.EnvironmentType).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct().OrderBy(value => value))
                                {
                                    <option value="@environment" />
                                }
                            </datalist>
                        </label>
                        <label>
                            Appearance
                            <input list="race-appearance-options"
                                   placeholder="All appearances"
                                   @bind="raceAppearance"
                                   @bind:event="oninput"
                                   @bind:after="ResetRaceWindow" />
                            <datalist id="race-appearance-options">
                                @foreach (var appearance in sectorRaces.Select(race => race.AppearanceType).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct().OrderBy(value => value))
                                {
                                    <option value="@appearance" />
                                }
                            </datalist>
                        </label>
                    }
                    <button type="button" class="timeline-clear-button" @onclick="ClearRaceFilters">Clear filters</button>
                </details>
                @{
                    var raceWindow = GetFilteredRaces(sectorRaces)
                        .Take(raceVisibleCount + 1)
                        .ToList();
                    var hasMoreRaces = raceWindow.Count > raceVisibleCount;
                    var visibleRaces = raceWindow.Take(raceVisibleCount).ToList();
                    raceHasMoreRecords = hasMoreRaces;
                }
                <div class="timeline-count">Showing @visibleRaces.Count race@(visibleRaces.Count == 1 ? string.Empty : "s")@(hasMoreRaces ? "+" : string.Empty)</div>
                @if (visibleRaces.Count == 0)
                {
                    <article class="timeline-event-card">
                        <span class="timeline-century">No matches</span>
                        <p>Adjust the filters to widen the race list.</p>
                    </article>
                }
                @foreach (var race in visibleRaces)
                {
                    <button type="button" class="record-row @(selectedRace?.Id == race.Id ? "active" : null)" @onclick="() => SelectRace(race.Id)">
                        <strong>@race.Name</strong>
                        <span>@race.AppearanceType; @race.EnvironmentType</span>
                    </button>
                }
                @if (hasMoreRaces)
                {
                    <div @ref="raceLoadMoreElement" class="timeline-load-more">
                        <button type="button" @onclick="LoadMoreRaces">Load more</button>
                    </div>
                }
            </div>

            @if (selectedRace is not null)
            {
                var gurpsTemplate = BuildGurpsTemplate(selectedRace, sectorEmpires);
                var homeWorld = FindWorld(selectedRace.HomePlanetId);
                var raceMemberships = GetRaceEmpireMemberships(selectedRace, sectorEmpires).ToList();
                var primaryEmpire = GetPrimaryEmpire(selectedRace, sectorEmpires);
                var raceHighlights = GetRaceHighlights(selectedRace).ToList();
                var baselineTraits = GetBaselineCivilizationTraits(selectedRace);
                var empireTraitOverrides = GetEmpireCivilizationOverrides(selectedRace, sectorEmpires);
                var raceImages = GetEntityImages(EntityImageTargetKind.AlienRace, selectedRace.Id);
                <article class="detail-panel alien-detail-panel">
                    <span class="panel-kicker">Alien biology</span>
                    <EditableEntityName Name="@selectedRace.Name"
                                        Label="Race"
                                        NameSaved="name => SaveEntityNameAsync(EntityNoteTargetKind.AlienRace, selectedRace.Id, name)" />
                    <div class="alien-overview-grid">
                        <section class="alien-summary-card alien-summary-card-primary">
                            <div class="parent-actions">
                                @if (homeWorld is not null)
                                {
                                    <button type="button" @onclick="() => NavigateToWorld(homeWorld.Id)">Homeworld: @homeWorld.Name</button>
                                }
                            </div>
                            <dl class="field-grid alien-field-grid alien-field-grid-primary">
                                <div><dt>Appearance</dt><dd>@DisplayText(selectedRace.AppearanceType)</dd></div>
                                <div><dt>Environment</dt><dd>@DisplayText(selectedRace.EnvironmentType)</dd></div>
                                <div><dt>Biology</dt><dd>@DisplayText(selectedRace.BodyChemistry)</dd></div>
                                <div><dt>Body cover</dt><dd>@DisplayText(selectedRace.BodyCoverType)</dd></div>
                                <div><dt>Mass</dt><dd>@selectedRace.MassKg kg</dd></div>
                                <div><dt>Size</dt><dd>@selectedRace.SizeCm cm</dd></div>
                                <div><dt>Limb pairs</dt><dd>@selectedRace.LimbPairCount</dd></div>
                                <div><dt>Limb summary</dt><dd>@GetLimbSummary(selectedRace)</dd></div>
                                <div><dt>Lifespan</dt><dd>@DisplayLifespan(selectedRace.BiologyProfile.Lifespan)</dd></div>
                                <div><dt>Body</dt><dd>@selectedRace.BiologyProfile.Body</dd></div>
                                <div><dt>Mind</dt><dd>@selectedRace.BiologyProfile.Mind</dd></div>
                                <div><dt>Speed</dt><dd>@selectedRace.BiologyProfile.Speed</dd></div>
                                <div><dt>Psi</dt><dd>@selectedRace.BiologyProfile.PsiRating</dd></div>
                                <div><dt>Gravity pref.</dt><dd>@DisplayText(selectedRace.GravityPreference)</dd></div>
                                <div><dt>Temperature pref.</dt><dd>@DisplayText(selectedRace.TemperaturePreference)</dd></div>
                                <div><dt>Atmosphere breathed</dt><dd>@DisplayText(selectedRace.AtmosphereBreathed)</dd></div>
                            </dl>
                            @if (raceHighlights.Count > 0)
                            {
                                <div class="tag-group alien-tag-group">
                                    @foreach (var highlight in raceHighlights)
                                    {
                                        <span>@highlight</span>
                                    }
                                </div>
                            }
                        </section>

                        <section class="entity-image-panel alien-image-panel @(raceImages.Count == 0 ? "compact-empty" : null)">
                            <div class="image-panel-header">
                                <h4>Race images</h4>
                                <span>Multiple allowed</span>
                            </div>
                            @if (raceImages.Count > 0)
                            {
                                <div class="entity-image-grid">
                                    @foreach (var image in raceImages)
                                    {
                                        <figure>
                                            <img src="@image.RelativePath" alt="@image.FileName" />
                                            <figcaption>@(image.IsPrimary ? "Primary" : image.FileName)</figcaption>
                                        </figure>
                                    }
                                </div>
                            }
                            else
                            {
                                <p>No image uploaded.</p>
                            }
                            <label class="image-upload-control">
                                <span>Add image</span>
                                <InputFile OnChange="@(args => UploadEntityImage(EntityImageTargetKind.AlienRace, selectedRace.Id, args))" accept="image/jpeg,image/png,image/gif,image/webp" />
                            </label>
                            @if (!string.IsNullOrWhiteSpace(imageUploadStatus))
                            {
                                <small>@imageUploadStatus</small>
                            }
                        </section>
                    </div>

                    <div class="alien-secondary-grid">
                        <section class="alien-summary-card">
                            <h3>Society</h3>
                            <dl class="field-grid alien-field-grid">
                                <div><dt>Primary empire</dt><dd>@DisplayText(primaryEmpire?.Name)</dd></div>
                                <div><dt>Government</dt><dd>@DisplayText(primaryEmpire?.GovernmentType)</dd></div>
                                <div><dt>Tech level</dt><dd>@(primaryEmpire?.CivilizationProfile.TechLevel.ToString() ?? "N/A")</dd></div>
                                <div><dt>Spatial age</dt><dd>@(primaryEmpire?.CivilizationProfile.SpatialAge.ToString() ?? "N/A")</dd></div>
                                <div><dt>Diet</dt><dd>@DisplayText(selectedRace.Diet)</dd></div>
                                <div><dt>Faith</dt><dd>@DisplayJoinedValues(primaryEmpire?.Religions.Select(religion => religion.ReligionName) ?? [])</dd></div>
                                <div><dt>Devotion</dt><dd>@selectedRace.DevotionLevel</dd></div>
                                <div><dt>Reproduction</dt><dd>@DisplayText(selectedRace.Reproduction)</dd></div>
                                <div><dt>Method</dt><dd>@DisplayText(selectedRace.ReproductionMethod)</dd></div>
                            </dl>
                        </section>

                        <section class="alien-summary-card">
                            <h3>Derived data</h3>
                            <dl class="field-grid alien-field-grid">
                                <div><dt>Edition</dt><dd>@DisplayGurpsEdition(gurpsTemplate.Edition)</dd></div>
                                <div><dt>Total cost</dt><dd>@DisplayPoints(gurpsTemplate.TotalPointCost)</dd></div>
                                <div><dt>Trait entries</dt><dd>@CountGurpsTraits(gurpsTemplate)</dd></div>
                                <div><dt>Memberships</dt><dd>@raceMemberships.Count</dd></div>
                                <div><dt>Source</dt><dd>StarWin conversion</dd></div>
                            </dl>
                            @if (!string.IsNullOrWhiteSpace(gurpsTemplate.Notes))
                            {
                                <p>@gurpsTemplate.Notes</p>
                            }
                        </section>
                    </div>

                    <details class="alien-disclosure-card">
                        <summary>Species baseline traits <span>@baselineTraits.Count</span></summary>
                        <div class="alien-gurps-body">
                            <dl class="field-grid alien-field-grid">
                                @foreach (var trait in baselineTraits)
                                {
                                    <div><dt>@trait.Name</dt><dd>@trait.Baseline</dd></div>
                                }
                            </dl>
                        </div>
                    </details>

                    <details class="alien-disclosure-card">
                        <summary>Empire modifiers <span>@empireTraitOverrides.Count</span></summary>
                        @if (empireTraitOverrides.Count == 0)
                        {
                            <p class="alien-empty-state">No empire-specific civilization modifiers in this sector.</p>
                        }
                        else
                        {
                            <div class="relationship-list">
                                @foreach (var entry in empireTraitOverrides)
                                {
                                    <article class="timeline-event-card">
                                        <span class="timeline-century">@entry.Empire.Name</span>
                                        <dl class="field-grid alien-field-grid">
                                            @foreach (var trait in entry.Traits)
                                            {
                                                <div><dt>@trait.Name</dt><dd>@trait.Computed (base @trait.Baseline, mod @DisplayModifier(trait.Modifier))</dd></div>
                                            }
                                        </dl>
                                    </article>
                                }
                            </div>
                        }
                    </details>

                    <details class="alien-disclosure-card" @(raceMemberships.Count > 0 ? null : "open")>
                        <summary>Empire memberships <span>@raceMemberships.Count</span></summary>
                        @if (raceMemberships.Count == 0)
                        {
                            <p class="alien-empty-state">No empire memberships in this sector.</p>
                        }
                        else
                        {
                            <div class="relationship-list">
                                @foreach (var membership in raceMemberships)
                                {
                                    <button type="button" class="relationship-row" @onclick="() => NavigateToEmpire(membership.Empire.Id)">
                                        <strong>@membership.Empire.Name</strong>
                                        <span>@membership.Membership.Role; @membership.Membership.PopulationMillions million</span>
                                    </button>
                                }
                            </div>
                        }
                    </details>

                    <details class="alien-disclosure-card">
                        <summary>Physical traits</summary>
                        <div class="alien-gurps-body">
                            <dl class="field-grid alien-field-grid">
                                <div><dt>Limb details</dt><dd>@DisplayJoinedValues(selectedRace.LimbTypes)</dd></div>
                                <div><dt>Abilities</dt><dd>@DisplayJoinedValues(selectedRace.Abilities)</dd></div>
                                <div><dt>Body characteristics</dt><dd>@DisplayJoinedValues(selectedRace.BodyCharacteristics)</dd></div>
                                <div><dt>Body colors</dt><dd>@DisplayJoinedValues(selectedRace.Colors)</dd></div>
                                <div><dt>Color pattern</dt><dd>@DisplayText(selectedRace.ColorPattern)</dd></div>
                                <div><dt>Eye details</dt><dd>@DisplayJoinedValues(selectedRace.EyeCharacteristics)</dd></div>
                                <div><dt>Eye colors</dt><dd>@DisplayJoinedValues(selectedRace.EyeColors)</dd></div>
                                <div><dt>Hair type</dt><dd>@DisplayText(selectedRace.HairType)</dd></div>
                                <div><dt>Hair colors</dt><dd>@DisplayJoinedValues(selectedRace.HairColors)</dd></div>
                            </dl>
                        </div>
                    </details>

                    <details class="alien-disclosure-card">
                        <summary>Visual profile</summary>
                        <p class="alien-empty-state">Copy this block into ChatGPT or another image model as a starting point for race concept art.</p>
                        <pre class="timeline-import-data">@BuildVisualDescriptionPrompt(selectedRace)</pre>
                    </details>

                    <details class="alien-disclosure-card">
                        <summary>Notes</summary>
                        <EntityNotesPanel TargetKind="EntityNoteTargetKind.AlienRace"
                                          TargetId="selectedRace.Id"
                                          Title="Alien notes" />
                    </details>

                    @if (!string.IsNullOrWhiteSpace(selectedRace.ImportDataJson))
                    {
                        <details class="alien-disclosure-card">
                            <summary>Import data</summary>
                            <pre class="timeline-import-data">@selectedRace.ImportDataJson</pre>
                        </details>
                    }

                    <details class="alien-disclosure-card">
                        <summary>GURPS template <span>@CountGurpsTraits(gurpsTemplate) entries</span></summary>
                        <div class="alien-gurps-body">
                            @if (!string.IsNullOrWhiteSpace(gurpsTemplate.Notes))
                            {
                                <p>@gurpsTemplate.Notes</p>
                            }
                            <div class="gurps-grid">
                                <article>
                                    <h4>Attributes</h4>
                                    @if (!gurpsTemplate.AttributeModifiers.Any())
                                    {
                                        <p>No entries.</p>
                                    }
                                    @foreach (var trait in gurpsTemplate.AttributeModifiers)
                                    {
                                        <div class="gurps-trait">
                                            <span>@DisplayTraitName(trait)</span>
                                            <strong>@DisplayPoints(trait.PointCost)</strong>
                                            @if (!string.IsNullOrWhiteSpace(trait.Notes))
                                            {
                                                <small>@trait.Notes</small>
                                            }
                                        </div>
                                    }
                                </article>
                                <article>
                                    <h4>Secondary</h4>
                                    @if (!gurpsTemplate.SecondaryCharacteristicModifiers.Any())
                                    {
                                        <p>No entries.</p>
                                    }
                                    @foreach (var trait in gurpsTemplate.SecondaryCharacteristicModifiers)
                                    {
                                        <div class="gurps-trait">
                                            <span>@DisplayTraitName(trait)</span>
                                            <strong>@DisplayPoints(trait.PointCost)</strong>
                                            @if (!string.IsNullOrWhiteSpace(trait.Notes))
                                            {
                                                <small>@trait.Notes</small>
                                            }
                                        </div>
                                    }
                                </article>
                                <article>
                                    <h4>Advantages</h4>
                                    @if (!gurpsTemplate.Advantages.Any())
                                    {
                                        <p>No entries.</p>
                                    }
                                    @foreach (var trait in gurpsTemplate.Advantages)
                                    {
                                        <div class="gurps-trait">
                                            <span>@DisplayTraitName(trait)</span>
                                            <strong>@DisplayPoints(trait.PointCost)</strong>
                                            @if (!string.IsNullOrWhiteSpace(trait.Notes))
                                            {
                                                <small>@trait.Notes</small>
                                            }
                                        </div>
                                    }
                                </article>
                                <article>
                                    <h4>Disadvantages</h4>
                                    @if (!gurpsTemplate.Disadvantages.Any())
                                    {
                                        <p>No entries.</p>
                                    }
                                    @foreach (var trait in gurpsTemplate.Disadvantages)
                                    {
                                        <div class="gurps-trait">
                                            <span>@DisplayTraitName(trait)</span>
                                            <strong>@DisplayPoints(trait.PointCost)</strong>
                                            @if (!string.IsNullOrWhiteSpace(trait.Notes))
                                            {
                                                <small>@trait.Notes</small>
                                            }
                                        </div>
                                    }
                                </article>
                                <article>
                                    <h4>Quirks</h4>
                                    @if (!gurpsTemplate.Quirks.Any())
                                    {
                                        <p>No entries.</p>
                                    }
                                    @foreach (var trait in gurpsTemplate.Quirks)
                                    {
                                        <div class="gurps-trait">
                                            <span>@DisplayTraitName(trait)</span>
                                            <strong>@DisplayPoints(trait.PointCost)</strong>
                                            @if (!string.IsNullOrWhiteSpace(trait.Notes))
                                            {
                                                <small>@trait.Notes</small>
                                            }
                                        </div>
                                    }
                                </article>
                                <article>
                                    <h4>Features</h4>
                                    @if (!gurpsTemplate.Features.Any())
                                    {
                                        <p>No entries.</p>
                                    }
                                    @foreach (var trait in gurpsTemplate.Features)
                                    {
                                        <div class="gurps-trait">
                                            <span>@DisplayTraitName(trait)</span>
                                            <strong>@DisplayPoints(trait.PointCost)</strong>
                                            @if (!string.IsNullOrWhiteSpace(trait.Notes))
                                            {
                                                <small>@trait.Notes</small>
                                            }
                                        </div>
                                    }
                                </article>
                                <article>
                                    <h4>Skills</h4>
                                    @if (!gurpsTemplate.Skills.Any())
                                    {
                                        <p>No entries.</p>
                                    }
                                    @foreach (var trait in gurpsTemplate.Skills)
                                    {
                                        <div class="gurps-trait">
                                            <span>@DisplayTraitName(trait)</span>
                                            <strong>@DisplayPoints(trait.PointCost)</strong>
                                            @if (!string.IsNullOrWhiteSpace(trait.Notes))
                                            {
                                                <small>@trait.Notes</small>
                                            }
                                        </div>
                                    }
                                </article>
                            </div>
                        </div>
                    </details>
                </article>
            }
        </section>
