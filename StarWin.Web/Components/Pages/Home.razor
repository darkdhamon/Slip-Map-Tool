        worldsById ??= Workspace.Sectors
            .SelectMany(sector => sector.Systems)
            .SelectMany(system => system.Worlds)
            .GroupBy(world => world.Id)
            .ToDictionary(group => group.Key, group => group.First());

    protected override void OnInitialized()
    {
        var initialSector = RequestedSectorId is int requestedSectorId
            ? Workspace.Sectors.FirstOrDefault(sector => sector.Id == requestedSectorId) ?? Workspace.CurrentSector
            : Workspace.CurrentSector;

        selectedSectorId = initialSector.Id;
        selectedSystemId = initialSector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(initialSector, selectedSystemId);
        routeOriginSystemId = selectedSystemId;
        routeOriginText = FormatSelectedSystem(initialSector, routeOriginSystemId);
        selectedWorldId = initialSector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Id ?? 0;
        SelectDefaultCivilizationRecords(initialSector);
        LoadSectorConfigurationForm(initialSector);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreExplorerSessionAsync();
            browserSessionReady = true;
            StateHasChanged();
            return;
        }

        if (activeSection == "Timeline")
        {
            renderedOverview = false;
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        if (activeSection == "Colonies")
        {
            renderedOverview = false;
            await EnsureEntityImagesLoadedAsync();
            await ConfigureColonyObserverAsync();
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        colonyObserverConfigured = false;
        if (activeSection == "Systems")
        {
            renderedOverview = false;
            await EnsureEntityImagesLoadedAsync();
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        if (activeSection == "Worlds")
        {
            renderedOverview = false;
            await EnsureEntityImagesLoadedAsync();
            await ConfigureRecordObserverAsync("world", worldHasMoreRecords, () => worldObserverConfigured, value => worldObserverConfigured = value, worldLoadMoreElement, "LoadMoreWorlds");
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        worldObserverConfigured = false;
        if (activeSection == "Aliens")
        {
            renderedOverview = false;
            await EnsureEntityImagesLoadedAsync();
            await ConfigureRecordObserverAsync("race", raceHasMoreRecords, () => raceObserverConfigured, value => raceObserverConfigured = value, raceLoadMoreElement, "LoadMoreRaces");
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        raceObserverConfigured = false;
        if (activeSection == "Empires")
        {
            renderedOverview = false;
            await EnsureEntityImagesLoadedAsync();
            await ConfigureRecordObserverAsync("empire", empireHasMoreRecords, () => empireObserverConfigured, value => empireObserverConfigured = value, empireLoadMoreElement, "LoadMoreEmpires");
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        empireObserverConfigured = false;
        if (activeSection != "Overview")
        {
            renderedOverview = false;
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        if (!sectorMapRequested)
        {
            if (autoLoadSectorMap)
            {
                sectorMapRequested = true;
                renderedOverview = false;
                StateHasChanged();
                return;
            }

            renderedOverview = false;
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        if (!firstRender
            && renderedOverview
            && renderedSectorId == sector.Id
            && renderedSystemId == selectedSystemId
            && renderedViewDistanceParsecs == sectorMapViewDistanceParsecs
            && renderedRouteOriginSystemId == routeOriginSystemId
            && renderedRouteDestinationSystemId == routeDestinationSystemId
            && Math.Abs(renderedRouteDistanceParsecs - GetHyperlaneRouteDistanceParsecs(sector)) < 0.001)
        {
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        sectorMapModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/sectorMap3d.js");
        dotNetReference ??= DotNetObjectReference.Create(this);

        await sectorMapModule.InvokeVoidAsync(
            "renderSectorMap",
            sectorMapElement,
            BuildSectorMap(sector, selectedSystemId),
            selectedSystemId,
            dotNetReference);

        renderedSectorId = sector.Id;
        renderedSystemId = selectedSystemId;
        renderedViewDistanceParsecs = sectorMapViewDistanceParsecs;
        renderedRouteDistanceParsecs = GetHyperlaneRouteDistanceParsecs(sector);
        renderedRouteOriginSystemId = routeOriginSystemId;
        renderedRouteDestinationSystemId = routeDestinationSystemId;
        renderedOverview = true;
        await CompleteSectionLoadingIfReadyAsync();
    }

    private async Task EnsureEntityImagesLoadedAsync()
    {
        if (entityImagesLoaded)
        {
            return;
        }

        entityImages = await ImageService.GetImagesAsync();
        entityImagesLoaded = true;
        StateHasChanged();
    }

    private async Task SelectSectionAsync(string sectionName)
    {
        if (activeSection == sectionName || sectionLoadingVisible)
        {
            return;
        }

        sectionLoadingTarget = sectionName;
        sectionLoadingStatus = $"Preparing {sectionName} records...";
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingVisible = true;
        StateHasChanged();

        await Task.Delay(80);

        sectionLoadingStatus = $"Rendering {sectionName}...";
        activeSection = sectionName;
        sectionLoadingAwaitingTargetRender = true;
        StateHasChanged();
    }

    private async Task CompleteSectionLoadingIfReadyAsync()
    {
        if (!sectionLoadingVisible
            || !sectionLoadingAwaitingTargetRender
            || !string.Equals(activeSection, sectionLoadingTarget, StringComparison.Ordinal))
        {
            return;
        }

        sectionLoadingStatus = $"{activeSection} ready.";
        StateHasChanged();
        await Task.Delay(140);

        sectionLoadingVisible = false;
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingTarget = string.Empty;
        sectionLoadingStatus = string.Empty;
        StateHasChanged();
    }

