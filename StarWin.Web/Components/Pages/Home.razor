    private async Task ConfigureColonyObserverAsync()
    {
        if (!colonyHasMoreRecords)
        {
            colonyObserverConfigured = false;
            if (timelineScrollModule is not null)
            {
                await timelineScrollModule.InvokeVoidAsync("disconnectColonyLoadMore");
            }

            return;
        }

        if (colonyObserverConfigured)
        {
            return;
        }

        timelineScrollModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/timelineInfiniteScroll.js");
        dotNetReference ??= DotNetObjectReference.Create(this);
        await timelineScrollModule.InvokeVoidAsync("observeColonyLoadMore", colonyLoadMoreElement, dotNetReference);
        colonyObserverConfigured = true;
    }

    private async Task ConfigureRecordObserverAsync(
        string key,
        bool hasMoreRecords,
        Func<bool> isConfigured,
        Action<bool> setConfigured,
        ElementReference loadMoreElement,
        string loadMoreMethodName)
    {
        if (!hasMoreRecords)
        {
            setConfigured(false);
            if (timelineScrollModule is not null)
            {
                await timelineScrollModule.InvokeVoidAsync("disconnectLoadMore", key);
            }

            return;
        }

        if (isConfigured())
        {
            return;
        }

        timelineScrollModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/timelineInfiniteScroll.js");
        dotNetReference ??= DotNetObjectReference.Create(this);
        await timelineScrollModule.InvokeVoidAsync("observeLoadMore", key, loadMoreElement, dotNetReference, loadMoreMethodName);
        setConfigured(true);
    }

