                    </article>
                }
            </section>
            break;
    }
</section>

@code {
    private const int DefaultSectorMapViewDistanceParsecs = 5;
    private const int SectorMapMaximumRenderedSystems = 1_000;
    private const double SectorMapMaximumLabelDistanceParsecs = 5;
    private const string ExplorerSessionStorageKey = "starforgedAtlas.explorerSelection";

    [SupplyParameterFromQuery(Name = "sectorId")]
    public int? RequestedSectorId { get; set; }

    private readonly string[] sections = ["Overview", "Timeline", "Configuration", "Systems", "Worlds", "Colonies", "Aliens", "Empires"];
    private string activeSection = "Overview";
    private int selectedSectorId;
    private int selectedSystemId;
    private int selectedWorldId;
    private int selectedHabitatId;
    private int selectedRaceId;
    private int selectedEmpireId;
    private string searchQuery = string.Empty;
    private IReadOnlyList<StarWinSearchResult> searchResults = [];
    private ElementReference sectorMapElement;
    private DotNetObjectReference<Home>? dotNetReference;
    private IJSObjectReference? sectorMapModule;
    private int renderedSectorId;
    private int renderedSystemId;
    private int renderedViewDistanceParsecs;
    private double renderedRouteDistanceParsecs;
    private bool renderedOverview;
    private bool browserSessionRestored;
    private bool browserSessionReady;
    private IReadOnlyList<EntityImage> entityImages = [];
    private string imageUploadStatus = string.Empty;
    private string timelineQuery = string.Empty;
    private int timelineRaceId;
    private int timelineEmpireId;
    private int timelineColonyId;
    private int timelineSystemId;
    private int timelineWorldId;
    private string timelineEventType = string.Empty;
    private string basicHyperlaneTierName = "Basic";
    private decimal basicHyperlaneMaximumLengthParsecs = 1m;
    private string sectorConfigurationStatus = string.Empty;
    private int sectorMapViewDistanceParsecs = DefaultSectorMapViewDistanceParsecs;

    protected override void OnInitialized()
    {
        var initialSector = RequestedSectorId is int requestedSectorId
            ? Workspace.Sectors.FirstOrDefault(sector => sector.Id == requestedSectorId) ?? Workspace.CurrentSector
            : Workspace.CurrentSector;

        selectedSectorId = initialSector.Id;
        selectedSystemId = initialSector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedWorldId = initialSector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Id ?? 0;
        SelectDefaultCivilizationRecords(initialSector);
        LoadSectorConfigurationForm(initialSector);
    }

    protected override async Task OnInitializedAsync()
    {
        entityImages = await ImageService.GetImagesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreExplorerSessionAsync();
            browserSessionReady = true;
            StateHasChanged();
            return;
        }

        if (activeSection != "Overview")
        {
            renderedOverview = false;
            return;
        }

        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        if (!firstRender
            && renderedOverview
            && renderedSectorId == sector.Id
            && renderedSystemId == selectedSystemId
            && renderedViewDistanceParsecs == sectorMapViewDistanceParsecs
            && Math.Abs(renderedRouteDistanceParsecs - GetHyperlaneRouteDistanceParsecs(sector)) < 0.001)
        {
            return;
        }

        sectorMapModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/sectorMap3d.js");
        dotNetReference ??= DotNetObjectReference.Create(this);

        await sectorMapModule.InvokeVoidAsync(
            "renderSectorMap",
            sectorMapElement,
            BuildSectorMap(sector, selectedSystemId),
            selectedSystemId,
            dotNetReference);

        renderedSectorId = sector.Id;
        renderedSystemId = selectedSystemId;
        renderedViewDistanceParsecs = sectorMapViewDistanceParsecs;
        renderedRouteDistanceParsecs = GetHyperlaneRouteDistanceParsecs(sector);
        renderedOverview = true;
    }

    private void SelectSystem(int systemId)
    {
        selectedSystemId = systemId;
        activeSection = activeSection == "Overview" ? "Overview" : "Systems";
        SelectDefaultWorld();
        _ = PersistExplorerSessionAsync();
    }

    private void OpenSelectedSystemRecord()
    {
        activeSection = "Systems";
    }

    private async Task ToggleSectorMapFullscreen()
    {
        sectorMapModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/sectorMap3d.js");
        await sectorMapModule.InvokeVoidAsync("toggleMapFullscreen", sectorMapElement);
    }

    [JSInvokable]
    public async Task SelectSystemFromMap(int systemId)
    {
        selectedSystemId = systemId;
        activeSection = "Overview";
        SelectDefaultWorld();
        await PersistExplorerSessionAsync();
        StateHasChanged();
    }

    private void SelectWorld(int worldId)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var system = sector.Systems.FirstOrDefault(system => system.Worlds.Any(world => world.Id == worldId));
        if (system is not null)
        {
            selectedSystemId = system.Id;
        }

        selectedWorldId = worldId;
        selectedHabitatId = 0;
        activeSection = "Worlds";
        _ = PersistExplorerSessionAsync();
    }

    private void SelectHabitat(int habitatId)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var system = sector.Systems.FirstOrDefault(system => system.SpaceHabitats.Any(habitat => habitat.Id == habitatId));
        if (system is not null)
        {
            selectedSystemId = system.Id;
        }

        selectedHabitatId = habitatId;
        activeSection = "Worlds";
        _ = PersistExplorerSessionAsync();
    }

    private void SelectParentOfHabitat(SpaceHabitat habitat)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var system = sector.Systems.FirstOrDefault(system => system.SpaceHabitats.Any(item => item.Id == habitat.Id))
            ?? sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId);

        if (system is not null)
        {
            selectedSystemId = system.Id;
            _ = PersistExplorerSessionAsync();
        }

        if (habitat.OrbitTargetKind == OrbitTargetKind.World
            && system?.Worlds.FirstOrDefault(world => world.Id == habitat.OrbitTargetId) is World parentWorld)
        {
            SelectWorld(parentWorld.Id);
            return;
        }

        activeSection = "Systems";
    }

    private void SelectColony(int worldId)
    {
        SelectWorld(worldId);
        activeSection = "Colonies";
    }

    private void SelectRace(int raceId)
    {
        selectedRaceId = raceId;
        activeSection = "Aliens";
    }

    private void SelectEmpire(int empireId)
    {
        selectedEmpireId = empireId;
        activeSection = "Empires";
    }

    private void SelectDefaultSystem()
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        selectedSystemId = sector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedWorldId = sector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedHabitatId = 0;
        sectorMapViewDistanceParsecs = Math.Min(
            sectorMapViewDistanceParsecs,
            GetSectorMapMaximumViewDistance(sector));
        SelectDefaultCivilizationRecords(sector);
        LoadSectorConfigurationForm(sector);
        ClearTimelineFilters();
        _ = PersistExplorerSessionAsync();
    }

    private void SelectDefaultWorld()
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var system = sector.Systems.FirstOrDefault(item => item.Id == selectedSystemId);
        selectedWorldId = system?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedHabitatId = 0;
        _ = PersistExplorerSessionAsync();
    }

    private async Task RestoreExplorerSessionAsync()
    {
        if (browserSessionRestored)
        {
            return;
        }

        browserSessionRestored = true;
        if (RequestedSectorId is not null)
        {
            await PersistExplorerSessionAsync(force: true);
            return;
        }

        string? storedValue;
        try
        {
            storedValue = await JS.InvokeAsync<string?>("sessionStorage.getItem", ExplorerSessionStorageKey);
        }
        catch (InvalidOperationException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(storedValue))
        {
            return;
        }

        ExplorerSessionSelection? storedSelection;
        try
        {
            storedSelection = System.Text.Json.JsonSerializer.Deserialize<ExplorerSessionSelection>(storedValue);
        }
        catch (System.Text.Json.JsonException)
        {
            return;
        }

        if (storedSelection is null)
        {
            return;
        }

        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == storedSelection.SectorId);
        if (sector is null)
        {
            return;
        }

        selectedSectorId = sector.Id;
        selectedSystemId = sector.Systems.Any(system => system.Id == storedSelection.SystemId)
            ? storedSelection.SystemId
            : sector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedWorldId = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId)?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedHabitatId = 0;
        sectorMapViewDistanceParsecs = Math.Min(
            sectorMapViewDistanceParsecs,
            GetSectorMapMaximumViewDistance(sector));
        SelectDefaultCivilizationRecords(sector);
        LoadSectorConfigurationForm(sector);
        ClearTimelineFilters();
    }

    private async Task PersistExplorerSessionAsync(bool force = false)
    {
        if (!browserSessionReady && !force)
        {
            return;
        }

        var selection = new ExplorerSessionSelection(selectedSectorId, selectedSystemId);
        var value = System.Text.Json.JsonSerializer.Serialize(selection);
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", ExplorerSessionStorageKey, value);
        }
        catch (InvalidOperationException)
        {
        }
    }

    private void LoadSectorConfigurationForm(StarWinSector sector)
    {
        basicHyperlaneTierName = GetHyperlaneTierName(sector);
        basicHyperlaneMaximumLengthParsecs = Math.Round(sector.Configuration.BasicHyperlaneMaximumLengthParsecs, 3);
        sectorConfigurationStatus = string.Empty;
    }

    private async Task SaveSectorConfiguration()
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var configuration = await SectorConfigurationService.SaveBasicHyperlaneSettingsAsync(
            sector.Id,
            basicHyperlaneTierName,
            basicHyperlaneMaximumLengthParsecs);

        sector.Configuration.BasicHyperlaneTierName = configuration.BasicHyperlaneTierName;
        sector.Configuration.BasicHyperlaneMaximumLengthParsecs = configuration.BasicHyperlaneMaximumLengthParsecs;
        sector.Configuration.UpdatedAtUtc = configuration.UpdatedAtUtc;
        LoadSectorConfigurationForm(sector);
        sectorConfigurationStatus = $"{configuration.BasicHyperlaneTierName} hyperlanes now connect systems up to {configuration.BasicHyperlaneMaximumLengthParsecs:0.###} parsecs apart.";
        renderedOverview = false;
    }

    private void RunSearch()
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var sectorWorlds = sector.Systems.SelectMany(system => system.Worlds).ToList();
        var sectorColonies = sectorWorlds
            .Where(world => world.Colony is not null)
            .Select(world => (World: world, Colony: world.Colony!))
            .ToList();
        var sectorRaceIds = GetSectorRaceIds(sector, sectorWorlds, sectorColonies);
        var sectorEmpireIds = GetSectorEmpireIds(sector, sectorWorlds, sectorColonies);

        searchResults = SearchService.Search(searchQuery)
            .Where(result => result.Type switch
            {
                StarWinSearchResultType.AlienRace => result.RaceId is int raceId && sectorRaceIds.Contains(raceId),
                StarWinSearchResultType.Empire => result.EmpireId is int empireId && sectorEmpireIds.Contains(empireId),
                _ => true
            })
            .ToList();
    }

    private void NavigateToSearchResult(StarWinSearchResult result)
    {
        activeSection = sections.Contains(result.Tab) ? result.Tab : "Overview";

        if (result.SectorId is int sectorId)
        {
            selectedSectorId = sectorId;
        }

        if (result.SystemId is int systemId)
        {
            selectedSystemId = systemId;
        }

        if (result.WorldId is int worldId)
        {
            selectedWorldId = worldId;
            selectedHabitatId = 0;
        }

        if (result.SpaceHabitatId is int habitatId)
        {
            selectedHabitatId = habitatId;
            activeSection = "Worlds";
        }

        if (result.RaceId is int raceId)
        {
            selectedRaceId = raceId;
        }

        if (result.EmpireId is int empireId)
        {
            selectedEmpireId = empireId;
        }

        searchQuery = result.Title;
        searchResults = [];
        _ = PersistExplorerSessionAsync();
    }

    private string DisplayAllegiance(ushort allegianceId)
    {
        if (allegianceId == ushort.MaxValue)
        {
            return "Independent";
        }

        return Workspace.Empires.FirstOrDefault(empire => empire.Id == allegianceId)?.Name ?? allegianceId.ToString();
    }

    private string DisplayEmpire(int? empireId)
    {
        return empireId is null
            ? "Unassigned"
            : Workspace.Empires.FirstOrDefault(empire => empire.Id == empireId)?.Name ?? empireId.Value.ToString();
    }

    private string DisplayRace(int raceId)
    {
        return Workspace.AlienRaces.FirstOrDefault(race => race.Id == raceId)?.Name ?? raceId.ToString();
    }

    private IEnumerable<HistoryEvent> GetFilteredTimelineEvents(
        StarWinSector sector,
        IReadOnlyList<(World World, Colony Colony)> sectorColonies)
    {
        return sector.History
            .Where(history => TimelineMatches(history, sector, sectorColonies))
            .OrderBy(history => history.Century)
            .ThenBy(history => history.EventType);
    }

    private bool TimelineMatches(
        HistoryEvent history,
        StarWinSector sector,
        IReadOnlyList<(World World, Colony Colony)> sectorColonies)
    {
        if (timelineRaceId != 0 && history.RaceId != timelineRaceId && history.OtherRaceId != timelineRaceId)
        {
            return false;
        }

        if (timelineEmpireId != 0 && history.EmpireId != timelineEmpireId)
        {
            return false;
        }

        if (timelineColonyId != 0 && history.ColonyId != timelineColonyId)
        {
            return false;
        }

        if (timelineSystemId != 0 && history.StarSystemId != timelineSystemId)
        {
            return false;
        }

        if (timelineWorldId != 0 && history.PlanetId != timelineWorldId)
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(timelineEventType)
            && !string.Equals(history.EventType, timelineEventType, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(timelineQuery))
        {
            return true;
        }

        var query = timelineQuery.Trim();
        var systemName = sector.Systems.FirstOrDefault(system => system.Id == history.StarSystemId)?.Name;
        var worldName = sector.Systems.SelectMany(system => system.Worlds).FirstOrDefault(world => world.Id == history.PlanetId)?.Name;
        var colonyName = sectorColonies.FirstOrDefault(item => item.Colony.Id == history.ColonyId) is var colonyListing
            && colonyListing.Colony is not null
                ? $"{colonyListing.Colony.ColonyClass} {colonyListing.World.Name}"
                : null;
        var raceName = history.RaceId is int raceId ? DisplayRace(raceId) : null;
        var otherRaceName = history.OtherRaceId is int otherRaceId ? DisplayRace(otherRaceId) : null;
        var empireName = history.EmpireId is int empireId ? DisplayEmpire(empireId) : null;

        return ContainsTimelineQuery(history.EventType, query)
            || ContainsTimelineQuery(history.Description, query)
            || ContainsTimelineQuery(systemName, query)
            || ContainsTimelineQuery(worldName, query)
            || ContainsTimelineQuery(colonyName, query)
            || ContainsTimelineQuery(raceName, query)
            || ContainsTimelineQuery(otherRaceName, query)
            || ContainsTimelineQuery(empireName, query);
    }

    private void ClearTimelineFilters()
    {
        timelineQuery = string.Empty;
        timelineRaceId = 0;
        timelineEmpireId = 0;
        timelineColonyId = 0;
        timelineSystemId = 0;
        timelineWorldId = 0;
        timelineEventType = string.Empty;
    }

    private static bool ContainsTimelineQuery(string? value, string query)
    {
        return value?.Contains(query, StringComparison.OrdinalIgnoreCase) == true;
    }

    private World? FindWorld(int? worldId)
    {
        if (worldId is null or 0)
        {
            return null;
        }

        return Workspace.Sectors
            .SelectMany(sector => sector.Systems)
            .SelectMany(system => system.Worlds)
            .FirstOrDefault(world => world.Id == worldId.Value);
    }

    private void SelectDefaultCivilizationRecords(StarWinSector sector)
    {
        var sectorWorlds = sector.Systems.SelectMany(system => system.Worlds).ToList();
        var sectorColonies = sectorWorlds
            .Where(world => world.Colony is not null)
            .Select(world => (World: world, Colony: world.Colony!))
            .ToList();
        var sectorRaceIds = GetSectorRaceIds(sector, sectorWorlds, sectorColonies);
        var sectorEmpireIds = GetSectorEmpireIds(sector, sectorWorlds, sectorColonies);

        selectedRaceId = sectorRaceIds.Contains(selectedRaceId)
            ? selectedRaceId
            : Workspace.AlienRaces.FirstOrDefault(race => sectorRaceIds.Contains(race.Id))?.Id ?? 0;
        selectedEmpireId = sectorEmpireIds.Contains(selectedEmpireId)
            ? selectedEmpireId
            : Workspace.Empires.FirstOrDefault(empire => sectorEmpireIds.Contains(empire.Id))?.Id ?? 0;
    }

    private HashSet<int> GetSectorRaceIds(
        StarWinSector sector,
        IReadOnlyList<World> sectorWorlds,
        IReadOnlyList<(World World, Colony Colony)> sectorColonies)
    {
        var raceIds = new HashSet<int>();

        foreach (var world in sectorWorlds)
        {
            if (world.AlienRaceId is int worldRaceId)
            {
                raceIds.Add(worldRaceId);
            }
        }

        foreach (var item in sectorColonies)
        {
            raceIds.Add(item.Colony.RaceId);
            foreach (var demographic in item.Colony.Demographics)
            {
                raceIds.Add(demographic.RaceId);
            }
        }

        foreach (var history in sector.History)
        {
            if (history.RaceId is int raceId)
            {
                raceIds.Add(raceId);
            }

            if (history.OtherRaceId is int otherRaceId)
            {
                raceIds.Add(otherRaceId);
            }
        }

        return raceIds;
    }

    private HashSet<int> GetSectorEmpireIds(
        StarWinSector sector,
        IReadOnlyList<World> sectorWorlds,
        IReadOnlyList<(World World, Colony Colony)> sectorColonies)
    {
        var empireIds = new HashSet<int>();

        foreach (var system in sector.Systems)
        {
            if (system.AllegianceId != ushort.MaxValue)
            {
                empireIds.Add(system.AllegianceId);
            }

            foreach (var habitat in system.SpaceHabitats)
            {
                if (habitat.BuiltByEmpireId is int builtByEmpireId)
                {
                    empireIds.Add(builtByEmpireId);
                }

                if (habitat.ControlledByEmpireId is int controlledByEmpireId)
                {
                    empireIds.Add(controlledByEmpireId);
                }
            }
        }

        foreach (var world in sectorWorlds)
        {
            if (world.ControlledByEmpireId is int controlledByEmpireId)
            {
                empireIds.Add(controlledByEmpireId);
            }

            if (world.AllegianceId != ushort.MaxValue)
            {
                empireIds.Add(world.AllegianceId);
            }
        }

        foreach (var item in sectorColonies)
        {
            if (item.Colony.ControllingEmpireId is int controllingEmpireId)
            {
                empireIds.Add(controllingEmpireId);
            }

            if (item.Colony.FoundingEmpireId is int foundingEmpireId)
            {
                empireIds.Add(foundingEmpireId);
            }

            if (item.Colony.ParentEmpireId is int parentEmpireId)
            {
                empireIds.Add(parentEmpireId);
            }

            if (item.Colony.AllegianceId != ushort.MaxValue)
            {
                empireIds.Add(item.Colony.AllegianceId);
            }
        }

        foreach (var history in sector.History)
        {
            if (history.EmpireId is int empireId)
            {
                empireIds.Add(empireId);
            }
        }

        return empireIds;
    }

    private IEnumerable<RaceEmpireMembership> GetRaceEmpireMemberships(AlienRace race, IReadOnlyCollection<Empire> sectorEmpires)
    {
        return sectorEmpires
            .SelectMany(empire => empire.RaceMemberships
                .Where(membership => membership.RaceId == race.Id)
                .Select(membership => new RaceEmpireMembership(empire, membership)))
            .OrderByDescending(item => item.Membership.IsPrimary)
            .ThenBy(item => item.Empire.Name);
    }

    private IEnumerable<ColonyListing> GetEmpireColonies(Empire empire, StarWinSector sector)
    {
        return sector.Systems.Select(system => new { sector, system })
            .SelectMany(item => item.system.Worlds
                .Where(world => world.Colony is not null)
                .Select(world => new ColonyListing(item.sector, item.system, world, world.Colony!)))
            .Where(listing => listing.Colony.IsControlledBy(empire.Id) || listing.Colony.FoundingEmpireId == empire.Id)
            .OrderByDescending(listing => listing.Colony.EstimatedPopulation)
            .ThenBy(listing => listing.World.Name);
    }

    private ColonyListing? GetCapitalColony(Empire empire)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var colonies = GetEmpireColonies(empire, sector).ToList();
        var homeworldColony = colonies.FirstOrDefault(listing => listing.World.Id == empire.Founding.FoundingWorldId);
        if (homeworldColony is not null && homeworldColony.Colony.IsControlledBy(empire.Id))
        {
            return homeworldColony;
        }

        return colonies.FirstOrDefault(listing => listing.Colony.IsControlledBy(empire.Id)) ?? colonies.FirstOrDefault();
    }

    private GurpsTemplate BuildGurpsTemplate(AlienRace race)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var sectorWorlds = sector.Systems.SelectMany(system => system.Worlds).ToList();
        var sectorColonies = sectorWorlds
            .Where(world => world.Colony is not null)
            .Select(world => (World: world, Colony: world.Colony!))
            .ToList();
        var sectorEmpires = Workspace.Empires
            .Where(empire => GetSectorEmpireIds(sector, sectorWorlds, sectorColonies).Contains(empire.Id))
            .ToList();
        var memberships = GetRaceEmpireMemberships(race, sectorEmpires).ToList();
        var primaryEmpire = memberships.FirstOrDefault(item => item.Membership.IsPrimary)?.Empire
            ?? memberships.FirstOrDefault()?.Empire;

        var profile = new AlienRaceExportProfile
        {
            Race = race,
            Empire = primaryEmpire,
            HomeWorld = FindWorld(race.HomePlanetId)
        };

        foreach (var listing in sector.Systems
            .SelectMany(system => system.Worlds)
            .Where(world => world.Colony is not null && world.Colony.Demographics.Any(demographic => demographic.RaceId == race.Id))
            .Select(world => world.Colony!))
        {
            profile.Colonies.Add(listing);
        }

        var builder = new StarWin.Domain.Services.GurpsTemplateBuilder();
        return builder.Build(profile, GurpsTemplateEdition.FourthEdition);
    }

