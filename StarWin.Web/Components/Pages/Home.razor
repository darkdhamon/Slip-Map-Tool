                            <div class="relationship-list">
                                @foreach (var listing in empireColonies)
                                {
                                    <button type="button" class="relationship-row" @onclick="() => SelectColony(listing.World.Id)">
                                        <strong>@listing.Colony.ColonyClass on @listing.World.Name</strong>
                                        <span>@listing.System.Name; @DisplayPopulation(listing.Colony.EstimatedPopulation)</span>
                                    </button>
                                }
                            </div>
                        </section>
                    </article>
                }
            </section>
            break;
    }
</section>

@code {
    private const int DefaultSectorMapViewDistanceParsecs = 5;
    private const int SectorMapMaximumRenderedSystems = 1_000;
    private const int ColonyBatchSize = 120;
    private const int ExplorerListBatchSize = 120;
    private const int TimelineAllFilterId = -1;
    private const double SectorMapMaximumLabelDistanceParsecs = 5;
    private const string ExplorerSessionStorageKey = "starforgedAtlas.explorerSelection";

    [SupplyParameterFromQuery(Name = "sectorId")]
    public int? RequestedSectorId { get; set; }

    private readonly string[] sections = ["Overview", "Timeline", "Configuration", "Systems", "Worlds", "Colonies", "Aliens", "Empires"];
    private readonly ExplorerSectorCacheBuilder sectorCacheBuilder = new();
    private string activeSection = "Overview";
    private string sectionLoadingTarget = string.Empty;
    private string sectionLoadingStatus = string.Empty;
    private bool sectionLoadingVisible;
    private bool sectionLoadingAwaitingTargetRender;
    private int selectedSectorId;
    private int selectedSystemId;
    private int selectedWorldId;
    private int selectedHabitatId;
    private int selectedRaceId;
    private int selectedEmpireId;
    private string searchQuery = string.Empty;
    private IReadOnlyList<StarWinSearchResult> searchResults = [];
    private ElementReference sectorMapElement;
    private ElementReference colonyLoadMoreElement;
    private ElementReference systemLoadMoreElement;
    private ElementReference worldLoadMoreElement;
    private ElementReference raceLoadMoreElement;
    private ElementReference empireLoadMoreElement;
    private DotNetObjectReference<Home>? dotNetReference;
    private IJSObjectReference? sectorMapModule;
    private IJSObjectReference? timelineScrollModule;
    private int renderedSectorId;
    private int renderedSystemId;
    private int renderedViewDistanceParsecs;
    private double renderedRouteDistanceParsecs;
    private bool renderedOverview;
    private bool sectorMapRequested;
    private bool browserSessionRestored;
    private bool browserSessionReady;
    private IReadOnlyList<EntityImage> entityImages = [];
    private string imageUploadStatus = string.Empty;
    private string colonyQuery = string.Empty;
    private int colonyRaceId = TimelineAllFilterId;
    private int colonyEmpireId = TimelineAllFilterId;
    private string colonyStatus = string.Empty;
    private string colonyClass = string.Empty;
    private int colonyVisibleCount = ColonyBatchSize;
    private bool colonyHasMoreRecords;
    private bool colonyObserverConfigured;
    private string systemQuery = string.Empty;
    private int systemEmpireId = TimelineAllFilterId;
    private int systemVisibleCount = ExplorerListBatchSize;
    private bool systemHasMoreRecords;
    private bool systemObserverConfigured;
    private string worldQuery = string.Empty;
    private string worldKind = string.Empty;
    private string worldType = string.Empty;
    private int worldVisibleCount = ExplorerListBatchSize;
    private bool worldHasMoreRecords;
    private bool worldObserverConfigured;
    private string raceQuery = string.Empty;
    private string raceEnvironment = string.Empty;
    private string raceAppearance = string.Empty;
    private int raceVisibleCount = ExplorerListBatchSize;
    private bool raceHasMoreRecords;
    private bool raceObserverConfigured;
    private string empireQuery = string.Empty;
    private int empireRaceId = TimelineAllFilterId;
    private int empireVisibleCount = ExplorerListBatchSize;
    private bool empireHasMoreRecords;
    private bool empireObserverConfigured;
    private string basicHyperlaneTierName = "Basic";
    private decimal basicHyperlaneMaximumLengthParsecs = 1m;
    private string sectorConfigurationStatus = string.Empty;
    private int sectorMapViewDistanceParsecs = DefaultSectorMapViewDistanceParsecs;

    private IReadOnlyDictionary<int, AlienRace>? alienRacesById;
    private IReadOnlyDictionary<int, Empire>? empiresById;
    private IReadOnlyDictionary<int, World>? worldsById;

    private ExplorerSectorCache GetSectorCache(StarWinSector sector)
    {
        return sectorCacheBuilder.Get(sector);
    }

    private IReadOnlyDictionary<int, AlienRace> AlienRacesById =>
        alienRacesById ??= Workspace.AlienRaces.ToDictionary(race => race.Id);

    private IReadOnlyDictionary<int, Empire> EmpiresById =>
        empiresById ??= Workspace.Empires.ToDictionary(empire => empire.Id);

    private IReadOnlyDictionary<int, World> WorldsById =>
        worldsById ??= Workspace.Sectors
            .SelectMany(sector => sector.Systems)
            .SelectMany(system => system.Worlds)
            .GroupBy(world => world.Id)
            .ToDictionary(group => group.Key, group => group.First());

    protected override void OnInitialized()
    {
        var initialSector = RequestedSectorId is int requestedSectorId
            ? Workspace.Sectors.FirstOrDefault(sector => sector.Id == requestedSectorId) ?? Workspace.CurrentSector
            : Workspace.CurrentSector;

        selectedSectorId = initialSector.Id;
        selectedSystemId = initialSector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedWorldId = initialSector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Id ?? 0;
        SelectDefaultCivilizationRecords(initialSector);
        LoadSectorConfigurationForm(initialSector);
    }

    protected override async Task OnInitializedAsync()
    {
        entityImages = await ImageService.GetImagesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreExplorerSessionAsync();
            browserSessionReady = true;
            StateHasChanged();
            return;
        }

        if (activeSection == "Timeline")
        {
            renderedOverview = false;
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        if (activeSection == "Colonies")
        {
            renderedOverview = false;
            await ConfigureColonyObserverAsync();
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        colonyObserverConfigured = false;
        if (activeSection == "Systems")
        {
            renderedOverview = false;
            await ConfigureRecordObserverAsync("system", systemHasMoreRecords, () => systemObserverConfigured, value => systemObserverConfigured = value, systemLoadMoreElement, "LoadMoreSystems");
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        systemObserverConfigured = false;
        if (activeSection == "Worlds")
        {
            renderedOverview = false;
            await ConfigureRecordObserverAsync("world", worldHasMoreRecords, () => worldObserverConfigured, value => worldObserverConfigured = value, worldLoadMoreElement, "LoadMoreWorlds");
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        worldObserverConfigured = false;
        if (activeSection == "Aliens")
        {
            renderedOverview = false;
            await ConfigureRecordObserverAsync("race", raceHasMoreRecords, () => raceObserverConfigured, value => raceObserverConfigured = value, raceLoadMoreElement, "LoadMoreRaces");
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        raceObserverConfigured = false;
        if (activeSection == "Empires")
        {
            renderedOverview = false;
            await ConfigureRecordObserverAsync("empire", empireHasMoreRecords, () => empireObserverConfigured, value => empireObserverConfigured = value, empireLoadMoreElement, "LoadMoreEmpires");
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        empireObserverConfigured = false;
        if (activeSection != "Overview")
        {
            renderedOverview = false;
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        if (!sectorMapRequested)
        {
            renderedOverview = false;
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        if (!firstRender
            && renderedOverview
            && renderedSectorId == sector.Id
            && renderedSystemId == selectedSystemId
            && renderedViewDistanceParsecs == sectorMapViewDistanceParsecs
            && Math.Abs(renderedRouteDistanceParsecs - GetHyperlaneRouteDistanceParsecs(sector)) < 0.001)
        {
            await CompleteSectionLoadingIfReadyAsync();
            return;
        }

        sectorMapModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/sectorMap3d.js");
        dotNetReference ??= DotNetObjectReference.Create(this);

        await sectorMapModule.InvokeVoidAsync(
            "renderSectorMap",
            sectorMapElement,
            BuildSectorMap(sector, selectedSystemId),
            selectedSystemId,
            dotNetReference);

        renderedSectorId = sector.Id;
        renderedSystemId = selectedSystemId;
        renderedViewDistanceParsecs = sectorMapViewDistanceParsecs;
        renderedRouteDistanceParsecs = GetHyperlaneRouteDistanceParsecs(sector);
        renderedOverview = true;
        await CompleteSectionLoadingIfReadyAsync();
    }

    private async Task SelectSectionAsync(string sectionName)
    {
        if (activeSection == sectionName || sectionLoadingVisible)
        {
            return;
        }

        sectionLoadingTarget = sectionName;
        sectionLoadingStatus = $"Preparing {sectionName} records...";
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingVisible = true;
        StateHasChanged();

        await Task.Delay(80);

        sectionLoadingStatus = $"Rendering {sectionName}...";
        activeSection = sectionName;
        sectionLoadingAwaitingTargetRender = true;
        StateHasChanged();
    }

    private async Task CompleteSectionLoadingIfReadyAsync()
    {
        if (!sectionLoadingVisible
            || !sectionLoadingAwaitingTargetRender
            || !string.Equals(activeSection, sectionLoadingTarget, StringComparison.Ordinal))
        {
            return;
        }

        sectionLoadingStatus = $"{activeSection} ready.";
        StateHasChanged();
        await Task.Delay(140);

        sectionLoadingVisible = false;
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingTarget = string.Empty;
        sectionLoadingStatus = string.Empty;
        StateHasChanged();
    }

    private void LoadSectorMap()
    {
        sectorMapRequested = true;
        renderedOverview = false;
    }

    private void SelectSystem(int systemId)
    {
        selectedSystemId = systemId;
        activeSection = activeSection == "Overview" ? "Overview" : "Systems";
        SelectDefaultWorld();
        _ = PersistExplorerSessionAsync();
    }

    private void OpenSelectedSystemRecord()
    {
        activeSection = "Systems";
    }

    private async Task ToggleSectorMapFullscreen()
    {
        if (!sectorMapRequested)
        {
            LoadSectorMap();
            return;
        }

        sectorMapModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/sectorMap3d.js");
        await sectorMapModule.InvokeVoidAsync("toggleMapFullscreen", sectorMapElement);
