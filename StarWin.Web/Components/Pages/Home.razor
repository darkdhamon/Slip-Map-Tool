            </section>
            break;
        case "Empires":
            <section class="content-grid">
                <div class="record-list">
                    @foreach (var empire in sectorEmpires)
                    {
                        <button type="button" class="record-row @(selectedEmpire?.Id == empire.Id ? "active" : null)" @onclick="() => selectedEmpireId = empire.Id">
                            <strong>@empire.Name</strong>
                            <span>TL @empire.CivilizationProfile.TechLevel; @empire.Planets planets</span>
                        </button>
                    }
                </div>

                @if (selectedEmpire is not null)
                {
                    <article class="detail-panel">
                        <span class="panel-kicker">Empire profile</span>
                        <h2>@selectedEmpire.Name</h2>
                        @RenderImagePanel(EntityImageTargetKind.Empire, selectedEmpire.Id, "Empire flag", false)
                        @{
                            var empireHomeworld = FindWorld(selectedEmpire.Founding.FoundingWorldId);
                            var capitalColony = GetCapitalColony(selectedEmpire);
                            var empireColonies = GetEmpireColonies(selectedEmpire, sector).ToList();
                        }
                        <div class="parent-actions">
                            @if (empireHomeworld is not null)
                            {
                                <button type="button" @onclick="() => SelectWorld(empireHomeworld.Id)">Homeworld: @empireHomeworld.Name</button>
