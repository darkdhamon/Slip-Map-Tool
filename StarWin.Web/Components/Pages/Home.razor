    private async Task ConvertIndependentColoniesAsync(int sectorId)
    {
        sectorConfigurationStatus = "Converting independent colonies...";
        try
        {
            var result = await IndependentColonyService.ConvertIndependentColoniesAsync(sectorId);
            ApplyIndependentColonyConversion(sectorId, result);
            sectorConfigurationStatus = result.Assignments.Count == 0
                ? "No independent colonies needed conversion."
                : $"Created {result.CreatedEmpires.Count:N0} empire{(result.CreatedEmpires.Count == 1 ? string.Empty : "s")} and assigned {result.Assignments.Count:N0} colon{(result.Assignments.Count == 1 ? "y" : "ies")}.";
        }
        catch (InvalidOperationException ex)
        {
            sectorConfigurationStatus = ex.Message;
        }
    }

    private void ApplyIndependentColonyConversion(int sectorId, IndependentColonyConversionResult result)
    {
        if (result.Assignments.Count == 0)
        {
            return;
        }

        if (Workspace.Empires is IList<Empire> empireList)
        {
            foreach (var empire in result.CreatedEmpires.Where(empire => empireList.All(existing => existing.Id != empire.Id)))
            {
                empireList.Add(empire);
            }
        }

        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == sectorId);
        if (sector is not null)
        {
            var assignmentsByColonyId = result.Assignments.ToDictionary(assignment => assignment.ColonyId);
            foreach (var colony in sector.Systems
                .SelectMany(system => system.Worlds)
                .Select(world => world.Colony)
                .OfType<Colony>())
            {
                if (assignmentsByColonyId.TryGetValue(colony.Id, out var assignment))
                {
                    colony.ControllingEmpireId = assignment.EmpireId;
                    colony.FoundingEmpireId = assignment.EmpireId;
                    colony.PoliticalStatus = ColonyPoliticalStatus.Controlled;
                    colony.AllegianceName = assignment.EmpireName;
                }
            }

            sector.History.Add(new HistoryEvent
            {
                SectorId = sector.Id,
                Century = 0,
                EventType = "Configuration",
                Description = $"Created {result.CreatedEmpires.Count:N0} independent colony empires and assigned {result.Assignments.Count:N0} colonies."
            });
            sectorCacheBuilder.Invalidate(sector.Id);
        }

        empiresById = null;
        renderedOverview = false;
    }

    private async Task PlotSelectedRouteAsync()
    {
        if (sectionLoadingVisible)
        {
            return;
        }

        sectionLoadingTarget = "Route";
        sectionLoadingStatus = "Reading origin system and destination...";
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingVisible = true;
        StateHasChanged();
        await Task.Yield();
        await Task.Delay(60);

        ApplyRouteOriginText();
        ApplyRouteDestinationText();
        if (routeOriginSystemId == 0 || routeDestinationSystemId == 0)
        {
            sectionLoadingVisible = false;
            sectionLoadingTarget = string.Empty;
            sectionLoadingStatus = string.Empty;
            StateHasChanged();
            return;
        }

        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var origin = sector.Systems.FirstOrDefault(system => system.Id == routeOriginSystemId);
        var destination = sector.Systems.FirstOrDefault(system => system.Id == routeDestinationSystemId);
        if (origin is null || destination is null || origin.Id == destination.Id)
        {
            ClearPlottedRoutePlan();
            sectionLoadingVisible = false;
            sectionLoadingTarget = string.Empty;
            sectionLoadingStatus = string.Empty;
            StateHasChanged();
            return;
        }

        sectionLoadingStatus = "Following hyperlanes as far as possible...";
        StateHasChanged();
        await Task.Yield();
        await Task.Delay(40);

        var adjacency = await GetRouteAdjacencyAsync(sector);

        sectionLoadingStatus = "Minimizing any unavoidable void crossing...";
        StateHasChanged();
        await Task.Yield();
        plottedRoutePlan = await Task.Run(() => BuildHyperlanePreferredRoute(origin, destination, adjacency));
        plottedRouteSectorId = sector.Id;
        plottedRouteOriginSystemId = origin.Id;
        plottedRouteDestinationSystemId = destination.Id;
        plottedRouteDistanceParsecs = GetHyperlaneRouteDistanceParsecs(sector);
        plottedOwnedRouteDistanceParsecs = GetOwnedHyperlaneBaseLengthParsecs(sector);

        sectorMapRequested = true;
        renderedOverview = false;
        sectionLoadingStatus = "Rendering route map...";
        StateHasChanged();
        await Task.Delay(140);

        sectionLoadingVisible = false;
        sectionLoadingTarget = string.Empty;
        sectionLoadingStatus = string.Empty;
        StateHasChanged();
    }

