    [JSInvokable]
    public Task ReduceSectorMapRenderLimit(int suggestedMaximumSystems, double averageFrameMilliseconds, int previousMaximumSystems)
    {
        var nextLimit = Math.Clamp(suggestedMaximumSystems, SectorMapMinimumRenderedSystems, SectorMapUnrestrictedRenderedSystems);
        if (nextLimit >= sectorMapRenderLimit)
        {
            return Task.CompletedTask;
        }

        sectorMapRenderLimit = nextLimit;
        sectorMapPerformanceStatus = $"The map reduced visible systems from {previousMaximumSystems:N0} to {sectorMapRenderLimit:N0} to improve performance after slow frames ({averageFrameMilliseconds:0} ms avg).";
        renderedOverview = false;
        return InvokeAsync(StateHasChanged);
    }

