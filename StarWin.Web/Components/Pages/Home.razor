    private void ApplySavedEntityName(EntityNoteTargetKind targetKind, int targetId, string savedName)
    {
        switch (targetKind)
        {
            case EntityNoteTargetKind.StarSystem:
                foreach (var system in Workspace.Sectors.SelectMany(sector => sector.Systems).Where(system => system.Id == targetId))
                {
                    system.Name = savedName;
                }

                break;
            case EntityNoteTargetKind.World:
                foreach (var world in Workspace.Sectors.SelectMany(sector => sector.Systems).SelectMany(system => system.Worlds).Where(world => world.Id == targetId))
                {
                    world.Name = savedName;
                }

                break;
            case EntityNoteTargetKind.Colony:
                foreach (var colony in Workspace.Sectors
                    .SelectMany(sector => sector.Systems)
                    .SelectMany(system => system.Worlds)
                    .Select(world => world.Colony)
                    .OfType<Colony>()
                    .Where(colony => colony.Id == targetId))
                {
                    colony.Name = savedName;
                }

                break;
            case EntityNoteTargetKind.AlienRace:
                if (Workspace.AlienRaces.FirstOrDefault(race => race.Id == targetId) is { } race)
                {
                    race.Name = savedName;
                }

                break;
            case EntityNoteTargetKind.Empire:
                if (Workspace.Empires.FirstOrDefault(empire => empire.Id == targetId) is { } empire)
                {
                    empire.Name = savedName;
                }

                break;
        }
    }

    private static bool ContainsTimelineQuery(string? value, string query)
    {
        return value?.Contains(query, StringComparison.OrdinalIgnoreCase) == true;
    }

    private IEnumerable<(World World, Colony Colony)> GetFilteredColonies(ExplorerSectorCache sectorCache)
    {
        return sectorCache.ColoniesByPopulation.Where(ColonyMatches);
    }

    private bool ColonyMatches((World World, Colony Colony) item)
    {
        if (colonyRaceId != TimelineAllFilterId
            && item.Colony.RaceId != colonyRaceId
            && !item.Colony.Demographics.Any(demographic => demographic.RaceId == colonyRaceId))
        {
            return false;
        }

        if (colonyEmpireId != TimelineAllFilterId
            && item.Colony.AllegianceId != colonyEmpireId
            && item.Colony.ControllingEmpireId != colonyEmpireId
            && item.Colony.FoundingEmpireId != colonyEmpireId
            && item.Colony.ParentEmpireId != colonyEmpireId)
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(colonyStatus)
            && !string.Equals(item.Colony.PoliticalStatus.ToString(), colonyStatus, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(colonyClass)
            && !string.Equals(item.Colony.ColonyClass, colonyClass, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(colonyQuery))
        {
            return true;
        }

        var query = colonyQuery.Trim();
        return ContainsTimelineQuery(item.World.Name, query)
            || ContainsTimelineQuery(item.World.WorldType, query)
            || ContainsTimelineQuery(item.Colony.Id.ToString(), query)
            || ContainsTimelineQuery(item.Colony.Name, query)
            || ContainsTimelineQuery(item.Colony.WorldId.ToString(), query)
            || ContainsTimelineQuery(item.Colony.ColonyClass, query)
            || ContainsTimelineQuery(item.Colony.ColonistRaceName, query)
            || ContainsTimelineQuery(item.Colony.AllegianceName, query)
            || ContainsTimelineQuery(item.Colony.Starport, query)
            || ContainsTimelineQuery(item.Colony.GovernmentType, query)
            || ContainsTimelineQuery(item.Colony.ExportResource, query)
            || ContainsTimelineQuery(item.Colony.ImportResource, query)
            || item.Colony.Demographics.Any(demographic => ContainsTimelineQuery(demographic.RaceName, query));
    }

    private IEnumerable<ExplorerWorldRecord> GetFilteredExplorerWorldRecords(StarSystem? system)
    {
        if (system is null)
        {
            return [];
        }

        return GetExplorerWorldRecords(system)
            .Where(ExplorerWorldRecordMatches)
            .OrderBy(record => record.KindSort)
            .ThenBy(record => record.OrbitSort)
            .ThenBy(record => record.Name);
    }

    private static IEnumerable<ExplorerWorldRecord> GetExplorerWorldRecords(StarSystem system)
    {
        foreach (var world in system.Worlds)
        {
            yield return ExplorerWorldRecord.FromWorld(system, world);
        }

        foreach (var habitat in system.SpaceHabitats)
        {
            yield return ExplorerWorldRecord.FromHabitat(system, habitat);
        }
    }

    private bool ExplorerWorldRecordMatches(ExplorerWorldRecord record)
    {
        if (!string.IsNullOrWhiteSpace(worldKind)
            && !string.Equals(record.Kind, worldKind, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(worldType)
            && !string.Equals(record.Type, worldType, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(worldQuery))
        {
            return true;
        }

        var query = worldQuery.Trim();
        return ContainsTimelineQuery(record.Name, query)
            || ContainsTimelineQuery(record.Kind, query)
            || ContainsTimelineQuery(record.Type, query)
            || ContainsTimelineQuery(record.System.Name, query)
            || ContainsTimelineQuery(record.World?.Id.ToString(), query)
            || ContainsTimelineQuery(record.Habitat?.Id.ToString(), query)
            || ContainsTimelineQuery(record.World?.LegacyPlanetId?.ToString(), query)
            || ContainsTimelineQuery(record.World?.LegacyMoonId?.ToString(), query)
            || ContainsTimelineQuery(record.World?.AtmosphereType, query)
            || ContainsTimelineQuery(record.World?.AtmosphereComposition, query)
            || ContainsTimelineQuery(record.World?.WaterType, query)
            || ContainsTimelineQuery(record.World?.Colony?.ColonyClass, query)
            || ContainsTimelineQuery(record.World?.Colony?.AllegianceName, query)
            || ContainsTimelineQuery(DisplayEmpire(record.Habitat?.ControlledByEmpireId), query);
    }

    private IEnumerable<AlienRace> GetFilteredRaces(IReadOnlyList<AlienRace> races)
    {
        return races
            .Where(RaceMatches)
            .OrderBy(race => race.Name)
            .ThenBy(race => race.Id);
    }

    private bool RaceMatches(AlienRace race)
    {
        if (!string.IsNullOrWhiteSpace(raceEnvironment)
            && !string.Equals(race.EnvironmentType, raceEnvironment, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(raceAppearance)
            && !string.Equals(race.AppearanceType, raceAppearance, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(raceQuery))
        {
            return true;
        }

        var query = raceQuery.Trim();
        var homeWorld = FindWorld(race.HomePlanetId);
        return ContainsTimelineQuery(race.Name, query)
            || ContainsTimelineQuery(race.Id.ToString(), query)
            || ContainsTimelineQuery(race.AppearanceType, query)
            || ContainsTimelineQuery(race.BodyChemistry, query)
            || ContainsTimelineQuery(race.EnvironmentType, query)
            || ContainsTimelineQuery(race.GovernmentType, query)
            || ContainsTimelineQuery(race.ReproductionMethod, query)
            || ContainsTimelineQuery(race.Diet, query)
            || ContainsTimelineQuery(race.Religion, query)
            || ContainsTimelineQuery(race.BiologyProfile.Body.ToString(), query)
            || ContainsTimelineQuery(race.BiologyProfile.Mind.ToString(), query)
            || ContainsTimelineQuery(race.BiologyProfile.Speed.ToString(), query)
            || ContainsTimelineQuery(race.BiologyProfile.PsiRating.ToString(), query)
            || ContainsTimelineQuery(homeWorld?.Name, query);
    }

    private IEnumerable<Empire> GetFilteredEmpires(IReadOnlyList<Empire> empires)
    {
        return empires
            .Where(EmpireMatches)
            .OrderBy(empire => empire.Name)
            .ThenBy(empire => empire.Id);
    }

    private bool EmpireMatches(Empire empire)
    {
        if (empireRaceId != TimelineAllFilterId
            && !empire.RaceMemberships.Any(membership => membership.RaceId == empireRaceId))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(empireQuery))
        {
            return true;
        }

        var query = empireQuery.Trim();
        var homeWorld = FindWorld(empire.Founding.FoundingWorldId);
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        return ContainsTimelineQuery(empire.Name, query)
            || ContainsTimelineQuery(empire.Id.ToString(), query)
            || ContainsTimelineQuery(empire.LegacyRaceId?.ToString(), query)
            || ContainsTimelineQuery(empire.ExpansionPolicy.ToString(), query)
            || (IsFallenEmpire(empire, sector) && ContainsTimelineQuery("Fallen empire", query))
            || ContainsTimelineQuery(homeWorld?.Name, query)
            || empire.RaceMemberships.Any(membership =>
                ContainsTimelineQuery(DisplayRace(membership.RaceId), query)
                || ContainsTimelineQuery(membership.Role.ToString(), query))
            || empire.Contacts.Any(contact =>
                ContainsTimelineQuery(contact.Relation, query)
                || ContainsTimelineQuery(DisplayEmpire(contact.OtherEmpireId), query));
    }

    private World? FindWorld(int? worldId)
    {
        if (worldId is null or 0)
        {
            return null;
        }

        return WorldsById.TryGetValue(worldId.Value, out var world) ? world : null;
    }

    private void SelectDefaultCivilizationRecords(StarWinSector sector)
    {
        var sectorSummary = GetSectorSummary(sector);

        selectedRaceId = sectorSummary.RaceIds.Contains(selectedRaceId)
            ? selectedRaceId
            : Workspace.AlienRaces.FirstOrDefault(race => sectorSummary.RaceIds.Contains(race.Id))?.Id ?? 0;
        selectedEmpireId = sectorSummary.EmpireIds.Contains(selectedEmpireId)
            ? selectedEmpireId
            : Workspace.Empires.FirstOrDefault(empire => sectorSummary.EmpireIds.Contains(empire.Id))?.Id ?? 0;
    }

    private IEnumerable<RaceEmpireMembership> GetRaceEmpireMemberships(AlienRace race, IReadOnlyCollection<Empire> sectorEmpires)
    {
        return sectorEmpires
            .SelectMany(empire => empire.RaceMemberships
                .Where(membership => membership.RaceId == race.Id)
                .Select(membership => new RaceEmpireMembership(empire, membership)))
            .OrderByDescending(item => item.Membership.IsPrimary)
            .ThenBy(item => item.Empire.Name);
    }

    private IEnumerable<ColonyListing> GetEmpireColonies(Empire empire, StarWinSector sector)
    {
        return sector.Systems.Select(system => new { sector, system })
            .SelectMany(item => item.system.Worlds
                .Where(world => world.Colony is not null)
                .Select(world => new ColonyListing(item.sector, item.system, world, world.Colony!)))
            .Where(listing => listing.Colony.IsControlledBy(empire.Id) || listing.Colony.FoundingEmpireId == empire.Id)
            .OrderByDescending(listing => listing.Colony.EstimatedPopulation)
            .ThenBy(listing => listing.World.Name);
    }

    private IEnumerable<ColonyListing> GetControlledEmpireColonies(Empire empire, StarWinSector sector)
    {
        return GetEmpireColonies(empire, sector)
            .Where(listing => listing.Colony.IsControlledBy(empire.Id));
    }

    private bool IsFallenEmpire(Empire empire, StarWinSector sector)
    {
        var colonies = GetEmpireColonies(empire, sector).ToList();
        if (colonies.Any(listing => listing.Colony.IsControlledBy(empire.Id)))
        {
            return false;
        }

        return colonies.Count > 0
            || empire.Planets > 0
            || empire.Moons > 0
            || empire.SpaceHabitats > 0
            || empire.NativePopulationMillions > 0
            || empire.SubjectPopulationMillions > 0;
    }

    private ColonyListing? GetCapitalColony(Empire empire)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var colonies = GetEmpireColonies(empire, sector).ToList();
        var homeworldColony = colonies.FirstOrDefault(listing => listing.World.Id == empire.Founding.FoundingWorldId);
        if (homeworldColony is not null && homeworldColony.Colony.IsControlledBy(empire.Id))
        {
            return homeworldColony;
        }

        return colonies.FirstOrDefault(listing => listing.Colony.IsControlledBy(empire.Id)) ?? colonies.FirstOrDefault();
    }

    private GurpsTemplate BuildGurpsTemplate(AlienRace race)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var sectorCache = GetSectorCache(sector);
        var sectorEmpires = Workspace.Empires
            .Where(empire => sectorCache.EmpireIds.Contains(empire.Id))
            .ToList();
        var memberships = GetRaceEmpireMemberships(race, sectorEmpires).ToList();
        var primaryEmpire = memberships.FirstOrDefault(item => item.Membership.IsPrimary)?.Empire
            ?? memberships.FirstOrDefault()?.Empire;

        var profile = new AlienRaceExportProfile
        {
            Race = race,
            Empire = primaryEmpire,
            HomeWorld = FindWorld(race.HomePlanetId)
        };

        foreach (var listing in sectorCache.Worlds
            .Where(world => world.Colony is not null && world.Colony.Demographics.Any(demographic => demographic.RaceId == race.Id))
            .Select(world => world.Colony!))
        {
            profile.Colonies.Add(listing);
        }

        var builder = new StarWin.Domain.Services.GurpsTemplateBuilder();
        return builder.Build(profile, GurpsTemplateEdition.FourthEdition);
    }

