    private object BuildSectorMap(StarWinSector sector, int focusedSystemId)
    {
        var focusedSystem = sector.Systems.FirstOrDefault(system => system.Id == focusedSystemId)
            ?? sector.Systems.FirstOrDefault();
        var routePlan = GetPlottedRoutePlan(sector);
        var routeSystemIds = routePlan?.Systems.Select(system => system.Id).ToHashSet() ?? [];
        var mappedSystems = GetSectorMapSystems(sector, focusedSystemId, routePlan).ToList();
        var routeDistance = GetHyperlaneRouteDistanceParsecs(sector);
        var ownedRouteDistance = GetOwnedHyperlaneBaseLengthParsecs(sector);
        var routes = BuildSectorMapRoutes(mappedSystems, routeDistance, ownedRouteDistance, EmpiresById);

        return new
        {
            sector = sector.Name,
            viewDistanceParsecs = sectorMapViewDistanceParsecs,
            fadeStartParsecs = Math.Max(0, sectorMapViewDistanceParsecs - 1),
            maximumRenderedSystems = SectorMapMaximumRenderedSystems,
            labelDistanceParsecs = SectorMapMaximumLabelDistanceParsecs,
            routeDistanceParsecs = routeDistance,
            ownedRouteDistanceParsecs = ownedRouteDistance,
            maximumVoidRouteDistanceParsecs = MaximumVoidRouteDistanceParsecs,
            totalSystemCount = sector.Systems.Count,
            visibleSystemCount = mappedSystems.Count,
            visibleRouteCount = routes.Count,
            routeActive = routePlan is not null,
            routeSystemIds = routeSystemIds.ToArray(),
            systems = mappedSystems.Select(system => new
            {
                id = system.Id,
                name = system.Name,
                x = system.Coordinates.XParsecs,
                y = system.Coordinates.YParsecs,
                z = system.Coordinates.ZParsecs,
                distanceFromFocus = focusedSystem is null
                    ? 0
                    : CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates),
                isRouteSystem = routeSystemIds.Contains(system.Id),
                showLabel = routeSystemIds.Contains(system.Id) || ShouldShowSectorMapLabel(system, focusedSystem),
                bodies = system.AstralBodies.Take(3).Select(body => new
                {
                    kind = body.Kind.ToString(),
                    role = body.Role.ToString(),
                    classification = body.Classification,
                    luminosity = body.Luminosity,
                    solarMasses = body.SolarMasses,
                    imageUrl = GetPrimaryEntityImage(EntityImageTargetKind.AstralBody, body.Id)?.RelativePath
                }).ToArray()
            }).ToArray(),
            routes = routes.Select(route => new
            {
                sourceId = route.Source.Id,
                targetId = route.Target.Id,
                distanceParsecs = route.DistanceParsecs,
                isOwned = route.IsOwned,
                isGold = route.IsGold
            }).ToArray(),
            routePath = (routePlan?.Legs ?? []).Select(leg => new
            {
                sourceId = leg.Source.Id,
                targetId = leg.Target.Id,
                distanceParsecs = leg.DistanceParsecs,
                isHyperlane = leg.IsHyperlane
            }).ToArray()
        };
    }

    private IReadOnlyList<StarSystem> GetSectorMapSystems(StarWinSector sector, int focusedSystemId, SectorMapRoutePlan? routePlan = null)
    {
        var focusedSystem = sector.Systems.FirstOrDefault(system => system.Id == focusedSystemId)
            ?? sector.Systems.FirstOrDefault();

        if (focusedSystem is null)
        {
            return [];
        }

        var nearbySystems = sector.Systems
            .Select(system => new
            {
                System = system,
                Distance = CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates)
            })
            .Where(item => item.Distance <= sectorMapViewDistanceParsecs)
            .OrderBy(item => item.Distance)
            .ThenBy(item => item.System.Name)
            .Take(SectorMapMaximumRenderedSystems)
            .Select(item => item.System)
            .ToList();

        if (routePlan is not null)
        {
            var mappedSystemIds = nearbySystems.Select(system => system.Id).ToHashSet();
            foreach (var routeSystem in routePlan.Systems)
            {
                if (mappedSystemIds.Add(routeSystem.Id))
                {
                    nearbySystems.Add(routeSystem);
                }
            }
        }

        return nearbySystems;
    }

    private static bool ShouldShowSectorMapLabel(StarSystem system, StarSystem? focusedSystem)
    {
        if (focusedSystem is null || system.Id == focusedSystem.Id)
        {
            return true;
        }

        if (system.Worlds.Any(world => world.Colony is not null))
        {
            return true;
        }

        return CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates) <= SectorMapMaximumLabelDistanceParsecs;
    }

    private SectorMapRoutePlan? GetPlottedRoutePlan(StarWinSector sector)
    {
        if (plottedRoutePlan is null
            || plottedRouteSectorId != sector.Id
            || plottedRouteOriginSystemId != routeOriginSystemId
            || plottedRouteDestinationSystemId != routeDestinationSystemId
            || Math.Abs(plottedRouteDistanceParsecs - GetHyperlaneRouteDistanceParsecs(sector)) >= 0.001
            || Math.Abs(plottedOwnedRouteDistanceParsecs - GetOwnedHyperlaneBaseLengthParsecs(sector)) >= 0.001)
        {
            return null;
        }

        return plottedRoutePlan;
    }

    private async Task<IReadOnlyDictionary<int, List<SectorMapRouteLeg>>> GetRouteAdjacencyAsync(StarWinSector sector)
    {
        var cacheKey = new RouteGraphCacheKey(
            sector.Id,
            Math.Round(GetHyperlaneRouteDistanceParsecs(sector), 3),
            Math.Round(GetOwnedHyperlaneBaseLengthParsecs(sector), 3),
            MaximumVoidRouteDistanceParsecs);
        if (routeGraphCaches.TryGetValue(cacheKey, out var cachedAdjacency))
        {
            return cachedAdjacency;
        }

        var systems = sector.Systems.ToList();
        var routeDistanceParsecs = GetHyperlaneRouteDistanceParsecs(sector);
        var ownedRouteDistanceParsecs = GetOwnedHyperlaneBaseLengthParsecs(sector);
        var empiresById = EmpiresById;
        var adjacency = await Task.Run(() => BuildRouteAdjacency(
            systems,
            routeDistanceParsecs,
            ownedRouteDistanceParsecs,
            empiresById,
            MaximumVoidRouteDistanceParsecs));
        routeGraphCaches[cacheKey] = adjacency;
        return adjacency;
    }

    private static SectorMapRoutePlan? BuildHyperlanePreferredRoute(
        StarSystem origin,
        StarSystem destination,
        IReadOnlyDictionary<int, List<SectorMapRouteLeg>> adjacency)
    {
        if (!adjacency.ContainsKey(origin.Id) || !adjacency.ContainsKey(destination.Id))
        {
            return null;
        }

        var searchResult = SearchPreferredRoute(origin, destination.Id, adjacency);
        var routePath = BuildRoutePath(searchResult, origin.Id, destination.Id);
        if (routePath is not null)
        {
            return BuildRoutePlan(origin, destination, routePath);
        }

        return null;
    }

    private static Dictionary<int, List<SectorMapRouteLeg>> BuildRouteAdjacency(
        IReadOnlyList<StarSystem> systems,
        double routeDistanceParsecs,
        double ownedRouteDistanceParsecs,
        IReadOnlyDictionary<int, Empire> empiresById,
        double maximumVoidRouteDistanceParsecs)
    {
        var adjacency = BuildHyperlaneAdjacency(systems, routeDistanceParsecs, ownedRouteDistanceParsecs, empiresById);
        if (systems.Count < 2 || maximumVoidRouteDistanceParsecs <= routeDistanceParsecs)
        {
            return adjacency;
        }

        var cellSize = Math.Max(0.1, maximumVoidRouteDistanceParsecs);
        var cells = systems
            .GroupBy(system => GetRouteCell(system, cellSize))
            .ToDictionary(group => group.Key, group => group.ToList());

        foreach (var source in systems)
        {
            var originCell = GetRouteCell(source, cellSize);
            for (var x = originCell.X - 1; x <= originCell.X + 1; x++)
            {
                for (var y = originCell.Y - 1; y <= originCell.Y + 1; y++)
                {
                    for (var z = originCell.Z - 1; z <= originCell.Z + 1; z++)
                    {
                        if (!cells.TryGetValue((x, y, z), out var candidates))
                        {
                            continue;
                        }

                        foreach (var target in candidates)
                        {
                            if (target.Id <= source.Id)
                            {
                                continue;
                            }

                            var voidDistance = CalculateParsecDistance(source.Coordinates, target.Coordinates);
                            if (voidDistance <= routeDistanceParsecs || voidDistance > maximumVoidRouteDistanceParsecs)
                            {
                                continue;
                            }

                            adjacency[source.Id].Add(new SectorMapRouteLeg(source, target, voidDistance, false));
                            adjacency[target.Id].Add(new SectorMapRouteLeg(target, source, voidDistance, false));
                        }
                    }
                }
            }
        }

        return adjacency;
    }

    private static (int X, int Y, int Z) GetRouteCell(StarSystem system, double cellSize)
    {
        return (
            X: (int)Math.Floor(system.Coordinates.XParsecs / cellSize),
            Y: (int)Math.Floor(system.Coordinates.YParsecs / cellSize),
            Z: (int)Math.Floor(system.Coordinates.ZParsecs / cellSize));
    }

    private static SectorMapRoutePlan BuildRoutePlan(StarSystem origin, StarSystem destination, IReadOnlyList<SectorMapRouteLeg> legs)
    {
        var routeSystems = legs
            .Select(leg => leg.Source)
            .Concat(legs.Select(leg => leg.Target))
            .DistinctBy(system => system.Id)
            .ToList();

        return new SectorMapRoutePlan(origin, destination, routeSystems, legs);
    }

    private static Dictionary<int, List<SectorMapRouteLeg>> BuildHyperlaneAdjacency(
        IReadOnlyList<StarSystem> systems,
        double routeDistanceParsecs,
        double ownedRouteDistanceParsecs,
        IReadOnlyDictionary<int, Empire> empiresById)
    {
        var adjacency = systems.ToDictionary(system => system.Id, _ => new List<SectorMapRouteLeg>());
        foreach (var route in BuildSectorMapRoutes(systems, routeDistanceParsecs, ownedRouteDistanceParsecs, empiresById))
        {
            adjacency[route.Source.Id].Add(new SectorMapRouteLeg(route.Source, route.Target, route.DistanceParsecs, true));
            adjacency[route.Target.Id].Add(new SectorMapRouteLeg(route.Target, route.Source, route.DistanceParsecs, true));
        }

        return adjacency;
    }

    private static HyperlaneSearchResult SearchHyperlaneRoutes(
        StarSystem origin,
        IReadOnlyDictionary<int, List<SectorMapRouteLeg>> adjacency)
    {
        var distances = adjacency.Keys.ToDictionary(systemId => systemId, _ => double.PositiveInfinity);
        var previousLegs = new Dictionary<int, SectorMapRouteLeg>();
        var queue = new PriorityQueue<int, double>();
        var settledSystemIds = new HashSet<int>();

        distances[origin.Id] = 0;
        queue.Enqueue(origin.Id, 0);

        while (queue.Count > 0)
        {
            var systemId = queue.Dequeue();
            if (!settledSystemIds.Add(systemId))
            {
                continue;
            }

            foreach (var leg in adjacency[systemId])
            {
                var nextSystemId = leg.Target.Id;
                var nextDistance = distances[systemId] + leg.DistanceParsecs;
                if (nextDistance >= distances[nextSystemId])
                {
                    continue;
                }

                distances[nextSystemId] = nextDistance;
                previousLegs[nextSystemId] = leg;
                queue.Enqueue(nextSystemId, nextDistance);
            }
        }

        return new HyperlaneSearchResult(distances, previousLegs);
    }

    private static PreferredRouteSearchResult SearchPreferredRoute(
        StarSystem origin,
        int destinationSystemId,
        IReadOnlyDictionary<int, List<SectorMapRouteLeg>> adjacency)
    {
        const double voidLegPenalty = 1_000_000;
        const double voidDistancePenalty = 1_000;
        var costs = adjacency.Keys.ToDictionary(systemId => systemId, _ => double.PositiveInfinity);
        var previousLegs = new Dictionary<int, SectorMapRouteLeg>();
        var queue = new PriorityQueue<int, double>();
        var settledSystemIds = new HashSet<int>();

        costs[origin.Id] = 0;
        queue.Enqueue(origin.Id, 0);

        while (queue.Count > 0)
        {
            var systemId = queue.Dequeue();
            if (!settledSystemIds.Add(systemId))
            {
                continue;
            }

            if (systemId == destinationSystemId)
            {
                break;
            }

            foreach (var leg in adjacency[systemId])
            {
                var nextSystemId = leg.Target.Id;
                var legCost = leg.DistanceParsecs
                    + (leg.IsHyperlane ? 0 : voidLegPenalty + leg.DistanceParsecs * voidDistancePenalty);
                var nextCost = costs[systemId] + legCost;
                if (nextCost >= costs[nextSystemId])
                {
                    continue;
                }

                costs[nextSystemId] = nextCost;
                previousLegs[nextSystemId] = leg;
                queue.Enqueue(nextSystemId, nextCost);
            }
        }

        return new PreferredRouteSearchResult(costs, previousLegs);
    }

    private static IReadOnlyList<SectorMapRouteLeg>? BuildHyperlanePath(HyperlaneSearchResult searchResult, int originSystemId, int targetSystemId)
    {
        if (originSystemId == targetSystemId)
        {
            return [];
        }

        if (!searchResult.PreviousLegs.ContainsKey(targetSystemId))
        {
            return null;
        }

        var legs = new List<SectorMapRouteLeg>();
        var currentSystemId = targetSystemId;
        while (currentSystemId != originSystemId)
        {
            var leg = searchResult.PreviousLegs[currentSystemId];
            legs.Add(leg);
            currentSystemId = leg.Source.Id;
        }

        legs.Reverse();
        return legs;
    }

    private static IReadOnlyList<SectorMapRouteLeg>? BuildRoutePath(PreferredRouteSearchResult searchResult, int originSystemId, int targetSystemId)
    {
        if (originSystemId == targetSystemId)
        {
            return [];
        }

        if (!searchResult.PreviousLegs.ContainsKey(targetSystemId))
        {
            return null;
        }

        var legs = new List<SectorMapRouteLeg>();
        var currentSystemId = targetSystemId;
        while (currentSystemId != originSystemId)
        {
            var leg = searchResult.PreviousLegs[currentSystemId];
            legs.Add(leg);
            currentSystemId = leg.Source.Id;
        }

        legs.Reverse();
        return legs;
    }

    private static IReadOnlyList<SectorMapRouteLeg> ReverseRouteLegs(IReadOnlyList<SectorMapRouteLeg> legs)
    {
        return legs
            .Reverse()
            .Select(leg => new SectorMapRouteLeg(leg.Target, leg.Source, leg.DistanceParsecs, leg.IsHyperlane))
            .ToList();
    }

    private int GetSectorMapSystemCount(StarWinSector sector, StarSystem? focusedSystem)
    {
        return GetSectorMapSystems(sector, focusedSystem?.Id ?? 0).Count;
    }

    private bool IsSectorMapCapped(StarWinSector sector, StarSystem? focusedSystem)
    {
        var focused = focusedSystem ?? sector.Systems.FirstOrDefault();
        return focused is not null
            && sector.Systems.Count(system => CalculateParsecDistance(focused.Coordinates, system.Coordinates) <= sectorMapViewDistanceParsecs) > SectorMapMaximumRenderedSystems;
    }

    private int GetSectorMapRouteCount(StarWinSector sector, StarSystem? focusedSystem)
    {
        return BuildSectorMapRoutes(
            GetSectorMapSystems(sector, focusedSystem?.Id ?? 0),
            GetHyperlaneRouteDistanceParsecs(sector),
            GetOwnedHyperlaneBaseLengthParsecs(sector),
            EmpiresById).Count;
    }

    private static IReadOnlyList<SectorMapRoute> BuildSectorMapRoutes(
        IReadOnlyList<StarSystem> systems,
        double routeDistanceParsecs,
        double ownedRouteDistanceParsecs,
        IReadOnlyDictionary<int, Empire> empiresById)
    {
        if (systems.Count < 2)
        {
            return [];
        }

        var maximumRouteDistanceParsecs = Math.Max(routeDistanceParsecs, ownedRouteDistanceParsecs * GetMaximumOwnedHyperlaneTechMultiplier(empiresById));
        var cellSize = Math.Max(0.1, maximumRouteDistanceParsecs);
        var cells = systems
            .GroupBy(system => (
                X: (int)Math.Floor(system.Coordinates.XParsecs / cellSize),
                Y: (int)Math.Floor(system.Coordinates.YParsecs / cellSize),
                Z: (int)Math.Floor(system.Coordinates.ZParsecs / cellSize)))
            .ToDictionary(group => group.Key, group => group.ToList());
        var routes = new List<SectorMapRoute>();

        foreach (var system in systems)
        {
            var originCell = (
                X: (int)Math.Floor(system.Coordinates.XParsecs / cellSize),
                Y: (int)Math.Floor(system.Coordinates.YParsecs / cellSize),
                Z: (int)Math.Floor(system.Coordinates.ZParsecs / cellSize));

            for (var x = originCell.X - 1; x <= originCell.X + 1; x++)
            {
                for (var y = originCell.Y - 1; y <= originCell.Y + 1; y++)
                {
                    for (var z = originCell.Z - 1; z <= originCell.Z + 1; z++)
                    {
                        if (!cells.TryGetValue((x, y, z), out var candidates))
                        {
                            continue;
                        }

                        foreach (var candidate in candidates)
                        {
                            if (candidate.Id <= system.Id)
                            {
                                continue;
                            }

                            var distance = CalculateParsecDistance(system.Coordinates, candidate.Coordinates);
                            if (distance <= routeDistanceParsecs)
                            {
                                routes.Add(new SectorMapRoute(system, candidate, distance, false, false));
                                continue;
                            }

                            if (TryGetOwnedHyperlaneMaximumDistance(system, candidate, ownedRouteDistanceParsecs, empiresById, out var ownedMaximumDistance)
                                && distance <= ownedMaximumDistance)
                            {
                                routes.Add(new SectorMapRoute(system, candidate, distance, true, false));
                            }
                        }
                    }
                }
            }
        }

        AddGoldHyperlaneRoutes(systems, routes, empiresById);

        return routes;
    }

    private static void AddGoldHyperlaneRoutes(
        IReadOnlyList<StarSystem> systems,
        List<SectorMapRoute> routes,
        IReadOnlyDictionary<int, Empire> empiresById)
    {
        var goldRouteKeys = new HashSet<(int SourceId, int TargetId)>();
        var goldEmpireIds = empiresById.Values
            .Where(IsGoldHyperlaneEmpire)
            .Select(empire => empire.Id)
            .ToHashSet();
        if (goldEmpireIds.Count == 0)
        {
            return;
        }

        var systemsByGoldEmpire = systems
            .SelectMany(system => GetControlledColonyEmpireIds(system)
                .Where(goldEmpireIds.Contains)
                .Select(empireId => new { EmpireId = empireId, System = system }))
            .GroupBy(item => item.EmpireId, item => item.System);

        foreach (var empireSystems in systemsByGoldEmpire)
        {
            var ownedSystems = empireSystems
                .DistinctBy(system => system.Id)
                .OrderBy(system => system.Id)
                .ToList();
            for (var sourceIndex = 0; sourceIndex < ownedSystems.Count; sourceIndex++)
            {
                var source = ownedSystems[sourceIndex];
                for (var targetIndex = sourceIndex + 1; targetIndex < ownedSystems.Count; targetIndex++)
                {
                    var target = ownedSystems[targetIndex];
                    var routeKey = GetSectorMapRouteKey(source.Id, target.Id);
                    if (!goldRouteKeys.Add(routeKey))
                    {
                        continue;
                    }

                    routes.RemoveAll(route => GetSectorMapRouteKey(route.Source.Id, route.Target.Id) == routeKey);
                    routes.Add(new SectorMapRoute(
                        source,
                        target,
                        CalculateParsecDistance(source.Coordinates, target.Coordinates),
                        false,
                        true));
                }
            }
        }
    }

    private static (int SourceId, int TargetId) GetSectorMapRouteKey(int sourceId, int targetId)
    {
        return sourceId < targetId ? (sourceId, targetId) : (targetId, sourceId);
    }

    private static bool TryGetOwnedHyperlaneMaximumDistance(
        StarSystem source,
        StarSystem target,
        double ownedRouteDistanceParsecs,
        IReadOnlyDictionary<int, Empire> empiresById,
        out double maximumDistanceParsecs)
    {
        maximumDistanceParsecs = 0;
        var sharedEmpireIds = GetControlledColonyEmpireIds(source)
            .Intersect(GetControlledColonyEmpireIds(target))
            .ToList();
        if (sharedEmpireIds.Count == 0)
        {
            return false;
        }

        maximumDistanceParsecs = sharedEmpireIds
            .Select(empireId => GetOwnedHyperlaneMaximumDistance(ownedRouteDistanceParsecs, empiresById.GetValueOrDefault(empireId)))
            .DefaultIfEmpty(0)
            .Max();
        return maximumDistanceParsecs > 0;
    }

    private static IEnumerable<int> GetControlledColonyEmpireIds(StarSystem system)
    {
        return system.Worlds
            .Where(world => world.Colony is not null)
            .SelectMany(world => GetControlledColonyEmpireIds(world.Colony!))
            .Distinct();
    }

    private static IEnumerable<int> GetControlledColonyEmpireIds(Colony colony)
    {
        if (colony.ControllingEmpireId is int controllingEmpireId)
        {
            yield return controllingEmpireId;
        }

        if (colony.AllegianceId != ushort.MaxValue)
        {
            yield return colony.AllegianceId;
        }
    }

    private static double GetMaximumOwnedHyperlaneTechMultiplier(IReadOnlyDictionary<int, Empire> empiresById)
    {
        return empiresById.Count == 0
            ? 1
            : empiresById.Values.Max(empire => GetOwnedHyperlaneTechMultiplier(empire));
    }

    private static double GetOwnedHyperlaneMaximumDistance(double ownedRouteDistanceParsecs, Empire? empire)
    {
        return ownedRouteDistanceParsecs * GetOwnedHyperlaneTechMultiplier(empire);
    }

    private static double GetOwnedHyperlaneTechMultiplier(Empire? empire)
    {
        var techLevel = empire?.CivilizationProfile.TechLevel ?? 10;
        return 1 + Math.Max(0, techLevel - 10) * 0.05;
    }

    private static bool IsGoldHyperlaneEmpire(Empire empire)
    {
        return GetGurpsTechLevel(empire) >= 12;
    }

    private static int GetGurpsTechLevel(Empire empire)
    {
        return empire.CivilizationProfile.TechLevel + 2;
    }

    private static int GetSectorMapMaximumViewDistance(StarWinSector sector)
    {
        if (sector.Systems.Count < 2)
        {
            return DefaultSectorMapViewDistanceParsecs;
        }

        var minX = sector.Systems.Min(system => system.Coordinates.XParsecs);
        var maxX = sector.Systems.Max(system => system.Coordinates.XParsecs);
        var minY = sector.Systems.Min(system => system.Coordinates.YParsecs);
        var maxY = sector.Systems.Max(system => system.Coordinates.YParsecs);
        var minZ = sector.Systems.Min(system => system.Coordinates.ZParsecs);
        var maxZ = sector.Systems.Max(system => system.Coordinates.ZParsecs);
        var diagonal = Math.Sqrt(
            Math.Pow(maxX - minX, 2)
            + Math.Pow(maxY - minY, 2)
            + Math.Pow(maxZ - minZ, 2));

        return Math.Max(DefaultSectorMapViewDistanceParsecs, (int)Math.Ceiling(diagonal));
    }

    private static double CalculateParsecDistance(Coordinates origin, Coordinates target)
    {
        var deltaX = origin.XParsecs - target.XParsecs;
        var deltaY = origin.YParsecs - target.YParsecs;
        var deltaZ = origin.ZParsecs - target.ZParsecs;

        return Math.Sqrt(deltaX * deltaX + deltaY * deltaY + deltaZ * deltaZ);
    }

    private static IEnumerable<OrbitalSatellite> GetAstralBodySatellites(StarSystem system, int astralBodySequence)
    {
        foreach (var world in system.Worlds
            .Where(world => world.ParentWorldId is null && (world.PrimaryAstralBodySequence ?? 0) == astralBodySequence)
            .OrderBy(world => world.OrbitRadiusAu ?? double.MaxValue)
            .ThenBy(world => world.Name))
        {
            yield return OrbitalSatellite.FromWorld(world);
        }

        foreach (var habitat in system.SpaceHabitats
            .Where(habitat => habitat.OrbitTargetKind == OrbitTargetKind.AstralBody && habitat.OrbitTargetId == astralBodySequence)
            .OrderBy(habitat => habitat.OrbitRadiusKm ?? double.MaxValue)
            .ThenBy(habitat => habitat.Name))
        {
            yield return OrbitalSatellite.FromHabitat(habitat);
        }
    }

    private static IEnumerable<OrbitalSatellite> GetWorldSatellites(StarSystem? system, World world)
    {
        if (system is null)
        {
            yield break;
        }

        foreach (var satellite in system.Worlds
            .Where(item => item.ParentWorldId == world.Id)
            .OrderBy(item => item.OrbitRadiusKm ?? double.MaxValue)
            .ThenBy(item => item.Name))
        {
            yield return OrbitalSatellite.FromWorld(satellite);
        }

        foreach (var habitat in system.SpaceHabitats
            .Where(item => item.OrbitTargetKind == OrbitTargetKind.World && item.OrbitTargetId == world.Id)
            .OrderBy(item => item.OrbitRadiusKm ?? double.MaxValue)
            .ThenBy(item => item.Name))
        {
            yield return OrbitalSatellite.FromHabitat(habitat);
        }
    }

    private sealed record OrbitalSatellite(string Name, string Kind, World? World, SpaceHabitat? Habitat)
    {
        public static OrbitalSatellite FromWorld(World world)
        {
            return new OrbitalSatellite(world.Name, world.Kind.ToString(), world, null);
        }

        public static OrbitalSatellite FromHabitat(SpaceHabitat habitat)
        {
            return new OrbitalSatellite(habitat.Name, "Habitat", null, habitat);
        }
    }

    private sealed record RaceEmpireMembership(Empire Empire, EmpireRaceMembership Membership);

    private sealed record ColonyListing(StarWinSector Sector, StarSystem System, World World, Colony Colony);

    private sealed record SectorMapRoute(StarSystem Source, StarSystem Target, double DistanceParsecs, bool IsOwned, bool IsGold);

    private sealed record SectorMapRoutePlan(
        StarSystem Origin,
        StarSystem Destination,
        IReadOnlyList<StarSystem> Systems,
        IReadOnlyList<SectorMapRouteLeg> Legs)
    {
        public double DirectDistanceParsecs => CalculateParsecDistance(Origin.Coordinates, Destination.Coordinates);

        public double TotalDistanceParsecs => Legs.Sum(leg => leg.DistanceParsecs);

        public double ExtraDistanceParsecs => Math.Max(0, TotalDistanceParsecs - DirectDistanceParsecs);

        public int HyperlaneLegCount => Legs.Count(leg => leg.IsHyperlane);

        public int OffHyperlaneLegCount => Legs.Count(leg => !leg.IsHyperlane);
    }

    private sealed record SectorMapRouteLeg(
        StarSystem Source,
        StarSystem Target,
        double DistanceParsecs,
        bool IsHyperlane);

    private sealed record RouteGraphCacheKey(
        int SectorId,
        double RouteDistanceParsecs,
        double OwnedRouteDistanceParsecs,
        double MaximumVoidRouteDistanceParsecs);

    private sealed record HyperlaneSearchResult(
        IReadOnlyDictionary<int, double> Distances,
        IReadOnlyDictionary<int, SectorMapRouteLeg> PreviousLegs);

    private sealed record PreferredRouteSearchResult(
        IReadOnlyDictionary<int, double> Costs,
        IReadOnlyDictionary<int, SectorMapRouteLeg> PreviousLegs);

    private sealed record ExplorerSessionSelection(int SectorId, int SystemId, bool AutoLoadSectorMap = false);

    public async ValueTask DisposeAsync()
    {
        if (sectorMapModule is not null)
        {
            try
            {
                await sectorMapModule.InvokeVoidAsync("disposeSectorMap", sectorMapElement);
                await sectorMapModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        if (timelineScrollModule is not null)
        {
            try
            {
                await timelineScrollModule.InvokeVoidAsync("disconnectAllLoadMore");
                await timelineScrollModule.InvokeVoidAsync("disconnectTimelineLoadMore");
                await timelineScrollModule.InvokeVoidAsync("disconnectColonyLoadMore");
                await timelineScrollModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        dotNetReference?.Dispose();
    }
}
