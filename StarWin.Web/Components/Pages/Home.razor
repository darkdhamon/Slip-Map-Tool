    private void SelectParentOfHabitat(SpaceHabitat habitat)
    {
        var sector = GetSelectedSector();
        var system = sector.Systems.FirstOrDefault(system => system.SpaceHabitats.Any(item => item.Id == habitat.Id))
            ?? sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId);

