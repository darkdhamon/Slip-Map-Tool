@page "/"
@rendermode InteractiveServer
@inject IStarWinWorkspace Workspace
@inject IStarWinSearchService SearchService
@inject IStarWinImageService ImageService
@inject IStarWinSectorConfigurationService SectorConfigurationService
@inject IJSRuntime JS
@implements IAsyncDisposable

@{
    var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
    var sectorCache = GetSectorCache(sector);
    var selectedSystem = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId) ?? sector.Systems.FirstOrDefault();
    var selectedHabitat = selectedSystem?.SpaceHabitats.FirstOrDefault(habitat => habitat.Id == selectedHabitatId);
    var selectedWorld = selectedHabitat is null
        ? selectedSystem?.Worlds.FirstOrDefault(world => world.Id == selectedWorldId) ?? selectedSystem?.Worlds.FirstOrDefault()
        : null;
    var sectorWorlds = sectorCache.Worlds;
    var sectorColonies = sectorCache.Colonies;
    var sectorRaceIds = sectorCache.RaceIds;
    var sectorEmpireIds = sectorCache.EmpireIds;
    var sectorRaces = Workspace.AlienRaces.Where(race => sectorRaceIds.Contains(race.Id)).OrderBy(race => race.Name).ToList();
    var sectorEmpires = Workspace.Empires.Where(empire => sectorEmpireIds.Contains(empire.Id)).OrderBy(empire => empire.Name).ToList();
    var selectedRace = sectorRaces.FirstOrDefault(race => race.Id == selectedRaceId) ?? sectorRaces.FirstOrDefault();
    var selectedEmpire = sectorEmpires.FirstOrDefault(empire => empire.Id == selectedEmpireId) ?? sectorEmpires.FirstOrDefault();
    var selectedColony = selectedWorld?.Colony ?? sectorColonies.FirstOrDefault().Colony;
    var selectedColonyWorld = selectedColony is null || !sectorCache.WorldsById.TryGetValue(selectedColony.WorldId, out var colonyWorld)
        ? null
        : colonyWorld;
}

<PageTitle>Starforged Atlas</PageTitle>

<section class="explorer-page">
    <header class="explorer-hero">
        <div class="hero-copy">
            <p class="eyebrow">Starforged Atlas</p>
            <h1>Sector command, civilization records, and RPG world survey data.</h1>
            <p class="hero-summary">Browse sectors, inspect systems, find colonies, compare empires, and prepare science-fiction campaign material from StarWin and Slip Map data.</p>
        </div>

        <div class="hero-search">
            <label for="global-search-input">Search the archive</label>
            <input id="global-search-input"
                   placeholder="Try Lincolnshire, Desert, Arachnoid, capital..."
                   @bind="searchQuery"
                   @bind:event="oninput"
                   @bind:after="RunSearch" />

            @if (searchResults.Count > 0)
            {
                <div class="search-results">
                    @foreach (var result in searchResults)
                    {
                        <button type="button" class="search-result" @onclick="() => NavigateToSearchResult(result)">
                            <span>@DisplayResultType(result.Type)</span>
                            <strong>@result.Title</strong>
                            <small>@result.Subtitle</small>
                        </button>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                <p class="search-empty">No matching systems, worlds, races, colonies, or empires.</p>
            }
        </div>
    </header>

    <section class="control-strip">
        <label>
            Sector
            <select @bind="selectedSectorId" @bind:after="SelectDefaultSystem">
                @foreach (var item in Workspace.Sectors)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </label>

        <label>
            System
            <select @bind="selectedSystemId" @bind:after="SelectDefaultWorld">
                @foreach (var system in sector.Systems)
                {
                    <option value="@system.Id">@system.Name</option>
                }
            </select>
        </label>

        <ExplorerSectionTabs Sections="sections"
                             ActiveSection="@activeSection"
                             IsLoading="@sectionLoadingVisible"
                             LoadingTarget="@sectionLoadingTarget"
                             LoadingStatus="@sectionLoadingStatus"
                             SectionSelected="SelectSectionAsync" />
    </section>

    <ExplorerMetricsBand SystemCount="@sector.Systems.Count"
                         WorldCount="@sectorWorlds.Count"
                         ColonyCount="@sectorColonies.Count"
                         EmpireCount="@sectorEmpires.Count"
                         RaceCount="@sectorRaces.Count" />

    @switch (activeSection)
    {
        case "Overview":
            <section class="overview-layout">
                <div class="sector-map-three" @ref="sectorMapElement" aria-label="interactive 3D sector map">
                    @if (!sectorMapRequested)
                    {
                        <article class="map-request-panel">
                            <span class="panel-kicker">3D Sector Map</span>
                            <h2>@sector.Name</h2>
                            <p>The interactive map is available on request so large imported sectors do not slow down the explorer while you browse records.</p>
                            <button type="button" class="overlay-action" @onclick="LoadSectorMap">Load 3D map</button>
                        </article>
                    }
                    else
                    {
                        <div class="map-hud">
                            <span>3D Sector Map</span>
                            <strong>@sector.Name</strong>
                            <small>@GetSectorMapSystemCount(sector, selectedSystem) of @sector.Systems.Count systems within @sectorMapViewDistanceParsecs parsecs@(IsSectorMapCapped(sector, selectedSystem) ? " (closest 1,000 shown)" : string.Empty)</small>
                            <small>@GetSectorMapRouteCount(sector, selectedSystem) @GetHyperlaneTierName(sector) hyperlanes within @Format(GetHyperlaneRouteDistanceParsecs(sector)) parsecs</small>
                            <label class="map-distance-control">
                                <span>View distance</span>
                                <input type="range"
                                       min="@DefaultSectorMapViewDistanceParsecs"
                                       max="@GetSectorMapMaximumViewDistance(sector)"
                                       step="1"
                                       @bind="sectorMapViewDistanceParsecs"
                                       @bind:event="oninput" />
                                <strong>@sectorMapViewDistanceParsecs pc</strong>
                            </label>
                        </div>
                        <button type="button" class="map-fullscreen-button" @onclick="ToggleSectorMapFullscreen">
                            <span class="enter-fullscreen">Full screen</span>
                            <span class="exit-fullscreen">Exit full screen</span>
                        </button>
                        <div class="map-controls-hint">
                            <span>Drag rotate</span>
                            <span>WASD/QE rotate</span>
                            <span>Wheel zoom</span>
                            <span>Right-drag pan</span>
                        </div>
                        @if (selectedSystem is not null)
                        {
                            <article class="fullscreen-system-overlay">
                                <span class="panel-kicker">Current system</span>
                                <h2>@selectedSystem.Name</h2>
                                <dl class="data-list">
                                    <div><dt>Coordinates</dt><dd>@DisplayCoordinates(selectedSystem.Coordinates)</dd></div>
                                    <div><dt>Allegiance</dt><dd>@DisplayAllegiance(selectedSystem.AllegianceId)</dd></div>
                                    <div><dt>Astral bodies</dt><dd>@selectedSystem.AstralBodies.Count</dd></div>
                                    <div><dt>Worlds</dt><dd>@selectedSystem.Worlds.Count</dd></div>
                                </dl>
                                <button type="button" class="overlay-action" @onclick="OpenSelectedSystemRecord">Open system record</button>
                            </article>
                        }
                    }
                </div>

                <div class="stacked-panels">
                    <article class="feature-panel">
                        <span class="panel-kicker">Current system</span>
                        <h2>@(selectedSystem?.Name ?? "No system selected")</h2>
                        @if (selectedSystem is not null)
                        {
                            <dl class="data-list">
                                <div><dt>Coordinates</dt><dd>@DisplayCoordinates(selectedSystem.Coordinates)</dd></div>
                                <div><dt>Allegiance</dt><dd>@DisplayAllegiance(selectedSystem.AllegianceId)</dd></div>
                                <div><dt>Astral bodies</dt><dd>@selectedSystem.AstralBodies.Count</dd></div>
                                <div><dt>Worlds</dt><dd>@selectedSystem.Worlds.Count</dd></div>
                            </dl>
                        }
                    </article>

                    <article class="feature-panel">
                        <span class="panel-kicker">Recent sector history</span>
                        @foreach (var history in sector.History.Take(4))
                        {
                            <div class="timeline-row">
                                <strong>C@history.Century @history.EventType</strong>
                                <span>@history.Description</span>
                            </div>
                        }
                    </article>
                </div>
            </section>
            break;
        case "Timeline":
            <ExplorerTimelineSection Sector="sector"
                                     SectorCache="sectorCache"
                                     Races="sectorRaces"
                                     Empires="sectorEmpires"
                                     RaceSelected="SelectRace"
                                     EmpireSelected="SelectEmpire"
                                     ColonySelected="SelectColony"
                                     WorldSelected="SelectWorld"
                                     SystemSelected="SelectSystem" />
            break;
        case "Configuration":
            <section class="detail-panel">
                <span class="panel-kicker">Sector Configuration</span>
                <h2>@sector.Name</h2>
                <p class="panel-note">Configure sector-level travel assumptions used by the map and future civilization systems.</p>
                <div class="form-grid">
                    <label>
                        Hyperlane tier
                        <input @bind="basicHyperlaneTierName" />
                    </label>
                    <label>
                        Maximum hyperlane length
                        <input type="number"
                               min="0.1"
                               max="100"
                               step="0.1"
                               @bind="basicHyperlaneMaximumLengthParsecs" />
                    </label>
                </div>
                <dl class="field-grid">
                    <div><dt>Default</dt><dd>1 parsec</dd></div>
                    <div><dt>Current map routes</dt><dd>@GetSectorMapRouteCount(sector, selectedSystem) visible hyperlanes</dd></div>
                    <div><dt>Last saved</dt><dd>@DisplayDateTime(sector.Configuration.UpdatedAtUtc)</dd></div>
                </dl>
                <div class="parent-actions">
                    <button type="button" @onclick="SaveSectorConfiguration">Save configuration</button>
                    <button type="button" @onclick="() => LoadSectorConfigurationForm(sector)">Reset form</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(sectorConfigurationStatus))
                {
                    <p class="search-empty">@sectorConfigurationStatus</p>
                }
            </section>
            break;
        case "Systems":
            <section class="content-grid">
                <div class="record-list">
                    <section class="record-filter-panel">
                        <label>
                            Search
                            <input placeholder="Name, ID, coordinates..."
                                   @bind="systemQuery"
                                   @bind:event="oninput"
                                   @bind:after="ResetSystemWindow" />
                        </label>
                        <label>
                            Allegiance
                            <select @bind="systemEmpireId" @bind:after="ResetSystemWindow">
                                <option value="@TimelineAllFilterId">All allegiances</option>
                                @foreach (var empire in sectorEmpires)
                                {
                                    <option value="@empire.Id">@empire.Name</option>
                                }
                            </select>
                        </label>
                        <button type="button" class="timeline-clear-button" @onclick="ClearSystemFilters">Clear filters</button>
                    </section>
                    @{
                        var systemWindow = GetFilteredSystems(sectorCache.SystemsByName)
                            .Take(systemVisibleCount + 1)
                            .ToList();
                        var hasMoreSystems = systemWindow.Count > systemVisibleCount;
                        var visibleSystems = systemWindow.Take(systemVisibleCount).ToList();
                        systemHasMoreRecords = hasMoreSystems;
                    }
                    <div class="timeline-count">Showing @visibleSystems.Count system@(visibleSystems.Count == 1 ? string.Empty : "s")@(hasMoreSystems ? "+" : string.Empty)</div>
                    @if (visibleSystems.Count == 0)
                    {
                        <article class="timeline-event-card">
                            <span class="timeline-century">No matches</span>
                            <p>Adjust the filters to widen the system list.</p>
                        </article>
                    }
                    @foreach (var system in visibleSystems)
                    {
                        <button type="button" class="record-row @(selectedSystem?.Id == system.Id ? "active" : null)" @onclick="() => SelectSystem(system.Id)">
                            <strong>@system.Name</strong>
                            <span>@DisplayCoordinates(system.Coordinates)</span>
                        </button>
                    }
                    @if (hasMoreSystems)
                    {
                        <div @ref="systemLoadMoreElement" class="timeline-load-more">
                            <button type="button" @onclick="LoadMoreSystems">Load more</button>
                        </div>
                    }
                </div>

                @if (selectedSystem is not null)
                {
                    <article class="detail-panel">
                        <span class="panel-kicker">System survey</span>
                        <h2>@selectedSystem.Name</h2>
                        <dl class="field-grid">
                            <div><dt>System id</dt><dd>@selectedSystem.Id</dd></div>
                            <div><dt>Map code</dt><dd>@selectedSystem.MapCode</dd></div>
                            <div><dt>Allegiance</dt><dd>@DisplayAllegiance(selectedSystem.AllegianceId)</dd></div>
                            <div><dt>World count</dt><dd>@selectedSystem.Worlds.Count</dd></div>
                        </dl>

                        <div class="stellar-grid">
                            @foreach (var bodyItem in selectedSystem.AstralBodies.Select((body, index) => new { Body = body, Sequence = index }))
                            {
                                <article class="stellar-card">
                                    @RenderAstralBodyIcon(bodyItem.Body)
                                    <h3>@bodyItem.Body.Role</h3>
                                    @RenderImagePanel(EntityImageTargetKind.AstralBody, bodyItem.Body.Id, "Astral image", false)
                                    <dl class="data-list">
                                        <div><dt>Kind</dt><dd>@bodyItem.Body.Kind</dd></div>
                                        <div><dt>Type</dt><dd>@bodyItem.Body.Classification</dd></div>
                                        <div><dt>Luminosity</dt><dd>@Format(bodyItem.Body.Luminosity)</dd></div>
                                        <div><dt>Mass</dt><dd>@Format(bodyItem.Body.SolarMasses)</dd></div>
                                    </dl>

                                    <div class="satellite-list">
                                        <h4>Satellites</h4>
                                        @foreach (var satellite in GetAstralBodySatellites(selectedSystem, bodyItem.Sequence))
                                        {
                                            if (satellite.World is not null)
                                            {
                                                <button type="button" class="satellite-link" @onclick="() => SelectWorld(satellite.World.Id)">
                                                    <span>@satellite.Kind</span>
                                                    <strong>@satellite.Name</strong>
                                                </button>
                                            }
                                            else if (satellite.Habitat is not null)
                                            {
                                                <button type="button" class="satellite-link habitat" @onclick="() => SelectHabitat(satellite.Habitat.Id)">
                                                    <span>Habitat</span>
                                                    <strong>@satellite.Name</strong>
                                                </button>
                                            }
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </article>
                }
            </section>
            break;
        case "Worlds":
            <section class="content-grid">
                <div class="record-list">
                    <section class="record-filter-panel">
                        <label>
                            Search
                            <input placeholder="Name, type, atmosphere..."
                                   @bind="worldQuery"
                                   @bind:event="oninput"
                                   @bind:after="ResetWorldWindow" />
                        </label>
                        <label>
                            Kind
                            <select @bind="worldKind" @bind:after="ResetWorldWindow">
                                <option value="">All kinds</option>
                                <option value="@WorldKind.Planet.ToString()">Planets</option>
                                <option value="@WorldKind.Moon.ToString()">Moons</option>
                                <option value="SpaceHabitat">Habitats</option>
                            </select>
                        </label>
                        <label>
                            Type
                            <select @bind="worldType" @bind:after="ResetWorldWindow">
                                <option value="">All types</option>
                                @foreach (var itemType in (selectedSystem?.Worlds.Select(world => world.WorldType) ?? []).Distinct().OrderBy(item => item))
                                {
                                    <option value="@itemType">@itemType</option>
                                }
                            </select>
                        </label>
                        <button type="button" class="timeline-clear-button" @onclick="ClearWorldFilters">Clear filters</button>
                    </section>
                    @{
                        var worldWindow = GetFilteredExplorerWorldRecords(selectedSystem)
                            .Take(worldVisibleCount + 1)
                            .ToList();
                        var hasMoreWorlds = worldWindow.Count > worldVisibleCount;
                        var visibleExplorerWorldRecords = worldWindow.Take(worldVisibleCount).ToList();
                        worldHasMoreRecords = hasMoreWorlds;
                    }
                    <div class="timeline-count">Showing @visibleExplorerWorldRecords.Count world@(visibleExplorerWorldRecords.Count == 1 ? string.Empty : "s")@(hasMoreWorlds ? "+" : string.Empty)</div>
                    @if (visibleExplorerWorldRecords.Count == 0)
                    {
                        <article class="timeline-event-card">
                            <span class="timeline-century">No matches</span>
                            <p>Adjust the filters to widen the world list.</p>
                        </article>
                    }
                    @foreach (var record in visibleExplorerWorldRecords)
                    {
                        if (record.World is not null)
                        {
                            var world = record.World;
                            <button type="button" class="record-row @(selectedWorld?.Id == world.Id ? "active" : null)" @onclick="() => SelectWorld(world.Id)">
                                <strong>@world.Name</strong>
                                <span>@world.Kind; @world.WorldType</span>
                            </button>
                        }
                        else if (record.Habitat is not null)
                        {
                            var habitat = record.Habitat;
                            <button type="button" class="record-row @(selectedHabitat?.Id == habitat.Id ? "active" : null)" @onclick="() => SelectHabitat(habitat.Id)">
                                <strong>@habitat.Name</strong>
                                <span>Space Habitat; @DisplayPopulation(habitat.Population)</span>
                            </button>
                        }
                    }
                    @if (hasMoreWorlds)
                    {
                        <div @ref="worldLoadMoreElement" class="timeline-load-more">
                            <button type="button" @onclick="LoadMoreWorlds">Load more</button>
                        </div>
                    }
                </div>

                @if (selectedHabitat is not null)
                {
                    <article class="detail-panel world-detail">
                        @RenderEntityOrb(EntityImageTargetKind.SpaceHabitat, selectedHabitat.Id, "world-orb habitat", selectedHabitat.Name)
                        <span class="panel-kicker">Space habitat</span>
                        <h2>@selectedHabitat.Name</h2>
                        @RenderImagePanel(EntityImageTargetKind.SpaceHabitat, selectedHabitat.Id, "Habitat image", false)
                        <div class="parent-actions">
                            <button type="button" @onclick="() => SelectParentOfHabitat(selectedHabitat)">Parent: @DisplayOrbitTarget(selectedSystem, selectedHabitat)</button>
                        </div>
                        <dl class="field-grid">
                            <div><dt>Habitat id</dt><dd>@selectedHabitat.Id</dd></div>
                            <div><dt>Population</dt><dd>@DisplayPopulation(selectedHabitat.Population)</dd></div>
                            <div><dt>Orbit target</dt><dd>@DisplayOrbitTarget(selectedSystem, selectedHabitat)</dd></div>
                            <div><dt>Orbit radius</dt><dd>@DisplayNullable(selectedHabitat.OrbitRadiusKm, " km")</dd></div>
                            <div><dt>Built by</dt><dd>@DisplayEmpire(selectedHabitat.BuiltByEmpireId)</dd></div>
                            <div><dt>Controlled by</dt><dd>@DisplayEmpire(selectedHabitat.ControlledByEmpireId)</dd></div>
                            <div><dt>Constructed</dt><dd>@DisplayNullable(selectedHabitat.ConstructedCentury, " century")</dd></div>
                        </dl>

                        <div class="satellite-panel">
                            <h3>Satellites</h3>
                            <p>Space habitats are world records, but they cannot have satellites.</p>
                        </div>
                    </article>
                }
                else if (selectedWorld is not null)
                {
                    <article class="detail-panel world-detail">
                        @RenderEntityOrb(EntityImageTargetKind.World, selectedWorld.Id, $"world-orb {selectedWorld.WorldType.ToLowerInvariant()}", selectedWorld.Name)
                        <span class="panel-kicker">@selectedWorld.Kind survey</span>
                        <h2>@selectedWorld.Name</h2>
                        @RenderImagePanel(EntityImageTargetKind.World, selectedWorld.Id, "World image", false)
                        <div class="parent-actions">
                            @if (selectedWorld.ParentWorldId is int parentWorldId
                                                    && selectedSystem?.Worlds.FirstOrDefault(world => world.Id == parentWorldId) is World parentWorld)
                            {
                                <button type="button" @onclick="() => SelectWorld(parentWorld.Id)">Parent world: @parentWorld.Name</button>
                            }
                            else if (selectedSystem is not null)
                            {
                                <button type="button" @onclick="OpenSelectedSystemRecord">Parent astral body: @DisplayAstralBody(selectedSystem, selectedWorld.PrimaryAstralBodySequence ?? 0)</button>
                            }
                        </div>
                        <dl class="field-grid">
                            <div><dt>World type</dt><dd>@selectedWorld.WorldType</dd></div>
                            <div><dt>Orbit</dt><dd>@DisplayOrbit(selectedWorld)</dd></div>
                            <div><dt>Diameter</dt><dd>@selectedWorld.DiameterKm km</dd></div>
                            <div><dt>Gravity</dt><dd>@Format(selectedWorld.GravityEarthG) g</dd></div>
                            <div><dt>Mass</dt><dd>@Format(selectedWorld.MassEarthMasses)</dd></div>
                            <div><dt>Escape velocity</dt><dd>@Format(selectedWorld.EscapeVelocityKmPerSecond) km/s</dd></div>
                            <div><dt>Atmosphere</dt><dd>@selectedWorld.AtmosphereType</dd></div>
                            <div><dt>Composition</dt><dd>@selectedWorld.AtmosphereComposition</dd></div>
                            <div><dt>Pressure</dt><dd>@selectedWorld.AtmosphericPressure atm</dd></div>
                            <div><dt>Water</dt><dd>@selectedWorld.WaterType</dd></div>
                            <div><dt>Ice</dt><dd>@selectedWorld.Hydrography.IcePercent%</dd></div>
                            <div><dt>Clouds</dt><dd>@selectedWorld.Hydrography.CloudPercent%</dd></div>
                            <div><dt>Average temp</dt><dd>@selectedWorld.AverageTemperatureCelsius C</dd></div>
                            <div><dt>Boiling point</dt><dd>@DisplayNullable(selectedWorld.BoilingPointCelsius, " C")</dd></div>
                            <div><dt>Magnetic field</dt><dd>@DisplayNullable(selectedWorld.MagneticFieldGauss, " gauss")</dd></div>
                        </dl>

                        <div class="tag-group">
                            @if (selectedWorld.UnusualCharacteristics.Count == 0)
                            {
                                <span>Standard survey profile</span>
                            }
                            @foreach (var item in selectedWorld.UnusualCharacteristics)
                            {
                                <span>@item.Name</span>
                            }
                        </div>

                        <div class="satellite-panel">
                            <h3>Satellites</h3>
                            @{
                                var worldSatellites = GetWorldSatellites(selectedSystem, selectedWorld).ToList();
                            }
                            @if (worldSatellites.Count == 0)
                            {
                                <p>No satellites recorded.</p>
                            }
                            @foreach (var satellite in worldSatellites)
                            {
                                if (satellite.World is not null)
                                {
                                    <button type="button" class="satellite-link" @onclick="() => SelectWorld(satellite.World.Id)">
                                        <span>@satellite.Kind</span>
                                        <strong>@satellite.Name</strong>
                                    </button>
                                }
                                else if (satellite.Habitat is not null)
                                {
                                    <button type="button" class="satellite-link habitat" @onclick="() => SelectHabitat(satellite.Habitat.Id)">
                                        <span>Habitat</span>
                                        <strong>@satellite.Name</strong>
                                    </button>
                                }
                            }
                        </div>
                    </article>
                }
            </section>
            break;
        case "Colonies":
            <section class="content-grid">
                <div class="record-list colony-record-list">
                    <section class="record-filter-panel">
                        <label>
                            Search
                            <input placeholder="World, class, race, empire..."
                                   @bind="colonyQuery"
                                   @bind:event="oninput"
                                   @bind:after="ResetColonyWindow" />
                        </label>
                        <label>
                            Race
                            <select @bind="colonyRaceId" @bind:after="ResetColonyWindow">
                                <option value="@TimelineAllFilterId">All races</option>
                                @foreach (var race in sectorRaces)
                                {
                                    <option value="@race.Id">@race.Name</option>
                                }
                            </select>
                        </label>
                        <label>
                            Allegiance
                            <select @bind="colonyEmpireId" @bind:after="ResetColonyWindow">
                                <option value="@TimelineAllFilterId">All allegiances</option>
                                @foreach (var empire in sectorEmpires)
                                {
                                    <option value="@empire.Id">@empire.Name</option>
                                }
                            </select>
                        </label>
                        <label>
                            Status
                            <select @bind="colonyStatus" @bind:after="ResetColonyWindow">
                                <option value="">All statuses</option>
                                @foreach (var status in Enum.GetValues<ColonyPoliticalStatus>())
                                {
                                    <option value="@status.ToString()">@status</option>
                                }
                            </select>
                        </label>
                        <label>
                            Class
                            <select @bind="colonyClass" @bind:after="ResetColonyWindow">
                                <option value="">All classes</option>
                                @foreach (var itemClass in sectorColonies.Select(item => item.Colony.ColonyClass).Distinct().OrderBy(item => item))
                                {
                                    <option value="@itemClass">@itemClass</option>
                                }
                            </select>
                        </label>
                        <button type="button" class="timeline-clear-button" @onclick="ClearColonyFilters">Clear filters</button>
                    </section>
                    @{
                        var colonyWindow = GetFilteredColonies(sectorCache)
                            .Take(colonyVisibleCount + 1)
                            .ToList();
                        var hasMoreColonies = colonyWindow.Count > colonyVisibleCount;
                        var visibleColonies = colonyWindow
                            .Take(colonyVisibleCount)
                            .ToList();
                        colonyHasMoreRecords = hasMoreColonies;
                    }
                    <div class="timeline-count">Showing @visibleColonies.Count colon@(visibleColonies.Count == 1 ? "y" : "ies")@(hasMoreColonies ? "+" : string.Empty)</div>
                    @if (visibleColonies.Count == 0)
                    {
                        <article class="timeline-event-card">
