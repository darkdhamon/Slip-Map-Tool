                        <section class="relationship-section">
                            <h3>Member races</h3>
                            <div class="relationship-list">
                                @foreach (var membership in selectedEmpire.RaceMemberships
                                                        .Where(item => sectorRaceIds.Contains(item.RaceId))
                                                        .OrderByDescending(item => item.IsPrimary)
                                                        .ThenBy(item => item.RaceId))
                                {
                                    <button type="button" class="relationship-row" @onclick="() => SelectRace(membership.RaceId)">
                                        <strong>@DisplayRace(membership.RaceId)</strong>
                                        <span>@membership.Role; @membership.PopulationMillions million</span>
