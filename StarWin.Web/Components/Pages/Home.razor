    private void ApplySelectedSystemText()
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var systemId = ParseComboId(selectedSystemText);
        if (systemId == TimelineAllFilterId || sector.Systems.All(system => system.Id != systemId))
        {
            selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
            return;
        }

        selectedSystemId = systemId;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        SelectDefaultWorld();
    }

    private void ApplyRouteOriginText()
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var systemId = ParseComboId(routeOriginText);
        if (systemId == TimelineAllFilterId || sector.Systems.All(system => system.Id != systemId))
        {
            routeOriginSystemId = 0;
            routeOriginText = string.Empty;
            ClearPlottedRoutePlan();
            renderedOverview = false;
            return;
        }

        routeOriginSystemId = systemId;
        routeOriginText = FormatSelectedSystem(sector, routeOriginSystemId);
        ClearPlottedRoutePlan();
        renderedOverview = false;
    }

    private void ApplyRouteDestinationText()
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var systemId = ParseComboId(routeDestinationText);
        if (systemId == TimelineAllFilterId || sector.Systems.All(system => system.Id != systemId))
        {
