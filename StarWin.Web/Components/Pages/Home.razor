    private static bool ContainsTimelineQuery(string? value, string query)
    {
        return value?.Contains(query, StringComparison.OrdinalIgnoreCase) == true;
    }

    private IEnumerable<(World World, Colony Colony)> GetFilteredColonies(ExplorerSectorCache sectorCache)
    {
        return sectorCache.ColoniesByPopulation.Where(ColonyMatches);
    }

    private bool ColonyMatches((World World, Colony Colony) item)
    {
        if (colonyRaceId != TimelineAllFilterId
            && item.Colony.RaceId != colonyRaceId
            && !item.Colony.Demographics.Any(demographic => demographic.RaceId == colonyRaceId))
        {
            return false;
        }

        if (colonyEmpireId != TimelineAllFilterId
            && item.Colony.AllegianceId != colonyEmpireId
            && item.Colony.ControllingEmpireId != colonyEmpireId
            && item.Colony.FoundingEmpireId != colonyEmpireId
            && item.Colony.ParentEmpireId != colonyEmpireId)
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(colonyStatus)
            && !string.Equals(item.Colony.PoliticalStatus.ToString(), colonyStatus, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(colonyClass)
            && !string.Equals(item.Colony.ColonyClass, colonyClass, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(colonyQuery))
        {
            return true;
        }

        var query = colonyQuery.Trim();
        return ContainsTimelineQuery(item.World.Name, query)
            || ContainsTimelineQuery(item.World.WorldType, query)
            || ContainsTimelineQuery(item.Colony.Id.ToString(), query)
            || ContainsTimelineQuery(item.Colony.WorldId.ToString(), query)
            || ContainsTimelineQuery(item.Colony.ColonyClass, query)
            || ContainsTimelineQuery(item.Colony.ColonistRaceName, query)
            || ContainsTimelineQuery(item.Colony.AllegianceName, query)
            || ContainsTimelineQuery(item.Colony.Starport, query)
            || ContainsTimelineQuery(item.Colony.GovernmentType, query)
            || ContainsTimelineQuery(item.Colony.ExportResource, query)
            || ContainsTimelineQuery(item.Colony.ImportResource, query)
            || item.Colony.Demographics.Any(demographic => ContainsTimelineQuery(demographic.RaceName, query));
    }

    private IEnumerable<StarSystem> GetFilteredSystems(IEnumerable<StarSystem> systems)
    {
        return systems.Where(SystemMatches);
    }

    private bool SystemMatches(StarSystem system)
    {
        if (systemEmpireId != TimelineAllFilterId && system.AllegianceId != systemEmpireId)
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(systemQuery))
        {
            return true;
        }

        var query = systemQuery.Trim();
        return ContainsTimelineQuery(system.Name, query)
            || ContainsTimelineQuery(system.Id.ToString(), query)
            || ContainsTimelineQuery(system.LegacySystemId?.ToString(), query)
            || ContainsTimelineQuery(DisplayCoordinates(system.Coordinates), query)
            || ContainsTimelineQuery(DisplayAllegiance(system.AllegianceId), query)
            || system.AstralBodies.Any(body =>
                ContainsTimelineQuery(body.Kind.ToString(), query)
                || ContainsTimelineQuery(body.Classification, query)
                || ContainsTimelineQuery(body.Role.ToString(), query))
            || system.Worlds.Any(world =>
                ContainsTimelineQuery(world.Name, query)
                || ContainsTimelineQuery(world.WorldType, query));
    }

    private IEnumerable<ExplorerWorldRecord> GetFilteredExplorerWorldRecords(StarSystem? system)
    {
        if (system is null)
        {
            return [];
        }

        return GetExplorerWorldRecords(system)
            .Where(ExplorerWorldRecordMatches)
            .OrderBy(record => record.KindSort)
            .ThenBy(record => record.OrbitSort)
            .ThenBy(record => record.Name);
    }

    private static IEnumerable<ExplorerWorldRecord> GetExplorerWorldRecords(StarSystem system)
    {
        foreach (var world in system.Worlds)
        {
            yield return ExplorerWorldRecord.FromWorld(system, world);
        }

        foreach (var habitat in system.SpaceHabitats)
        {
            yield return ExplorerWorldRecord.FromHabitat(system, habitat);
        }
    }

    private bool ExplorerWorldRecordMatches(ExplorerWorldRecord record)
    {
        if (!string.IsNullOrWhiteSpace(worldKind)
            && !string.Equals(record.Kind, worldKind, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(worldType)
            && !string.Equals(record.Type, worldType, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(worldQuery))
        {
            return true;
        }

        var query = worldQuery.Trim();
        return ContainsTimelineQuery(record.Name, query)
            || ContainsTimelineQuery(record.Kind, query)
            || ContainsTimelineQuery(record.Type, query)
            || ContainsTimelineQuery(record.System.Name, query)
            || ContainsTimelineQuery(record.World?.Id.ToString(), query)
            || ContainsTimelineQuery(record.Habitat?.Id.ToString(), query)
            || ContainsTimelineQuery(record.World?.LegacyPlanetId?.ToString(), query)
            || ContainsTimelineQuery(record.World?.LegacyMoonId?.ToString(), query)
            || ContainsTimelineQuery(record.World?.AtmosphereType, query)
            || ContainsTimelineQuery(record.World?.AtmosphereComposition, query)
            || ContainsTimelineQuery(record.World?.WaterType, query)
            || ContainsTimelineQuery(record.World?.Colony?.ColonyClass, query)
            || ContainsTimelineQuery(record.World?.Colony?.AllegianceName, query)
            || ContainsTimelineQuery(DisplayEmpire(record.Habitat?.ControlledByEmpireId), query);
    }

    private IEnumerable<AlienRace> GetFilteredRaces(IReadOnlyList<AlienRace> races)
    {
        return races
            .Where(RaceMatches)
            .OrderBy(race => race.Name)
            .ThenBy(race => race.Id);
    }

    private bool RaceMatches(AlienRace race)
    {
        if (!string.IsNullOrWhiteSpace(raceEnvironment)
            && !string.Equals(race.EnvironmentType, raceEnvironment, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!string.IsNullOrWhiteSpace(raceAppearance)
            && !string.Equals(race.AppearanceType, raceAppearance, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(raceQuery))
        {
            return true;
        }

        var query = raceQuery.Trim();
        var homeWorld = FindWorld(race.HomePlanetId);
        return ContainsTimelineQuery(race.Name, query)
            || ContainsTimelineQuery(race.Id.ToString(), query)
            || ContainsTimelineQuery(race.AppearanceType, query)
            || ContainsTimelineQuery(race.BodyChemistry, query)
            || ContainsTimelineQuery(race.EnvironmentType, query)
            || ContainsTimelineQuery(race.GovernmentType, query)
            || ContainsTimelineQuery(race.ReproductionMethod, query)
            || ContainsTimelineQuery(race.Diet, query)
            || ContainsTimelineQuery(race.Religion, query)
            || ContainsTimelineQuery(race.BiologyProfile.Body.ToString(), query)
            || ContainsTimelineQuery(race.BiologyProfile.Mind.ToString(), query)
            || ContainsTimelineQuery(race.BiologyProfile.Speed.ToString(), query)
            || ContainsTimelineQuery(race.BiologyProfile.PsiRating.ToString(), query)
            || ContainsTimelineQuery(homeWorld?.Name, query);
    }

    private IEnumerable<Empire> GetFilteredEmpires(IReadOnlyList<Empire> empires)
    {
        return empires
            .Where(EmpireMatches)
            .OrderBy(empire => empire.Name)
            .ThenBy(empire => empire.Id);
    }

    private bool EmpireMatches(Empire empire)
    {
        if (empireRaceId != TimelineAllFilterId
            && !empire.RaceMemberships.Any(membership => membership.RaceId == empireRaceId))
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(empireQuery))
        {
            return true;
        }

        var query = empireQuery.Trim();
        var homeWorld = FindWorld(empire.Founding.FoundingWorldId);
        return ContainsTimelineQuery(empire.Name, query)
            || ContainsTimelineQuery(empire.Id.ToString(), query)
            || ContainsTimelineQuery(empire.LegacyRaceId?.ToString(), query)
            || ContainsTimelineQuery(empire.ExpansionPolicy.ToString(), query)
            || ContainsTimelineQuery(homeWorld?.Name, query)
            || empire.RaceMemberships.Any(membership =>
                ContainsTimelineQuery(DisplayRace(membership.RaceId), query)
                || ContainsTimelineQuery(membership.Role.ToString(), query))
            || empire.Contacts.Any(contact =>
                ContainsTimelineQuery(contact.Relation, query)
                || ContainsTimelineQuery(DisplayEmpire(contact.OtherEmpireId), query));
    }

    private World? FindWorld(int? worldId)
    {
        if (worldId is null or 0)
        {
            return null;
        }

        return WorldsById.TryGetValue(worldId.Value, out var world) ? world : null;
    }

    private void SelectDefaultCivilizationRecords(StarWinSector sector)
    {
        var sectorCache = GetSectorCache(sector);

        selectedRaceId = sectorCache.RaceIds.Contains(selectedRaceId)
            ? selectedRaceId
            : Workspace.AlienRaces.FirstOrDefault(race => sectorCache.RaceIds.Contains(race.Id))?.Id ?? 0;
        selectedEmpireId = sectorCache.EmpireIds.Contains(selectedEmpireId)
            ? selectedEmpireId
            : Workspace.Empires.FirstOrDefault(empire => sectorCache.EmpireIds.Contains(empire.Id))?.Id ?? 0;
    }

    private IEnumerable<RaceEmpireMembership> GetRaceEmpireMemberships(AlienRace race, IReadOnlyCollection<Empire> sectorEmpires)
    {
        return sectorEmpires
            .SelectMany(empire => empire.RaceMemberships
                .Where(membership => membership.RaceId == race.Id)
                .Select(membership => new RaceEmpireMembership(empire, membership)))
            .OrderByDescending(item => item.Membership.IsPrimary)
            .ThenBy(item => item.Empire.Name);
    }

    private IEnumerable<ColonyListing> GetEmpireColonies(Empire empire, StarWinSector sector)
    {
        return sector.Systems.Select(system => new { sector, system })
            .SelectMany(item => item.system.Worlds
                .Where(world => world.Colony is not null)
                .Select(world => new ColonyListing(item.sector, item.system, world, world.Colony!)))
            .Where(listing => listing.Colony.IsControlledBy(empire.Id) || listing.Colony.FoundingEmpireId == empire.Id)
            .OrderByDescending(listing => listing.Colony.EstimatedPopulation)
            .ThenBy(listing => listing.World.Name);
    }

    private ColonyListing? GetCapitalColony(Empire empire)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var colonies = GetEmpireColonies(empire, sector).ToList();
        var homeworldColony = colonies.FirstOrDefault(listing => listing.World.Id == empire.Founding.FoundingWorldId);
        if (homeworldColony is not null && homeworldColony.Colony.IsControlledBy(empire.Id))
        {
            return homeworldColony;
        }

        return colonies.FirstOrDefault(listing => listing.Colony.IsControlledBy(empire.Id)) ?? colonies.FirstOrDefault();
    }

    private GurpsTemplate BuildGurpsTemplate(AlienRace race)
    {
        var sector = Workspace.Sectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? Workspace.CurrentSector;
        var sectorCache = GetSectorCache(sector);
        var sectorEmpires = Workspace.Empires
            .Where(empire => sectorCache.EmpireIds.Contains(empire.Id))
            .ToList();
        var memberships = GetRaceEmpireMemberships(race, sectorEmpires).ToList();
        var primaryEmpire = memberships.FirstOrDefault(item => item.Membership.IsPrimary)?.Empire
            ?? memberships.FirstOrDefault()?.Empire;

        var profile = new AlienRaceExportProfile
        {
            Race = race,
            Empire = primaryEmpire,
            HomeWorld = FindWorld(race.HomePlanetId)
        };

        foreach (var listing in sectorCache.Worlds
            .Where(world => world.Colony is not null && world.Colony.Demographics.Any(demographic => demographic.RaceId == race.Id))
            .Select(world => world.Colony!))
        {
            profile.Colonies.Add(listing);
        }

        var builder = new StarWin.Domain.Services.GurpsTemplateBuilder();
        return builder.Build(profile, GurpsTemplateEdition.FourthEdition);
    }

    private static string DisplayGurpsEdition(GurpsTemplateEdition edition)
    {
        return edition switch
        {
            GurpsTemplateEdition.FourthEdition => "GURPS Fourth Edition",
            GurpsTemplateEdition.LegacyStarWin => "Legacy StarWin",
            _ => edition.ToString()
        };
    }

    private static string DisplayPoints(int points)
    {
        return points > 0 ? $"+{points} points" : $"{points} points";
    }

    private static RenderFragment RenderGurpsTraitGroup(string title, IEnumerable<GurpsTemplateTrait> traits)
    {
        return @<article>
            <h4>@title</h4>
            @if (!traits.Any())
            {
                <p>No entries.</p>
            }
            @foreach (var trait in traits)
            {
                <div class="gurps-trait">
                    <span>@DisplayTraitName(trait)</span>
                    <strong>@DisplayPoints(trait.PointCost)</strong>
                    @if (!string.IsNullOrWhiteSpace(trait.Notes))
                    {
                        <small>@trait.Notes</small>
                    }
                </div>
            }
        </article>;
    }

    private static string DisplayTraitName(GurpsTemplateTrait trait)
    {
        return trait.Level == 0 ? trait.Name : $"{trait.Name} {trait.Level:+#;-#;0}";
    }

    private IReadOnlyList<EntityImage> GetEntityImages(EntityImageTargetKind targetKind, int targetId)
    {
        return entityImages
            .Where(image => image.TargetKind == targetKind && image.TargetId == targetId)
            .OrderByDescending(image => image.IsPrimary)
            .ThenBy(image => image.UploadedAt)
            .ToList();
    }

    private EntityImage? GetPrimaryEntityImage(EntityImageTargetKind targetKind, int targetId)
    {
        return GetEntityImages(targetKind, targetId).FirstOrDefault();
    }

    private RenderFragment RenderAstralBodyIcon(AstralBody body)
    {
        return RenderEntityOrb(
            EntityImageTargetKind.AstralBody,
            body.Id,
            $"stellar-orb {body.Kind.ToString().ToLowerInvariant()}",
            $"{body.Role} {body.Kind}");
    }

    private RenderFragment RenderEntityOrb(EntityImageTargetKind targetKind, int targetId, string fallbackClass, string altText)
    {
        var image = GetPrimaryEntityImage(targetKind, targetId);
        return image is null
            ? @<div class="@fallbackClass"></div>
            : @<img class="@($"{fallbackClass} entity-orb-image")" src="@image.RelativePath" alt="@altText" />;
    }

    private async Task UploadEntityImage(EntityImageTargetKind targetKind, int targetId, InputFileChangeEventArgs args)
    {
        var file = args.File;
        try
        {
            await using var stream = file.OpenReadStream(10 * 1024 * 1024);
            await ImageService.UploadImageAsync(targetKind, targetId, file.Name, file.ContentType, stream);
            entityImages = await ImageService.GetImagesAsync();
            imageUploadStatus = $"{file.Name} uploaded.";
        }
        catch (Exception exception)
        {
            imageUploadStatus = exception.Message;
        }
    }

    private RenderFragment RenderImagePanel(EntityImageTargetKind targetKind, int targetId, string title, bool allowMultiple)
    {
        var images = GetEntityImages(targetKind, targetId);
        return @<section class="entity-image-panel">
            <div class="image-panel-header">
                <h4>@title</h4>
                <span>@(allowMultiple ? "Multiple allowed" : "One image")</span>
            </div>
            @if (images.Count > 0)
            {
                <div class="entity-image-grid @(allowMultiple ? string.Empty : "single")">
                    @foreach (var image in images)
                    {
                        <figure>
                            <img src="@image.RelativePath" alt="@image.FileName" />
                            <figcaption>@(image.IsPrimary ? "Primary" : image.FileName)</figcaption>
                        </figure>
                    }
                </div>
            }
            else
            {
                <p>No image uploaded.</p>
            }
            <label class="image-upload-control">
                <span>@(allowMultiple ? "Add image" : "Upload image")</span>
                <InputFile OnChange="@(args => UploadEntityImage(targetKind, targetId, args))" accept="image/jpeg,image/png,image/gif,image/webp" />
            </label>
            @if (!string.IsNullOrWhiteSpace(imageUploadStatus))
            {
                <small>@imageUploadStatus</small>
            }
        </section>;
    }

    private static string DisplayOrbit(World world)
    {
        if (world.OrbitRadiusAu is not null)
        {
            return $"{world.OrbitRadiusAu:0.###} AU";
        }

        if (world.OrbitRadiusKm is not null)
        {
            return $"{world.OrbitRadiusKm:0,0} km";
        }

        return "N/A";
    }

    private static string DisplayNullable(double? value, string suffix)
    {
        return value is null ? "N/A" : $"{value:0.###}{suffix}";
    }

    private static string DisplayOrbitTarget(StarSystem? system, SpaceHabitat habitat)
    {
        if (system is null)
        {
            return "Unknown";
        }

        return habitat.OrbitTargetKind switch
        {
            OrbitTargetKind.AstralBody => DisplayAstralBody(system, habitat.OrbitTargetId),
            OrbitTargetKind.World => system.Worlds.FirstOrDefault(world => world.Id == habitat.OrbitTargetId)?.Name ?? $"World {habitat.OrbitTargetId}",
            OrbitTargetKind.SpaceHabitat => $"Habitat {habitat.OrbitTargetId}",
            _ => "Unknown"
        };
    }

    private static string DisplayAstralBody(StarSystem system, int sequence)
    {
        var body = system.AstralBodies.ElementAtOrDefault(sequence);
        if (body is null)
        {
            return $"Astral body {sequence}";
        }

        return string.IsNullOrWhiteSpace(body.Classification)
            ? body.Role.ToString()
            : $"{body.Role} ({body.Classification})";
    }

    private static string DisplayNullable(int? value, string suffix)
    {
        return value is null ? "N/A" : $"{value}{suffix}";
    }

    private static string DisplayCoordinates(Coordinates coordinates)
    {
        return $"{coordinates.XParsecs:0.#}, {coordinates.YParsecs:0.#}, {coordinates.ZParsecs:0.#}";
    }

    private static string DisplayPopulation(long population)
    {
        return population >= 1_000_000_000
            ? $"{population / 1_000_000_000m:0.#} billion"
            : $"{population / 1_000_000m:0.#} million";
    }

    private static long GetDemographicPopulation(Colony colony, ColonyDemographic demographic)
    {
        if (demographic.Population > 0)
        {
            return demographic.Population;
        }

        return demographic.PopulationPercent <= 0
            ? 0
            : (long)Math.Round(colony.EstimatedPopulation * demographic.PopulationPercent / 100m);
    }

    private static string Format(double? value)
    {
        return value is null ? "N/A" : $"{value:0.###}";
    }

    private static string DisplayDateTime(DateTime value)
    {
        return value == default ? "Not saved" : value.ToLocalTime().ToString("g");
    }

    private static string GetHyperlaneTierName(StarWinSector sector)
    {
        return string.IsNullOrWhiteSpace(sector.Configuration.BasicHyperlaneTierName)
            ? "Basic"
            : sector.Configuration.BasicHyperlaneTierName;
    }

    private static double GetHyperlaneRouteDistanceParsecs(StarWinSector sector)
    {
        return (double)Math.Max(0.1m, sector.Configuration.BasicHyperlaneMaximumLengthParsecs);
    }

    private static string DisplayResultType(StarWinSearchResultType type)
    {
        return type switch
        {
            StarWinSearchResultType.StarSystem => "System",
            StarWinSearchResultType.AlienRace => "Race",
            StarWinSearchResultType.SpaceHabitat => "Habitat",
            _ => type.ToString()
        };
    }

    private object BuildSectorMap(StarWinSector sector, int focusedSystemId)
    {
        var mappedSystems = GetSectorMapSystems(sector, focusedSystemId).ToList();
        var focusedSystem = sector.Systems.FirstOrDefault(system => system.Id == focusedSystemId)
            ?? sector.Systems.FirstOrDefault();
        var routeDistance = GetHyperlaneRouteDistanceParsecs(sector);
        var routes = BuildSectorMapRoutes(mappedSystems, routeDistance);

        return new
        {
            sector = sector.Name,
            viewDistanceParsecs = sectorMapViewDistanceParsecs,
            fadeStartParsecs = Math.Max(0, sectorMapViewDistanceParsecs - 1),
            maximumRenderedSystems = SectorMapMaximumRenderedSystems,
            labelDistanceParsecs = SectorMapMaximumLabelDistanceParsecs,
            routeDistanceParsecs = routeDistance,
            totalSystemCount = sector.Systems.Count,
            visibleSystemCount = mappedSystems.Count,
            visibleRouteCount = routes.Count,
            systems = mappedSystems.Select(system => new
            {
                id = system.Id,
                name = system.Name,
                x = system.Coordinates.XParsecs,
                y = system.Coordinates.YParsecs,
                z = system.Coordinates.ZParsecs,
                distanceFromFocus = focusedSystem is null
                    ? 0
                    : CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates),
                showLabel = ShouldShowSectorMapLabel(system, focusedSystem),
                bodies = system.AstralBodies.Take(3).Select(body => new
                {
                    kind = body.Kind.ToString(),
                    role = body.Role.ToString(),
                    classification = body.Classification,
                    luminosity = body.Luminosity,
                    solarMasses = body.SolarMasses,
                    imageUrl = GetPrimaryEntityImage(EntityImageTargetKind.AstralBody, body.Id)?.RelativePath
                }).ToArray()
            }).ToArray(),
            routes = routes.Select(route => new
            {
                sourceId = route.Source.Id,
                targetId = route.Target.Id,
                distanceParsecs = route.DistanceParsecs
            }).ToArray()
        };
    }

    private IReadOnlyList<StarSystem> GetSectorMapSystems(StarWinSector sector, int focusedSystemId)
    {
        var focusedSystem = sector.Systems.FirstOrDefault(system => system.Id == focusedSystemId)
            ?? sector.Systems.FirstOrDefault();

        if (focusedSystem is null)
        {
            return [];
        }

        return sector.Systems
            .Select(system => new
            {
                System = system,
                Distance = CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates)
            })
            .Where(item => item.Distance <= sectorMapViewDistanceParsecs)
            .OrderBy(item => item.Distance)
            .ThenBy(item => item.System.Name)
            .Take(SectorMapMaximumRenderedSystems)
            .Select(item => item.System)
            .ToList();
    }

    private static bool ShouldShowSectorMapLabel(StarSystem system, StarSystem? focusedSystem)
    {
        if (focusedSystem is null || system.Id == focusedSystem.Id)
        {
            return true;
        }

        if (system.Worlds.Any(world => world.Colony is not null))
        {
            return true;
        }

        return CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates) <= SectorMapMaximumLabelDistanceParsecs;
    }

    private int GetSectorMapSystemCount(StarWinSector sector, StarSystem? focusedSystem)
    {
        return GetSectorMapSystems(sector, focusedSystem?.Id ?? 0).Count;
    }

    private bool IsSectorMapCapped(StarWinSector sector, StarSystem? focusedSystem)
    {
        var focused = focusedSystem ?? sector.Systems.FirstOrDefault();
        return focused is not null
            && sector.Systems.Count(system => CalculateParsecDistance(focused.Coordinates, system.Coordinates) <= sectorMapViewDistanceParsecs) > SectorMapMaximumRenderedSystems;
    }

    private int GetSectorMapRouteCount(StarWinSector sector, StarSystem? focusedSystem)
    {
        return BuildSectorMapRoutes(
            GetSectorMapSystems(sector, focusedSystem?.Id ?? 0),
            GetHyperlaneRouteDistanceParsecs(sector)).Count;
    }

    private static IReadOnlyList<SectorMapRoute> BuildSectorMapRoutes(IReadOnlyList<StarSystem> systems, double routeDistanceParsecs)
    {
        if (systems.Count < 2)
        {
            return [];
        }

        var cellSize = Math.Max(0.1, routeDistanceParsecs);
        var cells = systems
            .GroupBy(system => (
                X: (int)Math.Floor(system.Coordinates.XParsecs / cellSize),
                Y: (int)Math.Floor(system.Coordinates.YParsecs / cellSize),
                Z: (int)Math.Floor(system.Coordinates.ZParsecs / cellSize)))
            .ToDictionary(group => group.Key, group => group.ToList());
        var routes = new List<SectorMapRoute>();

        foreach (var system in systems)
        {
            var originCell = (
                X: (int)Math.Floor(system.Coordinates.XParsecs / cellSize),
                Y: (int)Math.Floor(system.Coordinates.YParsecs / cellSize),
                Z: (int)Math.Floor(system.Coordinates.ZParsecs / cellSize));

            for (var x = originCell.X - 1; x <= originCell.X + 1; x++)
            {
                for (var y = originCell.Y - 1; y <= originCell.Y + 1; y++)
                {
                    for (var z = originCell.Z - 1; z <= originCell.Z + 1; z++)
                    {
                        if (!cells.TryGetValue((x, y, z), out var candidates))
                        {
                            continue;
                        }

                        foreach (var candidate in candidates)
                        {
                            if (candidate.Id <= system.Id)
                            {
                                continue;
                            }

                            var distance = CalculateParsecDistance(system.Coordinates, candidate.Coordinates);
                            if (distance <= routeDistanceParsecs)
                            {
                                routes.Add(new SectorMapRoute(system, candidate, distance));
                            }
                        }
                    }
                }
            }
        }

        return routes;
    }

    private static int GetSectorMapMaximumViewDistance(StarWinSector sector)
    {
        if (sector.Systems.Count < 2)
        {
            return DefaultSectorMapViewDistanceParsecs;
        }

        var minX = sector.Systems.Min(system => system.Coordinates.XParsecs);
        var maxX = sector.Systems.Max(system => system.Coordinates.XParsecs);
        var minY = sector.Systems.Min(system => system.Coordinates.YParsecs);
        var maxY = sector.Systems.Max(system => system.Coordinates.YParsecs);
        var minZ = sector.Systems.Min(system => system.Coordinates.ZParsecs);
        var maxZ = sector.Systems.Max(system => system.Coordinates.ZParsecs);
        var diagonal = Math.Sqrt(
            Math.Pow(maxX - minX, 2)
            + Math.Pow(maxY - minY, 2)
            + Math.Pow(maxZ - minZ, 2));

        return Math.Max(DefaultSectorMapViewDistanceParsecs, (int)Math.Ceiling(diagonal));
    }

    private static double CalculateParsecDistance(Coordinates origin, Coordinates target)
    {
        var deltaX = origin.XParsecs - target.XParsecs;
        var deltaY = origin.YParsecs - target.YParsecs;
        var deltaZ = origin.ZParsecs - target.ZParsecs;

        return Math.Sqrt(deltaX * deltaX + deltaY * deltaY + deltaZ * deltaZ);
    }

    private static IEnumerable<OrbitalSatellite> GetAstralBodySatellites(StarSystem system, int astralBodySequence)
    {
        foreach (var world in system.Worlds
            .Where(world => world.ParentWorldId is null && (world.PrimaryAstralBodySequence ?? 0) == astralBodySequence)
            .OrderBy(world => world.OrbitRadiusAu ?? double.MaxValue)
            .ThenBy(world => world.Name))
        {
            yield return OrbitalSatellite.FromWorld(world);
        }

        foreach (var habitat in system.SpaceHabitats
            .Where(habitat => habitat.OrbitTargetKind == OrbitTargetKind.AstralBody && habitat.OrbitTargetId == astralBodySequence)
            .OrderBy(habitat => habitat.OrbitRadiusKm ?? double.MaxValue)
            .ThenBy(habitat => habitat.Name))
        {
            yield return OrbitalSatellite.FromHabitat(habitat);
        }
    }

    private static IEnumerable<OrbitalSatellite> GetWorldSatellites(StarSystem? system, World world)
    {
        if (system is null)
        {
            yield break;
        }

        foreach (var satellite in system.Worlds
            .Where(item => item.ParentWorldId == world.Id)
            .OrderBy(item => item.OrbitRadiusKm ?? double.MaxValue)
            .ThenBy(item => item.Name))
        {
            yield return OrbitalSatellite.FromWorld(satellite);
        }

        foreach (var habitat in system.SpaceHabitats
            .Where(item => item.OrbitTargetKind == OrbitTargetKind.World && item.OrbitTargetId == world.Id)
            .OrderBy(item => item.OrbitRadiusKm ?? double.MaxValue)
            .ThenBy(item => item.Name))
        {
            yield return OrbitalSatellite.FromHabitat(habitat);
        }
    }

    private sealed record OrbitalSatellite(string Name, string Kind, World? World, SpaceHabitat? Habitat)
    {
        public static OrbitalSatellite FromWorld(World world)
        {
            return new OrbitalSatellite(world.Name, world.Kind.ToString(), world, null);
        }

        public static OrbitalSatellite FromHabitat(SpaceHabitat habitat)
        {
            return new OrbitalSatellite(habitat.Name, "Habitat", null, habitat);
        }
    }

