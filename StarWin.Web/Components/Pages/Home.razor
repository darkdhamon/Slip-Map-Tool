@page "/"
@rendermode InteractiveServer
@inject IStarWinWorkspace Workspace
@inject IStarWinExplorerContextService ExplorerContextService
@inject IStarWinSearchService SearchService
@inject IStarWinImageService ImageService
@inject IStarWinSectorConfigurationService SectorConfigurationService
@inject IStarWinSectorRouteService SectorRouteService
@inject IStarWinEntityNameService EntityNameService
@inject IStarWinIndependentColonyService IndependentColonyService
@inject IStarWinSpaceHabitatService SpaceHabitatService
@inject IJSRuntime JS
@implements IAsyncDisposable
@using StarWin.Domain.Services

@{
    var sector = GetSelectedSector();
    var mapSector = GetMapSector();
    var mapPanelTitle = GetMapPanelTitle(sector);
    var mapContextActionLabel = GetMapContextActionLabel();
    var sectorSummary = GetSectorSummary(sector);
    var sectorCache = ShouldUseFullSectorCache(activeSection) ? GetSectorCache(sector) : null;
    var selectedSystem = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId) ?? sector.Systems.FirstOrDefault();
    var selectedMapSystem = mapSector.Systems.FirstOrDefault(system => system.Id == selectedSystemId) ?? mapSector.Systems.FirstOrDefault();
    var selectedHabitat = selectedSystem?.SpaceHabitats.FirstOrDefault(habitat => habitat.Id == selectedHabitatId);
    var selectedWorld = selectedHabitat is null
        ? selectedSystem?.Worlds.FirstOrDefault(world => world.Id == selectedWorldId) ?? selectedSystem?.Worlds.FirstOrDefault()
        : null;
    var sectorWorlds = sectorCache?.Worlds ?? [];
    var sectorColonies = sectorCache?.Colonies ?? [];
    var sectorRaceIds = sectorCache?.RaceIds ?? sectorSummary.RaceIds;
    var sectorEmpireIds = sectorCache?.EmpireIds ?? sectorSummary.EmpireIds;
    var sectorRaces = ExplorerAlienRaces.Where(race => sectorRaceIds.Contains(race.Id)).OrderBy(race => race.Name).ToList();
    var sectorEmpires = ExplorerEmpires.Where(empire => sectorEmpireIds.Contains(empire.Id)).OrderBy(empire => empire.Name).ToList();
    var selectedRace = sectorRaces.FirstOrDefault(race => race.Id == selectedRaceId) ?? sectorRaces.FirstOrDefault();
    var selectedEmpire = sectorEmpires.FirstOrDefault(empire => empire.Id == selectedEmpireId) ?? sectorEmpires.FirstOrDefault();
    var selectedColony = selectedWorld?.Colony ?? sectorColonies.Select(item => item.Colony).FirstOrDefault();
    var selectedColonyWorld = selectedColony is null || sectorCache is null || !sectorCache.WorldsById.TryGetValue(selectedColony.WorldId, out var colonyWorld)
        ? null
        : colonyWorld;
    var selectedRoutePlan = activeSection == "Overview"
        ? GetPlottedRoutePlan(sector)
        : null;
    var hyperlaneSectionCache = ShouldUseHyperlaneSectionCache(activeSection) ? GetHyperlaneSectionCache(sector) : null;
    var savedHyperlanes = activeSection == "Hyperlanes" ? hyperlaneSectionCache?.Routes ?? [] : [];
    var hyperlaneWindow = activeSection == "Hyperlanes"
        ? savedHyperlanes.Take(hyperlaneVisibleCount + 1).ToList()
        : [];
    var hasMoreHyperlanes = activeSection == "Hyperlanes" && hyperlaneWindow.Count > hyperlaneVisibleCount;
    var visibleHyperlanes = activeSection == "Hyperlanes"
        ? hyperlaneWindow.Take(hyperlaneVisibleCount).ToList()
        : [];
    var selectedHyperlane = activeSection == "Hyperlanes"
        ? savedHyperlanes.FirstOrDefault(route => route.Id == selectedHyperlaneId)
        : null;
    var savedHyperlaneReport = hyperlaneSectionCache?.NetworkReport ?? SectorHyperlaneNetworkReport.Empty;
    hyperlaneHasMoreRecords = hasMoreHyperlanes;
}

<PageTitle>Starforged Atlas</PageTitle>

<section class="explorer-page">
    @if (activeSection == "Overview")
    {
        <header class="explorer-hero">
            <div class="hero-copy">
                <p class="eyebrow">Starforged Atlas</p>
                <h1>Sector command, civilization records, and RPG world survey data.</h1>
        <p class="hero-summary">Browse sectors, inspect systems, find colonies, compare empires, and prepare science-fiction campaign material from legacy StarWin and Slip Map data.</p>
            </div>
        </header>
    }

    <section class="control-strip">
        <label class="control-field sector-field">
            Sector
            <select @bind="selectedSectorId" @bind:after="SelectDefaultSystem">
                @foreach (var item in ExplorerSectors)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </label>

        <label class="control-field system-field">
            System
            <input list="sector-system-options"
                   placeholder="Select system..."
                   @bind="selectedSystemText"
                   @bind:after="ApplySelectedSystemText" />
            <datalist id="sector-system-options">
                @foreach (var system in sector.Systems)
                {
                    <option value="@FormatSystemOption(system)" />
                }
            </datalist>
        </label>

        <div class="archive-search">
            <label for="archive-search-input">Archive search</label>
            <input id="archive-search-input"
                   placeholder="System, world, colony, race, empire..."
                   @bind="searchQuery"
                   @bind:event="oninput"
                   @bind:after="RunSearch" />

            @if (searchResults.Count > 0)
            {
                <div class="search-results">
                    @foreach (var result in searchResults)
                    {
                        <button type="button" class="search-result" @onclick="() => NavigateToSearchResult(result)">
                            <span>@DisplayResultType(result.Type)</span>
                            <strong>@result.Title</strong>
                            <small>@result.Subtitle</small>
                        </button>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                <p class="search-empty">No matching systems, worlds, races, colonies, empires, habitats, or history.</p>
            }
        </div>

        <ExplorerSectionTabs Sections="sections"
                             ActiveSection="@activeSection"
                             IsLoading="@sectionLoadingVisible"
                             LoadingTarget="@sectionLoadingTarget"
                             LoadingStatus="@sectionLoadingStatus"
                             SectionSelected="SelectSectionAsync" />
    </section>

    @if (!string.IsNullOrWhiteSpace(explorerRenderError))
    {
        <article class="timeline-event-card">
            <span class="timeline-century">Section error</span>
            <p>@explorerRenderError</p>
        </article>
    }

    @if (activeSection == "Overview")
    {
        <ExplorerMetricsBand SystemCount="@sectorSummary.SystemCount"
                             WorldCount="@sectorSummary.WorldCount"
                             ColonyCount="@sectorSummary.ColonyCount"
                             EmpireCount="@sectorSummary.EmpireIds.Count"
                             RaceCount="@sectorSummary.RaceIds.Count" />
    }

    @switch (activeSection)
    {
        case "Overview":
            <section class="overview-layout">
                <div class="sector-map-three" @ref="sectorMapElement" aria-label="interactive 3D sector map">
                    @if (!sectorMapRequested)
                    {
                        <article class="map-request-panel">
                            <span class="panel-kicker">3D Sector Map</span>
                            <h2>@mapPanelTitle</h2>
                            <p>The interactive map is available on request so large imported sectors do not slow down the explorer while you browse records.</p>
                            <label class="switch-field">
                                <input type="checkbox"
                                       checked="@autoLoadSectorMap"
                                       @onchange="ToggleAutoLoadSectorMap" />
                                <span>Auto-load map this session</span>
                            </label>
                            <button type="button" class="overlay-action" @onclick="RefreshSectorMapContextAsync" disabled="@mapContextRefreshing">@mapContextActionLabel</button>
                            <button type="button" class="overlay-action" @onclick="LoadSectorMap">Load 3D map</button>
                            @if (!string.IsNullOrWhiteSpace(mapContextStatus))
                            {
                                <p class="search-empty">@mapContextStatus</p>
                            }
                        </article>
                    }
                    else
                    {
                        <div class="map-hud">
                            <span>3D Sector Map</span>
                            <strong>@mapSector.Name</strong>
                            <small>@GetSectorMapSystemCount(mapSector, selectedMapSystem) of @mapSector.Systems.Count systems within @sectorMapViewDistanceParsecs parsecs@(IsSectorMapCapped(mapSector, selectedMapSystem) ? $" (closest {sectorMapRenderLimit:N0} shown)" : string.Empty)</small>
                        <small>@GetSectorMapRouteCount(mapSector, selectedMapSystem) visible hyperlanes</small>
                            @if (!string.IsNullOrWhiteSpace(sectorMapPerformanceStatus))
                            {
                                <small class="map-performance-status">@sectorMapPerformanceStatus</small>
                            }
                            @if (selectedRoutePlan is { } hudRoutePlan)
                            {
                                <small>@hudRoutePlan.Legs.Count route legs from @hudRoutePlan.Origin.Name to @hudRoutePlan.Destination.Name; @hudRoutePlan.OffHyperlaneLegCount off-lane</small>
                            }
                            <label class="switch-field compact">
                                <input type="checkbox"
                                       checked="@autoLoadSectorMap"
                                       @onchange="ToggleAutoLoadSectorMap" />
                                <span>Auto-load</span>
                            </label>
                            <label class="map-distance-control">
                                <span>View distance</span>
                                <input type="range"
                                       min="@DefaultSectorMapViewDistanceParsecs"
                                       max="@GetSectorMapMaximumViewDistance(sector)"
                                       step="1"
                                       @bind="sectorMapViewDistanceParsecs"
                                       @bind:event="oninput" />
                                <strong>@sectorMapViewDistanceParsecs pc</strong>
                            </label>
                            <button type="button" class="overlay-action" @onclick="RefreshSectorMapContextAsync" disabled="@mapContextRefreshing">@mapContextActionLabel</button>
                            @if (!string.IsNullOrWhiteSpace(mapContextStatus))
                            {
                                <small>@mapContextStatus</small>
                            }
                        </div>
                        <button type="button" class="map-fullscreen-button" @onclick="ToggleSectorMapFullscreen">
                            <span class="enter-fullscreen">Full screen</span>
                            <span class="exit-fullscreen">Exit full screen</span>
                        </button>
                        <div class="map-controls-hint">
                            <span>Drag rotate</span>
                            <span>WASD/QE rotate</span>
                            <span>Wheel zoom</span>
                            <span>Right-drag pan</span>
                        </div>
                    }
                    @if (sectorMapRequested && selectedMapSystem is not null)
                    {
                        <article class="fullscreen-system-overlay">
                            <span class="panel-kicker">Current system</span>
                            <h2>@selectedMapSystem.Name</h2>
                            <dl class="data-list">
                                <div><dt>Coordinates</dt><dd>@DisplayCoordinates(selectedMapSystem.Coordinates)</dd></div>
                                <div><dt>Allegiance</dt><dd>@DisplayAllegiance(selectedMapSystem.AllegianceId)</dd></div>
                                <div><dt>Astral bodies</dt><dd>@selectedMapSystem.AstralBodies.Count</dd></div>
                                <div><dt>Worlds</dt><dd>@selectedMapSystem.Worlds.Count</dd></div>
                            </dl>
                            <button type="button" class="overlay-action" @onclick="RecenterSectorMap">Recenter map</button>
                            <button type="button" class="overlay-action" @onclick="OpenSelectedSystemRecord">Open system record</button>
                        </article>
                    }
                    @if (sectorMapRequested)
                    {
                        <article class="fullscreen-route-planner route-planner-panel">
                            <span class="panel-kicker">Route planner</span>
                            <h2>Plot hyperlane route</h2>
                            <label>
                                Origin
                                <input list="fullscreen-route-system-options"
                                       placeholder="Select origin..."
                                       @bind="routeOriginText"
                                       @bind:after="ApplyRouteOriginText" />
                            </label>
                            <label>
                                Destination
                                <input list="fullscreen-route-system-options"
                                       placeholder="Select destination..."
                                       @bind="routeDestinationText"
                                       @bind:after="ApplyRouteDestinationText" />
                            </label>
                            <datalist id="fullscreen-route-system-options">
                                @foreach (var system in sector.Systems.OrderBy(system => system.Name).ThenBy(system => system.Id))
                                {
                                    <option value="@FormatSystemOption(system)" />
                                }
                            </datalist>
                            <div class="parent-actions">
                                <button type="button" @onclick="PlotSelectedRouteAsync" disabled="@sectionLoadingVisible">Plot route</button>
                                <button type="button" @onclick="ClearSelectedRoute">Clear route</button>
                            </div>
                            <div class="form-grid">
                                <label>
                                    Optimization
                                    <select @bind="routeOptimizationMode">
                                        <option value="@RouteOptimizationMode.ShortestDistance">Shortest distance</option>
                                        <option value="@RouteOptimizationMode.ShortestTravelTime">Shortest travel time</option>
                                    </select>
                                </label>
                                <MultiSelectCombo Label="Avoid empires"
                                                  Placeholder="Avoid selected empires..."
                                                  SearchPlaceholder="Search empires..."
                                                  Options="@GetRouteEmpireOptions()"
                                                  SelectedIds="avoidedEmpireIds"
                                                  SelectedIdsChanged="UpdateAvoidedEmpires" />
                                <MultiSelectCombo Label="Avoid systems"
                                                  Placeholder="Avoid selected systems..."
                                                  SearchPlaceholder="Search systems..."
                                                  Options="@GetRouteSystemOptions()"
                                                  SelectedIds="avoidedSystemIds"
                                                  SelectedIdsChanged="UpdateAvoidedSystems" />
                            </div>
                            @if (selectedRoutePlan is { } fullscreenRoutePlan)
                            {
                                <dl class="field-grid">
                                    <div><dt>Origin</dt><dd>@fullscreenRoutePlan.Origin.Name</dd></div>
                                    <div><dt>Destination</dt><dd>@fullscreenRoutePlan.Destination.Name</dd></div>
                                    <div><dt>Route distance</dt><dd>@Format(fullscreenRoutePlan.TotalDistanceParsecs) pc</dd></div>
                                    <div><dt>Travel time</dt><dd>@FormatTravelTime(fullscreenRoutePlan.TotalTravelTimeYears)</dd></div>
                                    <div><dt>Hyperlane jumps</dt><dd>@fullscreenRoutePlan.HyperlaneJumpCount</dd></div>
                                    <div><dt>Off-lane legs</dt><dd>@fullscreenRoutePlan.OffHyperlaneLegCount</dd></div>
                                </dl>
                                <div class="route-leg-list compact">
                                    @foreach (var leg in fullscreenRoutePlan.Legs)
                                    {
                                        <button type="button"
                                                class="route-leg @GetRouteLegCssClass(leg)"
                                                @onclick="() => SelectSystem(leg.Target.Id)">
                                            <span>@GetRouteLegTierLabel(leg)</span>
                                            <strong>@leg.Source.Name to @leg.Target.Name</strong>
                                            <small>@Format(leg.DistanceParsecs) pc • @FormatTravelTime(leg.TravelTimeYears) • @GetRouteLegOwnerLabel(leg)</small>
                                        </button>
                                    }
                                </div>
                            }
                            else if (routeDestinationSystemId is not 0)
                            {
                                <p>No route could be plotted without an off-lane flight over @Format(GetOffLaneMaximumDistanceParsecs(sector)) parsecs.</p>
                            }
                        </article>
                    }
                    @if (sectionLoadingVisible)
                    {
                        <div class="fullscreen-loading-modal-backdrop" role="status" aria-live="polite" aria-label="Loading route">
                            <section class="loading-modal">
                                <span class="panel-kicker">Loading @sectionLoadingTarget</span>
                                <h2>@sectionLoadingStatus</h2>
                                <LoadingElapsedTime IsVisible="@sectionLoadingVisible" />
                                <div class="loading-meter" aria-hidden="true">
                                    <span></span>
                                </div>
                                <ol>
                                    <li>Reading the current system and destination.</li>
                                    <li>Following connected hyperlane networks.</li>
                                    <li>Finding the shortest unavoidable void crossing.</li>
                                </ol>
                            </section>
                        </div>
                    }
                </div>

                <div class="stacked-panels">
                    <article class="feature-panel route-planner-panel">
                        <span class="panel-kicker">Route planner</span>
                        <h2>Plot hyperlane route</h2>
                        <label>
                            Origin
                            <input list="route-system-options"
                                   placeholder="Select origin..."
                                   @bind="routeOriginText"
                                   @bind:after="ApplyRouteOriginText" />
                        </label>
                        <label>
                            Destination
                            <input list="route-system-options"
                                   placeholder="Select destination..."
                                   @bind="routeDestinationText"
                                   @bind:after="ApplyRouteDestinationText" />
                        </label>
                        <datalist id="route-system-options">
                            @foreach (var system in sector.Systems.OrderBy(system => system.Name).ThenBy(system => system.Id))
                            {
                                <option value="@FormatSystemOption(system)" />
                            }
                        </datalist>
                        <div class="parent-actions">
                            <button type="button" @onclick="PlotSelectedRouteAsync" disabled="@sectionLoadingVisible">Plot route</button>
                            <button type="button" @onclick="ClearSelectedRoute">Clear route</button>
                        </div>
                        <div class="form-grid">
                            <label>
                                Optimization
                                <select @bind="routeOptimizationMode">
                                    <option value="@RouteOptimizationMode.ShortestDistance">Shortest distance</option>
                                    <option value="@RouteOptimizationMode.ShortestTravelTime">Shortest travel time</option>
                                </select>
                            </label>
                            <MultiSelectCombo Label="Avoid empires"
                                              Placeholder="Avoid selected empires..."
                                              SearchPlaceholder="Search empires..."
                                              Options="@GetRouteEmpireOptions()"
                                              SelectedIds="avoidedEmpireIds"
                                              SelectedIdsChanged="UpdateAvoidedEmpires" />
                            <MultiSelectCombo Label="Avoid systems"
                                              Placeholder="Avoid selected systems..."
                                              SearchPlaceholder="Search systems..."
                                              Options="@GetRouteSystemOptions()"
                                              SelectedIds="avoidedSystemIds"
                                              SelectedIdsChanged="UpdateAvoidedSystems" />
                        </div>
                        @if (selectedRoutePlan is { } routePlan)
                        {
                            <dl class="field-grid">
                                <div><dt>Origin</dt><dd>@routePlan.Origin.Name</dd></div>
                                <div><dt>Destination</dt><dd>@routePlan.Destination.Name</dd></div>
                                <div><dt>Direct distance</dt><dd>@Format(routePlan.DirectDistanceParsecs) pc</dd></div>
                                <div><dt>Route distance</dt><dd>@Format(routePlan.TotalDistanceParsecs) pc</dd></div>
                                <div><dt>Travel time</dt><dd>@FormatTravelTime(routePlan.TotalTravelTimeYears)</dd></div>
                                <div><dt>Extra travel</dt><dd>@Format(routePlan.ExtraDistanceParsecs) pc</dd></div>
                                <div><dt>Hyperlane jumps</dt><dd>@routePlan.HyperlaneJumpCount</dd></div>
                                <div><dt>Off-lane legs</dt><dd>@routePlan.OffHyperlaneLegCount</dd></div>
                                <div><dt>Off-lane limit</dt><dd>@Format(GetOffLaneMaximumDistanceParsecs(sector)) pc</dd></div>
                            </dl>
                            <div class="route-leg-list">
                                @foreach (var leg in routePlan.Legs)
                                {
                                    <button type="button"
                                            class="route-leg @GetRouteLegCssClass(leg)"
                                            @onclick="() => SelectSystem(leg.Target.Id)">
                                        <span>@GetRouteLegTierLabel(leg)</span>
                                        <strong>@leg.Source.Name to @leg.Target.Name</strong>
                                        <small>@Format(leg.DistanceParsecs) pc • @FormatTravelTime(leg.TravelTimeYears) • @GetRouteLegOwnerLabel(leg)</small>
                                    </button>
                                }
                            </div>
                        }
                        else if (routeDestinationSystemId is not 0)
                        {
                            <p>No route could be plotted without an off-lane flight over @Format(GetOffLaneMaximumDistanceParsecs(sector)) parsecs.</p>
                        }
                    </article>
                </div>
            </section>
            break;
        case "Timeline":
            <ExplorerTimelineSection Sector="sector"
                                     SectorCache="sectorCache!"
                                     Races="sectorRaces"
                                     Empires="sectorEmpires"
                                     RaceSelected="SelectRace"
                                     EmpireSelected="SelectEmpire"
                                     ColonySelected="SelectColony"
                                     WorldSelected="SelectWorld"
                                     SystemSelected="SelectSystem" />
            break;
        case "Configuration":
            <section class="detail-panel">
                <span class="panel-kicker">Sector Configuration</span>
                <h2>@sector.Name</h2>
                <p class="panel-note">Configure sector-level travel assumptions used by the map and future civilization systems.</p>
                <div class="configuration-groups">
                    <section class="configuration-card-group">
                        <div class="configuration-group-header">
                            <div>
                                <span class="panel-kicker">Defaults</span>
                                <h3>Sector and route controls</h3>
                            </div>
                            <p>Use compact cards for the values that affect the whole sector before diving into per-tier tuning.</p>
                        </div>
                        <div class="configuration-card-grid configuration-card-grid-wide">
                            <section class="configuration-card">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">General</span>
                                    <h4>Sector defaults</h4>
                                </div>
                                <div class="form-grid compact-card-grid">
                                    <label>
                                        Sector name
                                        <input maxlength="160" @bind="sectorName" />
                                    </label>
                                    <label>
                                        Off-lane distance
                                        <input type="number" min="0.1" step="0.1" @bind="offLaneMaximumDistanceParsecs" />
                                    </label>
                                </div>
                            </section>

                            <section class="configuration-card">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">Connections</span>
                                    <h4>Hyperlane caps</h4>
                                </div>
                                <div class="form-grid compact-card-grid">
                                    <label>
                                        TL9 and below max connections
                                        <input type="number" min="0" step="1" @bind="tl9AndBelowMaximumConnectionsPerSystem" />
                                    </label>
                                    <label>
                                        Extra cross-empire connections
                                        <input type="number" min="0" step="1" @bind="additionalCrossEmpireConnectionsPerSystem" />
                                    </label>
                                </div>
                            </section>

                            <section class="configuration-card configuration-card-metrics">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">Routing</span>
                                    <h4>Live route summary</h4>
                                </div>
                                <dl class="field-grid compact-field-grid">
                                    <div><dt>Route rule</dt><dd>Shared empires use the highest TL present in both systems; otherwise cross-empire routes use the best lower TL between endpoint empires</dd></div>
                                    <div><dt>Connection cap</dt><dd>@tl9AndBelowMaximumConnectionsPerSystem standard links plus @additionalCrossEmpireConnectionsPerSystem cross-empire bonus</dd></div>
                                    <div><dt>Off-lane scope</dt><dd>Sector-wide today, with ship-specific overrides planned later</dd></div>
                                    <div><dt>Current map routes</dt><dd>@GetConfigurationRouteSummary(sector, selectedSystem)</dd></div>
                                </dl>
                            </section>

                            <section class="configuration-card configuration-card-metrics">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">Networks</span>
                                    <h4>Saved route report</h4>
                                </div>
                                <dl class="field-grid compact-field-grid">
                                    <div><dt>Current saved routes</dt><dd>@sector.SavedRoutes.Count persisted hyperlane segments</dd></div>
                                    <div><dt>Hyperlane networks</dt><dd>@savedHyperlaneReport.DistinctNetworkCount distinct network@(savedHyperlaneReport.DistinctNetworkCount == 1 ? string.Empty : "s")</dd></div>
                                    <div><dt>Stranded systems</dt><dd>@savedHyperlaneReport.StrandedSystemCount TL6+ eligible system@(savedHyperlaneReport.StrandedSystemCount == 1 ? string.Empty : "s") still disconnected</dd></div>
                                    <div><dt>Last saved</dt><dd>@DisplayDateTime(sector.Configuration.UpdatedAtUtc)</dd></div>
                                </dl>
                            </section>
                        </div>
                    </section>

                    <section class="configuration-card-group">
                        <div class="configuration-group-header">
                            <div>
                                <span class="panel-kicker">Hyperlanes</span>
                                <h3>Tier cards</h3>
                            </div>
                            <p>Each TL tier now lives in its own card so related settings stay together and the page stays much more scan-friendly.</p>
                        </div>
                        <div class="configuration-card-grid configuration-tier-grid">
                            <section class="configuration-card configuration-tier-card">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">TL6</span>
                                    <h4>@tl6HyperlaneName</h4>
                                </div>
                                <p class="configuration-card-copy">Basic network defaults for early hyperlane infrastructure.</p>
                                <div class="form-grid compact-card-grid">
                                    <label>
                                        Tier name
                                        <input maxlength="80" @bind="tl6HyperlaneName" />
                                    </label>
                                    <label>
                                        Maximum distance
                                        <input type="number" min="0.1" step="0.1" @bind="tl6MaximumDistanceParsecs" />
                                    </label>
                                    <label>
                                        Off-lane speed
                                        <input type="number" min="0.1" step="0.25" @bind="tl6OffLaneSpeedMultiplier" />
                                    </label>
                                    <label>
                                        Hyperlane modifier
                                        <input type="number" min="0.1" step="0.05" @bind="tl6HyperlaneSpeedModifier" />
                                    </label>
                                </div>
                            </section>

                            <section class="configuration-card configuration-tier-card">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">TL7</span>
                                    <h4>@tl7HyperlaneName</h4>
                                </div>
                                <p class="configuration-card-copy">Enhanced routes with stronger off-lane performance and longer reach.</p>
                                <div class="form-grid compact-card-grid">
                                    <label>
                                        Tier name
                                        <input maxlength="80" @bind="tl7HyperlaneName" />
                                    </label>
                                    <label>
                                        Maximum distance
                                        <input type="number" min="0.1" step="0.1" @bind="tl7MaximumDistanceParsecs" />
                                    </label>
                                    <label>
                                        Off-lane speed
                                        <input type="number" min="0.1" step="0.25" @bind="tl7OffLaneSpeedMultiplier" />
                                    </label>
                                    <label>
                                        Hyperlane modifier
                                        <input type="number" min="0.1" step="0.05" @bind="tl7HyperlaneSpeedModifier" />
                                    </label>
                                </div>
                            </section>

                            <section class="configuration-card configuration-tier-card">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">TL8</span>
                                    <h4>@tl8HyperlaneName</h4>
                                </div>
                                <p class="configuration-card-copy">Advanced mid-sector travel settings for higher-throughput lane networks.</p>
                                <div class="form-grid compact-card-grid">
                                    <label>
                                        Tier name
                                        <input maxlength="80" @bind="tl8HyperlaneName" />
                                    </label>
                                    <label>
                                        Maximum distance
                                        <input type="number" min="0.1" step="0.1" @bind="tl8MaximumDistanceParsecs" />
                                    </label>
                                    <label>
                                        Off-lane speed
                                        <input type="number" min="0.1" step="0.25" @bind="tl8OffLaneSpeedMultiplier" />
                                    </label>
                                    <label>
                                        Hyperlane modifier
                                        <input type="number" min="0.1" step="0.05" @bind="tl8HyperlaneSpeedModifier" />
                                    </label>
                                </div>
                            </section>

                            <section class="configuration-card configuration-tier-card">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">TL9</span>
                                    <h4>@tl9HyperlaneName</h4>
                                </div>
                                <p class="configuration-card-copy">Prime long-haul lanes for powerful interstellar route networks.</p>
                                <div class="form-grid compact-card-grid">
                                    <label>
                                        Tier name
                                        <input maxlength="80" @bind="tl9HyperlaneName" />
                                    </label>
                                    <label>
                                        Maximum distance
                                        <input type="number" min="0.1" step="0.1" @bind="tl9MaximumDistanceParsecs" />
                                    </label>
                                    <label>
                                        Off-lane speed
                                        <input type="number" min="0.1" step="0.25" @bind="tl9OffLaneSpeedMultiplier" />
                                    </label>
                                    <label>
                                        Hyperlane modifier
                                        <input type="number" min="0.1" step="0.05" @bind="tl9HyperlaneSpeedModifier" />
                                    </label>
                                </div>
                            </section>

                            <section class="configuration-card configuration-tier-card">
                                <div class="configuration-card-header">
                                    <span class="panel-kicker">TL10</span>
                                    <h4>@tl10HyperlaneName</h4>
                                </div>
                                <p class="configuration-card-copy">Ascendant-tier travel, including the configurable unlimited-range flag.</p>
                                <div class="form-grid compact-card-grid">
                                    <label>
                                        Tier name
                                        <input maxlength="80" @bind="tl10HyperlaneName" />
                                    </label>
                                    <label>
                                        Maximum distance (`-1` = unlimited)
                                        <input type="number" step="0.1" @bind="tl10MaximumDistanceParsecs" />
                                    </label>
                                    <label>
                                        Off-lane speed
                                        <input type="number" min="0.1" step="0.25" @bind="tl10OffLaneSpeedMultiplier" />
                                    </label>
                                    <label>
                                        Hyperlane modifier
                                        <input type="number" min="0.1" step="0.05" @bind="tl10HyperlaneSpeedModifier" />
                                    </label>
                                </div>
                            </section>
                        </div>
                    </section>
                </div>
                <div class="parent-actions">
                    <button type="button" @onclick="SaveSectorConfiguration">Save configuration</button>
                    <button type="button" @onclick="SaveCurrentRoutesAsync" disabled="@(sectionLoadingVisible || routeSaveLoadingVisible)">
                        @(sector.SavedRoutes.Count == 0 ? "Save Current Routes" : "Update Current Routes")
                    </button>
                    <button type="button" @onclick="() => ConvertIndependentColoniesAsync(sector.Id)" disabled="@(sectionLoadingVisible || routeSaveLoadingVisible)">Convert independent colonies</button>
                    <button type="button" @onclick="() => LoadSectorConfigurationForm(sector)">Reset form</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(sectorConfigurationStatus))
                {
                    <p class="search-empty">@sectorConfigurationStatus</p>
                }
            </section>
            break;
        case "Hyperlanes":
            <section class="hyperlane-layout">
                <article class="feature-panel hyperlane-list-panel">
                    <span class="panel-kicker">Saved Hyperlanes</span>
                    <h2>@sector.Name</h2>
                    <p>Inspect the saved sector hyperlane cache, preserve manual links through regeneration, and review how many separate networks currently exist.</p>
                    <dl class="field-grid compact-field-grid hyperlane-network-summary">
                        <div><dt>Total saved</dt><dd>@savedHyperlanes.Count</dd></div>
                        <div><dt>Networks</dt><dd>@savedHyperlaneReport.DistinctNetworkCount</dd></div>
                        <div><dt>Connected systems</dt><dd>@savedHyperlaneReport.ConnectedSystemCount of @savedHyperlaneReport.EligibleSystemCount eligible</dd></div>
                        <div><dt>Stranded systems</dt><dd>@savedHyperlaneReport.StrandedSystemCount</dd></div>
                        <div><dt>Network sizes</dt><dd>@(savedHyperlaneReport.NetworkSizes.Count == 0 ? "None yet" : string.Join(", ", savedHyperlaneReport.NetworkSizes))</dd></div>
                        <div><dt>Manual preserve</dt><dd>@savedHyperlanes.Count(route => route.IsUserPersisted) user-persisted route@(savedHyperlanes.Count(route => route.IsUserPersisted) == 1 ? string.Empty : "s")</dd></div>
                    </dl>
                    <div class="parent-actions">
                        <button type="button" @onclick="() => StartNewHyperlane(sector)">Add hyperlane</button>
                        <button type="button" @onclick="SaveCurrentRoutesAsync" disabled="@(sectionLoadingVisible || routeSaveLoadingVisible)">
                            @(sector.SavedRoutes.Count == 0 ? "Save Generated Routes" : "Regenerate Non-Persisted Routes")
                        </button>
                    </div>
                    @if (savedHyperlanes.Count == 0)
                    {
                        <p class="notes-empty">No saved hyperlanes exist yet for this sector. You can add one manually or generate the current network from configuration.</p>
                    }
                    else
                    {
                        <div class="hyperlane-record-list">
                            <div class="timeline-count">Showing @visibleHyperlanes.Count saved hyperlane@(visibleHyperlanes.Count == 1 ? string.Empty : "s")@(hasMoreHyperlanes ? "+" : string.Empty)</div>
                            @foreach (var route in visibleHyperlanes)
                            {
                                var sourceSystem = sector.Systems.FirstOrDefault(system => system.Id == route.SourceSystemId);
                                var targetSystem = sector.Systems.FirstOrDefault(system => system.Id == route.TargetSystemId);
                                <button type="button"
                                        class="hyperlane-record @(route.Id == selectedHyperlaneId ? "active" : null)"
                                        @onclick="() => SelectHyperlane(sector, route.Id)">
                                    <strong>@(sourceSystem?.Name ?? $"System {route.SourceSystemId}") <span aria-hidden="true">&#8596;</span> @(targetSystem?.Name ?? $"System {route.TargetSystemId}")</strong>
                                    <small>TL@route.TechnologyLevel @route.TierName • @route.DistanceParsecs:0.### pc • @route.TravelTimeYears:0.###### years</small>
                                    <small>@FormatHyperlaneOwnerSummary(route)</small>
                                    @if (route.IsUserPersisted)
                                    {
                                        <span class="hyperlane-badge">User-persisted</span>
                                    }
                                </button>
                            }
                            @if (hasMoreHyperlanes)
                            {
                                <div @ref="hyperlaneLoadMoreElement" class="timeline-load-more">
                                    <button type="button" @onclick="LoadMoreHyperlanes">Load more</button>
                                </div>
                            }
                        </div>
                    }
                </article>

                <article class="detail-panel hyperlane-editor-panel">
                    <span class="panel-kicker">Hyperlane Editor</span>
                    <h2>@(selectedHyperlaneId > 0 ? "Edit saved hyperlane" : "Create saved hyperlane")</h2>
                    <p>Manual hyperlanes are stored in the database-backed sector cache. Mark a route as user-persisted to keep it intact when regeneration refreshes the rest of the sector.</p>
                    <div class="form-grid">
                        <label>
                            Source system
                            <select @bind="hyperlaneSourceSystemId">
                                @foreach (var system in sector.Systems.OrderBy(system => system.Name).ThenBy(system => system.Id))
                                {
                                    <option value="@system.Id">@system.Name (@system.Id)</option>
                                }
                            </select>
                        </label>
                        <label>
                            Target system
                            <select @bind="hyperlaneTargetSystemId">
                                @foreach (var system in sector.Systems.OrderBy(system => system.Name).ThenBy(system => system.Id))
                                {
                                    <option value="@system.Id">@system.Name (@system.Id)</option>
                                }
                            </select>
                        </label>
                        <label>
                            Technology level
                            <select @bind="hyperlaneTechnologyLevel">
                                @for (var tier = 6; tier <= 10; tier++)
                                {
                                    <option value="@tier">TL@tier</option>
                                }
                            </select>
                        </label>
                        <label>
                            Tier name
                            <input maxlength="80" @bind="hyperlaneTierName" />
                        </label>
                        <label>
                            Distance (parsecs)
                            <input type="number" min="0.001" step="0.001" @bind="hyperlaneDistanceParsecs" />
                        </label>
                        <label>
                            Travel time (years)
                            <input type="number" min="0.000001" step="0.000001" @bind="hyperlaneTravelTimeYears" />
                        </label>
                        <label>
                            Primary owner
                            <select @bind="hyperlanePrimaryOwnerEmpireId">
                                <option value="0">None</option>
                                @foreach (var empire in sectorEmpires.OrderBy(empire => empire.Name))
                                {
                                    <option value="@empire.Id">@empire.Name</option>
                                }
                            </select>
                        </label>
                        <label>
                            Secondary owner
                            <select @bind="hyperlaneSecondaryOwnerEmpireId">
                                <option value="0">None</option>
                                @foreach (var empire in sectorEmpires.OrderBy(empire => empire.Name))
                                {
                                    <option value="@empire.Id">@empire.Name</option>
                                }
                            </select>
                        </label>
                    </div>
                    <label class="switch-field hyperlane-persist-toggle">
                        <input type="checkbox" @bind="hyperlaneIsUserPersisted" />
                        <span>Keep this hyperlane unchanged during regeneration</span>
                    </label>
                    <div class="parent-actions">
                        <button type="button" @onclick="SaveHyperlaneAsync" disabled="@(sectionLoadingVisible || routeSaveLoadingVisible)">Save hyperlane</button>
                        <button type="button" @onclick="() => StartNewHyperlane(sector)">New draft</button>
                        <button type="button" @onclick="RecalculateHyperlaneTravelDefaults" disabled="@(hyperlaneSourceSystemId <= 0 || hyperlaneTargetSystemId <= 0)">Use sector travel defaults</button>
                        @if (selectedHyperlaneId > 0)
                        {
                            <button type="button" @onclick="DeleteSelectedHyperlaneAsync" disabled="@(sectionLoadingVisible || routeSaveLoadingVisible)">Delete hyperlane</button>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(hyperlaneStatus))
                    {
                        <p class="search-empty">@hyperlaneStatus</p>
                    }
                    @if (selectedHyperlane is not null)
                    {
                        <EntityNotesPanel TargetKind="EntityNoteTargetKind.HyperlaneRoute"
                                          TargetId="selectedHyperlane.Id"
                                          Title="Hyperlane notes" />
                    }
                    else
                    {
                        <p class="notes-empty">Save the hyperlane first if you want to attach notes to it.</p>
                    }
                </article>
            </section>
            break;
        case "Systems":
            <ExplorerSystemsSection SectorCache="sectorCache!"
                                    Empires="sectorEmpires"
                                    SectorId="@sector.Id"
                                    SelectedSystemId="@(selectedSystem?.Id ?? 0)"
                                    SystemSelected="SelectSystem">
                @if (selectedSystem is not null)
                {
                    <article class="detail-panel">
                        <span class="panel-kicker">System survey</span>
                        <EditableEntityName Name="@selectedSystem.Name"
                                            Label="System"
                                            NameSaved="name => SaveEntityNameAsync(EntityNoteTargetKind.StarSystem, selectedSystem.Id, name)" />
                        <dl class="field-grid">
                            <div><dt>System id</dt><dd>@selectedSystem.Id</dd></div>
                            <div><dt>Map code</dt><dd>@selectedSystem.MapCode</dd></div>
                            <div><dt>Allegiance</dt><dd>@DisplayAllegiance(selectedSystem.AllegianceId)</dd></div>
                            <div><dt>World count</dt><dd>@selectedSystem.Worlds.Count</dd></div>
                        </dl>

                        <EntityNotesPanel TargetKind="EntityNoteTargetKind.StarSystem"
                                          TargetId="selectedSystem.Id"
                                          Title="System notes" />

                        <div class="stellar-grid">
                            @foreach (var bodyItem in selectedSystem.AstralBodies.Select((body, index) => new { Body = body, Sequence = index }))
                            {
                                <article class="stellar-card">
                                    @RenderAstralBodyIcon(bodyItem.Body)
                                    <h3>@bodyItem.Body.Role</h3>
                                    @RenderImagePanel(EntityImageTargetKind.AstralBody, bodyItem.Body.Id, "Astral image", false)
                                    <dl class="data-list">
                                        <div><dt>Kind</dt><dd>@bodyItem.Body.Kind</dd></div>
                                        <div><dt>Type</dt><dd>@bodyItem.Body.Classification</dd></div>
                                        <div><dt>Luminosity</dt><dd>@Format(bodyItem.Body.Luminosity)</dd></div>
                                        <div><dt>Mass</dt><dd>@Format(bodyItem.Body.SolarMasses)</dd></div>
                                    </dl>

                                    <div class="satellite-list">
                                        <h4>Satellites</h4>
                                        @foreach (var satellite in GetAstralBodySatellites(selectedSystem, bodyItem.Sequence))
                                        {
                                            if (satellite.World is not null)
                                            {
                                                <button type="button" class="satellite-link" @onclick="() => SelectWorld(satellite.World.Id)">
                                                    <span>@satellite.Kind</span>
                                                    <strong>@satellite.Name</strong>
                                                </button>
                                            }
                                            else if (satellite.Habitat is not null)
                                            {
                                                <button type="button" class="satellite-link habitat" @onclick="() => SelectHabitat(satellite.Habitat.Id)">
                                                    <span>Habitat</span>
                                                    <strong>@satellite.Name</strong>
                                                </button>
                                            }
                                        }
                                        <div class="habitat-create-form">
                                            <input placeholder="Habitat name"
                                                   @bind="spaceHabitatName"
                                                   maxlength="160" />
                                            <select @bind="spaceHabitatEmpireId">
                                                <option value="0">Empire</option>
                                        @foreach (var empire in ExplorerEmpires.OrderBy(empire => empire.Name))
                                                {
                                                    <option value="@empire.Id">@empire.Name</option>
                                                }
                                            </select>
                                            <button type="button"
                                                    @onclick="() => CreateAstralBodySpaceHabitatAsync(selectedSystem, bodyItem.Sequence)"
                                                    disabled="@IsSpaceHabitatCreateDisabled">
                                                Create habitat
                                            </button>
                                            @if (!string.IsNullOrWhiteSpace(spaceHabitatStatus))
                                            {
                                                <p>@spaceHabitatStatus</p>
                                            }
                                        </div>
                                    </div>
                                </article>
                            }
                        </div>
                    </article>
                }
            </ExplorerSystemsSection>
            break;
        case "Worlds":
            <section class="content-grid">
                <div class="record-list">
                    <details class="record-filter-panel" open>
                        <summary class="record-filter-summary">Search</summary>
                        <label>
                            Search
                            <input placeholder="Name, type, atmosphere..."
                                   @bind="worldQuery"
                                   @bind:event="oninput"
                                   @bind:after="ResetWorldWindow" />
                        </label>
                        <label>
                            Kind
                            <select @bind="worldKind" @bind:after="ResetWorldWindow">
                                <option value="">All kinds</option>
                                <option value="@WorldKind.Planet.ToString()">Planets</option>
                                <option value="@WorldKind.Moon.ToString()">Moons</option>
                                <option value="SpaceHabitat">Habitats</option>
                            </select>
                        </label>
                        <button type="button" class="timeline-clear-button" @onclick="ToggleWorldFilters">
                            @(showWorldFilters ? "Hide filters" : "Show filters")
                        </button>
                        @if (showWorldFilters)
                        {
                            <label>
                                Type
                                <input list="world-type-options"
                                       placeholder="All types"
                                       @bind="worldType"
                                       @bind:event="oninput"
                                       @bind:after="ResetWorldWindow" />
                                <datalist id="world-type-options">
                                @foreach (var itemType in (selectedSystem?.Worlds.Select(world => world.WorldType) ?? []).Distinct().OrderBy(item => item))
                                {
                                    <option value="@itemType" />
                                }
                                </datalist>
                            </label>
                        }
                        <button type="button" class="timeline-clear-button" @onclick="ClearWorldFilters">Clear filters</button>
                    </details>
                    @{
                        var worldWindow = GetFilteredExplorerWorldRecords(selectedSystem)
                            .Take(worldVisibleCount + 1)
                            .ToList();
                        var hasMoreWorlds = worldWindow.Count > worldVisibleCount;
                        var visibleExplorerWorldRecords = worldWindow.Take(worldVisibleCount).ToList();
                        worldHasMoreRecords = hasMoreWorlds;
                    }
                    <div class="timeline-count">Showing @visibleExplorerWorldRecords.Count world@(visibleExplorerWorldRecords.Count == 1 ? string.Empty : "s")@(hasMoreWorlds ? "+" : string.Empty)</div>
                    @if (visibleExplorerWorldRecords.Count == 0)
                    {
                        <article class="timeline-event-card">
                            <span class="timeline-century">No matches</span>
                            <p>Adjust the filters to widen the world list.</p>
                        </article>
                    }
                    @foreach (var record in visibleExplorerWorldRecords)
                    {
                        if (record.World is not null)
                        {
                            var world = record.World;
                            <button type="button" class="record-row @(selectedWorld?.Id == world.Id ? "active" : null)" @onclick="() => SelectWorld(world.Id)">
                                <strong>@world.Name</strong>
                                <span>@world.Kind; @world.WorldType</span>
                            </button>
                        }
                        else if (record.Habitat is not null)
                        {
                            var habitat = record.Habitat;
                            <button type="button" class="record-row @(selectedHabitat?.Id == habitat.Id ? "active" : null)" @onclick="() => SelectHabitat(habitat.Id)">
                                <strong>@habitat.Name</strong>
                                <span>Space Habitat; @DisplayPopulation(habitat.Population)</span>
                            </button>
                        }
                    }
                    @if (hasMoreWorlds)
                    {
                        <div @ref="worldLoadMoreElement" class="timeline-load-more">
                            <button type="button" @onclick="LoadMoreWorlds">Load more</button>
                        </div>
                    }
                </div>

                @if (selectedHabitat is not null)
                {
                    <article class="detail-panel world-detail">
                        @RenderEntityOrb(EntityImageTargetKind.SpaceHabitat, selectedHabitat.Id, "world-orb habitat", selectedHabitat.Name)
                        <span class="panel-kicker">Space habitat</span>
                        <h2>@selectedHabitat.Name</h2>
                        @RenderImagePanel(EntityImageTargetKind.SpaceHabitat, selectedHabitat.Id, "Habitat image", false)
                        <div class="parent-actions">
                            <button type="button" @onclick="() => SelectParentOfHabitat(selectedHabitat)">Parent: @DisplayOrbitTarget(selectedSystem, selectedHabitat)</button>
                        </div>
                        <dl class="field-grid">
                            <div><dt>Habitat id</dt><dd>@selectedHabitat.Id</dd></div>
                            <div><dt>Population</dt><dd>@DisplayPopulation(selectedHabitat.Population)</dd></div>
                            <div><dt>Orbit target</dt><dd>@DisplayOrbitTarget(selectedSystem, selectedHabitat)</dd></div>
                            <div><dt>Orbit radius</dt><dd>@DisplayNullable(selectedHabitat.OrbitRadiusKm, " km")</dd></div>
                            <div><dt>Built by</dt><dd>@DisplayEmpire(selectedHabitat.BuiltByEmpireId)</dd></div>
                            <div><dt>Controlled by</dt><dd>@DisplayEmpire(selectedHabitat.ControlledByEmpireId)</dd></div>
                            <div><dt>Constructed</dt><dd>@DisplayNullable(selectedHabitat.ConstructedCentury, " century")</dd></div>
                        </dl>

                        <div class="satellite-panel">
                            <h3>Satellites</h3>
                            <p>Space habitats are world records, but they cannot have satellites.</p>
                        </div>
                    </article>
                }
                else if (selectedWorld is not null)
                {
                    <article class="detail-panel world-detail">
                        @RenderEntityOrb(EntityImageTargetKind.World, selectedWorld.Id, $"world-orb {selectedWorld.WorldType.ToLowerInvariant()}", selectedWorld.Name)
                        <span class="panel-kicker">@selectedWorld.Kind survey</span>
                        <EditableEntityName Name="@selectedWorld.Name"
                                            Label="World"
                                            NameSaved="name => SaveEntityNameAsync(EntityNoteTargetKind.World, selectedWorld.Id, name)" />
                        @RenderImagePanel(EntityImageTargetKind.World, selectedWorld.Id, "World image", false)
                        <div class="parent-actions">
                            @if (selectedWorld.ParentWorldId is int parentWorldId
                                                    && selectedSystem?.Worlds.FirstOrDefault(world => world.Id == parentWorldId) is World parentWorld)
                            {
                                <button type="button" @onclick="() => SelectWorld(parentWorld.Id)">Parent world: @parentWorld.Name</button>
                            }
                            else if (selectedSystem is not null)
                            {
                                <button type="button" @onclick="OpenSelectedSystemRecord">Parent astral body: @DisplayAstralBody(selectedSystem, selectedWorld.PrimaryAstralBodySequence ?? 0)</button>
                            }
                        </div>
                        <dl class="field-grid">
                            <div><dt>World type</dt><dd>@selectedWorld.WorldType</dd></div>
                            <div><dt>Orbit</dt><dd>@DisplayOrbit(selectedWorld)</dd></div>
                            <div><dt>Diameter</dt><dd>@selectedWorld.DiameterKm km</dd></div>
                            <div><dt>Gravity</dt><dd>@Format(selectedWorld.GravityEarthG) g</dd></div>
                            <div><dt>Mass</dt><dd>@Format(selectedWorld.MassEarthMasses)</dd></div>
                            <div><dt>Escape velocity</dt><dd>@Format(selectedWorld.EscapeVelocityKmPerSecond) km/s</dd></div>
                            <div><dt>Atmosphere</dt><dd>@selectedWorld.AtmosphereType</dd></div>
                            <div><dt>Composition</dt><dd>@selectedWorld.AtmosphereComposition</dd></div>
                            <div><dt>Pressure</dt><dd>@selectedWorld.AtmosphericPressure atm</dd></div>
                            <div><dt>Water</dt><dd>@selectedWorld.WaterType</dd></div>
                            <div><dt>Ice</dt><dd>@selectedWorld.Hydrography.IcePercent%</dd></div>
                            <div><dt>Clouds</dt><dd>@selectedWorld.Hydrography.CloudPercent%</dd></div>
                            <div><dt>Average temp</dt><dd>@selectedWorld.AverageTemperatureCelsius C</dd></div>
                            <div><dt>Boiling point</dt><dd>@DisplayNullable(selectedWorld.BoilingPointCelsius, " C")</dd></div>
                            <div><dt>Magnetic field</dt><dd>@DisplayNullable(selectedWorld.MagneticFieldGauss, " gauss")</dd></div>
                        </dl>

                        <EntityNotesPanel TargetKind="EntityNoteTargetKind.World"
                                          TargetId="selectedWorld.Id"
                                          Title="World notes" />

                        <div class="tag-group">
                            @if (selectedWorld.UnusualCharacteristics.Count == 0)
                            {
                                <span>Standard survey profile</span>
                            }
                            @foreach (var item in selectedWorld.UnusualCharacteristics)
                            {
                                <span>@item.Name</span>
                            }
                        </div>

                        <div class="satellite-panel">
                            <h3>Satellites</h3>
                            @{
                                var worldSatellites = GetWorldSatellites(selectedSystem, selectedWorld).ToList();
                            }
                            @if (worldSatellites.Count == 0)
                            {
                                <p>No satellites recorded.</p>
                            }
                            @foreach (var satellite in worldSatellites)
                            {
                                if (satellite.World is not null)
                                {
                                    <button type="button" class="satellite-link" @onclick="() => SelectWorld(satellite.World.Id)">
                                        <span>@satellite.Kind</span>
                                        <strong>@satellite.Name</strong>
                                    </button>
                                }
                                else if (satellite.Habitat is not null)
                                {
                                    <button type="button" class="satellite-link habitat" @onclick="() => SelectHabitat(satellite.Habitat.Id)">
                                        <span>Habitat</span>
                                        <strong>@satellite.Name</strong>
                                    </button>
                                }
                            }
                            <div class="habitat-create-form">
                                <input placeholder="Habitat name"
                                       @bind="spaceHabitatName"
                                       maxlength="160" />
                                <select @bind="spaceHabitatEmpireId">
                                    <option value="0">Empire</option>
                                        @foreach (var empire in ExplorerEmpires.OrderBy(empire => empire.Name))
                                    {
                                        <option value="@empire.Id">@empire.Name</option>
                                    }
                                </select>
                                <button type="button"
                                        @onclick="() => CreateWorldSpaceHabitatAsync(selectedWorld)"
                                        disabled="@IsSpaceHabitatCreateDisabled">
                                    Create habitat
                                </button>
                                @if (!string.IsNullOrWhiteSpace(spaceHabitatStatus))
                                {
                                    <p>@spaceHabitatStatus</p>
                                }
                            </div>
                        </div>
                    </article>
                }
            </section>
            break;
        case "Colonies":
            <section class="content-grid">
                <div class="record-list colony-record-list">
                    <details class="record-filter-panel" open>
                        <summary class="record-filter-summary">Search</summary>
                        <label>
                            Search
                            <input placeholder="World, class, race, empire..."
                                   @bind="colonyQuery"
                                   @bind:event="oninput"
                                   @bind:after="ResetColonyWindow" />
                        </label>
                        <button type="button" class="timeline-clear-button" @onclick="ToggleColonyFilters">
                            @(showColonyFilters ? "Hide filters" : "Show filters")
                        </button>
                        @if (showColonyFilters)
                        {
                            <label>
                                Race
                                <input list="colony-race-options"
                                       placeholder="All races"
                                       @bind="colonyRaceText"
                                       @bind:event="oninput"
                                       @bind:after="ApplyColonyRaceFilter" />
                                <datalist id="colony-race-options">
                                    @foreach (var race in sectorRaces)
                                    {
                                        <option value="@FormatRaceOption(race)" />
                                    }
                                </datalist>
                            </label>
                            <label>
                                Allegiance
                                <input list="colony-empire-options"
                                       placeholder="All allegiances"
                                       @bind="colonyEmpireText"
                                       @bind:event="oninput"
                                       @bind:after="ApplyColonyEmpireFilter" />
                                <datalist id="colony-empire-options">
                                    @foreach (var empire in sectorEmpires)
                                    {
                                        <option value="@FormatEmpireOption(empire)" />
                                    }
                                </datalist>
                            </label>
                            <label>
                                Status
                                <select @bind="colonyStatus" @bind:after="ResetColonyWindow">
                                    <option value="">All statuses</option>
                                    @foreach (var status in Enum.GetValues<ColonyPoliticalStatus>())
                                    {
                                        <option value="@status.ToString()">@status</option>
                                    }
                                </select>
                            </label>
                            <label>
                                Class
                                <input list="colony-class-options"
                                       placeholder="All classes"
                                       @bind="colonyClass"
                                       @bind:event="oninput"
                                       @bind:after="ResetColonyWindow" />
                                <datalist id="colony-class-options">
                                    @foreach (var itemClass in sectorColonies.Select(item => item.Colony.ColonyClass).Distinct().OrderBy(item => item))
                                    {
                                        <option value="@itemClass" />
                                    }
                                </datalist>
                            </label>
                        }
                        <button type="button" class="timeline-clear-button" @onclick="ClearColonyFilters">Clear filters</button>
                    </details>
                    @{
                        var colonyWindow = GetFilteredColonies(sectorCache!)
                            .Take(colonyVisibleCount + 1)
                            .ToList();
                        var hasMoreColonies = colonyWindow.Count > colonyVisibleCount;
                        var visibleColonies = colonyWindow
                            .Take(colonyVisibleCount)
                            .ToList();
                        colonyHasMoreRecords = hasMoreColonies;
                    }
                    <div class="timeline-count">Showing @visibleColonies.Count colon@(visibleColonies.Count == 1 ? "y" : "ies")@(hasMoreColonies ? "+" : string.Empty)</div>
                    @if (visibleColonies.Count == 0)
                    {
                        <article class="timeline-event-card">
                            <span class="timeline-century">No matches</span>
                            <p>Adjust the filters to widen the colony list.</p>
                        </article>
                    }
                    @foreach (var item in visibleColonies)
                    {
                        <button type="button" class="record-row @(selectedColony?.Id == item.Colony.Id ? "active" : null)" @onclick="() => SelectColony(item.World.Id)">
                                    <strong>@DisplayColonyName(item.Colony) on @item.World.Name</strong>
                            <span>@item.Colony.AllegianceName; @DisplayPopulation(item.Colony.EstimatedPopulation)</span>
                        </button>
                    }
                    @if (hasMoreColonies)
                    {
                        <div @ref="colonyLoadMoreElement" class="timeline-load-more">
                            <button type="button" @onclick="LoadMoreColonies">Load more</button>
                        </div>
                    }
                </div>

                @if (selectedColony is not null)
                {
                    <article class="detail-panel">
                        <span class="panel-kicker">Colony record</span>
                        <EditableEntityName Name="@DisplayColonyName(selectedColony)"
                                            Label="Colony"
                                            NameSaved="name => SaveEntityNameAsync(EntityNoteTargetKind.Colony, selectedColony.Id, name)" />
                        @RenderImagePanel(EntityImageTargetKind.Colony, selectedColony.Id, "Colony images", true)
                        @if (selectedColonyWorld is not null)
                        {
                            <div class="parent-actions">
                                <button type="button" @onclick="() => SelectWorld(selectedColonyWorld.Id)">Parent world: @selectedColonyWorld.Name</button>
                            </div>
                        }
                        <dl class="field-grid">
                            <div><dt>Colony id</dt><dd>@selectedColony.Id</dd></div>
                            <div><dt>World id</dt><dd>@selectedColony.WorldId</dd></div>
                            <div><dt>Race</dt><dd>@selectedColony.ColonistRaceName</dd></div>
                            <div><dt>Allegiance</dt><dd>@selectedColony.AllegianceName</dd></div>
                            <div><dt>Status</dt><dd>@selectedColony.PoliticalStatus</dd></div>
                            <div><dt>Population</dt><dd>@DisplayPopulation(selectedColony.EstimatedPopulation)</dd></div>
                            <div><dt>Natives</dt><dd>@selectedColony.NativePopulationPercent%</dd></div>
                            <div><dt>Starport</dt><dd>@selectedColony.Starport</dd></div>
                            <div><dt>GWP</dt><dd>@selectedColony.GrossWorldProductMcr MCr</dd></div>
                            <div><dt>Military</dt><dd>@selectedColony.MilitaryPower</dd></div>
                            <div><dt>Major export</dt><dd>@selectedColony.ExportResource</dd></div>
                            <div><dt>Major import</dt><dd>@selectedColony.ImportResource</dd></div>
                            <div><dt>Law</dt><dd>@selectedColony.Law</dd></div>
                            <div><dt>Stability</dt><dd>@selectedColony.Stability</dd></div>
                            <div><dt>Crime</dt><dd>@selectedColony.Crime</dd></div>
                        </dl>

                        <EntityNotesPanel TargetKind="EntityNoteTargetKind.Colony"
                                          TargetId="selectedColony.Id"
                                          Title="Colony notes" />

                        <section class="relationship-section">
                            <h3>Demographics</h3>
                            <div class="demographic-list">
                                @foreach (var demographic in selectedColony.Demographics.OrderByDescending(item => item.PopulationPercent))
                                {
                                    <button type="button" class="demographic-row" @onclick="() => SelectRace(demographic.RaceId)">
                                        <span>@demographic.RaceName</span>
                                        <strong>@($"{demographic.PopulationPercent:0.#}%")</strong>
                                        <em style="width: @($"{demographic.PopulationPercent:0.##}%")"></em>
                                        <small>@DisplayPopulation(GetDemographicPopulation(selectedColony, demographic))</small>
                                    </button>
                                }
                            </div>
                        </section>
                    </article>
                }
            </section>
            break;
        case "Aliens":
            <section class="content-grid">
                <div class="record-list">
                    <details class="record-filter-panel" open>
                        <summary class="record-filter-summary">Search</summary>
                        <label>
                            Search
                            <input placeholder="Name, biology, traits..."
                                   @bind="raceQuery"
                                   @bind:event="oninput"
                                   @bind:after="ResetRaceWindow" />
                        </label>
                        <button type="button" class="timeline-clear-button" @onclick="ToggleRaceFilters">
                            @(showRaceFilters ? "Hide filters" : "Show filters")
                        </button>
                        @if (showRaceFilters)
                        {
                            <label>
                                Environment
                                <input list="race-environment-options"
                                       placeholder="All environments"
                                       @bind="raceEnvironment"
                                       @bind:event="oninput"
                                       @bind:after="ResetRaceWindow" />
                                <datalist id="race-environment-options">
                                    @foreach (var environment in sectorRaces.Select(race => race.EnvironmentType).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct().OrderBy(value => value))
                                    {
                                        <option value="@environment" />
                                    }
                                </datalist>
                            </label>
                            <label>
                                Appearance
                                <input list="race-appearance-options"
                                       placeholder="All appearances"
                                       @bind="raceAppearance"
                                       @bind:event="oninput"
                                       @bind:after="ResetRaceWindow" />
                                <datalist id="race-appearance-options">
                                    @foreach (var appearance in sectorRaces.Select(race => race.AppearanceType).Where(value => !string.IsNullOrWhiteSpace(value)).Distinct().OrderBy(value => value))
                                    {
                                        <option value="@appearance" />
                                    }
                                </datalist>
                            </label>
                        }
                        <button type="button" class="timeline-clear-button" @onclick="ClearRaceFilters">Clear filters</button>
                    </details>
                    @{
                        var raceWindow = GetFilteredRaces(sectorRaces)
                            .Take(raceVisibleCount + 1)
                            .ToList();
                        var hasMoreRaces = raceWindow.Count > raceVisibleCount;
                        var visibleRaces = raceWindow.Take(raceVisibleCount).ToList();
                        raceHasMoreRecords = hasMoreRaces;
                    }
                    <div class="timeline-count">Showing @visibleRaces.Count race@(visibleRaces.Count == 1 ? string.Empty : "s")@(hasMoreRaces ? "+" : string.Empty)</div>
                    @if (visibleRaces.Count == 0)
                    {
                        <article class="timeline-event-card">
                            <span class="timeline-century">No matches</span>
                            <p>Adjust the filters to widen the race list.</p>
                        </article>
                    }
                    @foreach (var race in visibleRaces)
                    {
                            <button type="button" class="record-row @(selectedRace?.Id == race.Id ? "active" : null)" @onclick="() => SelectRace(race.Id)">
                            <strong>@race.Name</strong>
                            <span>@race.AppearanceType; @race.EnvironmentType</span>
                        </button>
                    }
                    @if (hasMoreRaces)
                    {
                        <div @ref="raceLoadMoreElement" class="timeline-load-more">
                            <button type="button" @onclick="LoadMoreRaces">Load more</button>
                        </div>
                    }
                </div>

                @if (selectedRace is not null)
                {
                    var gurpsTemplate = BuildGurpsTemplate(selectedRace);
                    var homeWorld = FindWorld(selectedRace.HomePlanetId);
                    var raceMemberships = GetRaceEmpireMemberships(selectedRace, sectorEmpires).ToList();
                    var raceHighlights = GetRaceHighlights(selectedRace).ToList();
                    <article class="detail-panel alien-detail-panel">
                        <span class="panel-kicker">Alien biology</span>
                        <EditableEntityName Name="@selectedRace.Name"
                                            Label="Race"
                                            NameSaved="name => SaveEntityNameAsync(EntityNoteTargetKind.AlienRace, selectedRace.Id, name)" />
                        <div class="alien-overview-grid">
                            <section class="alien-summary-card alien-summary-card-primary">
                                <div class="parent-actions">
                                    @if (homeWorld is not null)
                                    {
                                        <button type="button" @onclick="() => SelectWorld(homeWorld.Id)">Homeworld: @homeWorld.Name</button>
                                    }
                                </div>
                                <dl class="field-grid alien-field-grid alien-field-grid-primary">
                                    <div><dt>Appearance</dt><dd>@DisplayText(selectedRace.AppearanceType)</dd></div>
                                    <div><dt>Environment</dt><dd>@DisplayText(selectedRace.EnvironmentType)</dd></div>
                                    <div><dt>Biology</dt><dd>@DisplayText(selectedRace.BodyChemistry)</dd></div>
                                    <div><dt>Body cover</dt><dd>@DisplayText(selectedRace.BodyCoverType)</dd></div>
                                    <div><dt>Mass</dt><dd>@selectedRace.MassKg kg</dd></div>
                                    <div><dt>Size</dt><dd>@selectedRace.SizeCm cm</dd></div>
                                    <div><dt>Limb pairs</dt><dd>@selectedRace.LimbPairCount</dd></div>
                                    <div><dt>Lifespan</dt><dd>@selectedRace.BiologyProfile.Lifespan</dd></div>
                                    <div><dt>Body</dt><dd>@selectedRace.BiologyProfile.Body</dd></div>
                                    <div><dt>Mind</dt><dd>@selectedRace.BiologyProfile.Mind</dd></div>
                                    <div><dt>Speed</dt><dd>@selectedRace.BiologyProfile.Speed</dd></div>
                                    <div><dt>Psi</dt><dd>@selectedRace.BiologyProfile.PsiRating</dd></div>
                                </dl>
                                @if (raceHighlights.Count > 0)
                                {
                                    <div class="tag-group alien-tag-group">
                                        @foreach (var highlight in raceHighlights)
                                        {
                                            <span>@highlight</span>
                                        }
                                    </div>
                                }
                            </section>

                            @RenderImagePanel(EntityImageTargetKind.AlienRace, selectedRace.Id, "Race images", true, compactWhenEmpty: true, panelClass: "alien-image-panel")
                        </div>

                        <div class="alien-secondary-grid">
                            <section class="alien-summary-card">
                                <h3>Society</h3>
                                <dl class="field-grid alien-field-grid">
                                    <div><dt>Government</dt><dd>@DisplayText(selectedRace.GovernmentType)</dd></div>
                                    <div><dt>Diet</dt><dd>@DisplayText(selectedRace.Diet)</dd></div>
                                    <div><dt>Faith</dt><dd>@DisplayText(selectedRace.Religion)</dd></div>
                                    <div><dt>Devotion</dt><dd>@selectedRace.DevotionLevel</dd></div>
                                    <div><dt>Reproduction</dt><dd>@DisplayText(selectedRace.Reproduction)</dd></div>
                                    <div><dt>Method</dt><dd>@DisplayText(selectedRace.ReproductionMethod)</dd></div>
                                </dl>
                            </section>

                            <section class="alien-summary-card">
                                <h3>Derived data</h3>
                                <dl class="field-grid alien-field-grid">
                                    <div><dt>Edition</dt><dd>@DisplayGurpsEdition(gurpsTemplate.Edition)</dd></div>
                                    <div><dt>Total cost</dt><dd>@DisplayPoints(gurpsTemplate.TotalPointCost)</dd></div>
                                    <div><dt>Trait entries</dt><dd>@CountGurpsTraits(gurpsTemplate)</dd></div>
                                    <div><dt>Memberships</dt><dd>@raceMemberships.Count</dd></div>
                                    <div><dt>Source</dt><dd>StarWin conversion</dd></div>
                                </dl>
                                @if (!string.IsNullOrWhiteSpace(gurpsTemplate.Notes))
                                {
                                    <p>@gurpsTemplate.Notes</p>
                                }
                            </section>
                        </div>

                        <details class="alien-disclosure-card" @(raceMemberships.Count > 0 ? null : "open")>
                            <summary>Empire memberships <span>@raceMemberships.Count</span></summary>
                            @if (raceMemberships.Count == 0)
                            {
                                <p class="alien-empty-state">No empire memberships in this sector.</p>
                            }
                            else
                            {
                                <div class="relationship-list">
                                    @foreach (var membership in raceMemberships)
                                    {
                                        <button type="button" class="relationship-row" @onclick="() => SelectEmpire(membership.Empire.Id)">
                                            <strong>@membership.Empire.Name</strong>
                                            <span>@membership.Membership.Role; @membership.Membership.PopulationMillions million</span>
                                        </button>
                                    }
                                </div>
                            }
                        </details>

                        <details class="alien-disclosure-card">
                            <summary>Notes</summary>
                            <EntityNotesPanel TargetKind="EntityNoteTargetKind.AlienRace"
                                              TargetId="selectedRace.Id"
                                              Title="Alien notes" />
                        </details>

                        <details class="alien-disclosure-card">
                            <summary>GURPS template <span>@CountGurpsTraits(gurpsTemplate) entries</span></summary>
                            <div class="alien-gurps-body">
                                @if (!string.IsNullOrWhiteSpace(gurpsTemplate.Notes))
                                {
                                    <p>@gurpsTemplate.Notes</p>
                                }
                                <div class="gurps-grid">
                                    @RenderGurpsTraitGroup("Attributes", gurpsTemplate.AttributeModifiers)
                                    @RenderGurpsTraitGroup("Secondary", gurpsTemplate.SecondaryCharacteristicModifiers)
                                    @RenderGurpsTraitGroup("Advantages", gurpsTemplate.Advantages)
                                    @RenderGurpsTraitGroup("Disadvantages", gurpsTemplate.Disadvantages)
                                    @RenderGurpsTraitGroup("Quirks", gurpsTemplate.Quirks)
                                    @RenderGurpsTraitGroup("Features", gurpsTemplate.Features)
                                    @RenderGurpsTraitGroup("Skills", gurpsTemplate.Skills)
                                </div>
                            </div>
                        </details>
                    </article>
                }
            </section>
            break;
        case "Empires":
            <section class="content-grid">
                <div class="record-list">
                    <details class="record-filter-panel" open>
                        <summary class="record-filter-summary">Search</summary>
                        <label>
                            Search
                            <input placeholder="Name, policy, homeworld..."
                                   @bind="empireQuery"
                                   @bind:event="oninput"
                                   @bind:after="ResetEmpireWindow" />
                        </label>
                        <button type="button" class="timeline-clear-button" @onclick="ToggleEmpireFilters">
                            @(showEmpireFilters ? "Hide filters" : "Show filters")
                        </button>
                        @if (showEmpireFilters)
                        {
                            <label>
                                Race
                                <input list="empire-race-options"
                                       placeholder="All races"
                                       @bind="empireRaceText"
                                       @bind:event="oninput"
                                       @bind:after="ApplyEmpireRaceFilter" />
                                <datalist id="empire-race-options">
                                    @foreach (var race in sectorRaces)
                                    {
                                        <option value="@FormatRaceOption(race)" />
                                    }
                                </datalist>
                            </label>
                        }
                        <button type="button" class="timeline-clear-button" @onclick="ClearEmpireFilters">Clear filters</button>
                    </details>
                    @{
                        var empireWindow = GetFilteredEmpires(sectorEmpires)
                            .Take(empireVisibleCount + 1)
                            .ToList();
                        var hasMoreEmpires = empireWindow.Count > empireVisibleCount;
                        var visibleEmpires = empireWindow.Take(empireVisibleCount).ToList();
                        empireHasMoreRecords = hasMoreEmpires;
                    }
                    <div class="timeline-count">Showing @visibleEmpires.Count empire@(visibleEmpires.Count == 1 ? string.Empty : "s")@(hasMoreEmpires ? "+" : string.Empty)</div>
                    @if (visibleEmpires.Count == 0)
                    {
                        <article class="timeline-event-card">
                            <span class="timeline-century">No matches</span>
                            <p>Adjust the filters to widen the empire list.</p>
                        </article>
                    }
                    @foreach (var empire in visibleEmpires)
                    {
                        var empireIsFallen = IsFallenEmpire(empire, sector);
                        <button type="button" class="record-row @(selectedEmpire?.Id == empire.Id ? "active" : null) @(empireIsFallen ? "fallen" : null)" @onclick="() => SelectEmpire(empire.Id)">
                            <strong class="record-row-title">
                                <span>@empire.Name</span>
                                @if (empireIsFallen)
                                {
                                    <span class="empire-status fallen">Fallen empire</span>
                                }
                            </strong>
                            <span>@(empireIsFallen ? "No controlled colonies; former holdings conquered" : $"GURPS TL {GetGurpsTechLevel(empire)}; {empire.Planets} planets")</span>
                        </button>
                    }
                    @if (hasMoreEmpires)
                    {
                        <div @ref="empireLoadMoreElement" class="timeline-load-more">
                            <button type="button" @onclick="LoadMoreEmpires">Load more</button>
                        </div>
                    }
                </div>

                @if (selectedEmpire is not null)
                {
                    <article class="detail-panel">
                        <span class="panel-kicker">Empire profile</span>
                        <EditableEntityName Name="@selectedEmpire.Name"
                                            Label="Empire"
                                            NameSaved="name => SaveEntityNameAsync(EntityNoteTargetKind.Empire, selectedEmpire.Id, name)" />
                        @RenderImagePanel(EntityImageTargetKind.Empire, selectedEmpire.Id, "Empire flag", false)
                        @{
                            var empireHomeworld = FindWorld(selectedEmpire.Founding.FoundingWorldId);
                            var capitalColony = GetCapitalColony(selectedEmpire);
                            var empireColonies = GetEmpireColonies(selectedEmpire, sector).ToList();
                            var empireControlledColonies = GetControlledEmpireColonies(selectedEmpire, sector).ToList();
                            var selectedEmpireIsFallen = IsFallenEmpire(selectedEmpire, sector);
                        }
                        @if (selectedEmpireIsFallen)
                        {
                            <div class="empire-alert fallen">
                                <strong>Fallen empire</strong>
                                <span>This empire no longer controls any colonies in this sector.</span>
                            </div>
                        }
                        <div class="parent-actions">
                            @if (empireHomeworld is not null)
                            {
                                <button type="button" @onclick="() => SelectWorld(empireHomeworld.Id)">Homeworld: @empireHomeworld.Name</button>
                            }
                            @if (capitalColony is not null)
                            {
                                <button type="button" @onclick="() => SelectColony(capitalColony.World.Id)">Capital: @capitalColony.World.Name</button>
                            }
                        </div>
                        <dl class="field-grid">
                            <div><dt>Status</dt><dd>@(selectedEmpireIsFallen ? "Fallen empire" : "Active empire")</dd></div>
                            <div><dt>Controlled colonies</dt><dd>@empireControlledColonies.Count</dd></div>
                            <div><dt>Tech level</dt><dd>GURPS TL @GetGurpsTechLevel(selectedEmpire) / StarWin @selectedEmpire.CivilizationProfile.TechLevel</dd></div>
                            <div><dt>Military power</dt><dd>@selectedEmpire.MilitaryPower</dd></div>
                            <div><dt>Economic power</dt><dd>@selectedEmpire.EconomicPowerMcr MCr</dd></div>
                            <div><dt>Trade bonus</dt><dd>@selectedEmpire.TradeBonusMcr MCr</dd></div>
                            <div><dt>Planets</dt><dd>@selectedEmpire.Planets</dd></div>
                            <div><dt>Moons</dt><dd>@selectedEmpire.Moons</dd></div>
                            <div><dt>Captive planets</dt><dd>@selectedEmpire.CaptivePlanets</dd></div>
                            <div><dt>Space habitats</dt><dd>@selectedEmpire.SpaceHabitats</dd></div>
                            <div><dt>Native population</dt><dd>@selectedEmpire.NativePopulationMillions million</dd></div>
                            <div><dt>Captive population</dt><dd>@selectedEmpire.CaptivePopulationMillions million</dd></div>
                            <div><dt>Expansion</dt><dd>@selectedEmpire.ExpansionPolicy</dd></div>
                        </dl>

                        <EntityNotesPanel TargetKind="EntityNoteTargetKind.Empire"
                                          TargetId="selectedEmpire.Id"
                                          Title="Empire notes" />

                        <div class="force-grid">
                            <article>
                                <h3>Fleet</h3>
                                @foreach (var ship in selectedEmpire.MilitaryForces.Fleet)
                                {
                                    <div class="inline-row"><span>@ship.Quantity @ship.Name</span><strong>@ship.Code</strong></div>
                                }
                            </article>
                            <article>
                                <h3>Ground forces</h3>
                                @foreach (var force in selectedEmpire.MilitaryForces.GroundForces)
                                {
                                    <div class="inline-row"><span>@force.Name</span><strong>@force.Quantity</strong></div>
                                }
                            </article>
                        </div>

                        <section class="relationship-section">
                            <h3>Member races</h3>
                            <div class="relationship-list">
                                @foreach (var membership in selectedEmpire.RaceMemberships
                                                        .Where(item => sectorRaceIds.Contains(item.RaceId))
                                                        .OrderByDescending(item => item.IsPrimary)
                                                        .ThenBy(item => item.RaceId))
                                {
                                    <button type="button" class="relationship-row" @onclick="() => SelectRace(membership.RaceId)">
                                        <strong>@DisplayRace(membership.RaceId)</strong>
                                        <span>@membership.Role; @membership.PopulationMillions million</span>
                                    </button>
                                }
                            </div>
                        </section>

                        <section class="relationship-section">
                            <h3>Colonies</h3>
                            <div class="relationship-list">
                                @foreach (var listing in empireColonies)
                                {
                                    <button type="button" class="relationship-row" @onclick="() => SelectColony(listing.World.Id)">
                                                <strong>@DisplayColonyName(listing.Colony) on @listing.World.Name</strong>
                                        <span>@listing.System.Name; @DisplayPopulation(listing.Colony.EstimatedPopulation)</span>
                                    </button>
                                }
                            </div>
                        </section>
                    </article>
                }
            </section>
            break;
    }
</section>

@if (routeSaveLoadingVisible)
{
    <div class="loading-modal-backdrop" role="status" aria-live="polite" aria-label="Saving current routes">
        <section class="loading-modal">
            <span class="panel-kicker">Saving current routes</span>
            <h2>@routeSaveLoadingStatus</h2>
            <LoadingElapsedTime IsVisible="@routeSaveLoadingVisible" />
            @if (!string.IsNullOrWhiteSpace(routeSaveLoadingDetail))
            {
                <p class="loading-progress-detail">@routeSaveLoadingDetail</p>
            }
            @if (routeSaveProcessedItems is int processedItems && routeSaveTotalItems is int totalItems && totalItems > 0)
            {
                <strong class="loading-progress-value">@processedItems / @totalItems systems processed</strong>
            }
            <div class="loading-meter import-progress-meter" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="@routeSaveLoadingPercent">
                <span style="width: @routeSaveLoadingPercent%;"></span>
            </div>
            <strong class="loading-progress-value">@routeSaveLoadingPercent%</strong>
            <ol>
                <li>Load the current sector and empire data.</li>
                <li>Generate exactly one route per system pair.</li>
                <li>Write the refreshed route cache to the database.</li>
            </ol>
        </section>
    </div>
}

@if (mapContextRefreshing)
{
    var mapContextLoadingLabel = Workspace.IsLoaded ? "Refreshing map context" : "Loading map context";
    var mapContextLoadingStatus = Workspace.IsLoaded
        ? "Refreshing the cached 3D sector map data."
        : "Loading the cached 3D sector map data for the first time.";

    <div class="loading-modal-backdrop" role="status" aria-live="polite" aria-label="@mapContextLoadingLabel">
        <section class="loading-modal">
            <span class="panel-kicker">@mapContextLoadingLabel</span>
            <h2>@mapContextLoadingStatus</h2>
            <LoadingElapsedTime IsVisible="@mapContextRefreshing" />
            @if (!string.IsNullOrWhiteSpace(mapContextStatus))
            {
                <p class="loading-progress-detail">@mapContextStatus</p>
            }
            <div class="loading-meter" aria-hidden="true">
                <span></span>
            </div>
            <ol>
                <li>Load the current sector cache from the database.</li>
                <li>Refresh system, route, and civilization references for the map.</li>
                <li>Prepare the 3D map so the selected sector can render.</li>
            </ol>
        </section>
    </div>
}

