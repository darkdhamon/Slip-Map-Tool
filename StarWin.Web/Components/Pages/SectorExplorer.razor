@layout SectorExplorerLayout
@page "/sector-explorer"
@rendermode InteractiveServer
@inject IStarWinWorkspace Workspace
@inject IStarWinExplorerContextService ExplorerContextService
@inject IStarWinExplorerQueryService ExplorerQueryService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@using Microsoft.AspNetCore.WebUtilities
@using StarWin.Domain.Services

@{
    var explorerSelectionReady = selectedSectorId > 0;
    var sector = GetSelectedSector();
    var overviewData = explorerSelectionReady ? GetSectorOverviewData(sector.Id) : null;
    RenderFragment heroContent = @<ExplorerHero />;
    var layoutState = new SectorExplorerLayoutState(
        heroContent,
        ExplorerSectors,
        sector.Systems.ToList(),
        selectedSectorId,
        EventCallback.Factory.Create<int>(this, HandleSectorChangedAsync),
        selectedSystemText,
        EventCallback.Factory.Create<string>(this, HandleSelectedSystemTextChanged),
        searchQuery,
        EventCallback.Factory.Create<string>(this, HandleSearchQueryChangedAsync),
        searchResults,
        EventCallback.Factory.Create<StarWinSearchResult>(this, NavigateToSearchResult),
        sections,
        OverviewSectionName,
        explorerRenderError,
        DisplayResultType,
        BuildSectionRoute);
}

<PageTitle>Sector Explorer | Starforged Atlas</PageTitle>
<SectorExplorerLayoutSync State="layoutState" />

@if (overviewData is not null)
{
    <ExplorerMetricsBand SystemCount="@overviewData.SystemCount"
                         WorldCount="@overviewData.WorldCount"
                         ColonyCount="@overviewData.ColonyCount"
                         EmpireCount="@overviewData.EmpireCount"
                         RaceCount="@overviewData.RaceCount" />
}
else
{
    <section class="metrics-band" aria-label="sector summary">
        <article><span>Systems</span><strong>Loading...</strong></article>
        <article><span>Worlds</span><strong>Loading...</strong></article>
        <article><span>Colonies</span><strong>Loading...</strong></article>
        <article><span>Empires</span><strong>Loading...</strong></article>
        <article><span>Races</span><strong>Loading...</strong></article>
    </section>
}

<section class="overview-layout">
    @if (!explorerSelectionReady)
    {
        <div class="sector-map-three" aria-label="sector map workspace">
            <article class="map-request-panel">
                <span class="panel-kicker">Map workspace</span>
                <h2>Preparing explorer workspace</h2>
                <p>Selecting the active sector and loading the initial overview data before the map and route planner initialize.</p>
            </article>
        </div>

        <div class="stacked-panels">
            <article class="feature-panel route-planner-panel">
                <span class="panel-kicker">Route planner</span>
                <h2>Preparing route-planning workspace</h2>
                <p>The route planner unlocks after the active sector has been selected and the overview data is ready.</p>
            </article>
        </div>
    }
    else if (!overviewMapWorkspaceReady)
    {
        <div class="sector-map-three" aria-label="sector map workspace">
            <article class="map-request-panel">
                <span class="panel-kicker">Map workspace</span>
                <h2>Preparing map workspace</h2>
                <p>The Overview page is ready first. The 3D map and route planner load in right after the initial page render so they do not block the rest of the Explorer.</p>
            </article>
        </div>

        <div class="stacked-panels">
            <article class="feature-panel route-planner-panel">
                <span class="panel-kicker">Route planner</span>
                <h2>Preparing route-planning workspace</h2>
                <p>The route planner is loading as a follow-up component after the main Overview content appears.</p>
            </article>
        </div>
    }
    else
    {
        <SectorExplorerMapWorkspace SectorId="selectedSectorId"
                                    SystemId="selectedSystemId" />
    }
</section>
@code {
    private const string OverviewSectionName = "Overview";
    private const int ComboAllFilterId = -1;
    private const string ExplorerSessionStorageKey = "starforgedAtlas.explorerSelection";

    [SupplyParameterFromQuery(Name = "sectorId")]
    public int? RequestedSectorId { get; set; }

    [SupplyParameterFromQuery(Name = "systemId")]
    public int? RequestedSystemId { get; set; }

    [SupplyParameterFromQuery(Name = "worldId")]
    public int? RequestedWorldId { get; set; }

    [SupplyParameterFromQuery(Name = "colonyId")]
    public int? RequestedColonyId { get; set; }

    [SupplyParameterFromQuery(Name = "habitatId")]
    public int? RequestedHabitatId { get; set; }

    [SupplyParameterFromQuery(Name = "raceId")]
    public int? RequestedRaceId { get; set; }

    [SupplyParameterFromQuery(Name = "empireId")]
    public int? RequestedEmpireId { get; set; }

    private static readonly IReadOnlyList<string> sections = SectorExplorerSections.All;
    private readonly Dictionary<int, ExplorerSectorOverviewData> sectorOverviewDataById = [];
    private StarWinExplorerContext explorerContext = StarWinExplorerContext.Empty;
    private (int? SectorId, int? SystemId, int? WorldId, int? ColonyId, int? HabitatId, int? RaceId, int? EmpireId) lastAppliedRequest;
    private bool overviewMapWorkspaceReady;
    private int selectedSectorId;
    private int selectedSystemId;
    private string selectedSystemText = string.Empty;
    private string searchQuery = string.Empty;
    private IReadOnlyList<StarWinSearchResult> searchResults = [];
    private bool browserSessionRestored;
    private bool browserSessionReady;
    private string explorerRenderError = string.Empty;

    private IReadOnlyList<StarWinSector> ExplorerSectors => explorerContext.Sectors;

    protected override async Task OnInitializedAsync()
    {
        await RefreshExplorerDataAsync();
        var initialSector = GetSelectedSector();
        await ApplyRequestedSelectionAsync(initialSector);
        await EnsureSectorSelectionAsync(selectedSectorId, selectedSystemId);
        lastAppliedRequest = GetCurrentRequest();
    }

    protected override async Task OnParametersSetAsync()
    {
        var currentRequest = GetCurrentRequest();
        if (currentRequest == lastAppliedRequest)
        {
            return;
        }

        if (ExplorerSectors.Count > 0)
        {
            if (RequestedSectorId is int requestedSectorId
                && ExplorerSectors.Any(sector => sector.Id == requestedSectorId))
            {
                selectedSectorId = requestedSectorId;
            }

            await ApplyRequestedSelectionAsync(GetSelectedSector());
        }

        lastAppliedRequest = currentRequest;
    }

    private async Task RefreshExplorerDataAsync(CancellationToken cancellationToken = default)
    {
        var previousSectorId = selectedSectorId;
        var previousSystemId = selectedSystemId;

        explorerContext = await ExplorerContextService.LoadShellAsync(
            preferredSectorId: RequestedSectorId ?? selectedSectorId,
            cancellationToken: cancellationToken);

        if (ExplorerSectors.Count == 0)
        {
            selectedSectorId = 0;
            selectedSystemId = 0;
            selectedSystemText = string.Empty;
            return;
        }

        await EnsureSectorSelectionAsync(
            previousSectorId > 0 ? previousSectorId : RequestedSectorId,
            previousSystemId > 0 ? previousSystemId : RequestedSystemId,
            cancellationToken);

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            await RunSearchAsync();
        }
    }

    private ExplorerSectorOverviewData? GetSectorOverviewData(int sectorId)
    {
        return sectorOverviewDataById.TryGetValue(sectorId, out var overviewData) ? overviewData : null;
    }

    private async Task LoadSectorOverviewDataAsync(int sectorId, CancellationToken cancellationToken = default)
    {
        if (sectorId <= 0)
        {
            return;
        }

        sectorOverviewDataById[sectorId] = await ExplorerQueryService.LoadSectorOverviewAsync(sectorId, cancellationToken);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreExplorerSessionAsync();
            browserSessionReady = true;
            if (!overviewMapWorkspaceReady)
            {
                overviewMapWorkspaceReady = true;
            }

            StateHasChanged();
            return;
        }

        try
        {
            if (!overviewMapWorkspaceReady)
            {
                overviewMapWorkspaceReady = true;
                StateHasChanged();
                return;
            }
        }
        catch (Exception ex)
        {
            explorerRenderError = ex.GetBaseException().Message;
            StateHasChanged();
        }
    }

    private async Task SelectDefaultSystem()
    {
        await LoadSectorOverviewDataAsync(selectedSectorId);
        var sector = GetSelectedSector();
        selectedSystemId = sector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        SyncCurrentExplorerRoute(replaceHistory: true);
        await PersistExplorerSessionAsync();
    }

    private async Task ApplySelectedSystemTextAsync()
    {
        var sector = GetSelectedSector();
        var systemId = ParseComboId(selectedSystemText);
        if (systemId == ComboAllFilterId || sector.Systems.All(system => system.Id != systemId))
        {
            selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
            return;
        }

        if (systemId == selectedSystemId)
        {
            selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
            return;
        }

        selectedSystemId = systemId;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        SyncCurrentExplorerRoute(replaceHistory: true);
        await PersistExplorerSessionAsync();
    }

    private async Task HandleSectorChangedAsync(int sectorId)
    {
        selectedSectorId = sectorId;
        await SelectDefaultSystem();
    }

    private async Task HandleSelectedSystemTextChanged(string value)
    {
        selectedSystemText = value;
        await ApplySelectedSystemTextAsync();
    }

    private async Task RestoreExplorerSessionAsync()
    {
        if (browserSessionRestored)
        {
            return;
        }

        browserSessionRestored = true;
        if (RequestedSectorId is not null)
        {
            await EnsureSectorSelectionAsync(RequestedSectorId, RequestedSystemId);
            await PersistExplorerSessionAsync(force: true);
            return;
        }

        string? storedValue;
        try
        {
            storedValue = await JS.InvokeAsync<string?>("sessionStorage.getItem", ExplorerSessionStorageKey);
        }
        catch (InvalidOperationException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(storedValue))
        {
            await EnsureSectorSelectionAsync(updateRoute: true);
            await PersistExplorerSessionAsync(force: true);
            return;
        }

        ExplorerSessionSelection? storedSelection;
        try
        {
            storedSelection = System.Text.Json.JsonSerializer.Deserialize<ExplorerSessionSelection>(storedValue);
        }
        catch (System.Text.Json.JsonException)
        {
            return;
        }

        if (storedSelection is null)
        {
            await EnsureSectorSelectionAsync(updateRoute: true);
            await PersistExplorerSessionAsync(force: true);
            return;
        }

        var sector = ExplorerSectors.FirstOrDefault(item => item.Id == storedSelection.SectorId);
        if (sector is null)
        {
            await EnsureSectorSelectionAsync(updateRoute: true);
            await PersistExplorerSessionAsync(force: true);
            return;
        }

        await EnsureSectorSelectionAsync(sector.Id, storedSelection.SystemId, updateRoute: true);
        await PersistExplorerSessionAsync(force: true);
    }

    private async Task PersistExplorerSessionAsync(bool force = false)
    {
        if (!browserSessionReady && !force)
        {
            return;
        }

        var selection = new ExplorerSessionSelection(selectedSectorId, selectedSystemId);
        var value = System.Text.Json.JsonSerializer.Serialize(selection);
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", ExplorerSessionStorageKey, value);
        }
        catch (InvalidOperationException)
        {
        }
    }

    private Task HandleSearchQueryChangedAsync(string value)
    {
        searchQuery = value;
        return RunSearchAsync();
    }

    private async Task RunSearchAsync()
    {
        searchResults = await ExplorerQueryService.SearchSectorAsync(selectedSectorId, searchQuery);
    }

    private void NavigateToSearchResult(StarWinSearchResult result)
    {
        var sectionName = sections.Contains(result.Tab) ? result.Tab : OverviewSectionName;
        var sectorId = result.SectorId ?? selectedSectorId;
        var systemId = result.SystemId ?? 0;

        searchQuery = result.Title;
        searchResults = [];
        NavigationManager.NavigateTo(SectorExplorerRoutes.BuildSectionUri(
             sectionName,
             sectorId,
             systemId,
             result.WorldId ?? 0,
             result.ColonyId ?? 0,
             result.SpaceHabitatId ?? 0,
             result.RaceId ?? 0,
             result.EmpireId ?? 0));
    }

    private void SyncCurrentExplorerRoute(bool replaceHistory = false)
    {
        var targetUri = BuildSectionUri(OverviewSectionName, selectedSectorId, selectedSystemId);
        var absoluteTargetUri = NavigationManager.ToAbsoluteUri(targetUri).ToString();
        if (string.Equals(NavigationManager.Uri, absoluteTargetUri, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        NavigationManager.NavigateTo(targetUri, replace: replaceHistory);
    }

    private string BuildSectionRoute(string sectionName)
    {
        return SectorExplorerRoutes.BuildSectionUri(sectionName, selectedSectorId, selectedSystemId);
    }

    private static string BuildSectionUri(string sectionName, int sectorId, int systemId)
    {
        return SectorExplorerRoutes.BuildSectionUri(sectionName, sectorId, systemId);
    }

    private (int? SectorId, int? SystemId, int? WorldId, int? ColonyId, int? HabitatId, int? RaceId, int? EmpireId) GetCurrentRequest()
    {
        return (
            RequestedSectorId,
            RequestedSystemId,
            RequestedWorldId,
            RequestedColonyId,
            RequestedHabitatId,
            RequestedRaceId,
            RequestedEmpireId);
    }

    private async Task ApplyRequestedSelectionAsync(StarWinSector sector, CancellationToken cancellationToken = default)
    {
        if (RequestedSystemId is int requestedSystemId
            && sector.Systems.Any(system => system.Id == requestedSystemId))
        {
            selectedSystemId = requestedSystemId;
        }

        var resolvedSystemId = await ResolveRequestedSystemIdAsync(sector.Id, cancellationToken);
        if (resolvedSystemId is int requestedSelectionSystemId
            && sector.Systems.Any(system => system.Id == requestedSelectionSystemId))
        {
            selectedSystemId = requestedSelectionSystemId;
        }

        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
    }

    private static string FormatSystemOption(StarSystem system)
    {
        return $"{system.Id} - {system.Name}";
    }

    private static string FormatSelectedSystem(StarWinSector sector, int systemId)
    {
        var system = sector.Systems.FirstOrDefault(item => item.Id == systemId);
        return system is null ? string.Empty : FormatSystemOption(system);
    }

    private static int ParseComboId(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return ComboAllFilterId;
        }

        var separatorIndex = value.IndexOf(" - ", StringComparison.Ordinal);
        var idText = separatorIndex < 0 ? value : value[..separatorIndex];
        return int.TryParse(idText, out var id) ? id : ComboAllFilterId;
    }

    private static string DisplayResultType(StarWinSearchResultType type)
    {
        return type switch
        {
            StarWinSearchResultType.StarSystem => "System",
            StarWinSearchResultType.AlienRace => "Race",
            StarWinSearchResultType.SpaceHabitat => "Habitat",
            _ => type.ToString()
        };
    }

    private StarWinSector GetSelectedSector()
    {
        return ExplorerSectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? explorerContext.CurrentSector;
    }

    private async Task EnsureSectorSelectionAsync(
        int? preferredSectorId = null,
        int? preferredSystemId = null,
        CancellationToken cancellationToken = default,
        bool updateRoute = false)
    {
        if (ExplorerSectors.Count == 0)
        {
            selectedSectorId = 0;
            selectedSystemId = 0;
            selectedSystemText = string.Empty;
            return;
        }

        var sector = preferredSectorId is int sectorId && sectorId > 0
            ? ExplorerSectors.FirstOrDefault(item => item.Id == sectorId)
            : null;
        sector ??= ExplorerSectors.FirstOrDefault(item => item.Id == selectedSectorId);
        sector ??= explorerContext.CurrentSector;
        sector ??= ExplorerSectors.First();

        selectedSectorId = sector.Id;
        await LoadSectorOverviewDataAsync(sector.Id, cancellationToken);

        var systemId = preferredSystemId ?? selectedSystemId;
        selectedSystemId = sector.Systems.Any(system => system.Id == systemId)
            ? systemId
            : sector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);

        if (updateRoute)
        {
            SyncCurrentExplorerRoute(replaceHistory: true);
        }
    }

    private Task<int?> ResolveRequestedSystemIdAsync(int sectorId, CancellationToken cancellationToken = default)
    {
        if (RequestedColonyId is int requestedColonyId)
        {
            return ExplorerQueryService.ResolveSystemIdAsync(
                sectorId,
                colonyId: requestedColonyId,
                cancellationToken: cancellationToken);
        }

        if (RequestedHabitatId is int requestedHabitatId)
        {
            return ExplorerQueryService.ResolveSystemIdAsync(
                sectorId,
                habitatId: requestedHabitatId,
                cancellationToken: cancellationToken);
        }

        if (RequestedWorldId is int requestedWorldId)
        {
            return ExplorerQueryService.ResolveSystemIdAsync(
                sectorId,
                worldId: requestedWorldId,
                cancellationToken: cancellationToken);
        }

        return Task.FromResult<int?>(null);
    }

    private sealed record ExplorerSessionSelection(int SectorId, int SystemId);
}

