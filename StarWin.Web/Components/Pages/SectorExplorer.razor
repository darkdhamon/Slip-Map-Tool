    private void ApplyRouteOriginText()
    {
        var sector = GetSelectedSector();
        var systemId = ParseComboId(routeOriginText);
        if (systemId == ComboAllFilterId || sector.Systems.All(system => system.Id != systemId))
        {
            routeOriginSystemId = 0;
            routeOriginText = string.Empty;
            ClearPlottedRoutePlan();
            renderedOverview = false;
            return;
