    }

    private void ClearPlottedRoutePlan()
    {
        plottedRoutePlan = null;
        plottedRouteSectorId = 0;
        plottedRouteOriginSystemId = 0;
        plottedRouteDestinationSystemId = 0;
        plottedRouteOptimizationMode = RouteOptimizationMode.ShortestDistance;
        plottedRouteConfigurationStamp = 0;
    }

    private async Task PlotSelectedRouteAsync()
    {
        if (sectionLoadingVisible)
        {
            return;
        }

        sectionLoadingTarget = "Route";
        sectionLoadingStatus = "Reading origin system and destination...";
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingVisible = true;
        StateHasChanged();
        await Task.Yield();
        await Task.Delay(60);

        ApplyRouteOriginText();
        ApplyRouteDestinationText();
        if (routeOriginSystemId == 0 || routeDestinationSystemId == 0)
        {
            sectionLoadingVisible = false;
            sectionLoadingTarget = string.Empty;
            sectionLoadingStatus = string.Empty;
            StateHasChanged();
            return;
        }

        var sector = GetSelectedSector();
        var origin = sector.Systems.FirstOrDefault(system => system.Id == routeOriginSystemId);
        var destination = sector.Systems.FirstOrDefault(system => system.Id == routeDestinationSystemId);
        if (origin is null || destination is null || origin.Id == destination.Id)
        {
            ClearPlottedRoutePlan();
            sectionLoadingVisible = false;
            sectionLoadingTarget = string.Empty;
            sectionLoadingStatus = string.Empty;
            StateHasChanged();
            return;
        }

        sectionLoadingStatus = "Following hyperlanes as far as possible...";
        StateHasChanged();
        await Task.Yield();
        await Task.Delay(40);

        var adjacency = await GetRouteAdjacencyAsync(sector);

        sectionLoadingStatus = routeOptimizationMode == RouteOptimizationMode.ShortestTravelTime
            ? "Optimizing total travel time..."
            : "Optimizing total travel distance...";
        StateHasChanged();
        await Task.Yield();
        plottedRoutePlan = await Task.Run(() => BuildHyperlanePreferredRoute(origin, destination, adjacency));
        plottedRouteSectorId = sector.Id;
        plottedRouteOriginSystemId = origin.Id;
        plottedRouteDestinationSystemId = destination.Id;
        plottedRouteOptimizationMode = routeOptimizationMode;
        plottedRouteConfigurationStamp = GetRouteConfigurationStamp(sector);

        await LoadSectorMap();
        renderedOverview = false;
        sectionLoadingStatus = "Rendering route map...";
        StateHasChanged();
        await Task.Delay(140);

        sectionLoadingVisible = false;
        sectionLoadingTarget = string.Empty;
        sectionLoadingStatus = string.Empty;
        StateHasChanged();
    }

    private void ClearSelectedRoute()
    {
        var sector = GetSelectedSector();
        routeOriginSystemId = selectedSystemId;
        routeOriginText = FormatSelectedSystem(sector, routeOriginSystemId);
        routeDestinationSystemId = 0;
        routeDestinationText = string.Empty;
        ClearPlottedRoutePlan();
        renderedOverview = false;
    }

    private async Task ConfigureRecordObserverAsync(
        string key,
        bool hasMoreRecords,
        Func<bool> isConfigured,
        Action<bool> setConfigured,
        ElementReference loadMoreElement,
        string loadMoreMethodName)
    {
        if (!hasMoreRecords)
        {
            setConfigured(false);
            if (loadMoreScrollModule is not null)
            {
                await loadMoreScrollModule.InvokeVoidAsync("disconnectLoadMore", key);
            }

            return;
        }

        if (isConfigured())
        {
            return;
        }

        loadMoreScrollModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/timelineInfiniteScroll.js");
        dotNetReference ??= DotNetObjectReference.Create(this);
        await loadMoreScrollModule.InvokeVoidAsync("observeLoadMore", key, loadMoreElement, dotNetReference, loadMoreMethodName);
        setConfigured(true);
    }

    private async Task RestoreExplorerSessionAsync()
    {
        if (browserSessionRestored)
        {
            return;
        }

        browserSessionRestored = true;
        if (RequestedSectorId is not null)
        {
            await PersistExplorerSessionAsync(force: true);
            return;
        }

        string? storedValue;
        try
        {
            storedValue = await JS.InvokeAsync<string?>("sessionStorage.getItem", ExplorerSessionStorageKey);
        }
        catch (InvalidOperationException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(storedValue))
        {
            return;
        }

        ExplorerSessionSelection? storedSelection;
        try
        {
            storedSelection = System.Text.Json.JsonSerializer.Deserialize<ExplorerSessionSelection>(storedValue);
        }
        catch (System.Text.Json.JsonException)
        {
            return;
        }

        if (storedSelection is null)
        {
            return;
        }

        var sector = ExplorerSectors.FirstOrDefault(item => item.Id == storedSelection.SectorId);
        if (sector is null)
        {
            return;
        }

        selectedSectorId = sector.Id;
        await LoadSectorOverviewDataAsync(sector.Id);
        autoLoadSectorMap = storedSelection.AutoLoadSectorMap;
        sectorMapRequested = autoLoadSectorMap && Workspace.IsLoaded;
        selectedSystemId = sector.Systems.Any(system => system.Id == storedSelection.SystemId)
            ? storedSelection.SystemId
            : sector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        routeOriginSystemId = selectedSystemId;
        routeOriginText = FormatSelectedSystem(sector, routeOriginSystemId);
        selectedWorldId = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId)?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId)?.Worlds.FirstOrDefault()?.Colony?.Id ?? 0;
        selectedHabitatId = 0;
        sectorMapViewDistanceParsecs = Math.Min(
            sectorMapViewDistanceParsecs,
            GetSectorMapMaximumViewDistance(sector));
        SelectDefaultCivilizationRecords(sector);
        SyncCurrentExplorerRoute(replaceHistory: true);
    }

    private async Task PersistExplorerSessionAsync(bool force = false)
    {
        if (!browserSessionReady && !force)
        {
            return;
        }

        var selection = new ExplorerSessionSelection(selectedSectorId, selectedSystemId, autoLoadSectorMap, GetSectionSlug(activeSection));
        var value = System.Text.Json.JsonSerializer.Serialize(selection);
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", ExplorerSessionStorageKey, value);
        }
        catch (InvalidOperationException)
        {
        }
    }

    private void RunSearch()
    {
        var sector = GetSelectedSector();
        var sectorSummary = GetSectorSummary(sector);

        searchResults = SearchService.Search(searchQuery)
            .Where(result => result.Type switch
            {
                StarWinSearchResultType.AlienRace => result.RaceId is int raceId && sectorSummary.RaceIds.Contains(raceId),
                StarWinSearchResultType.Empire => result.EmpireId is int empireId && sectorSummary.EmpireIds.Contains(empireId),
                _ => true
            })
            .ToList();
    }

    private void NavigateToSearchResult(StarWinSearchResult result)
    {
        SetActiveSection(sections.Contains(result.Tab) ? result.Tab : "Overview", syncRoute: false);

        if (result.SectorId is int sectorId)
        {
            selectedSectorId = sectorId;
        }

        if (result.SystemId is int systemId)
        {
            selectedSystemId = systemId;
        }

        if (result.WorldId is int worldId)
        {
            selectedWorldId = worldId;
            selectedColonyId = GetSelectedSector().Systems
                .SelectMany(system => system.Worlds)
                .FirstOrDefault(world => world.Id == worldId)
                ?.Colony?.Id ?? 0;
            selectedHabitatId = 0;
        }

        if (result.SpaceHabitatId is int habitatId)
        {
            selectedHabitatId = habitatId;
            SetActiveSection("Worlds", syncRoute: false);
        }

        if (result.RaceId is int raceId)
        {
            selectedRaceId = raceId;
        }

        if (result.EmpireId is int empireId)
        {
            selectedEmpireId = empireId;
        }

        var sector = GetSelectedSector();
        if (sector.Systems.All(system => system.Id != selectedSystemId))
        {
            selectedSystemId = sector.Systems.FirstOrDefault()?.Id ?? 0;
        }

        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        searchQuery = result.Title;
        searchResults = [];
        SyncCurrentExplorerRoute(replaceHistory: true);
        _ = PersistExplorerSessionAsync();
    }

    private void SetActiveSection(string sectionName, bool syncRoute = true)
    {
        activeSection = sections.Contains(sectionName) ? sectionName : "Overview";
        if (syncRoute)
        {
            SyncCurrentExplorerRoute();
        }
    }

    private void SyncCurrentExplorerRoute(bool replaceHistory = false)
    {
        var targetUri = BuildSectionUri(activeSection, selectedSectorId);
        var absoluteTargetUri = NavigationManager.ToAbsoluteUri(targetUri).ToString();
        if (string.Equals(NavigationManager.Uri, absoluteTargetUri, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            JS.InvokeVoidAsync("starforgedAtlasNavigation.syncExplorerUrl", targetUri, replaceHistory);
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }

