    private async Task LoadSectorMap()
    {
        if (!Workspace.IsLoaded)
        {
            await RefreshSectorMapContextAsync();
            if (!Workspace.IsLoaded)
            {
                return;
            }
        }

        sectorMapRequested = true;
        renderedOverview = false;
    }

    private async Task RefreshSectorMapContextAsync()
    {
        if (mapContextRefreshing)
        {
            return;
        }

        var loadingMapContext = !Workspace.IsLoaded;
        mapContextRefreshing = true;
        mapContextStatus = loadingMapContext
            ? "Loading cached sector map context..."
            : "Refreshing cached sector map context...";
        StateHasChanged();
        await Task.Yield();

        try
        {
            await Workspace.ReloadAsync();
            generatedSectorRouteCache.Clear();
            routeGraphCaches.Clear();
            renderedOverview = false;
            mapContextStatus = loadingMapContext
                ? "Sector map context loaded."
                : "Sector map context refreshed.";
        }
        catch (Exception ex)
        {
            mapContextStatus = $"Map context refresh failed: {ex.GetBaseException().Message}";
        }
        finally
        {
            mapContextRefreshing = false;
            StateHasChanged();
        }
    }

