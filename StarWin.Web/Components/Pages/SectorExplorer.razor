@page "/sector-explorer"
@page "/sector-explorer/{SectionSlug}"
@rendermode InteractiveServer
@inject IStarWinWorkspace Workspace
@inject IStarWinExplorerContextService ExplorerContextService
@inject IStarWinExplorerQueryService ExplorerQueryService
@inject IStarWinSearchService SearchService
@inject IStarWinImageService ImageService
@inject IStarWinEntityNameService EntityNameService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable
@using Microsoft.AspNetCore.WebUtilities
@using StarWin.Domain.Services

@{
    var sector = GetSelectedSector();
    var mapSector = GetMapSector();
    var mapPanelTitle = GetMapPanelTitle(sector);
    var mapContextActionLabel = GetMapContextActionLabel();
    var sectorSummary = GetSectorSummary(sector);
    var overviewData = GetSectorOverviewData(sector.Id);
    var usesSectionCache = ShouldUseSectionCache(activeSection);
    var needsSectorRaceList = activeSection is "Overview" or "Colonies" or "Aliens" or "Empires";
    var needsSectorEmpireList = activeSection is "Overview" or "Systems" or "Colonies" or "Empires";
    var sectionCache = usesSectionCache ? GetSectorCache(sector) : null;
    var selectedSystem = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId) ?? sector.Systems.FirstOrDefault();
    var selectedMapSystem = mapSector.Systems.FirstOrDefault(system => system.Id == selectedSystemId) ?? mapSector.Systems.FirstOrDefault();
    var selectedHabitat = selectedSystem?.SpaceHabitats.FirstOrDefault(habitat => habitat.Id == selectedHabitatId);
    var selectedWorld = selectedHabitat is null
        ? selectedSystem?.Worlds.FirstOrDefault(world => world.Id == selectedWorldId) ?? selectedSystem?.Worlds.FirstOrDefault()
        : null;
    var sectorWorlds = sectionCache?.Worlds ?? [];
    var sectorColonies = sectionCache?.Colonies ?? [];
    var sectorRaceIds = sectionCache?.RaceIds ?? sectorSummary.RaceIds;
    var sectorEmpireIds = sectionCache?.EmpireIds ?? sectorSummary.EmpireIds;
    var sectorRaces = needsSectorRaceList
        ? ExplorerAlienRaces.Where(race => sectorRaceIds.Contains(race.Id)).OrderBy(race => race.Name).ToList()
        : [];
    var sectorEmpires = needsSectorEmpireList
        ? ExplorerEmpires.Where(empire => sectorEmpireIds.Contains(empire.Id)).OrderBy(empire => empire.Name).ToList()
        : [];
    var selectedColony = activeSection is "Colonies" or "Empires"
        ? sectorColonies.Select(item => item.Colony).FirstOrDefault(colony => colony.Id == selectedColonyId)
            ?? selectedWorld?.Colony
            ?? sectorColonies.Select(item => item.Colony).FirstOrDefault()
        : null;
    var selectedColonyWorld = selectedColony is null || !WorldsById.TryGetValue(selectedColony.WorldId, out var colonyWorld)
        ? null
        : colonyWorld;
    var selectedRoutePlan = activeSection == "Overview"
        ? GetPlottedRoutePlan(sector)
        : null;
}

<PageTitle>Sector Explorer | Starforged Atlas</PageTitle>

<section class="explorer-page">
    @if (activeSection == "Overview")
    {
        <header class="explorer-hero">
            <div class="hero-copy">
                <p class="eyebrow">Sector Explorer</p>
                <h1>Sector command, civilization records, and RPG world survey data.</h1>
        <p class="hero-summary">Browse sectors, inspect systems, find colonies, compare empires, and prepare science-fiction campaign material from legacy StarWin and Slip Map data.</p>
            </div>
        </header>
    }

    <section class="control-strip">
        <label class="control-field sector-field">
            Sector
            <select @bind="selectedSectorId" @bind:after="SelectDefaultSystem">
                @foreach (var item in ExplorerSectors)
                {
                    <option value="@item.Id">@item.Name</option>
                }
            </select>
        </label>

        <label class="control-field system-field">
            System
            <input list="sector-system-options"
                   placeholder="Select system..."
                   @bind="selectedSystemText"
                   @bind:after="ApplySelectedSystemText" />
            <datalist id="sector-system-options">
                @foreach (var system in sector.Systems)
                {
                    <option value="@FormatSystemOption(system)" />
                }
            </datalist>
        </label>

        <div class="archive-search">
            <label for="archive-search-input">Archive search</label>
            <input id="archive-search-input"
                   placeholder="System, world, colony, race, empire..."
                   @bind="searchQuery"
                   @bind:event="oninput"
                   @bind:after="RunSearch" />

            @if (searchResults.Count > 0)
            {
                <div class="search-results">
                    @foreach (var result in searchResults)
                    {
                        <button type="button" class="search-result" @onclick="() => NavigateToSearchResult(result)">
                            <span>@DisplayResultType(result.Type)</span>
                            <strong>@result.Title</strong>
                            <small>@result.Subtitle</small>
                        </button>
                    }
                </div>
            }
            else if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                <p class="search-empty">No matching systems, worlds, races, colonies, empires, habitats, or history.</p>
            }
        </div>

        <ExplorerSectionTabs Sections="sections"
                             ActiveSection="@activeSection"
                             IsLoading="@sectionLoadingVisible"
                             LoadingTarget="@sectionLoadingTarget"
                             LoadingStatus="@sectionLoadingStatus"
                             SectionHrefFactory="BuildSectionRoute" />
    </section>

    @if (!string.IsNullOrWhiteSpace(explorerRenderError))
    {
        <article class="timeline-event-card">
            <span class="timeline-century">Section error</span>
            <p>@explorerRenderError</p>
        </article>
    }

    @if (activeSection == "Overview")
    {
        <ExplorerMetricsBand SystemCount="@(overviewData?.SystemCount ?? 0)"
                             WorldCount="@(overviewData?.WorldCount ?? 0)"
                             ColonyCount="@(overviewData?.ColonyCount ?? 0)"
                             EmpireCount="@(overviewData?.EmpireCount ?? 0)"
                             RaceCount="@(overviewData?.RaceCount ?? 0)" />
    }

    @switch (activeSection)
    {
        case "Overview":
            <section class="overview-layout">
                <div class="sector-map-three" @ref="sectorMapElement" aria-label="interactive 3D sector map">
                    @if (!sectorMapRequested)
                    {
                        <article class="map-request-panel">
                            <span class="panel-kicker">3D Sector Map</span>
                            <h2>@mapPanelTitle</h2>
                            <p>The interactive map is available on request so large imported sectors do not slow down the explorer while you browse records.</p>
                            <label class="switch-field">
                                <input type="checkbox"
                                       checked="@autoLoadSectorMap"
                                       @onchange="ToggleAutoLoadSectorMap" />
                                <span>Auto-load map this session</span>
                            </label>
                            <button type="button" class="overlay-action" @onclick="LoadSectorMap">Load 3D map</button>
                            @if (!string.IsNullOrWhiteSpace(mapContextStatus))
                            {
                                <p class="search-empty">@mapContextStatus</p>
                            }
                        </article>
                    }
                    else
                    {
                        <div class="map-hud">
                            <span>3D Sector Map</span>
                            <strong>@mapSector.Name</strong>
                            <small>@GetSectorMapSystemCount(mapSector, selectedMapSystem) of @mapSector.Systems.Count systems within @sectorMapViewDistanceParsecs parsecs@(IsSectorMapCapped(mapSector, selectedMapSystem) ? $" (closest {sectorMapRenderLimit:N0} shown)" : string.Empty)</small>
                        <small>@GetSectorMapRouteCount(mapSector, selectedMapSystem) visible hyperlanes</small>
                            @if (!string.IsNullOrWhiteSpace(sectorMapPerformanceStatus))
                            {
                                <small class="map-performance-status">@sectorMapPerformanceStatus</small>
                            }
                            @if (selectedRoutePlan is { } hudRoutePlan)
                            {
                                <small>@hudRoutePlan.Legs.Count route legs from @hudRoutePlan.Origin.Name to @hudRoutePlan.Destination.Name; @hudRoutePlan.OffHyperlaneLegCount off-lane</small>
                            }
                            <label class="switch-field compact">
                                <input type="checkbox"
                                       checked="@autoLoadSectorMap"
                                       @onchange="ToggleAutoLoadSectorMap" />
                                <span>Auto-load</span>
                            </label>
                            <label class="map-distance-control">
                                <span>View distance</span>
                                <input type="range"
                                       min="@DefaultSectorMapViewDistanceParsecs"
                                       max="@GetSectorMapMaximumViewDistance(sector)"
                                       step="1"
                                       @bind="sectorMapViewDistanceParsecs"
                                       @bind:event="oninput" />
                                <strong>@sectorMapViewDistanceParsecs pc</strong>
                            </label>
                            <button type="button" class="overlay-action" @onclick="RefreshSectorMapContextAsync" disabled="@mapContextRefreshing">@mapContextActionLabel</button>
                            @if (!string.IsNullOrWhiteSpace(mapContextStatus))
                            {
                                <small>@mapContextStatus</small>
                            }
                        </div>
                        <button type="button" class="map-fullscreen-button" @onclick="ToggleSectorMapFullscreen">
                            <span class="enter-fullscreen">Full screen</span>
                            <span class="exit-fullscreen">Exit full screen</span>
                        </button>
                        <div class="map-controls-hint">
                            <span>Drag rotate</span>
                            <span>WASD/QE rotate</span>
                            <span>Wheel zoom</span>
                            <span>Right-drag pan</span>
                        </div>
                    }
                    @if (sectorMapRequested && selectedMapSystem is not null)
                    {
                        <article class="fullscreen-system-overlay">
                            <span class="panel-kicker">Current system</span>
                            <h2>@selectedMapSystem.Name</h2>
                            <dl class="data-list">
                                <div><dt>Coordinates</dt><dd>@DisplayCoordinates(selectedMapSystem.Coordinates)</dd></div>
                                <div><dt>Allegiance</dt><dd>@DisplayAllegiance(selectedMapSystem.AllegianceId)</dd></div>
                                <div><dt>Astral bodies</dt><dd>@selectedMapSystem.AstralBodies.Count</dd></div>
                                <div><dt>Worlds</dt><dd>@selectedMapSystem.Worlds.Count</dd></div>
                            </dl>
                            <button type="button" class="overlay-action" @onclick="RecenterSectorMap">Recenter map</button>
                            <button type="button" class="overlay-action" @onclick="OpenSelectedSystemRecord">Open system record</button>
                        </article>
                    }
                    @if (sectorMapRequested)
                    {
                        <article class="fullscreen-route-planner route-planner-panel">
                            <span class="panel-kicker">Route planner</span>
                            <h2>Plot hyperlane route</h2>
                            <label>
                                Origin
                                <input list="fullscreen-route-system-options"
                                       placeholder="Select origin..."
                                       @bind="routeOriginText"
                                       @bind:after="ApplyRouteOriginText" />
                            </label>
                            <label>
                                Destination
                                <input list="fullscreen-route-system-options"
                                       placeholder="Select destination..."
                                       @bind="routeDestinationText"
                                       @bind:after="ApplyRouteDestinationText" />
                            </label>
                            <datalist id="fullscreen-route-system-options">
                                @foreach (var system in GetRouteSystemOptions())
                                {
                                    <option value="@FormatRouteOption(system)" />
                                }
                            </datalist>
                            <div class="parent-actions">
                                <button type="button" @onclick="PlotSelectedRouteAsync" disabled="@sectionLoadingVisible">Plot route</button>
                                <button type="button" @onclick="ClearSelectedRoute">Clear route</button>
                            </div>
                            <div class="form-grid">
                                <label>
                                    Optimization
                                    <select @bind="routeOptimizationMode">
                                        <option value="@RouteOptimizationMode.ShortestDistance">Shortest distance</option>
                                        <option value="@RouteOptimizationMode.ShortestTravelTime">Shortest travel time</option>
                                    </select>
                                </label>
                                <MultiSelectCombo Label="Avoid empires"
                                                  Placeholder="Avoid selected empires..."
                                                  SearchPlaceholder="Search empires..."
                                                  Options="@GetRouteEmpireOptions()"
                                                  SelectedIds="avoidedEmpireIds"
                                                  SelectedIdsChanged="UpdateAvoidedEmpires" />
                                <MultiSelectCombo Label="Avoid systems"
                                                  Placeholder="Avoid selected systems..."
                                                  SearchPlaceholder="Search systems..."
                                                  Options="@GetRouteSystemOptions()"
                                                  SelectedIds="avoidedSystemIds"
                                                  SelectedIdsChanged="UpdateAvoidedSystems" />
                            </div>
                            @if (selectedRoutePlan is { } fullscreenRoutePlan)
                            {
                                <dl class="field-grid">
                                    <div><dt>Origin</dt><dd>@fullscreenRoutePlan.Origin.Name</dd></div>
                                    <div><dt>Destination</dt><dd>@fullscreenRoutePlan.Destination.Name</dd></div>
                                    <div><dt>Route distance</dt><dd>@Format(fullscreenRoutePlan.TotalDistanceParsecs) pc</dd></div>
                                    <div><dt>Travel time</dt><dd>@FormatTravelTime(fullscreenRoutePlan.TotalTravelTimeYears)</dd></div>
                                    <div><dt>Hyperlane jumps</dt><dd>@fullscreenRoutePlan.HyperlaneJumpCount</dd></div>
                                    <div><dt>Off-lane legs</dt><dd>@fullscreenRoutePlan.OffHyperlaneLegCount</dd></div>
                                </dl>
                                <div class="route-leg-list compact">
                                    @foreach (var leg in fullscreenRoutePlan.Legs)
                                    {
                                        <button type="button"
                                                class="route-leg @GetRouteLegCssClass(leg)"
                                                @onclick="() => SelectSystem(leg.Target.Id)">
                                            <span>@GetRouteLegTierLabel(leg)</span>
                                            <strong>@leg.Source.Name to @leg.Target.Name</strong>
                                            <small>@Format(leg.DistanceParsecs) pc • @FormatTravelTime(leg.TravelTimeYears) • @GetRouteLegOwnerLabel(leg)</small>
                                        </button>
                                    }
                                </div>
                            }
                            else if (routeDestinationSystemId is not 0)
                            {
                                <p>No route could be plotted without an off-lane flight over @Format(GetOffLaneMaximumDistanceParsecs(sector)) parsecs.</p>
                            }
                        </article>
                    }
                    @if (sectionLoadingVisible)
                    {
                        <div class="fullscreen-loading-modal-backdrop" role="status" aria-live="polite" aria-label="Loading route">
                            <section class="loading-modal">
                                <span class="panel-kicker">Loading @sectionLoadingTarget</span>
                                <h2>@sectionLoadingStatus</h2>
                                <div class="loading-meter" aria-hidden="true">
                                    <span></span>
                                </div>
                                <ol>
                                    <li>Reading the current system and destination.</li>
                                    <li>Following connected hyperlane networks.</li>
                                    <li>Finding the shortest unavoidable void crossing.</li>
                                </ol>
                            </section>
                        </div>
                    }
                </div>

                <div class="stacked-panels">
                    <article class="feature-panel route-planner-panel">
                        <span class="panel-kicker">Route planner</span>
                        <h2>Plot hyperlane route</h2>
                        <label>
                            Origin
                            <input list="route-system-options"
                                   placeholder="Select origin..."
                                   @bind="routeOriginText"
                                   @bind:after="ApplyRouteOriginText" />
                        </label>
                        <label>
                            Destination
                            <input list="route-system-options"
                                   placeholder="Select destination..."
                                   @bind="routeDestinationText"
                                   @bind:after="ApplyRouteDestinationText" />
                        </label>
                        <datalist id="route-system-options">
                            @foreach (var system in GetRouteSystemOptions())
                            {
                                <option value="@FormatRouteOption(system)" />
                            }
                        </datalist>
                        <div class="parent-actions">
                            <button type="button" @onclick="PlotSelectedRouteAsync" disabled="@sectionLoadingVisible">Plot route</button>
                            <button type="button" @onclick="ClearSelectedRoute">Clear route</button>
                        </div>
                        <div class="form-grid">
                            <label>
                                Optimization
                                <select @bind="routeOptimizationMode">
                                    <option value="@RouteOptimizationMode.ShortestDistance">Shortest distance</option>
                                    <option value="@RouteOptimizationMode.ShortestTravelTime">Shortest travel time</option>
                                </select>
                            </label>
                            <MultiSelectCombo Label="Avoid empires"
                                              Placeholder="Avoid selected empires..."
                                              SearchPlaceholder="Search empires..."
                                              Options="@GetRouteEmpireOptions()"
                                              SelectedIds="avoidedEmpireIds"
                                              SelectedIdsChanged="UpdateAvoidedEmpires" />
                            <MultiSelectCombo Label="Avoid systems"
                                              Placeholder="Avoid selected systems..."
                                              SearchPlaceholder="Search systems..."
                                              Options="@GetRouteSystemOptions()"
                                              SelectedIds="avoidedSystemIds"
                                              SelectedIdsChanged="UpdateAvoidedSystems" />
                        </div>
                        @if (selectedRoutePlan is { } routePlan)
                        {
                            <dl class="field-grid">
                                <div><dt>Origin</dt><dd>@routePlan.Origin.Name</dd></div>
                                <div><dt>Destination</dt><dd>@routePlan.Destination.Name</dd></div>
                                <div><dt>Direct distance</dt><dd>@Format(routePlan.DirectDistanceParsecs) pc</dd></div>
                                <div><dt>Route distance</dt><dd>@Format(routePlan.TotalDistanceParsecs) pc</dd></div>
                                <div><dt>Travel time</dt><dd>@FormatTravelTime(routePlan.TotalTravelTimeYears)</dd></div>
                                <div><dt>Extra travel</dt><dd>@Format(routePlan.ExtraDistanceParsecs) pc</dd></div>
                                <div><dt>Hyperlane jumps</dt><dd>@routePlan.HyperlaneJumpCount</dd></div>
                                <div><dt>Off-lane legs</dt><dd>@routePlan.OffHyperlaneLegCount</dd></div>
                                <div><dt>Off-lane limit</dt><dd>@Format(GetOffLaneMaximumDistanceParsecs(sector)) pc</dd></div>
                            </dl>
                            <div class="route-leg-list">
                                @foreach (var leg in routePlan.Legs)
                                {
                                    <button type="button"
                                            class="route-leg @GetRouteLegCssClass(leg)"
                                            @onclick="() => SelectSystem(leg.Target.Id)">
                                        <span>@GetRouteLegTierLabel(leg)</span>
                                        <strong>@leg.Source.Name to @leg.Target.Name</strong>
                                        <small>@Format(leg.DistanceParsecs) pc • @FormatTravelTime(leg.TravelTimeYears) • @GetRouteLegOwnerLabel(leg)</small>
                                    </button>
                                }
                            </div>
                        }
                        else if (routeDestinationSystemId is not 0)
                        {
                            <p>No route could be plotted without an off-lane flight over @Format(GetOffLaneMaximumDistanceParsecs(sector)) parsecs.</p>
                        }
                    </article>
                </div>
            </section>
            break;
    }
</section>

@if (mapContextRefreshing)
{
    var mapContextLoadingLabel = Workspace.IsLoaded ? "Refreshing map context" : "Loading map context";
    var mapContextLoadingStatus = Workspace.IsLoaded
        ? "Refreshing the cached 3D sector map data."
        : "Loading the cached 3D sector map data for the first time.";

    <div class="loading-modal-backdrop" role="status" aria-live="polite" aria-label="@mapContextLoadingLabel">
        <section class="loading-modal">
            <span class="panel-kicker">@mapContextLoadingLabel</span>
            <h2>@mapContextLoadingStatus</h2>
            @if (!string.IsNullOrWhiteSpace(mapContextStatus))
            {
                <p class="loading-progress-detail">@mapContextStatus</p>
            }
            <div class="loading-meter" aria-hidden="true">
                <span></span>
            </div>
            <ol>
                <li>Load the current sector cache from the database.</li>
                <li>Refresh system, route, and civilization references for the map.</li>
                <li>Prepare the 3D map so the selected sector can render.</li>
            </ol>
        </section>
    </div>
}

@code {
    private const int DefaultSectorMapViewDistanceParsecs = 5;
    private const int MaximumSectorMapViewDistanceParsecs = 20;
    private const int SectorMapUnrestrictedRenderedSystems = int.MaxValue;
    private const int SectorMapMinimumRenderedSystems = 150;
    private const int ColonyBatchSize = 120;
    private const int ExplorerListBatchSize = 120;
    private const int ComboAllFilterId = -1;
    private const string ExplorerSessionStorageKey = "starforgedAtlas.explorerSelection";

    [SupplyParameterFromQuery(Name = "sectorId")]
    public int? RequestedSectorId { get; set; }

    [SupplyParameterFromQuery(Name = "systemId")]
    public int? RequestedSystemId { get; set; }

    [SupplyParameterFromQuery(Name = "worldId")]
    public int? RequestedWorldId { get; set; }

    [SupplyParameterFromQuery(Name = "colonyId")]
    public int? RequestedColonyId { get; set; }

    [SupplyParameterFromQuery(Name = "habitatId")]
    public int? RequestedHabitatId { get; set; }

    [SupplyParameterFromQuery(Name = "raceId")]
    public int? RequestedRaceId { get; set; }

    [SupplyParameterFromQuery(Name = "empireId")]
    public int? RequestedEmpireId { get; set; }

    [Parameter]
    public string? SectionSlug { get; set; }

    private readonly string[] sections = ["Overview", "Timeline", "Configuration", "Hyperlanes", "Systems", "Worlds", "Colonies", "Aliens", "Empires"];
    private readonly ExplorerSectorCacheBuilder sectorCacheBuilder = new();
    private readonly Dictionary<int, ExplorerSectorOverviewData> sectorOverviewDataById = [];
    private readonly Dictionary<int, ExplorerSectorLoadSections> loadedSectorSectionsById = [];
    private StarWinExplorerContext explorerContext = StarWinExplorerContext.Empty;
    private string activeSection = "Overview";
    private string lastAppliedSectionSlug = string.Empty;
    private string sectionLoadingTarget = string.Empty;
    private string sectionLoadingStatus = string.Empty;
    private bool sectionLoadingVisible;
    private bool sectionLoadingAwaitingTargetRender;
    private DateTimeOffset sectionLoadingStartedAtUtc;
    private int selectedSectorId;
    private int selectedSystemId;
    private string selectedSystemText = string.Empty;
    private int selectedWorldId;
    private int selectedColonyId;
    private int selectedHabitatId;
    private int selectedRaceId;
    private int selectedEmpireId;
    private string searchQuery = string.Empty;
    private IReadOnlyList<StarWinSearchResult> searchResults = [];
    private ElementReference sectorMapElement;
    private DotNetObjectReference<SectorExplorer>? dotNetReference;
    private IJSObjectReference? sectorMapModule;
    private IJSObjectReference? loadMoreScrollModule;
    private int renderedSectorId;
    private int renderedSystemId;
    private int renderedViewDistanceParsecs;
    private int renderedMapRenderLimit;
    private int renderedRouteOriginSystemId;
    private int renderedRouteDestinationSystemId;
    private long renderedRouteConfigurationStamp;
    private bool renderedOverview;
    private bool sectorMapRequested;
    private bool autoLoadSectorMap;
    private bool mapContextRefreshing;
    private string mapContextStatus = string.Empty;
    private SectorMapRoutePlan? plottedRoutePlan;
    private int plottedRouteSectorId;
    private int plottedRouteOriginSystemId;
    private int plottedRouteDestinationSystemId;
    private RouteOptimizationMode plottedRouteOptimizationMode = RouteOptimizationMode.ShortestDistance;
    private long plottedRouteConfigurationStamp;
    private readonly Dictionary<RouteGraphCacheKey, IReadOnlyDictionary<int, List<SectorMapRouteLeg>>> routeGraphCaches = [];
    private readonly Dictionary<int, IReadOnlyList<SectorMapRoute>> generatedSectorRouteCache = [];
    private bool browserSessionRestored;
    private bool browserSessionReady;
    private IReadOnlyList<EntityImage> entityImages = [];
    private bool entityImagesLoaded;
    private bool entityImagesLoading;
    private string imageUploadStatus = string.Empty;
    private string routeOriginText = string.Empty;
    private int routeOriginSystemId;
    private string routeDestinationText = string.Empty;
    private int routeDestinationSystemId;
    private string explorerRenderError = string.Empty;
    private int sectorMapViewDistanceParsecs = DefaultSectorMapViewDistanceParsecs;
    private int sectorMapRenderLimit = SectorMapUnrestrictedRenderedSystems;
    private string sectorMapPerformanceStatus = string.Empty;
    private RouteOptimizationMode routeOptimizationMode = RouteOptimizationMode.ShortestDistance;
    private HashSet<int> avoidedEmpireIds = [];
    private HashSet<int> avoidedSystemIds = [];

    private IReadOnlyDictionary<int, AlienRace>? alienRacesById;
    private IReadOnlyDictionary<int, Empire>? empiresById;
    private IReadOnlyDictionary<int, World>? worldsById;

    private ExplorerSectorCache GetSectorCache(StarWinSector sector)
    {
        return sectorCacheBuilder.Get(sector);
    }

    private ExplorerSectorSummary GetSectorSummary(StarWinSector sector)
    {
        return sectorCacheBuilder.GetSummary(sector);
    }

    private static bool ShouldUseSectionCache(string sectionName)
    {
        return sectionName is "Systems" or "Colonies" or "Aliens" or "Empires";
    }

    private IReadOnlyDictionary<int, AlienRace> AlienRacesById =>
        alienRacesById ??= ExplorerAlienRaces.ToDictionary(race => race.Id);

    private IReadOnlyDictionary<int, Empire> EmpiresById =>
        empiresById ??= ExplorerEmpires.ToDictionary(empire => empire.Id);

    private IReadOnlyDictionary<int, World> WorldsById =>
        worldsById ??= ExplorerSectors
            .SelectMany(sector => sector.Systems)
            .SelectMany(system => system.Worlds)
            .GroupBy(world => world.Id)
            .ToDictionary(group => group.Key, group => group.First());

    private IReadOnlyList<StarWinSector> ExplorerSectors => explorerContext.Sectors;

    private IReadOnlyList<AlienRace> ExplorerAlienRaces => explorerContext.AlienRaces;

    private IReadOnlyList<Empire> ExplorerEmpires => explorerContext.Empires;

    protected override async Task OnInitializedAsync()
    {
        activeSection = GetSectionNameFromSlug(SectionSlug);
        lastAppliedSectionSlug = SectionSlug ?? string.Empty;
        await RefreshExplorerDataAsync();

        var initialSector = RequestedSectorId is int requestedSectorId
            ? ExplorerSectors.FirstOrDefault(sector => sector.Id == requestedSectorId) ?? explorerContext.CurrentSector
            : explorerContext.CurrentSector;

        selectedSectorId = initialSector.Id;
        await LoadSectorOverviewDataAsync(initialSector.Id);
        selectedSystemId = initialSector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(initialSector, selectedSystemId);
        routeOriginSystemId = selectedSystemId;
        routeOriginText = FormatSelectedSystem(initialSector, routeOriginSystemId);
        selectedWorldId = initialSector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = initialSector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Colony?.Id ?? 0;
        SelectDefaultCivilizationRecords(initialSector);
        ApplyRequestedSelection(initialSector);
    }

    protected override void OnParametersSet()
    {
        var currentSectionSlug = SectionSlug ?? string.Empty;
        if (string.Equals(lastAppliedSectionSlug, currentSectionSlug, StringComparison.Ordinal))
        {
            return;
        }

        lastAppliedSectionSlug = currentSectionSlug;
        activeSection = GetSectionNameFromSlug(SectionSlug);
        if (ExplorerSectors.Count > 0)
        {
            if (RequestedSectorId is int requestedSectorId
                && ExplorerSectors.Any(sector => sector.Id == requestedSectorId))
            {
                selectedSectorId = requestedSectorId;
            }

            ApplyRequestedSelection(GetSelectedSector());
        }
    }

    private async Task RefreshExplorerDataAsync(CancellationToken cancellationToken = default)
    {
        var previousSectorIds = ExplorerSectors.Select(sector => sector.Id).ToList();
        var previousSectorId = selectedSectorId;
        var previousSystemId = selectedSystemId;
        var previousWorldId = selectedWorldId;
        var previousColonyId = selectedColonyId;
        var previousHabitatId = selectedHabitatId;
        var previousRaceId = selectedRaceId;
        var previousEmpireId = selectedEmpireId;

        explorerContext = await ExplorerContextService.LoadShellAsync(
            includeSavedRoutes: RequiresSavedRoutesInShell(activeSection),
            includeReferenceData: RequiresReferenceDataInShell(activeSection),
            cancellationToken: cancellationToken);
        loadedSectorSectionsById.Clear();
        ResetExplorerCaches(previousSectorIds);

        if (ExplorerSectors.Count == 0)
        {
            selectedSectorId = 0;
            selectedSystemId = 0;
            selectedWorldId = 0;
            selectedColonyId = 0;
            selectedHabitatId = 0;
            selectedRaceId = 0;
            selectedEmpireId = 0;
            selectedSystemText = string.Empty;
            routeOriginSystemId = 0;
            routeOriginText = string.Empty;
            routeDestinationSystemId = 0;
            routeDestinationText = string.Empty;
            return;
        }

        var selectedSector = ExplorerSectors.FirstOrDefault(sector => sector.Id == previousSectorId) ?? explorerContext.CurrentSector;
        selectedSector = await EnsureSectorDataLoadedAsync(selectedSector.Id, activeSection, cancellationToken) ?? selectedSector;
        selectedSectorId = selectedSector.Id;
        await LoadSectorOverviewDataAsync(selectedSector.Id, cancellationToken);
        selectedSystemId = selectedSector.Systems.Any(system => system.Id == previousSystemId)
            ? previousSystemId
            : selectedSector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedWorldId = selectedSector.Systems
            .SelectMany(system => system.Worlds)
            .Any(world => world.Id == previousWorldId)
            ? previousWorldId
            : selectedSector.Systems.FirstOrDefault(system => system.Id == selectedSystemId)?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = selectedSector.Systems
            .SelectMany(system => system.Worlds)
            .Select(world => world.Colony)
            .Where(colony => colony is not null)
            .Select(colony => colony!)
            .Any(colony => colony.Id == previousColonyId)
            ? previousColonyId
            : selectedSector.Systems
                .SelectMany(system => system.Worlds)
                .FirstOrDefault(world => world.Id == selectedWorldId)
                ?.Colony?.Id ?? 0;
        selectedHabitatId = selectedSector.Systems
            .SelectMany(system => system.SpaceHabitats)
            .Any(habitat => habitat.Id == previousHabitatId)
            ? previousHabitatId
            : 0;
        selectedSystemText = FormatSelectedSystem(selectedSector, selectedSystemId);
        routeOriginSystemId = selectedSector.Systems.Any(system => system.Id == routeOriginSystemId)
            ? routeOriginSystemId
            : selectedSystemId;
        routeOriginText = FormatSelectedSystem(selectedSector, routeOriginSystemId);
        routeDestinationSystemId = selectedSector.Systems.Any(system => system.Id == routeDestinationSystemId)
            ? routeDestinationSystemId
            : 0;
        routeDestinationText = routeDestinationSystemId == 0 ? string.Empty : FormatSelectedSystem(selectedSector, routeDestinationSystemId);

        var sectorSummary = GetSectorSummary(selectedSector);
        selectedRaceId = sectorSummary.RaceIds.Contains(previousRaceId)
            ? previousRaceId
            : ExplorerAlienRaces.FirstOrDefault(race => sectorSummary.RaceIds.Contains(race.Id))?.Id ?? 0;
        selectedEmpireId = sectorSummary.EmpireIds.Contains(previousEmpireId)
            ? previousEmpireId
            : ExplorerEmpires.FirstOrDefault(empire => sectorSummary.EmpireIds.Contains(empire.Id))?.Id ?? 0;

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            RunSearch();
        }
    }

    private void ResetExplorerCaches(IEnumerable<int>? sectorIdsToInvalidate = null)
    {
        foreach (var sectorId in sectorIdsToInvalidate ?? ExplorerSectors.Select(sector => sector.Id))
        {
            sectorCacheBuilder.Invalidate(sectorId);
            generatedSectorRouteCache.Remove(sectorId);
            sectorOverviewDataById.Remove(sectorId);
        }

        alienRacesById = null;
        empiresById = null;
        worldsById = null;
        routeGraphCaches.Clear();
        renderedOverview = false;
    }

    private async Task<StarWinSector?> EnsureSectorDataLoadedAsync(
        int sectorId,
        string sectionName,
        CancellationToken cancellationToken = default)
    {
        var requiredSections = GetSectorLoadSections(sectionName);
        if (sectorId <= 0
            || requiredSections == ExplorerSectorLoadSections.None)
        {
            return ExplorerSectors.FirstOrDefault(sector => sector.Id == sectorId);
        }

        loadedSectorSectionsById.TryGetValue(sectorId, out var loadedSections);
        if ((loadedSections & requiredSections) == requiredSections)
        {
            return ExplorerSectors.FirstOrDefault(sector => sector.Id == sectorId);
        }

        var detailedSector = await ExplorerContextService.LoadSectorAsync(sectorId, requiredSections, cancellationToken);
        if (detailedSector is null)
        {
            return ExplorerSectors.FirstOrDefault(sector => sector.Id == sectorId);
        }

        MergeSectorIntoExplorerContext(detailedSector);
        loadedSectorSectionsById[sectorId] = loadedSections | requiredSections;

        ResetExplorerCaches([sectorId]);
        return detailedSector;
    }

    private void MergeSectorIntoExplorerContext(StarWinSector sector)
    {
        var sectors = ExplorerSectors.ToList();
        var existingSectorIndex = sectors.FindIndex(item => item.Id == sector.Id);
        if (existingSectorIndex >= 0)
        {
            sectors[existingSectorIndex] = sector;
        }
        else
        {
            sectors.Add(sector);
            sectors = sectors.OrderBy(item => item.Name).ToList();
        }

        var currentSector = explorerContext.CurrentSector.Id == sector.Id
            ? sector
            : sectors.FirstOrDefault(item => item.Id == explorerContext.CurrentSector.Id) ?? sector;

        explorerContext = explorerContext with
        {
            Sectors = sectors,
            CurrentSector = currentSector
        };
    }

    private static ExplorerSectorLoadSections GetSectorLoadSections(string sectionName)
    {
        return sectionName switch
        {
            "Systems" => ExplorerSectorLoadSections.AstralBodies
                | ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.SpaceHabitats,
            "Worlds" => ExplorerSectorLoadSections.AstralBodies
                | ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.WorldCharacteristics
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics
                | ExplorerSectorLoadSections.SpaceHabitats,
            "Colonies" => ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics,
            "Aliens" => ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics,
            "Empires" => ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics,
            "Configuration" => ExplorerSectorLoadSections.SavedRoutes,
            "Hyperlanes" => ExplorerSectorLoadSections.SavedRoutes,
            _ => ExplorerSectorLoadSections.None
        };
    }

