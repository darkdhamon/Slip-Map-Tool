@layout SectorExplorerLayout
@page "/sector-explorer"
@rendermode InteractiveServer
@inject IStarWinWorkspace Workspace
@inject IStarWinExplorerContextService ExplorerContextService
@inject IStarWinExplorerQueryService ExplorerQueryService
@inject IStarWinSearchService SearchService
@inject IStarWinImageService ImageService
@inject IStarWinEntityNameService EntityNameService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable
@using Microsoft.AspNetCore.WebUtilities
@using StarWin.Domain.Services

@{
    var sector = GetSelectedSector();
    var sectorSummary = GetSectorSummary(sector);
    var overviewData = GetSectorOverviewData(sector.Id);
    var usesSectionCache = ShouldUseSectionCache(activeSection);
    var needsSectorRaceList = activeSection is "Overview" or "Colonies" or "Aliens" or "Empires";
    var needsSectorEmpireList = activeSection is "Overview" or "Systems" or "Colonies" or "Empires";
    var sectionCache = usesSectionCache ? GetSectorCache(sector) : null;
    var selectedSystem = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId) ?? sector.Systems.FirstOrDefault();
    var selectedHabitat = selectedSystem?.SpaceHabitats.FirstOrDefault(habitat => habitat.Id == selectedHabitatId);
    var selectedWorld = selectedHabitat is null
        ? selectedSystem?.Worlds.FirstOrDefault(world => world.Id == selectedWorldId) ?? selectedSystem?.Worlds.FirstOrDefault()
        : null;
    var sectorWorlds = sectionCache?.Worlds ?? [];
    var sectorColonies = sectionCache?.Colonies ?? [];
    var sectorRaceIds = sectionCache?.RaceIds ?? sectorSummary.RaceIds;
    var sectorEmpireIds = sectionCache?.EmpireIds ?? sectorSummary.EmpireIds;
    var sectorRaces = needsSectorRaceList
        ? ExplorerAlienRaces.Where(race => sectorRaceIds.Contains(race.Id)).OrderBy(race => race.Name).ToList()
        : [];
    var sectorEmpires = needsSectorEmpireList
        ? ExplorerEmpires.Where(empire => sectorEmpireIds.Contains(empire.Id)).OrderBy(empire => empire.Name).ToList()
        : [];
    var selectedColony = activeSection is "Colonies" or "Empires"
        ? sectorColonies.Select(item => item.Colony).FirstOrDefault(colony => colony.Id == selectedColonyId)
            ?? selectedWorld?.Colony
            ?? sectorColonies.Select(item => item.Colony).FirstOrDefault()
        : null;
    var selectedColonyWorld = selectedColony is null || !WorldsById.TryGetValue(selectedColony.WorldId, out var colonyWorld)
        ? null
        : colonyWorld;
    RenderFragment? heroContent = activeSection == "Overview"
        ? @<ExplorerHero />
        : null;
    var layoutState = new SectorExplorerLayoutState(
        heroContent,
        ExplorerSectors,
        sector.Systems.ToList(),
        selectedSectorId,
        EventCallback.Factory.Create<int>(this, HandleSectorChangedAsync),
        selectedSystemText,
        EventCallback.Factory.Create<string>(this, HandleSelectedSystemTextChanged),
        searchQuery,
        EventCallback.Factory.Create<string>(this, value =>
        {
            searchQuery = value;
            RunSearch();
        }),
        searchResults,
        EventCallback.Factory.Create<StarWinSearchResult>(this, NavigateToSearchResult),
        sections,
        activeSection,
        explorerRenderError,
        DisplayResultType,
        BuildSectionRoute);
}

<PageTitle>Sector Explorer | Starforged Atlas</PageTitle>
<SectorExplorerLayoutSync State="layoutState" />

@if (activeSection == "Overview")
{
    <ExplorerMetricsBand SystemCount="@(overviewData?.SystemCount ?? 0)"
                         WorldCount="@(overviewData?.WorldCount ?? 0)"
                         ColonyCount="@(overviewData?.ColonyCount ?? 0)"
                         EmpireCount="@(overviewData?.EmpireCount ?? 0)"
                         RaceCount="@(overviewData?.RaceCount ?? 0)" />
}

@switch (activeSection)
{
    case "Overview":
        <section class="overview-layout">
            @if (!overviewMapWorkspaceReady)
            {
                <div class="sector-map-three" aria-label="sector map workspace">
                    <article class="map-request-panel">
                        <span class="panel-kicker">Map workspace</span>
                        <h2>Preparing map workspace</h2>
                        <p>The Overview page is ready first. The 3D map and route planner load in right after the initial page render so they do not block the rest of the Explorer.</p>
                    </article>
                </div>

                <div class="stacked-panels">
                    <article class="feature-panel route-planner-panel">
                        <span class="panel-kicker">Route planner</span>
                        <h2>Preparing route-planning workspace</h2>
                        <p>The route planner is loading as a follow-up component after the main Overview content appears.</p>
                    </article>
                </div>
            }
            else
            {
                <SectorExplorerMapWorkspace SelectedSector="sector"
                                            SelectedSystemId="selectedSystemId"
                                            SelectedSystemChanged="HandleOverviewSystemSelectedAsync"
                                            OpenSystemRecordRequested="HandleOverviewOpenSystemRecordRequestedAsync"
                                            OverviewData="overviewData"
                                            AutoLoadRequested="autoLoadSectorMap"
                                            AutoLoadRequestedChanged="HandleOverviewAutoLoadSectorMapChangedAsync" />
            }
        </section>
        break;
}
@code {
    private const int ColonyBatchSize = 120;
    private const int ExplorerListBatchSize = 120;
    private const int ComboAllFilterId = -1;
    private const string ExplorerSessionStorageKey = "starforgedAtlas.explorerSelection";

    [SupplyParameterFromQuery(Name = "sectorId")]
    public int? RequestedSectorId { get; set; }

    [SupplyParameterFromQuery(Name = "systemId")]
    public int? RequestedSystemId { get; set; }

    [SupplyParameterFromQuery(Name = "worldId")]
    public int? RequestedWorldId { get; set; }

    [SupplyParameterFromQuery(Name = "colonyId")]
    public int? RequestedColonyId { get; set; }

    [SupplyParameterFromQuery(Name = "habitatId")]
    public int? RequestedHabitatId { get; set; }

    [SupplyParameterFromQuery(Name = "raceId")]
    public int? RequestedRaceId { get; set; }

    [SupplyParameterFromQuery(Name = "empireId")]
    public int? RequestedEmpireId { get; set; }

    private static readonly IReadOnlyList<string> sections = SectorExplorerSections.All;
    private readonly ExplorerSectorCacheBuilder sectorCacheBuilder = new();
    private readonly Dictionary<int, ExplorerSectorOverviewData> sectorOverviewDataById = [];
    private readonly Dictionary<int, ExplorerSectorLoadSections> loadedSectorSectionsById = [];
    private StarWinExplorerContext explorerContext = StarWinExplorerContext.Empty;
    private string activeSection = "Overview";
    private (int? SectorId, int? SystemId, int? WorldId, int? ColonyId, int? HabitatId, int? RaceId, int? EmpireId) lastAppliedRequest;
    private string sectionLoadingTarget = string.Empty;
    private string sectionLoadingStatus = string.Empty;
    private bool sectionLoadingVisible;
    private bool sectionLoadingAwaitingTargetRender;
    private DateTimeOffset sectionLoadingStartedAtUtc;
    private bool overviewMapWorkspaceReady;
    private int selectedSectorId;
    private int selectedSystemId;
    private string selectedSystemText = string.Empty;
    private int selectedWorldId;
    private int selectedColonyId;
    private int selectedHabitatId;
    private int selectedRaceId;
    private int selectedEmpireId;
    private string searchQuery = string.Empty;
    private IReadOnlyList<StarWinSearchResult> searchResults = [];
    private DotNetObjectReference<SectorExplorer>? dotNetReference;
    private IJSObjectReference? loadMoreScrollModule;
    private bool autoLoadSectorMap;
    private bool browserSessionRestored;
    private bool browserSessionReady;
    private IReadOnlyList<EntityImage> entityImages = [];
    private bool entityImagesLoaded;
    private bool entityImagesLoading;
    private string imageUploadStatus = string.Empty;
    private string explorerRenderError = string.Empty;

    private IReadOnlyDictionary<int, AlienRace>? alienRacesById;
    private IReadOnlyDictionary<int, Empire>? empiresById;
    private IReadOnlyDictionary<int, World>? worldsById;

    private ExplorerSectorCache GetSectorCache(StarWinSector sector)
    {
        return sectorCacheBuilder.Get(sector);
    }

    private ExplorerSectorSummary GetSectorSummary(StarWinSector sector)
    {
        return sectorCacheBuilder.GetSummary(sector);
    }

    private static bool ShouldUseSectionCache(string sectionName)
    {
        return sectionName is "Systems" or "Colonies" or "Aliens" or "Empires";
    }

    private IReadOnlyDictionary<int, AlienRace> AlienRacesById =>
        alienRacesById ??= ExplorerAlienRaces.ToDictionary(race => race.Id);

    private IReadOnlyDictionary<int, Empire> EmpiresById =>
        empiresById ??= ExplorerEmpires.ToDictionary(empire => empire.Id);

    private IReadOnlyDictionary<int, World> WorldsById =>
        worldsById ??= ExplorerSectors
            .SelectMany(sector => sector.Systems)
            .SelectMany(system => system.Worlds)
            .GroupBy(world => world.Id)
            .ToDictionary(group => group.Key, group => group.First());

    private IReadOnlyList<StarWinSector> ExplorerSectors => explorerContext.Sectors;

    private IReadOnlyList<AlienRace> ExplorerAlienRaces => explorerContext.AlienRaces;

    private IReadOnlyList<Empire> ExplorerEmpires => explorerContext.Empires;

    protected override async Task OnInitializedAsync()
    {
        await RefreshExplorerDataAsync();

        var initialSector = RequestedSectorId is int requestedSectorId
            ? ExplorerSectors.FirstOrDefault(sector => sector.Id == requestedSectorId) ?? explorerContext.CurrentSector
            : explorerContext.CurrentSector;

        selectedSectorId = initialSector.Id;
        await LoadSectorOverviewDataAsync(initialSector.Id);
        selectedSystemId = initialSector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(initialSector, selectedSystemId);
        selectedWorldId = initialSector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = initialSector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Colony?.Id ?? 0;
        SelectDefaultCivilizationRecords(initialSector);
        ApplyRequestedSelection(initialSector);
        lastAppliedRequest = GetCurrentRequest();
    }

    protected override void OnParametersSet()
    {
        var currentRequest = GetCurrentRequest();
        if (currentRequest == lastAppliedRequest)
        {
            return;
        }

        if (ExplorerSectors.Count > 0)
        {
            if (RequestedSectorId is int requestedSectorId
                && ExplorerSectors.Any(sector => sector.Id == requestedSectorId))
            {
                selectedSectorId = requestedSectorId;
            }

            ApplyRequestedSelection(GetSelectedSector());
        }

        lastAppliedRequest = currentRequest;
    }

    private async Task RefreshExplorerDataAsync(CancellationToken cancellationToken = default)
    {
        var previousSectorIds = ExplorerSectors.Select(sector => sector.Id).ToList();
        var previousSectorId = selectedSectorId;
        var previousSystemId = selectedSystemId;
        var previousWorldId = selectedWorldId;
        var previousColonyId = selectedColonyId;
        var previousHabitatId = selectedHabitatId;
        var previousRaceId = selectedRaceId;
        var previousEmpireId = selectedEmpireId;

        explorerContext = await ExplorerContextService.LoadShellAsync(
            includeSavedRoutes: RequiresSavedRoutesInShell(activeSection),
            includeReferenceData: RequiresReferenceDataInShell(activeSection),
            cancellationToken: cancellationToken);
        loadedSectorSectionsById.Clear();
        ResetExplorerCaches(previousSectorIds);

        if (ExplorerSectors.Count == 0)
        {
            selectedSectorId = 0;
            selectedSystemId = 0;
            selectedWorldId = 0;
            selectedColonyId = 0;
            selectedHabitatId = 0;
            selectedRaceId = 0;
            selectedEmpireId = 0;
            selectedSystemText = string.Empty;
            return;
        }

        var selectedSector = ExplorerSectors.FirstOrDefault(sector => sector.Id == previousSectorId) ?? explorerContext.CurrentSector;
        selectedSector = await EnsureSectorDataLoadedAsync(selectedSector.Id, activeSection, cancellationToken) ?? selectedSector;
        selectedSectorId = selectedSector.Id;
        await LoadSectorOverviewDataAsync(selectedSector.Id, cancellationToken);
        selectedSystemId = selectedSector.Systems.Any(system => system.Id == previousSystemId)
            ? previousSystemId
            : selectedSector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedWorldId = selectedSector.Systems
            .SelectMany(system => system.Worlds)
            .Any(world => world.Id == previousWorldId)
            ? previousWorldId
            : selectedSector.Systems.FirstOrDefault(system => system.Id == selectedSystemId)?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = selectedSector.Systems
            .SelectMany(system => system.Worlds)
            .Select(world => world.Colony)
            .Where(colony => colony is not null)
            .Select(colony => colony!)
            .Any(colony => colony.Id == previousColonyId)
            ? previousColonyId
            : selectedSector.Systems
                .SelectMany(system => system.Worlds)
                .FirstOrDefault(world => world.Id == selectedWorldId)
                ?.Colony?.Id ?? 0;
        selectedHabitatId = selectedSector.Systems
            .SelectMany(system => system.SpaceHabitats)
            .Any(habitat => habitat.Id == previousHabitatId)
            ? previousHabitatId
            : 0;
        selectedSystemText = FormatSelectedSystem(selectedSector, selectedSystemId);

        var sectorSummary = GetSectorSummary(selectedSector);
        selectedRaceId = sectorSummary.RaceIds.Contains(previousRaceId)
            ? previousRaceId
            : ExplorerAlienRaces.FirstOrDefault(race => sectorSummary.RaceIds.Contains(race.Id))?.Id ?? 0;
        selectedEmpireId = sectorSummary.EmpireIds.Contains(previousEmpireId)
            ? previousEmpireId
            : ExplorerEmpires.FirstOrDefault(empire => sectorSummary.EmpireIds.Contains(empire.Id))?.Id ?? 0;

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            RunSearch();
        }
    }

    private void ResetExplorerCaches(IEnumerable<int>? sectorIdsToInvalidate = null)
    {
        foreach (var sectorId in sectorIdsToInvalidate ?? ExplorerSectors.Select(sector => sector.Id))
        {
            sectorCacheBuilder.Invalidate(sectorId);
            sectorOverviewDataById.Remove(sectorId);
        }

        alienRacesById = null;
        empiresById = null;
        worldsById = null;
    }

    private async Task<StarWinSector?> EnsureSectorDataLoadedAsync(
        int sectorId,
        string sectionName,
        CancellationToken cancellationToken = default)
    {
        var requiredSections = GetSectorLoadSections(sectionName);
        if (sectorId <= 0
            || requiredSections == ExplorerSectorLoadSections.None)
        {
            return ExplorerSectors.FirstOrDefault(sector => sector.Id == sectorId);
        }

        loadedSectorSectionsById.TryGetValue(sectorId, out var loadedSections);
        if ((loadedSections & requiredSections) == requiredSections)
        {
            return ExplorerSectors.FirstOrDefault(sector => sector.Id == sectorId);
        }

        var detailedSector = await ExplorerContextService.LoadSectorAsync(sectorId, requiredSections, cancellationToken);
        if (detailedSector is null)
        {
            return ExplorerSectors.FirstOrDefault(sector => sector.Id == sectorId);
        }

        MergeSectorIntoExplorerContext(detailedSector);
        loadedSectorSectionsById[sectorId] = loadedSections | requiredSections;

        ResetExplorerCaches([sectorId]);
        return detailedSector;
    }

    private void MergeSectorIntoExplorerContext(StarWinSector sector)
    {
        var sectors = ExplorerSectors.ToList();
        var existingSectorIndex = sectors.FindIndex(item => item.Id == sector.Id);
        if (existingSectorIndex >= 0)
        {
            sectors[existingSectorIndex] = sector;
        }
        else
        {
            sectors.Add(sector);
            sectors = sectors.OrderBy(item => item.Name).ToList();
        }

        var currentSector = explorerContext.CurrentSector.Id == sector.Id
            ? sector
            : sectors.FirstOrDefault(item => item.Id == explorerContext.CurrentSector.Id) ?? sector;

        explorerContext = explorerContext with
        {
            Sectors = sectors,
            CurrentSector = currentSector
        };
    }

    private static ExplorerSectorLoadSections GetSectorLoadSections(string sectionName)
    {
        return sectionName switch
        {
            "Systems" => ExplorerSectorLoadSections.AstralBodies
                | ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.SpaceHabitats,
            "Worlds" => ExplorerSectorLoadSections.AstralBodies
                | ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.WorldCharacteristics
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics
                | ExplorerSectorLoadSections.SpaceHabitats,
            "Colonies" => ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics,
            "Aliens" => ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics,
            "Empires" => ExplorerSectorLoadSections.Worlds
                | ExplorerSectorLoadSections.Colonies
                | ExplorerSectorLoadSections.ColonyDemographics,
            "Configuration" => ExplorerSectorLoadSections.SavedRoutes,
            "Hyperlanes" => ExplorerSectorLoadSections.SavedRoutes,
            _ => ExplorerSectorLoadSections.None
        };
    }

    private static bool RequiresOverviewData(string sectionName)
    {
        return sectionName == "Overview";
    }

    private static bool RequiresSavedRoutesInShell(string sectionName)
    {
        return sectionName is "Configuration" or "Hyperlanes";
    }

    private static bool RequiresReferenceDataInShell(string sectionName)
    {
        return sectionName is "Systems" or "Worlds" or "Colonies" or "Aliens" or "Empires";
    }

    private ExplorerSectorOverviewData? GetSectorOverviewData(int sectorId)
    {
        return sectorOverviewDataById.TryGetValue(sectorId, out var overviewData) ? overviewData : null;
    }

    private async Task LoadSectorOverviewDataAsync(int sectorId, CancellationToken cancellationToken = default)
    {
        if (sectorId <= 0 || !RequiresOverviewData(activeSection))
        {
            return;
        }

        sectorOverviewDataById[sectorId] = await ExplorerQueryService.LoadSectorOverviewAsync(sectorId, cancellationToken);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await RestoreExplorerSessionAsync();
            browserSessionReady = true;
            if (activeSection == "Overview" && !overviewMapWorkspaceReady)
            {
                overviewMapWorkspaceReady = true;
            }

            StateHasChanged();
            return;
        }

        try
        {
            if (activeSection == "Timeline")
            {
                await CompleteSectionLoadingIfReadyAsync();
                return;
            }

            if (activeSection == "Systems")
            {
                await CompleteSectionLoadingIfReadyAsync();
                _ = EnsureEntityImagesLoadedAsync(backgroundLoad: true);
                return;
            }

            if (activeSection == "Overview")
            {
                if (!overviewMapWorkspaceReady)
                {
                    overviewMapWorkspaceReady = true;
                    StateHasChanged();
                    return;
                }

                await CompleteSectionLoadingIfReadyAsync();
                return;
            }

            await CompleteSectionLoadingIfReadyAsync();
        }
        catch (Exception ex)
        {
            explorerRenderError = ex.GetBaseException().Message;
            sectionLoadingVisible = false;
            sectionLoadingAwaitingTargetRender = false;
            sectionLoadingTarget = string.Empty;
            sectionLoadingStatus = string.Empty;
            await HideSectionLoadingOverlayAsync();
            StateHasChanged();
        }
    }

    private async Task EnsureEntityImagesLoadedAsync(bool backgroundLoad = false)
    {
        if (entityImagesLoaded || entityImagesLoading)
        {
            return;
        }

        entityImagesLoading = true;
        try
        {
            entityImages = await ImageService.GetImagesAsync();
            entityImagesLoaded = true;
            explorerRenderError = string.Empty;

            if (backgroundLoad)
            {
                await InvokeAsync(StateHasChanged);
            }
            else
            {
                StateHasChanged();
            }
        }
        finally
        {
            entityImagesLoading = false;
        }
    }

    private async Task SelectSectionAsync(string sectionName)
    {
        if (activeSection == sectionName || sectionLoadingVisible)
        {
            return;
        }

        sectionLoadingTarget = sectionName;
        sectionLoadingStatus = $"Preparing {sectionName} records...";
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingVisible = true;
        sectionLoadingStartedAtUtc = DateTimeOffset.UtcNow;
        explorerRenderError = string.Empty;
        StateHasChanged();
        await ShowSectionLoadingOverlayAsync(sectionName);

        await Task.Delay(80);

        sectionLoadingStatus = $"Loading {sectionName} data...";
        StateHasChanged();
        await EnsureSectorDataLoadedAsync(selectedSectorId, sectionName);

        sectionLoadingStatus = $"Rendering {sectionName}...";
        SetActiveSection(sectionName);
        sectionLoadingAwaitingTargetRender = true;
        StateHasChanged();
    }

    private async Task CompleteSectionLoadingIfReadyAsync()
    {
        if (!sectionLoadingVisible
            || !sectionLoadingAwaitingTargetRender
            || !string.Equals(activeSection, sectionLoadingTarget, StringComparison.Ordinal))
        {
            return;
        }

        sectionLoadingStatus = $"{activeSection} ready.";
        StateHasChanged();

        var elapsed = DateTimeOffset.UtcNow - sectionLoadingStartedAtUtc;
        var remainingVisibleTime = TimeSpan.FromMilliseconds(450) - elapsed;
        if (remainingVisibleTime > TimeSpan.Zero)
        {
            await Task.Delay(remainingVisibleTime);
        }

        sectionLoadingVisible = false;
        sectionLoadingAwaitingTargetRender = false;
        sectionLoadingTarget = string.Empty;
        sectionLoadingStatus = string.Empty;
        await HideSectionLoadingOverlayAsync();
        StateHasChanged();
    }

    private async Task HideSectionLoadingOverlayAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("starforgedAtlasNavigation.hideSectionLoading");
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private async Task ShowSectionLoadingOverlayAsync(string sectionName)
    {
        try
        {
            await JS.InvokeVoidAsync("starforgedAtlasNavigation.showSectionLoading", sectionName);
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }

    private void SelectSystem(int systemId)
    {
        selectedSystemId = systemId;
        var sector = GetSelectedSector();
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        if (activeSection == "Overview")
        {
            SetActiveSection("Overview");
            SelectDefaultWorld();
            _ = PersistExplorerSessionAsync();
            return;
        }

        NavigateToSystemRecord(systemId);
    }

    private void OpenSelectedSystemRecord()
    {
        NavigateToSystemRecord(selectedSystemId);
    }

    private void NavigateToSystemRecord(int systemId)
    {
        if (systemId <= 0)
        {
            return;
        }

        NavigationManager.NavigateTo(SectorExplorerRoutes.BuildSectionUri("Systems", selectedSectorId, systemId));
    }

    private void SelectWorld(int worldId)
    {
        var sector = GetSelectedSector();
        var system = sector.Systems.FirstOrDefault(system => system.Worlds.Any(world => world.Id == worldId));
        if (system is not null)
        {
            selectedSystemId = system.Id;
            selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        }

        NavigationManager.NavigateTo(SectorExplorerRoutes.BuildSectionUri("Worlds", selectedSectorId, selectedSystemId, worldId: worldId));
        _ = PersistExplorerSessionAsync();
    }

    private void SelectColony(int colonyId)
    {
        var sector = GetSelectedSector();
        var listing = sector.Systems
            .SelectMany(system => system.Worlds.Select(world => new { system, world }))
            .FirstOrDefault(item => item.world.Colony?.Id == colonyId);
        if (listing is null)
        {
            return;
        }

        NavigationManager.NavigateTo(SectorExplorerRoutes.BuildSectionUri("Colonies", selectedSectorId, listing.system.Id, listing.world.Id, colonyId));
    }

    private void SelectRace(int raceId)
    {
        selectedRaceId = raceId;
        SetActiveSection("Aliens");
    }

    private void SelectEmpire(int empireId)
    {
        selectedEmpireId = empireId;
        NavigationManager.NavigateTo(SectorExplorerRoutes.BuildSectionUri("Empires", selectedSectorId, selectedSystemId, empireId: empireId));
    }

    private async Task SelectDefaultSystem()
    {
        await LoadSectorOverviewDataAsync(selectedSectorId);
        var loadedSector = await EnsureSectorDataLoadedAsync(selectedSectorId, activeSection);
        if (loadedSector is not null)
        {
            selectedSectorId = loadedSector.Id;
        }

        var sector = GetSelectedSector();
        selectedSystemId = sector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        selectedWorldId = sector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = sector.Systems.FirstOrDefault()?.Worlds.FirstOrDefault()?.Colony?.Id ?? 0;
        selectedHabitatId = 0;
        SelectDefaultCivilizationRecords(sector);
        SyncCurrentExplorerRoute(replaceHistory: true);
        await PersistExplorerSessionAsync();
    }

    private void SelectDefaultWorld()
    {
        var sector = GetSelectedSector();
        var system = sector.Systems.FirstOrDefault(item => item.Id == selectedSystemId);
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        selectedWorldId = system?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = system?.Worlds.FirstOrDefault()?.Colony?.Id ?? 0;
        selectedHabitatId = 0;
        _ = PersistExplorerSessionAsync();
    }

    private void ApplySelectedSystemText()
    {
        var sector = GetSelectedSector();
        var systemId = ParseComboId(selectedSystemText);
        if (systemId == ComboAllFilterId || sector.Systems.All(system => system.Id != systemId))
        {
            selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
            return;
        }

        selectedSystemId = systemId;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        SelectDefaultWorld();
    }

    private async Task HandleSectorChangedAsync(int sectorId)
    {
        selectedSectorId = sectorId;
        await SelectDefaultSystem();
    }

    private Task HandleSelectedSystemTextChanged(string value)
    {
        selectedSystemText = value;
        ApplySelectedSystemText();
        return Task.CompletedTask;
    }

    private async Task HandleOverviewSystemSelectedAsync(int systemId)
    {
        if (systemId <= 0)
        {
            return;
        }

        selectedSystemId = systemId;
        SelectDefaultWorld();
        await PersistExplorerSessionAsync();
    }

    private async Task HandleOverviewAutoLoadSectorMapChangedAsync(bool value)
    {
        autoLoadSectorMap = value;
        await PersistExplorerSessionAsync();
    }

    private Task HandleOverviewOpenSystemRecordRequestedAsync(int systemId)
    {
        NavigateToSystemRecord(systemId);
        return Task.CompletedTask;
    }

    private async Task ConfigureRecordObserverAsync(
        string key,
        bool hasMoreRecords,
        Func<bool> isConfigured,
        Action<bool> setConfigured,
        ElementReference loadMoreElement,
        string loadMoreMethodName)
    {
        if (!hasMoreRecords)
        {
            setConfigured(false);
            if (loadMoreScrollModule is not null)
            {
                await loadMoreScrollModule.InvokeVoidAsync("disconnectLoadMore", key);
            }

            return;
        }

        if (isConfigured())
        {
            return;
        }

        loadMoreScrollModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/timelineInfiniteScroll.js");
        dotNetReference ??= DotNetObjectReference.Create(this);
        await loadMoreScrollModule.InvokeVoidAsync("observeLoadMore", key, loadMoreElement, dotNetReference, loadMoreMethodName);
        setConfigured(true);
    }

    private async Task RestoreExplorerSessionAsync()
    {
        if (browserSessionRestored)
        {
            return;
        }

        browserSessionRestored = true;
        if (RequestedSectorId is not null)
        {
            await PersistExplorerSessionAsync(force: true);
            return;
        }

        string? storedValue;
        try
        {
            storedValue = await JS.InvokeAsync<string?>("sessionStorage.getItem", ExplorerSessionStorageKey);
        }
        catch (InvalidOperationException)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(storedValue))
        {
            return;
        }

        ExplorerSessionSelection? storedSelection;
        try
        {
            storedSelection = System.Text.Json.JsonSerializer.Deserialize<ExplorerSessionSelection>(storedValue);
        }
        catch (System.Text.Json.JsonException)
        {
            return;
        }

        if (storedSelection is null)
        {
            return;
        }

        var sector = ExplorerSectors.FirstOrDefault(item => item.Id == storedSelection.SectorId);
        if (sector is null)
        {
            return;
        }

        selectedSectorId = sector.Id;
        await LoadSectorOverviewDataAsync(sector.Id);
        autoLoadSectorMap = storedSelection.AutoLoadSectorMap;
        selectedSystemId = sector.Systems.Any(system => system.Id == storedSelection.SystemId)
            ? storedSelection.SystemId
            : sector.Systems.FirstOrDefault()?.Id ?? 0;
        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        selectedWorldId = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId)?.Worlds.FirstOrDefault()?.Id ?? 0;
        selectedColonyId = sector.Systems.FirstOrDefault(system => system.Id == selectedSystemId)?.Worlds.FirstOrDefault()?.Colony?.Id ?? 0;
        selectedHabitatId = 0;
        SelectDefaultCivilizationRecords(sector);
        SyncCurrentExplorerRoute(replaceHistory: true);
    }

    private async Task PersistExplorerSessionAsync(bool force = false)
    {
        if (!browserSessionReady && !force)
        {
            return;
        }

        var selection = new ExplorerSessionSelection(selectedSectorId, selectedSystemId, autoLoadSectorMap, GetSectionSlug(activeSection));
        var value = System.Text.Json.JsonSerializer.Serialize(selection);
        try
        {
            await JS.InvokeVoidAsync("sessionStorage.setItem", ExplorerSessionStorageKey, value);
        }
        catch (InvalidOperationException)
        {
        }
    }

    private void RunSearch()
    {
        var sector = GetSelectedSector();
        var sectorSummary = GetSectorSummary(sector);

        searchResults = SearchService.Search(searchQuery)
            .Where(result => result.Type switch
            {
                StarWinSearchResultType.AlienRace => result.RaceId is int raceId && sectorSummary.RaceIds.Contains(raceId),
                StarWinSearchResultType.Empire => result.EmpireId is int empireId && sectorSummary.EmpireIds.Contains(empireId),
                _ => true
            })
            .ToList();
    }

    private void NavigateToSearchResult(StarWinSearchResult result)
    {
        SetActiveSection(sections.Contains(result.Tab) ? result.Tab : "Overview", syncRoute: false);

        if (result.SectorId is int sectorId)
        {
            selectedSectorId = sectorId;
        }

        if (result.SystemId is int systemId)
        {
            selectedSystemId = systemId;
        }

        if (result.WorldId is int worldId)
        {
            selectedWorldId = worldId;
            selectedColonyId = GetSelectedSector().Systems
                .SelectMany(system => system.Worlds)
                .FirstOrDefault(world => world.Id == worldId)
                ?.Colony?.Id ?? 0;
            selectedHabitatId = 0;
        }

        if (result.SpaceHabitatId is int habitatId)
        {
            selectedHabitatId = habitatId;
            SetActiveSection("Worlds", syncRoute: false);
        }

        if (result.RaceId is int raceId)
        {
            selectedRaceId = raceId;
        }

        if (result.EmpireId is int empireId)
        {
            selectedEmpireId = empireId;
        }

        var sector = GetSelectedSector();
        if (sector.Systems.All(system => system.Id != selectedSystemId))
        {
            selectedSystemId = sector.Systems.FirstOrDefault()?.Id ?? 0;
        }

        selectedSystemText = FormatSelectedSystem(sector, selectedSystemId);
        searchQuery = result.Title;
        searchResults = [];
        SyncCurrentExplorerRoute(replaceHistory: true);
        _ = PersistExplorerSessionAsync();
    }

    private void SetActiveSection(string sectionName, bool syncRoute = true)
    {
        activeSection = sections.Contains(sectionName) ? sectionName : "Overview";
        if (syncRoute)
        {
            SyncCurrentExplorerRoute();
        }
    }

    private void SyncCurrentExplorerRoute(bool replaceHistory = false)
    {
        var targetUri = BuildSectionUri(activeSection, selectedSectorId);
        var absoluteTargetUri = NavigationManager.ToAbsoluteUri(targetUri).ToString();
        if (string.Equals(NavigationManager.Uri, absoluteTargetUri, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        try
        {
            JS.InvokeVoidAsync("starforgedAtlasNavigation.syncExplorerUrl", targetUri, replaceHistory);
        }
        catch (InvalidOperationException)
        {
        }
        catch (JSDisconnectedException)
        {
        }
    }

