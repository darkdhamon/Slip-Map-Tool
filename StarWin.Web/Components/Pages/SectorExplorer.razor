    private object BuildSectorMap(StarWinSector sector, int focusedSystemId)
    {
        var focusedSystem = sector.Systems.FirstOrDefault(system => system.Id == focusedSystemId)
            ?? sector.Systems.FirstOrDefault();
        var routePlan = GetPlottedRoutePlan(sector);
        var routeSystemIds = routePlan?.Systems.Select(system => system.Id).ToHashSet() ?? [];
        var mappedSystems = GetSectorMapSystems(sector, focusedSystemId, routePlan).ToList();
        var routes = BuildVisibleSectorMapRoutes(
            sector,
            mappedSystems,
            selectedSystemId,
            routePlan);

        return new
        {
            sector = sector.Name,
            viewDistanceParsecs = sectorMapViewDistanceParsecs,
            fadeStartParsecs = Math.Max(0, sectorMapViewDistanceParsecs - 1),
            offLaneDistanceParsecs = GetOffLaneMaximumDistanceParsecs(sector),
            totalSystemCount = sector.Systems.Count,
            visibleSystemCount = mappedSystems.Count,
            visibleRouteCount = routes.Count,
            routeActive = routePlan is not null,
            routeSystemIds = routeSystemIds.ToArray(),
            systems = mappedSystems.Select(system => new
            {
                id = system.Id,
                name = system.Name,
                x = system.Coordinates.XParsecs,
                y = system.Coordinates.YParsecs,
                z = system.Coordinates.ZParsecs,
                distanceFromFocus = focusedSystem is null
                    ? 0
                    : SectorRoutePlanner.CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates),
                isRouteSystem = routeSystemIds.Contains(system.Id),
                showLabel = focusedSystem is null || system.Id == focusedSystem.Id || routeSystemIds.Contains(system.Id),
                bodies = system.AstralBodies.Take(3).Select(body => new
                {
                    kind = body.Kind.ToString(),
                    role = body.Role.ToString(),
                    classification = body.Classification,
                    luminosity = body.Luminosity,
                    solarMasses = body.SolarMasses,
                    imageUrl = GetPrimaryEntityImage(EntityImageTargetKind.AstralBody, body.Id)?.RelativePath
                }).ToArray()
            }).ToArray(),
            routes = routes.Select(route => new
            {
                sourceId = route.SourceSystemId,
                targetId = route.TargetSystemId,
                distanceParsecs = route.DistanceParsecs,
                travelTimeYears = route.TravelTimeYears,
                hyperlaneTechLevel = route.TechnologyLevel,
                tierName = route.TierName,
                primaryOwnerEmpireName = route.PrimaryOwnerEmpireName,
                secondaryOwnerEmpireName = route.SecondaryOwnerEmpireName
            }).ToArray(),
            routePath = (routePlan?.Legs ?? []).Select(leg => new
            {
                sourceId = leg.Source.Id,
                targetId = leg.Target.Id,
                distanceParsecs = leg.DistanceParsecs,
                travelTimeYears = leg.TravelTimeYears,
                hyperlaneTechLevel = leg.TechnologyLevel,
                tierName = leg.TierName,
                isHyperlane = leg.IsHyperlane,
                primaryOwnerEmpireName = leg.PrimaryOwnerEmpireName,
                secondaryOwnerEmpireName = leg.SecondaryOwnerEmpireName
            }).ToArray()
        };
    }

    private IReadOnlyList<StarSystem> GetSectorMapSystems(StarWinSector sector, int focusedSystemId, SectorMapRoutePlan? routePlan = null)
    {
        var focusedSystem = sector.Systems.FirstOrDefault(system => system.Id == focusedSystemId)
            ?? sector.Systems.FirstOrDefault();

        if (focusedSystem is null)
        {
            return [];
        }

        var nearbySystems = sector.Systems
            .Select(system => new
            {
                System = system,
                Distance = SectorRoutePlanner.CalculateParsecDistance(focusedSystem.Coordinates, system.Coordinates)
            })
            .Where(item => item.Distance <= sectorMapViewDistanceParsecs)
            .OrderBy(item => item.Distance)
            .ThenBy(item => item.System.Name)
            .Take(sectorMapRenderLimit)
            .Select(item => item.System)
            .ToList();

        if (routePlan is not null)
        {
            var mappedSystemIds = nearbySystems.Select(system => system.Id).ToHashSet();
            foreach (var routeSystem in routePlan.Systems)
            {
                if (mappedSystemIds.Add(routeSystem.Id))
                {
                    nearbySystems.Add(routeSystem);
                }
            }
        }

        return nearbySystems;
    }

    private SectorMapRoutePlan? GetPlottedRoutePlan(StarWinSector sector)
    {
        if (plottedRoutePlan is null
            || plottedRouteSectorId != sector.Id
            || plottedRouteOriginSystemId != routeOriginSystemId
            || plottedRouteDestinationSystemId != routeDestinationSystemId
            || plottedRouteOptimizationMode != routeOptimizationMode
            || plottedRouteConfigurationStamp != GetRouteConfigurationStamp(sector))
        {
            return null;
        }

        return plottedRoutePlan;
    }

    private async Task<IReadOnlyDictionary<int, List<SectorMapRouteLeg>>> GetRouteAdjacencyAsync(StarWinSector sector)
    {
        var cacheKey = new RouteGraphCacheKey(
            sector.Id,
            GetRouteConfigurationStamp(sector));
        if (routeGraphCaches.TryGetValue(cacheKey, out var cachedAdjacency))
        {
            return cachedAdjacency;
        }

        var adjacency = await Task.Run(() => BuildRouteAdjacency(
            sector,
            EmpiresById));
        routeGraphCaches[cacheKey] = adjacency;
        return adjacency;
    }

    private Dictionary<int, List<SectorMapRouteLeg>> BuildRouteAdjacency(
        StarWinSector sector,
        IReadOnlyDictionary<int, Empire> empiresById)
    {
        var adjacency = sector.Systems.ToDictionary(system => system.Id, _ => new List<SectorMapRouteLeg>());
        var systemsById = sector.Systems.ToDictionary(system => system.Id);

        foreach (var route in GetSectorHyperlaneRoutes(sector))
        {
            if (!systemsById.TryGetValue(route.SourceSystemId, out var source)
                || !systemsById.TryGetValue(route.TargetSystemId, out var target))
            {
                continue;
            }

            var leg = new SectorMapRouteLeg(
                source,
                target,
                route.DistanceParsecs,
                route.TravelTimeYears,
                true,
                route.TechnologyLevel,
                route.TierName,
                route.PrimaryOwnerEmpireId,
                route.PrimaryOwnerEmpireName,
                route.SecondaryOwnerEmpireId,
                route.SecondaryOwnerEmpireName);
            adjacency[source.Id].Add(leg);
            adjacency[target.Id].Add(leg with { Source = target, Target = source });
        }

        var offLaneMaximumDistanceParsecs = GetOffLaneMaximumDistanceParsecs(sector);
        if (sector.Systems.Count < 2 || offLaneMaximumDistanceParsecs <= 0)
        {
            return adjacency;
        }

        for (var sourceIndex = 0; sourceIndex < sector.Systems.Count; sourceIndex++)
        {
            var source = sector.Systems[sourceIndex];
            for (var targetIndex = sourceIndex + 1; targetIndex < sector.Systems.Count; targetIndex++)
            {
                var target = sector.Systems[targetIndex];
                var distanceParsecs = SectorRoutePlanner.CalculateParsecDistance(source.Coordinates, target.Coordinates);
                if (distanceParsecs > offLaneMaximumDistanceParsecs)
                {
                    continue;
                }

                var technologyLevel = ResolveOffLaneTechnologyLevel(source, target, empiresById);
                var travelTimeYears = SectorRoutePlanner.CalculateOffLaneTravelTimeYears(
                    sector.Configuration,
                    technologyLevel,
                    distanceParsecs);

                var leg = new SectorMapRouteLeg(
                    source,
                    target,
                    distanceParsecs,
                    travelTimeYears,
                    false,
                    technologyLevel,
                    "Off-lane");
                adjacency[source.Id].Add(leg);
                adjacency[target.Id].Add(leg with { Source = target, Target = source });
            }
        }

        return adjacency;
    }

    private SectorMapRoutePlan? BuildHyperlanePreferredRoute(
        StarSystem origin,
        StarSystem destination,
        IReadOnlyDictionary<int, List<SectorMapRouteLeg>> adjacency)
    {
        if (!adjacency.ContainsKey(origin.Id) || !adjacency.ContainsKey(destination.Id))
        {
            return null;
        }

        var searchResult = SearchPreferredRoute(origin, destination.Id, adjacency);
        var routePath = BuildRoutePath(searchResult, origin.Id, destination.Id);
        if (routePath is not null)
        {
            return BuildRoutePlan(origin, destination, routePath);
        }

        return null;
    }

    private static SectorMapRoutePlan BuildRoutePlan(StarSystem origin, StarSystem destination, IReadOnlyList<SectorMapRouteLeg> legs)
    {
        var routeSystems = legs
            .Select(leg => leg.Source)
            .Concat(legs.Select(leg => leg.Target))
            .DistinctBy(system => system.Id)
            .ToList();

        return new SectorMapRoutePlan(origin, destination, routeSystems, legs);
    }

    private PreferredRouteSearchResult SearchPreferredRoute(
        StarSystem origin,
        int destinationSystemId,
        IReadOnlyDictionary<int, List<SectorMapRouteLeg>> adjacency)
    {
        var costs = adjacency.Keys.ToDictionary(systemId => systemId, _ => double.PositiveInfinity);
        var previousLegs = new Dictionary<int, SectorMapRouteLeg>();
        var queue = new PriorityQueue<int, double>();
        var settledSystemIds = new HashSet<int>();

        costs[origin.Id] = 0;
        queue.Enqueue(origin.Id, 0);

        while (queue.Count > 0)
        {
            var systemId = queue.Dequeue();
            if (!settledSystemIds.Add(systemId))
            {
                continue;
            }

            if (systemId == destinationSystemId)
            {
                break;
            }

            foreach (var leg in adjacency[systemId])
            {
                var nextSystemId = leg.Target.Id;
                if (ShouldSkipLeg(origin.Id, destinationSystemId, leg))
                {
                    continue;
                }

                var legCost = routeOptimizationMode == RouteOptimizationMode.ShortestTravelTime
                    ? leg.TravelTimeYears
                    : leg.DistanceParsecs;
                var nextCost = costs[systemId] + legCost;
                if (nextCost >= costs[nextSystemId])
                {
                    continue;
                }

                costs[nextSystemId] = nextCost;
                previousLegs[nextSystemId] = leg;
                queue.Enqueue(nextSystemId, nextCost);
            }
        }

        return new PreferredRouteSearchResult(costs, previousLegs);
    }

    private bool ShouldSkipLeg(int originSystemId, int destinationSystemId, SectorMapRouteLeg leg)
    {
        if (avoidedSystemIds.Contains(leg.Target.Id)
            && leg.Target.Id != destinationSystemId
            && leg.Target.Id != originSystemId)
        {
            return true;
        }

        if (avoidedSystemIds.Contains(leg.Source.Id)
            && leg.Source.Id != destinationSystemId
            && leg.Source.Id != originSystemId)
        {
            return true;
        }

        if (leg.PrimaryOwnerEmpireId is int primaryOwnerEmpireId && avoidedEmpireIds.Contains(primaryOwnerEmpireId))
        {
            return true;
        }

        if (leg.SecondaryOwnerEmpireId is int secondaryOwnerEmpireId && avoidedEmpireIds.Contains(secondaryOwnerEmpireId))
        {
            return true;
        }

        return false;
    }

    private static IReadOnlyList<SectorMapRouteLeg>? BuildRoutePath(PreferredRouteSearchResult searchResult, int originSystemId, int targetSystemId)
    {
        if (originSystemId == targetSystemId)
        {
            return [];
        }

        if (!searchResult.PreviousLegs.ContainsKey(targetSystemId))
        {
            return null;
        }

        var legs = new List<SectorMapRouteLeg>();
        var currentSystemId = targetSystemId;
        while (currentSystemId != originSystemId)
        {
            var leg = searchResult.PreviousLegs[currentSystemId];
            legs.Add(leg);
            currentSystemId = leg.Source.Id;
        }

        legs.Reverse();
        return legs;
    }

    private static string GetRouteLegCssClass(SectorMapRouteLeg leg)
    {
        if (!leg.IsHyperlane)
        {
            return "off-lane";
        }

        return leg.TechnologyLevel switch
        {
            6 => "tl6-hyperlane",
            7 => "tl7-hyperlane",
            8 => "tl8-hyperlane",
            9 => "tl9-hyperlane",
            10 => "tl10-hyperlane",
            _ => "tl6-hyperlane"
        };
    }

    private static string GetRouteLegTierLabel(SectorMapRouteLeg leg)
    {
        if (!leg.IsHyperlane)
        {
            return $"Off-lane TL{leg.TechnologyLevel}";
        }

        return $"TL{leg.TechnologyLevel} {leg.TierName}";
    }

    private static string GetRouteLegOwnerLabel(SectorMapRouteLeg leg)
    {
        if (string.IsNullOrWhiteSpace(leg.PrimaryOwnerEmpireName))
        {
            return "No owner";
        }

        return string.IsNullOrWhiteSpace(leg.SecondaryOwnerEmpireName)
            ? leg.PrimaryOwnerEmpireName
            : $"{leg.PrimaryOwnerEmpireName} / {leg.SecondaryOwnerEmpireName}";
    }

    private int GetSectorMapSystemCount(StarWinSector sector, StarSystem? focusedSystem)
    {
        return GetSectorMapSystems(sector, focusedSystem?.Id ?? 0).Count;
    }

    private bool IsSectorMapCapped(StarWinSector sector, StarSystem? focusedSystem)
    {
        var focused = focusedSystem ?? sector.Systems.FirstOrDefault();
        return focused is not null
            && sector.Systems.Count(system => SectorRoutePlanner.CalculateParsecDistance(focused.Coordinates, system.Coordinates) <= sectorMapViewDistanceParsecs) > sectorMapRenderLimit;
    }

    private int GetSectorMapRouteCount(StarWinSector sector, StarSystem? focusedSystem)
    {
        var focusedSystemId = focusedSystem?.Id ?? 0;
        var routePlan = GetPlottedRoutePlan(sector);
        return BuildVisibleSectorMapRoutes(
            sector,
            GetSectorMapSystems(sector, focusedSystemId, routePlan),
            focusedSystemId,
            routePlan).Count;
    }

    private string GetConfigurationRouteSummary(StarWinSector sector, StarSystem? focusedSystem)
    {
        if (focusedSystem is null)
        {
            return "Select a system to preview visible hyperlanes.";
        }

        if (sector.SavedRoutes.Count > 0)
        {
            return $"{GetVisibleRouteCount(sector, focusedSystem, sector.SavedRoutes.Select(route => new SectorMapRoute(
                route.SourceSystemId,
                route.TargetSystemId,
                (double)route.DistanceParsecs,
                (double)route.TravelTimeYears,
                route.TechnologyLevel,
                route.TierName,
                route.PrimaryOwnerEmpireId,
                route.PrimaryOwnerEmpireName,
                route.SecondaryOwnerEmpireId,
                route.SecondaryOwnerEmpireName)).ToList())} visible hyperlanes from saved routes.";
        }

        if (generatedSectorRouteCache.TryGetValue(sector.Id, out var generatedRoutes))
        {
            return $"{GetVisibleRouteCount(sector, focusedSystem, generatedRoutes)} visible hyperlanes from the current in-memory route graph.";
        }

        return "Preview available after loading the sector map or saving routes for this sector.";
    }

    private int GetVisibleRouteCount(
        StarWinSector sector,
        StarSystem focusedSystem,
        IReadOnlyList<SectorMapRoute> routes)
    {
        var routePlan = GetPlottedRoutePlan(sector);
        var visibleSystemIds = GetSectorMapSystems(sector, focusedSystem.Id, routePlan)
            .Select(system => system.Id)
            .ToHashSet();
        var routePathKeys = routePlan?.Legs
            .Where(leg => leg.IsHyperlane)
            .Select(leg => GetSectorMapRouteKey(leg.Source.Id, leg.Target.Id))
            .ToHashSet() ?? [];

        return routes.Count(route =>
            visibleSystemIds.Contains(route.SourceSystemId)
            && visibleSystemIds.Contains(route.TargetSystemId)
            && (route.TechnologyLevel < 10
                || route.SourceSystemId == focusedSystem.Id
                || route.TargetSystemId == focusedSystem.Id
                || routePathKeys.Contains(GetSectorMapRouteKey(route.SourceSystemId, route.TargetSystemId))));
    }

    private IReadOnlyList<SectorMapRoute> BuildVisibleSectorMapRoutes(
        StarWinSector sector,
        IReadOnlyList<StarSystem> systems,
        int selectedSystemId,
        SectorMapRoutePlan? routePlan)
    {
        var systemIds = systems.Select(system => system.Id).ToHashSet();
        var routePathKeys = routePlan?.Legs
            .Where(leg => leg.IsHyperlane)
            .Select(leg => GetSectorMapRouteKey(leg.Source.Id, leg.Target.Id))
            .ToHashSet() ?? [];

        return GetSectorHyperlaneRoutes(sector)
            .Where(route => systemIds.Contains(route.SourceSystemId) && systemIds.Contains(route.TargetSystemId))
            .Where(route => route.TechnologyLevel < 10
                || route.SourceSystemId == selectedSystemId
                || route.TargetSystemId == selectedSystemId
                || routePathKeys.Contains(GetSectorMapRouteKey(route.SourceSystemId, route.TargetSystemId)))
            .ToList();
    }

    private IReadOnlyList<SectorMapRoute> GetSectorHyperlaneRoutes(StarWinSector sector)
    {
        if (sector.SavedRoutes.Count > 0)
        {
            return sector.SavedRoutes
                .Select(route => new SectorMapRoute(
                    route.SourceSystemId,
                    route.TargetSystemId,
                    (double)route.DistanceParsecs,
                    (double)route.TravelTimeYears,
                    route.TechnologyLevel,
                    route.TierName,
                    route.PrimaryOwnerEmpireId,
                    route.PrimaryOwnerEmpireName,
                    route.SecondaryOwnerEmpireId,
                    route.SecondaryOwnerEmpireName))
                .ToList();
        }

        if (generatedSectorRouteCache.TryGetValue(sector.Id, out var cachedRoutes))
        {
            return cachedRoutes;
        }

        var routes = SectorRoutePlanner.BuildHyperlaneRoutes(sector, EmpiresById)
            .Select(route => new SectorMapRoute(
                route.SourceSystemId,
                route.TargetSystemId,
                route.DistanceParsecs,
                route.TravelTimeYears,
                route.TechnologyLevel,
                route.TierName,
                route.PrimaryOwnerEmpireId,
                route.PrimaryOwnerEmpireName,
                route.SecondaryOwnerEmpireId,
                route.SecondaryOwnerEmpireName))
            .ToList();
        generatedSectorRouteCache[sector.Id] = routes;
        return routes;
    }

    private static (int SourceId, int TargetId) GetSectorMapRouteKey(int sourceId, int targetId)
    {
        return sourceId < targetId ? (sourceId, targetId) : (targetId, sourceId);
    }

    private static int ResolveOffLaneTechnologyLevel(
        StarSystem source,
        StarSystem target,
        IReadOnlyDictionary<int, Empire> empiresById)
    {
        if (SectorRoutePlanner.TryResolveHyperlaneRule(source, target, new StarWin.Domain.Model.Entity.StarMap.SectorConfiguration(), empiresById, out var tier, out _))
        {
            return tier;
        }

        return 6;
    }

    private static double GetOffLaneMaximumDistanceParsecs(StarWinSector sector)
    {
        return (double)sector.Configuration.OffLaneMaximumDistanceParsecs;
    }

    private StarWinSector GetSelectedSector()
    {
        return ExplorerSectors.FirstOrDefault(item => item.Id == selectedSectorId) ?? explorerContext.CurrentSector;
    }

    private long GetRouteConfigurationStamp(StarWinSector sector)
    {
        return HashCode.Combine(
            sector.Configuration.UpdatedAtUtc.Ticks,
            sector.SavedRoutes.Count,
            routeOptimizationMode,
            string.Join(',', avoidedEmpireIds.OrderBy(id => id)),
            string.Join(',', avoidedSystemIds.OrderBy(id => id)));
    }

    private IEnumerable<KeyValuePair<int, string>> GetRouteEmpireOptions()
    {
        return GetSectorOverviewData(selectedSectorId)?.Empires
            .Select(empire => new KeyValuePair<int, string>(empire.Id, empire.Name))
            .ToList() ?? [];
    }

    private IEnumerable<KeyValuePair<int, string>> GetRouteSystemOptions()
    {
        return GetSectorOverviewData(selectedSectorId)?.Systems
            .Select(system => new KeyValuePair<int, string>(system.Id, system.Name))
            .ToList() ?? [];
    }

    private static string FormatRouteOption(KeyValuePair<int, string> option)
    {
        return $"{option.Key} - {option.Value}";
    }

    private void UpdateAvoidedEmpires(HashSet<int> selectedIds)
    {
        avoidedEmpireIds = selectedIds;
        ClearPlottedRoutePlan();
    }

    private void UpdateAvoidedSystems(HashSet<int> selectedIds)
    {
        avoidedSystemIds = selectedIds;
        ClearPlottedRoutePlan();
    }

    private static string FormatTravelTime(double years)
    {
        if (years < 1d / 365d)
        {
            return $"{years * 24d * 365d:0.##} hours";
        }

        if (years < 1d)
        {
            return $"{years * 365d:0.##} days";
        }

        return $"{years:0.##} years";
    }

    private static int GetGurpsTechLevel(Empire empire)
    {
        return empire.CivilizationProfile.TechLevel + 2;
    }

    private static int GetSectorMapMaximumViewDistance(StarWinSector sector)
    {
        return MaximumSectorMapViewDistanceParsecs;
    }

    private enum RouteOptimizationMode
    {
        ShortestDistance,
        ShortestTravelTime
    }

    private sealed record ColonyListing(StarWinSector Sector, StarSystem System, World World, Colony Colony);

    private sealed record SectorMapRoute(
        int SourceSystemId,
        int TargetSystemId,
        double DistanceParsecs,
        double TravelTimeYears,
        int TechnologyLevel,
        string TierName,
        int? PrimaryOwnerEmpireId,
        string PrimaryOwnerEmpireName,
        int? SecondaryOwnerEmpireId,
        string SecondaryOwnerEmpireName);

    private sealed record SectorMapRoutePlan(
        StarSystem Origin,
        StarSystem Destination,
        IReadOnlyList<StarSystem> Systems,
        IReadOnlyList<SectorMapRouteLeg> Legs)
    {
        public double DirectDistanceParsecs => SectorRoutePlanner.CalculateParsecDistance(Origin.Coordinates, Destination.Coordinates);

        public double TotalDistanceParsecs => Legs.Sum(leg => leg.DistanceParsecs);

        public double TotalTravelTimeYears => Legs.Sum(leg => leg.TravelTimeYears);

        public double ExtraDistanceParsecs => Math.Max(0, TotalDistanceParsecs - DirectDistanceParsecs);

        public int HyperlaneJumpCount => Legs.Count(leg => leg.IsHyperlane);

        public int OffHyperlaneLegCount => Legs.Count(leg => !leg.IsHyperlane);
    }

    private sealed record SectorMapRouteLeg(
        StarSystem Source,
        StarSystem Target,
        double DistanceParsecs,
        double TravelTimeYears,
        bool IsHyperlane,
        int TechnologyLevel = 0,
        string TierName = "Off-lane",
        int? PrimaryOwnerEmpireId = null,
        string PrimaryOwnerEmpireName = "",
        int? SecondaryOwnerEmpireId = null,
        string SecondaryOwnerEmpireName = "");

    private sealed record RouteGraphCacheKey(
        int SectorId,
        long ConfigurationStamp);

    private sealed record PreferredRouteSearchResult(
        IReadOnlyDictionary<int, double> Costs,
        IReadOnlyDictionary<int, SectorMapRouteLeg> PreviousLegs);

    private sealed record ExplorerSessionSelection(int SectorId, int SystemId, bool AutoLoadSectorMap = false, string? SectionSlug = null);

    public async ValueTask DisposeAsync()
    {
        if (sectorMapModule is not null)
        {
            try
            {
                await sectorMapModule.InvokeVoidAsync("disposeSectorMap", sectorMapElement);
                await sectorMapModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        if (loadMoreScrollModule is not null)
        {
            try
            {
                await loadMoreScrollModule.InvokeVoidAsync("disconnectAllLoadMore");
                await loadMoreScrollModule.InvokeVoidAsync("disconnectColonyLoadMore");
                await loadMoreScrollModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        dotNetReference?.Dispose();
    }
}

