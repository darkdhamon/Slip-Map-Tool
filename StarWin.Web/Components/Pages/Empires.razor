@layout SectorExplorerLayout
@page "/sector-explorer/empires"
@rendermode InteractiveServer

@{
    var sector = GetSelectedSector();
    var sectorSummary = GetSectorSummary(sector);
    var sectionCache = GetSectorCache(sector);
    var sectorRaceIds = sectionCache.RaceIds;
    var sectorEmpireIds = sectionCache.EmpireIds;
    var sectorRaces = ExplorerAlienRaces.Where(race => sectorRaceIds.Contains(race.Id)).OrderBy(race => race.Name).ToList();
    var sectorEmpires = ExplorerEmpires.Where(empire => sectorEmpireIds.Contains(empire.Id)).OrderBy(empire => empire.Name).ToList();
    var selectedEmpire = sectorEmpires.FirstOrDefault(empire => empire.Id == selectedEmpireId) ?? sectorEmpires.FirstOrDefault();
    var layoutState = new SectorExplorerLayoutState(
        null,
        ExplorerSectors,
        sector.Systems.ToList(),
        selectedSectorId,
        EventCallback.Factory.Create<int>(this, HandleSectorChangedAsync),
        selectedSystemText,
        EventCallback.Factory.Create<string>(this, HandleSelectedSystemTextChangedAsync),
        searchQuery,
        EventCallback.Factory.Create<string>(this, HandleSearchQueryChangedAsync),
        searchResults,
        EventCallback.Factory.Create<StarWinSearchResult>(this, NavigateToSearchResult),
        sections,
        "Empires",
        explorerRenderError,
        DisplayResultType,
        BuildSectionRoute);
}

<PageTitle>Empires | Starforged Atlas</PageTitle>
<SectorExplorerLayoutSync State="layoutState" />

<section class="content-grid">
            <div class="record-list">
                <details class="record-filter-panel" open>
                    <summary class="record-filter-summary">Search</summary>
                    <label>
                        Search
                        <input placeholder="Name, policy, homeworld..."
                               @bind="empireQuery"
                               @bind:event="oninput"
                               @bind:after="ResetEmpireWindow" />
                    </label>
                    <button type="button" class="timeline-clear-button" @onclick="ToggleEmpireFilters">
                        @(showEmpireFilters ? "Hide filters" : "Show filters")
                    </button>
                    @if (showEmpireFilters)
                    {
                        <label>
                            Race
                            <input list="empire-race-options"
                                   placeholder="All races"
                                   @bind="empireRaceText"
                                   @bind:event="oninput"
                                   @bind:after="ApplyEmpireRaceFilter" />
                            <datalist id="empire-race-options">
                                @foreach (var race in sectorRaces)
                                {
                                    <option value="@FormatRaceOption(race)" />
                                }
                            </datalist>
                        </label>
                    }
                    <button type="button" class="timeline-clear-button" @onclick="ClearEmpireFilters">Clear filters</button>
                </details>
                @{
                    var empireWindow = GetFilteredEmpires(sectorEmpires)
                        .Take(empireVisibleCount + 1)
                        .ToList();
                    var hasMoreEmpires = empireWindow.Count > empireVisibleCount;
                    var visibleEmpires = empireWindow.Take(empireVisibleCount).ToList();
                    empireHasMoreRecords = hasMoreEmpires;
                }
                <div class="timeline-count">Showing @visibleEmpires.Count empire@(visibleEmpires.Count == 1 ? string.Empty : "s")@(hasMoreEmpires ? "+" : string.Empty)</div>
                @if (visibleEmpires.Count == 0)
                {
                    <article class="timeline-event-card">
                        <span class="timeline-century">No matches</span>
                        <p>Adjust the filters to widen the empire list.</p>
                    </article>
                }
                @foreach (var empire in visibleEmpires)
                {
                    var empireIsFallen = IsFallenEmpire(empire, sector);
                    <button type="button" class="record-row @(selectedEmpire?.Id == empire.Id ? "active" : null) @(empireIsFallen ? "fallen" : null)" @onclick="() => SelectEmpire(empire.Id)">
                        <strong class="record-row-title">
                            <span>@empire.Name</span>
                            @if (empireIsFallen)
                            {
                                <span class="empire-status fallen">Fallen empire</span>
                            }
                        </strong>
                        <span>@(empireIsFallen ? "No controlled colonies; former holdings conquered" : $"GURPS TL {GetGurpsTechLevel(empire)}; {empire.Planets} planets")</span>
                    </button>
                }
                @if (hasMoreEmpires)
                {
                    <div @ref="empireLoadMoreElement" class="timeline-load-more">
                        <button type="button" @onclick="LoadMoreEmpires">Load more</button>
                    </div>
                }
            </div>

            @if (selectedEmpire is not null)
            {
                <article class="detail-panel">
                    <span class="panel-kicker">Empire profile</span>
                    <EditableEntityName Name="@selectedEmpire.Name"
                                        Label="Empire"
                                        NameSaved="name => SaveEntityNameAsync(EntityNoteTargetKind.Empire, selectedEmpire.Id, name)" />
                    @{
                        var empireImages = GetEntityImages(EntityImageTargetKind.Empire, selectedEmpire.Id);
                    }
                    <section class="entity-image-panel">
                        <div class="image-panel-header">
                            <h4>Empire flag</h4>
                            <span>One image</span>
                        </div>
                        @if (empireImages.Count > 0)
                        {
                            <div class="entity-image-grid single">
                                @foreach (var image in empireImages)
                                {
                                    <figure>
                                        <img src="@image.RelativePath" alt="@image.FileName" />
                                        <figcaption>@(image.IsPrimary ? "Primary" : image.FileName)</figcaption>
                                    </figure>
                                }
                            </div>
                        }
                        else
                        {
                            <p>No image uploaded.</p>
                        }
                        <label class="image-upload-control">
                            <span>Upload image</span>
                            <InputFile OnChange="@(args => UploadEntityImage(EntityImageTargetKind.Empire, selectedEmpire.Id, args))" accept="image/jpeg,image/png,image/gif,image/webp" />
                        </label>
                        @if (!string.IsNullOrWhiteSpace(imageUploadStatus))
                        {
                            <small>@imageUploadStatus</small>
                        }
                    </section>
                    @{
                        var empireHomeworld = FindWorld(selectedEmpire.Founding.FoundingWorldId);
                        var capitalColony = GetCapitalColony(selectedEmpire);
                        var empireColonies = GetEmpireColonies(selectedEmpire, sector).ToList();
                        var empireControlledColonies = GetControlledEmpireColonies(selectedEmpire, sector).ToList();
                        var selectedEmpireIsFallen = IsFallenEmpire(selectedEmpire, sector);
                    }
                    @if (selectedEmpireIsFallen)
                    {
                        <div class="empire-alert fallen">
                            <strong>Fallen empire</strong>
                            <span>This empire no longer controls any colonies in this sector.</span>
                        </div>
                    }
                    <div class="parent-actions">
                        @if (empireHomeworld is not null)
                        {
                            <button type="button" @onclick="() => NavigateToWorld(empireHomeworld.Id)">Homeworld: @empireHomeworld.Name</button>
                        }
                        @if (capitalColony is not null)
                        {
                            <button type="button" @onclick="() => NavigateToColony(capitalColony.Colony.Id)">Capital: @capitalColony.World.Name</button>
                        }
                    </div>
                    <dl class="field-grid">
                        <div><dt>Status</dt><dd>@(selectedEmpireIsFallen ? "Fallen empire" : "Active empire")</dd></div>
                        <div><dt>Controlled colonies</dt><dd>@empireControlledColonies.Count</dd></div>
                        <div><dt>Tech level</dt><dd>GURPS TL @GetGurpsTechLevel(selectedEmpire) / StarWin @selectedEmpire.CivilizationProfile.TechLevel</dd></div>
                        <div><dt>Military power</dt><dd>@selectedEmpire.MilitaryPower</dd></div>
                        <div><dt>Economic power</dt><dd>@selectedEmpire.EconomicPowerMcr MCr</dd></div>
                        <div><dt>Trade bonus</dt><dd>@selectedEmpire.TradeBonusMcr MCr</dd></div>
                        <div><dt>Planets</dt><dd>@selectedEmpire.Planets</dd></div>
                        <div><dt>Moons</dt><dd>@selectedEmpire.Moons</dd></div>
                        <div><dt>Captive planets</dt><dd>@selectedEmpire.CaptivePlanets</dd></div>
                        <div><dt>Space habitats</dt><dd>@selectedEmpire.SpaceHabitats</dd></div>
                        <div><dt>Native population</dt><dd>@selectedEmpire.NativePopulationMillions million</dd></div>
                        <div><dt>Captive population</dt><dd>@selectedEmpire.CaptivePopulationMillions million</dd></div>
                        <div><dt>Expansion</dt><dd>@selectedEmpire.ExpansionPolicy</dd></div>
                    </dl>

                    <EntityNotesPanel TargetKind="EntityNoteTargetKind.Empire"
                                      TargetId="selectedEmpire.Id"
                                      Title="Empire notes" />

                    <div class="force-grid">
                        <article>
                            <h3>Fleet</h3>
                            @foreach (var ship in selectedEmpire.MilitaryForces.Fleet)
                            {
                                <div class="inline-row"><span>@ship.Quantity @ship.Name</span><strong>@ship.Code</strong></div>
                            }
                        </article>
                        <article>
                            <h3>Ground forces</h3>
                            @foreach (var force in selectedEmpire.MilitaryForces.GroundForces)
                            {
                                <div class="inline-row"><span>@force.Name</span><strong>@force.Quantity</strong></div>
                            }
                        </article>
                    </div>

                    <section class="relationship-section">
                        <h3>Member races</h3>
                        <div class="relationship-list">
                            @foreach (var membership in selectedEmpire.RaceMemberships
                                                    .Where(item => sectorRaceIds.Contains(item.RaceId))
                                                    .OrderByDescending(item => item.IsPrimary)
                                                    .ThenBy(item => item.RaceId))
                            {
                                <button type="button" class="relationship-row" @onclick="() => NavigateToRace(membership.RaceId)">
                                    <strong>@DisplayRace(membership.RaceId)</strong>
                                    <span>@membership.Role; @membership.PopulationMillions million</span>
                                </button>
                            }
                        </div>
                    </section>

                    <section class="relationship-section">
                        <h3>Colonies</h3>
                        <div class="relationship-list">
                            @foreach (var listing in empireColonies)
                            {
                                <button type="button" class="relationship-row" @onclick="() => NavigateToColony(listing.Colony.Id)">
                                    <strong>@DisplayColonyName(listing.Colony) on @listing.World.Name</strong>
                                    <span>@listing.System.Name; @DisplayPopulation(listing.Colony.EstimatedPopulation)</span>
                                </button>
                            }
                        </div>
                    </section>
                </article>
            }
        </section>
