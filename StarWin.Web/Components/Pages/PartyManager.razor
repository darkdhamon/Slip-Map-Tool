@page "/party-manager"
@rendermode InteractiveServer

<PageTitle>Party Manager - Starforged Atlas</PageTitle>

<section class="explorer-page">
    <header class="explorer-hero compact-hero">
        <div class="hero-copy">
            <p class="eyebrow">Party Manager</p>
            <h1>Player party roster and campaign logistics.</h1>
            <p class="hero-summary">Track the active crew, contacts, resources, and notes that move with the campaign between sector records.</p>
        </div>
    </header>

    <section class="generator-layout">
        <article class="detail-panel">
            <span class="panel-kicker">Roster</span>
            <h2>Party manifest</h2>
            <p>Party management tools will live here.</p>
        </article>
    </section>
</section>
